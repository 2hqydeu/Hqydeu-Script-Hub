local packetsCache = nil
local function GetPackets()
	if packetsCache then return packetsCache end
	local replicatedStorage = game:GetService("ReplicatedStorage")
	local packages = replicatedStorage:FindFirstChild("Packages")
	local packetsModule = packages and packages:FindFirstChild("Packets")
	if not packetsModule then
		return nil, "Packets not found"
	end
	local ok, result = pcall(require, packetsModule)
	if not ok then
		return nil, tostring(result)
	end
	packetsCache = result
	return packetsCache
end

local function FirePacket(name, payload)
	local packets, reason = GetPackets()
	if not packets or not packets[name] then
		return false, {Reason = reason or (name .. " packet missing")}
	end
	local callOk, packetOk, response = pcall(function()
		if payload == nil then
			return packets[name]:Fire()
		end
		return packets[name]:Fire(payload)
	end)
	if not callOk then
		return false, {Reason = tostring(packetOk)}
	end
	return packetOk, response
end

local function ResultMatches(result)
	if type(result) ~= "table" then return false end
	local rarity = result.Rarity or "Common"
	local mutation = result.Mutation
	local selectedMutation = MutationOptions[state.MutationIndex]
	local leaveout = LeaveoutOptions[state.LeaveoutIndex]
	if (RarityRank[rarity] or 1) < (RarityRank[RarityOptions[state.MinRarityIndex]] or 1) then
		return false
	end
	if leaveout ~= "Off" and mutation == leaveout then
		return false
	end
	if selectedMutation == "Any" then
		return true
	end
	if selectedMutation == "None" then
		return mutation == nil or mutation == ""
	end
	return mutation == selectedMutation
end

local function SortedResults(results)
	local sorted = {}
	for _, result in pairs(type(results) == "table" and results or {}) do
		table.insert(sorted, result)
	end
	table.sort(sorted, function(a, b)
		return (tonumber(a.Podium) or 255) < (tonumber(b.Podium) or 255)
	end)
	return sorted
end

local function AutoBuyResults(results)
	if state.BuyBusy then return 0 end
	state.BuyBusy = true
	local bought = 0
	for _, result in ipairs(SortedResults(results)) do
		if ResultMatches(result) and result.Podium then
			local ok, response = FirePacket("BuyBee", {Podium = result.Podium})
			if ok then
				bought += 1
				SetStatus(("Bought %s"):format(result.Rarity or "bee"))
				task.wait(0.12)
			elseif response and response.Reason then
				SetStatus(response.Reason)
			end
		end
	end
	state.BuyBusy = false
	return bought
end

local function FindText(root, name)
	if not root then return nil end
	for _, obj in ipairs(root:GetDescendants()) do
		if obj:IsA("TextLabel") and obj.Name == name then
			return obj.Text
		end
	end
	return nil
end

local function PromptMatches(prompt)
	local parent = prompt.Parent
	local rarity = FindText(parent, "Rarity") or "Common"
	if (RarityRank[rarity] or 1) < (RarityRank[RarityOptions[state.MinRarityIndex]] or 1) then
		return false
	end
	local mutation = FindText(parent, "Mutation")
	local selectedMutation = MutationOptions[state.MutationIndex]
	local leaveout = LeaveoutOptions[state.LeaveoutIndex]
	if leaveout ~= "Off" and mutation == leaveout then return false end
	if selectedMutation == "Any" then return true end
	if selectedMutation == "None" then return mutation == nil or mutation == "" end
	return mutation == selectedMutation
end

local function TryExistingBuyPrompts()
	if os.clock() - state.LastPromptBuy < 0.7 or state.BuyBusy then return end
	state.LastPromptBuy = os.clock()
	if type(fireproximityprompt) ~= "function" then return end
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("ProximityPrompt") then
			local action = string.lower(obj.ActionText or "")
			if (action:find("buy", 1, true) or action:find("claim", 1, true)) and PromptMatches(obj) then
				state.BuyBusy = true
				fireproximityprompt(obj)
				state.BuyBusy = false
				SetStatus("Used buy prompt")
				return
			end
		end
	end
end

local function DoRoll()
	if state.RollBusy then return end
	state.RollBusy = true
	SetStatus("Rolling...")
	local ok, response = FirePacket("RequestRoll")
	if ok and response and response.Results then
		local count = #SortedResults(response.Results)
		SetStatus(("Rolled %d"):format(count))
		if state.AutoBuy then
			local bought = AutoBuyResults(response.Results)
			if bought == 0 then SetStatus("Roll skipped") end
		end
	elseif response and response.Reason then
		SetStatus(response.Reason)
	else
		SetStatus("Roll failed")
	end
	state.RollBusy = false
end

local function DoSell()
	if state.SellBusy then return end
	state.SellBusy = true
	FirePacket("GrabHoney")
	task.wait(0.12)
	local ok, response = FirePacket("SellHoney")
	if ok and response and (response.Amount or 0) > 0 then
		SetStatus(("Sold honey: %s"):format(tostring(response.Amount)))
	elseif response and response.Reason then
		SetStatus(response.Reason)
	end
	state.SellBusy = false
end


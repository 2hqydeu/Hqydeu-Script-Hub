local function CopyBoolTable(saved, defaults)
	local result = {}
	for _, name in ipairs(defaults) do
		result[name] = type(saved) == "table" and saved[name] == true or false
	end
	return result
end

local defaultRarities = {}
for _, rarity in ipairs(RarityOptions) do
	defaultRarities[rarity] = rarity ~= "Common" and rarity ~= "Uncommon"
end
local defaultMutations = {}
for _, mutation in ipairs(MutationOptions) do
	defaultMutations[mutation] = true
end

local function ClampIndex(value, list, fallback)
	value = tonumber(value)
	if not value or value < 1 or value > #list then return fallback end
	return math.floor(value)
end

local function LoadSelection(saved, names, defaults)
	local result = {}
	local anySaved = type(saved) == "table"
	for _, name in ipairs(names) do
		if anySaved then
			result[name] = saved[name] == true
		else
			result[name] = defaults[name] == true
		end
	end
	return result
end

local function EnsureSelection(current, names, defaults)
	if type(current) ~= "table" then
		return LoadSelection(nil, names, defaults)
	end
	for _, name in ipairs(names) do
		if current[name] == nil then
			current[name] = defaults[name] == true
		end
	end
	return current
end


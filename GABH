local function LoadSelection(saved, names, defaults)
	local result = {}
	local anySaved = type(saved) == "table"
	for _, name in ipairs(names) do
		result[name] = anySaved and saved[name] == true or defaults[name] == true
	end
	return result
end

local function EnsureSelection(current, names, defaults)
	if type(current) ~= "table" then
		return LoadSelection(nil, names, defaults)
	end
	for _, name in ipairs(names) do
		if current[name] == nil then
			current[name] = defaults[name] == true
		end
	end
	return current
end

local function ClampSeconds(value, fallback)
	value = tonumber(value)
	if not value then return fallback end
	return math.clamp(value, 0.5, 60)
end

local function FormatSeconds(value)
	value = ClampSeconds(value, 2)
	if math.floor(value) == value then
		return tostring(value)
	end
	return string.format("%.1f", value)
end


local function SafeRequire(pathParts)
	local current = game
	for index, part in ipairs(pathParts) do
		if index == 1 and (part == "ReplicatedStorage" or part == "Players" or part == "Workspace") then
			current = game:GetService(part == "Workspace" and "Workspace" or part)
		else
			current = current and current:FindFirstChild(part)
		end
		if not current then return nil end
	end
	local ok, result = pcall(require, current)
	return ok and result or nil
end

local function GetDataClient()
	if dataClientCache ~= nil then return dataClientCache end
	local packages = game:GetService("ReplicatedStorage"):FindFirstChild("Packages")
	local dataService = packages and packages:FindFirstChild("DataService")
	local ok, result = pcall(function()
		return dataService and require(dataService).client
	end)
	dataClientCache = ok and result or false
	return dataClientCache ~= false and dataClientCache or nil
end

local function GetSeasonMath()
	if seasonMathCache ~= nil then return seasonMathCache end
	seasonMathCache = SafeRequire({"ReplicatedStorage", "Modules", "SeasonMath"}) or false
	return seasonMathCache ~= false and seasonMathCache or nil
end

local function GetBeeConfig()
	if beeConfigCache ~= nil then return beeConfigCache end
	beeConfigCache = SafeRequire({"ReplicatedStorage", "Configs", "BeeConfig"}) or false
	return beeConfigCache ~= false and beeConfigCache or nil
end

local function GetBeeInfo(beeIdOrName)
	local beeConfig = GetBeeConfig()
	if not beeConfig or not beeIdOrName then return nil end
	if type(beeConfig.Get) == "function" then
		local ok, info = pcall(beeConfig.Get, beeIdOrName)
		if ok and info then return info end
	end
	for _, info in ipairs(beeConfig.Roster or {}) do
		if info.Id == beeIdOrName or info.Name == beeIdOrName then
			return info
		end
	end
end

local function FormatCompactNumber(value)
	value = tonumber(value) or 0
	local absValue = math.abs(value)
	local suffixes = {
		{1e12, "T"},
		{1e9, "B"},
		{1e6, "M"},
		{1e3, "K"},
	}
	for _, suffix in ipairs(suffixes) do
		if absValue >= suffix[1] then
			return ("$%.1f%s"):format(value / suffix[1], suffix[2]):gsub("%.0", "")
		end
	end
	return "$" .. tostring(math.floor(value))
end

local function FormatClock(seconds)
	seconds = math.max(0, math.floor(tonumber(seconds) or 0))
	local hours = math.floor(seconds / 3600)
	local minutes = math.floor(seconds % 3600 / 60)
	local secs = seconds % 60
	if hours > 0 then
		return ("%d:%02d:%02d"):format(hours, minutes, secs)
	end
	return ("%02d:%02d"):format(minutes, secs)
end


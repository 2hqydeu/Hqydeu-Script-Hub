	name = tostring(name or "Bee")
	rarity = tostring(rarity or "?")
	mutation = mutation and tostring(mutation) ~= "" and tostring(mutation) or "None"
	local key = name .. "|" .. rarity .. "|" .. mutation
	if state.LastHistoryKey == key and os.clock() - (state.LastHistoryAt or 0) < 1 then
		return
	end
	state.LastHistoryKey = key
	state.LastHistoryAt = os.clock()
	table.insert(state.PurchaseHistory, 1, {Name = name, Rarity = rarity, Mutation = mutation})
	while #state.PurchaseHistory > 25 do
		table.remove(state.PurchaseHistory)
	end
	SaveOptions()
	if state.HistoryOpen then
		RefreshHistoryPanel()
	end
end


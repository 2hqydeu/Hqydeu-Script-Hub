		lastRemoteRoleAt = os.clock()
		if murderer ~= CurrentMurderer or sheriff ~= CurrentSheriff then
			CurrentMurderer = murderer or CurrentMurderer
			CurrentSheriff = sheriff or CurrentSheriff
			RefreshRoleDisplay()
		end
	end)
end


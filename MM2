-- Feature row layout: label left, toggle right. Same convention as UE/QOD's panels. order
-- sets LayoutOrder (rows stack in creation order if not given one).
local nextRowOrder = 1
-- Pill-shaped On/Off switch (oval track + round knob, track fills with a light color when
-- On) that replaces the old plain "On"/"Off" text button everywhere in this hub. Every
-- toggle call site already just does `toggle.Text = enabled and "On" or "Off"`, so this
-- hooks that same Text property instead of needing every call site rewritten: nothing
-- outside this function has to change to get the new visual.
local ToggleOffColor = Color3.fromRGB(50, 50, 50)
local ToggleOnColor = Color3.fromRGB(178, 155, 235)
local ToggleKnobColor = Color3.fromRGB(238, 233, 250)
local function StyleAsToggleSwitch(toggle)
	toggle.AutoButtonColor = false
	toggle.TextTransparency = 1
	toggle.BackgroundColor3 = ToggleOffColor
	toggle.BackgroundTransparency = 0
	Instance.new("UICorner", toggle).CornerRadius = UDim.new(1, 0)

	local knobSize = toggle.Size.Y.Offset - 6
	local knob = Instance.new("Frame")
	knob.Name = "Knob"
	knob.AnchorPoint = Vector2.new(0, 0.5)
	knob.Size = UDim2.new(0, knobSize, 0, knobSize)
	knob.Position = UDim2.new(0, 3, 0.5, 0)
	knob.BackgroundColor3 = ToggleKnobColor
	knob.BorderSizePixel = 0
	knob.ZIndex = toggle.ZIndex + 1
	knob.Parent = toggle
	Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
	-- The Role Reveal popup bulk-bumps every descendant's ZIndex to one flat value (see
	-- BumpZIndex further down), which would otherwise flatten the knob to the same layer
	-- as its own track. Keep it one layer above whatever the track's ZIndex becomes
	-- instead of a fixed value.
	toggle:GetPropertyChangedSignal("ZIndex"):Connect(function() knob.ZIndex = toggle.ZIndex + 1 end)

	local function Refresh(animate)
		local on = toggle.Text == "On"
		local trackColor = on and ToggleOnColor or ToggleOffColor
		local knobPosition = on and UDim2.new(1, -3 - knobSize, 0.5, 0) or UDim2.new(0, 3, 0.5, 0)
		if animate then
			local tweenInfo = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
			TweenService:Create(toggle, tweenInfo, {BackgroundColor3 = trackColor}):Play()
			TweenService:Create(knob, tweenInfo, {Position = knobPosition}):Play()
		else
			toggle.BackgroundColor3 = trackColor
			knob.Position = knobPosition
		end
	end

	toggle:GetPropertyChangedSignal("Text"):Connect(function() Refresh(true) end)
	Refresh(false)
end


-- Role detection: tool-based only (murderer holds a Knife, sheriff holds a Gun) -- the old
-- hub's remote-clue/round-data listening was dropped, this alone is reliable and self
-- contained. Scanned continuously (regardless of whether Role Reveal is open) so highlights
-- and combat features always have current info.
local CurrentMurderer, CurrentSheriff = nil, nil
local lastMurdererAvatarId, lastSheriffAvatarId = 0, 0

local function PlayerHasTool(targetPlayer, toolName)
	local wantedName = toolName:lower()
	local function containerHasTool(container)
		if not container then return false end
		for _, item in ipairs(container:GetChildren()) do
			if item.Name:lower() == wantedName then return true end
		end
		return false
	end
	return containerHasTool(targetPlayer.Character) or containerHasTool(targetPlayer:FindFirstChild("Backpack"))
end

local function FindRoleHolder(toolName)
	for _, targetPlayer in ipairs(Players:GetPlayers()) do
		if PlayerHasTool(targetPlayer, toolName) then return targetPlayer end
	end
	return nil
end

local function FormatRolePlayer(targetPlayer)
	if not targetPlayer then return "Unknown" end
	return string.format("%s (@%s)", targetPlayer.DisplayName or targetPlayer.Name, targetPlayer.Name)
end

local function UpdateRoleAvatar(imageLabel, targetPlayer)
	imageLabel.Image = ""
	if not targetPlayer then return end
	task.spawn(function()
		local success, image = pcall(function()
			return Players:GetUserThumbnailAsync(targetPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
		end)
		if success and ((imageLabel == MurdererAvatar and CurrentMurderer == targetPlayer) or (imageLabel == SheriffAvatar and CurrentSheriff == targetPlayer)) then
			imageLabel.Image = image
		end
	end)
end

-- Automatic: highlights whoever's currently detected as murderer/sheriff, no manual toggle.
local function UpdateRoleHighlights()
	for _, targetPlayer in ipairs(Players:GetPlayers()) do
		local character = targetPlayer.Character
		if character then
			local wantMurdererHighlight = targetPlayer ~= Player and targetPlayer == CurrentMurderer
			local wantSheriffHighlight = targetPlayer ~= Player and targetPlayer == CurrentSheriff
			local murdererHighlight = character:FindFirstChild("MM2MurdererHighlight")
			local sheriffHighlight = character:FindFirstChild("MM2SheriffHighlight")
			if wantMurdererHighlight then
				if not murdererHighlight then
					murdererHighlight = Instance.new("Highlight")
					murdererHighlight.Name = "MM2MurdererHighlight"
					murdererHighlight.FillColor = Color3.fromRGB(255, 70, 70)
					murdererHighlight.OutlineColor = Color3.fromRGB(255, 40, 40)
					murdererHighlight.FillTransparency = 0.72
					murdererHighlight.OutlineTransparency = 0
					murdererHighlight.Parent = character
				end
			elseif murdererHighlight then
				murdererHighlight:Destroy()
			end
			if wantSheriffHighlight then
				if not sheriffHighlight then
					sheriffHighlight = Instance.new("Highlight")
					sheriffHighlight.Name = "MM2SheriffHighlight"
					sheriffHighlight.FillColor = Color3.fromRGB(70, 130, 255)
					sheriffHighlight.OutlineColor = Color3.fromRGB(40, 100, 255)
					sheriffHighlight.FillTransparency = 0.72
					sheriffHighlight.OutlineTransparency = 0
					sheriffHighlight.Parent = character
				end
			elseif sheriffHighlight then
				sheriffHighlight:Destroy()
			end
		end
	end
end

-- Removes every role highlight this session put on OTHER players' characters -- these are
-- automatic now (no manual ESP toggle), so unlike everything else here they'd otherwise
-- keep showing on other people forever after closing.
local function ClearAllRoleHighlights()
	for _, targetPlayer in ipairs(Players:GetPlayers()) do
		local character = targetPlayer.Character
		if character then
			local murdererHighlight = character:FindFirstChild("MM2MurdererHighlight")
			if murdererHighlight then murdererHighlight:Destroy() end
			local sheriffHighlight = character:FindFirstChild("MM2SheriffHighlight")
			if sheriffHighlight then sheriffHighlight:Destroy() end
		end
	end
end

-- Lets Main's own regular Player ESP know when a player is already wearing MM2's own
-- murderer/sheriff highlight, so it can skip applying its own Outline/Box highlight to that
-- same player instead of the two visually fighting over the same character.
if type(getgenv) == "function" then
	getgenv().Serenity_MM2_IsMurderer = function(plr) return plr == CurrentMurderer end
	getgenv().Serenity_MM2_IsSheriff = function(plr) return plr == CurrentSheriff end
end

local function RefreshRoleDisplay()
	local murdererAvatarId = CurrentMurderer and CurrentMurderer.UserId or 0
	local sheriffAvatarId = CurrentSheriff and CurrentSheriff.UserId or 0
	if murdererAvatarId ~= lastMurdererAvatarId then
		lastMurdererAvatarId = murdererAvatarId
		UpdateRoleAvatar(MurdererAvatar, CurrentMurderer)
	end
	if sheriffAvatarId ~= lastSheriffAvatarId then
		lastSheriffAvatarId = sheriffAvatarId
		UpdateRoleAvatar(SheriffAvatar, CurrentSheriff)
	end
	MurdererNameLabel.Text = FormatRolePlayer(CurrentMurderer)
	SheriffNameLabel.Text = FormatRolePlayer(CurrentSheriff)
	UpdateRoleHighlights()
end

-- Role Reveal used to only ever find out who the murderer/sheriff were once they'd
-- actually equipped their Knife/Gun -- by then they're usually already hunting. The old
-- hub read the round's role data straight from the server (the same RemoteFunction its own
-- UI uses) so it knew before either weapon was ever picked up, with tool detection kept
-- around as the fail-safe: tools are ground truth the moment they appear, and toolRolesActive/
-- lastRemoteRoleAt below make sure an early remote-based guess doesn't get blanked out by
-- "nobody's holding a weapon yet" before it's had a chance to be confirmed.
local toolRolesActive = false
local lastRemoteRoleAt = 0

local function RefreshRolesFromTools()
	local murderer = FindRoleHolder("Knife")
	local sheriff = FindRoleHolder("Gun")
	if murderer or sheriff then
		toolRolesActive = true
		if murderer ~= CurrentMurderer or sheriff ~= CurrentSheriff then
			CurrentMurderer = murderer
			CurrentSheriff = sheriff
			RefreshRoleDisplay()
		end
		return
	end
	if toolRolesActive then
		-- Tools were confirmed and now nobody's holding either -- round's over, clear.
		toolRolesActive = false
		if CurrentMurderer or CurrentSheriff then
			CurrentMurderer = nil
			CurrentSheriff = nil
			RefreshRoleDisplay()
		end
		return
	end
	-- No tool ever seen yet this round. A recent remote-based guess is still allowed to
	-- stand (weapons just haven't been picked up yet); only clear once that guess goes
	-- stale, so a round with no remote data at all still eventually clears normally.
	if os.clock() - lastRemoteRoleAt < 30 then return end
	if CurrentMurderer or CurrentSheriff then
		CurrentMurderer = nil
		CurrentSheriff = nil
		RefreshRoleDisplay()
	end
end

local remoteRoleRequestBusy = false
local lastRemoteRoleCheck = 0
local function RefreshRolesFromRemote()
	if toolRolesActive then return end
	local now = os.clock()
	if now - lastRemoteRoleCheck < 1 or remoteRoleRequestBusy then return end
	lastRemoteRoleCheck = now
	local remotes = ReplicatedStorage:FindFirstChild("Remotes")
	local gameplay = remotes and remotes:FindFirstChild("Gameplay")
	local getCurrentPlayerData = gameplay and gameplay:FindFirstChild("GetCurrentPlayerData")
	if not getCurrentPlayerData or not getCurrentPlayerData:IsA("RemoteFunction") then return end
	remoteRoleRequestBusy = true
	task.spawn(function()
		local success, playerData = pcall(function() return getCurrentPlayerData:InvokeServer() end)
		remoteRoleRequestBusy = false
		if not success or type(playerData) ~= "table" or toolRolesActive then return end
		local murderer, sheriff
		for playerName, roundData in pairs(playerData) do
			if type(playerName) == "string" and type(roundData) == "table" then
				local targetPlayer = Players:FindFirstChild(playerName)
				local roleName = roundData.Role

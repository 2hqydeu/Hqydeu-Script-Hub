-- Sets a root's position while keeping it upright (zeroing pitch/roll, keeping the current
-- facing direction) -- same helper QOD uses, for Coin Farm/Auto Gun's approach nudges.
local function SetRootUpright(root, currentCFrame, targetPosition)
	local _, yRotation = currentCFrame:ToOrientation()
	root.CFrame = CFrame.new(targetPosition) * CFrame.Angles(0, yRotation, 0)
end


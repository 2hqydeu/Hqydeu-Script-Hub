-- Coin Farm: walks to the nearest coin, going "underground" (no-collide) so terrain/props
-- don't block the path, same timeout/skip logic as the old hub.
local coinFarmEnabled = false
local lastCoinRefresh, cachedCoins = 0, {}
local currentCoin, currentCoinStartedAt = nil, 0
local coinCollectionTimeout = 0.55
local skippedCoins = {}
local lastCoinFarmMove = 0

local function GetAllCoins()
	local now = os.clock()
	if now - lastCoinRefresh < 0.15 then return cachedCoins end
	lastCoinRefresh = now
	cachedCoins = {}
	local coinContainers = {}
	local directContainer = workspace:FindFirstChild("CoinContainer", true)
	if directContainer then table.insert(coinContainers, directContainer) end
	for _, obj in ipairs(workspace:GetChildren()) do
		local container = obj:FindFirstChild("CoinContainer")
		if container and container ~= directContainer then table.insert(coinContainers, container) end
	end
	for _, container in ipairs(coinContainers) do
		for _, obj in ipairs(container:GetChildren()) do
			if obj:IsA("BasePart") and obj.Name == "Coin_Server" then
				table.insert(cachedCoins, obj)
			end
		end
	end
	return cachedCoins
end

local function SetUnderground(enabled)
	local character = Player.Character
	if not character then return end
	for _, part in ipairs(character:GetDescendants()) do
		-- HumanoidRootPart is non-collidable by design in a normal character rig -- forcing
		-- it to collide (which restoring "true" on every part indiscriminately used to do)
		-- fights the Humanoid's own physics state and is what was ragdolling the character
		-- on close.
		if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
			part.CanCollide = not enabled
		end
	end
end

CoinFarmToggle.MouseButton1Click:Connect(function()
	coinFarmEnabled = not coinFarmEnabled
	CoinFarmToggle.Text = coinFarmEnabled and "On" or "Off"
	currentCoin = nil
	currentCoinStartedAt = 0
	skippedCoins = {}
	SetUnderground(coinFarmEnabled)
end)

RunService.Heartbeat:Connect(function()
	if not ScreenGui.Parent then return end
	if not coinFarmEnabled then return end
	local now = os.clock()
	if now - lastCoinFarmMove < 0.045 then return end
	lastCoinFarmMove = now

	local coins = GetAllCoins()
	if #coins == 0 then return end
	local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
	if not root then return end

	local availableCoins = {}
	for _, coin in ipairs(coins) do
		local skipUntil = skippedCoins[coin]
		if not skipUntil or now >= skipUntil then
			skippedCoins[coin] = nil
			table.insert(availableCoins, coin)
		end
	end
	if #availableCoins == 0 then return end

	table.sort(availableCoins, function(a, b)
		return (root.Position - a.Position).Magnitude < (root.Position - b.Position).Magnitude
	end)

	local target = availableCoins[1]
	if not target or not target.Parent then return end
	if currentCoin ~= target then
		currentCoin = target
		currentCoinStartedAt = now
	elseif now - currentCoinStartedAt >= coinCollectionTimeout then
		skippedCoins[target] = now + 4
		currentCoin = nil
		return
	end

	SetRootUpright(root, root.CFrame, target.Position + Vector3.new(0, 0.8, 0))
	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero
end)

-- Auto Gun: picks up the map's gun drop via touch-interest (falls back to a brief
-- teleport-nudge), staying away from the murderer until the pickup is safe.
local autoGunEnabled = false
local autoGunBusy = false
local lastGunDrop = nil
local lastGunDropSearch = 0
local lastGunPickupAttempt = 0
local cachedGunDrop = nil

local function GetGunDropCFrame(gunDrop)
	if gunDrop:IsA("BasePart") then return gunDrop.CFrame end
	if gunDrop:IsA("Model") then
		local part = gunDrop.PrimaryPart or gunDrop:FindFirstChildWhichIsA("BasePart", true)
		return part and part.CFrame or nil
	end
	return nil
end

local function GetGunDropTouchPart(gunDrop)
	if not gunDrop then return nil end
	if gunDrop:IsA("BasePart") then return gunDrop end
	if gunDrop:IsA("Model") then return gunDrop.PrimaryPart or gunDrop:FindFirstChildWhichIsA("BasePart", true) end
	return nil
end

local function GetTopLevelWorkspaceObject(instance)
	local current = instance
	while current and current.Parent and current.Parent ~= workspace do
		current = current.Parent
	end
	return current
end

local function IsAliveAndInsideActiveMap(gunDrop)
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if not humanoid or humanoid.Health <= 0 or not root then return false end
	local map = GetTopLevelWorkspaceObject(gunDrop)
	if not map or map.Parent ~= workspace then return false end
	if map:IsA("Model") then
		local mapCFrame, mapSize = map:GetBoundingBox()
		local localPosition = mapCFrame:PointToObjectSpace(root.Position)
		local padding = Vector3.new(20, 20, 20)
		local halfSize = (mapSize / 2) + padding
		return math.abs(localPosition.X) <= halfSize.X and math.abs(localPosition.Y) <= halfSize.Y and math.abs(localPosition.Z) <= halfSize.Z
	end
	return true
end

local function IsGunPickupSafe(gunPosition)
	RefreshRolesFromTools()
	local murderer = CurrentMurderer
	if not murderer or murderer == Player then return true end
	local murdererCharacter = murderer.Character
	local murdererHumanoid = murdererCharacter and murdererCharacter:FindFirstChildOfClass("Humanoid")
	local murdererRoot = murdererCharacter and murdererCharacter:FindFirstChild("HumanoidRootPart")
	if not murdererRoot or not murdererHumanoid or murdererHumanoid.Health <= 0 then return true end
	return (murdererRoot.Position - gunPosition).Magnitude >= 30
end

local function TryPickUpGun(gunDrop)
	if autoGunBusy or not autoGunEnabled or not gunDrop or not gunDrop.Parent then return end
	if not IsAliveAndInsideActiveMap(gunDrop) then return end
	local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
	local gunCFrame = GetGunDropCFrame(gunDrop)
	if not root or not gunCFrame then return end
	if not IsGunPickupSafe(gunCFrame.Position) then return end

	autoGunBusy = true
	local touchPart = GetGunDropTouchPart(gunDrop)
	if touchPart and type(firetouchinterest) == "function" then
		local character = Player.Character
		local touched = false
		if character then
			for _, part in ipairs(character:GetDescendants()) do
				if part:IsA("BasePart") then
					pcall(function()
						firetouchinterest(part, touchPart, 0)
						firetouchinterest(part, touchPart, 1)
						touched = true
					end)
				end
			end
		end
		if touched then
			task.delay(0.12, function() autoGunBusy = false end)
			return
		end
	end
	task.wait(0.08)
	-- This runs as its own coroutine (the task.wait above suspends it independently of the
	-- Heartbeat loop that started it) -- closing the panel mid-flight doesn't stop it on its
	-- own, so without this check it keeps teleporting/re-teleporting the character around
	-- after Close, which is exactly the kind of "character bugs out, only a Reset fixes it"
	-- symptom this was causing.
	if not ScreenGui.Parent or not autoGunEnabled or not gunDrop.Parent or not root.Parent or not IsGunPickupSafe(gunCFrame.Position) then
		autoGunBusy = false
		return
	end
	local originalCFrame = root.CFrame
	SetRootUpright(root, root.CFrame, gunCFrame.Position + Vector3.new(0, 1.2, 0))
	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero
	task.wait(0.045)
	if ScreenGui.Parent and root and root.Parent then
		SetRootUpright(root, root.CFrame, originalCFrame.Position)
		root.AssemblyLinearVelocity = Vector3.zero
		root.AssemblyAngularVelocity = Vector3.zero
	end
	autoGunBusy = false
end

AutoGunToggle.MouseButton1Click:Connect(function()
	autoGunEnabled = not autoGunEnabled
	AutoGunToggle.Text = autoGunEnabled and "On" or "Off"
	lastGunDrop = nil
	lastGunPickupAttempt = 0
	if autoGunEnabled then
		task.defer(function()
			local gunDrop = FindGunDrop()
			if gunDrop and gunDrop.Parent then
				lastGunDrop = gunDrop
				lastGunPickupAttempt = os.clock()
				TryPickUpGun(gunDrop)
			end
		end)
	end
end)

RunService.Heartbeat:Connect(function()
	if not ScreenGui.Parent then return end
	if not autoGunEnabled or autoGunBusy then return end
	local now = os.clock()
	if now - lastGunDropSearch >= 0.15 then
		lastGunDropSearch = now
		cachedGunDrop = FindGunDrop()
	end
	local gunDrop = cachedGunDrop
	if not gunDrop then
		lastGunDrop = nil
		return
	end
	if gunDrop ~= lastGunDrop then
		lastGunDrop = gunDrop
		lastGunPickupAttempt = 0
	end
	if now - lastGunPickupAttempt >= 0.25 then
		lastGunPickupAttempt = now
		task.delay(0, function()
			if lastGunDrop == gunDrop then TryPickUpGun(gunDrop) end
		end)
	end
end)

-- Auto Stab: equips the Knife (only fires while you're the actual murderer), prioritizes
-- the sheriff, cycles remaining targets, and swings via firetouchinterest -- falls back to
-- a temporary hitbox enlargement on executors without firetouchinterest.
local autoStabEnabled = false
local killHitboxOriginals = {}
local lastKnifeSwing = 0
local stabTargetIndex = 0

local function GetLocalKnife()
	local character = Player.Character
	local backpack = Player:FindFirstChild("Backpack")
	local knife = character and character:FindFirstChild("Knife")
	if not knife and backpack then knife = backpack:FindFirstChild("Knife") end
	return knife and knife:IsA("Tool") and knife or nil
end

local function RestoreKillHitboxes()
	for part, original in pairs(killHitboxOriginals) do
		if part and part.Parent then
			part.Size = original.Size
			part.Transparency = original.Transparency
			part.CanCollide = original.CanCollide
			part.CanTouch = original.CanTouch
			part.Massless = original.Massless
		end
	end
	killHitboxOriginals = {}
end

AutoStabToggle.MouseButton1Click:Connect(function()
	autoStabEnabled = not autoStabEnabled
	AutoStabToggle.Text = autoStabEnabled and "On" or "Off"
	if not autoStabEnabled then RestoreKillHitboxes() end
end)

RunService.Heartbeat:Connect(function()
	if not ScreenGui.Parent then return end
	if not autoStabEnabled then return end
	local knife = GetLocalKnife()
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if CurrentMurderer ~= Player or not knife or not humanoid or humanoid.Health <= 0 then
		RestoreKillHitboxes()
		return
	end
	if knife.Parent ~= character then
		pcall(function() humanoid:EquipTool(knife) end)
	end

	local aliveTargets = {}
	local priorityRoot = nil
	if CurrentSheriff and CurrentSheriff ~= Player then
		local sheriffCharacter = CurrentSheriff.Character
		local sheriffHumanoid = sheriffCharacter and sheriffCharacter:FindFirstChildOfClass("Humanoid")
		local sheriffRoot = sheriffCharacter and sheriffCharacter:FindFirstChild("HumanoidRootPart")
		if sheriffHumanoid and sheriffHumanoid.Health > 0 and sheriffRoot then priorityRoot = sheriffRoot end
	end
	if priorityRoot then
		for part, original in pairs(killHitboxOriginals) do
			if part ~= priorityRoot then
				if part and part.Parent then
					part.Size = original.Size
					part.Transparency = original.Transparency
					part.CanCollide = original.CanCollide
					part.CanTouch = original.CanTouch
					part.Massless = original.Massless
				end
				killHitboxOriginals[part] = nil
			end
		end
	end

	for _, targetPlayer in ipairs(Players:GetPlayers()) do
		if targetPlayer ~= Player then
			local targetCharacter = targetPlayer.Character
			local targetHumanoid = targetCharacter and targetCharacter:FindFirstChildOfClass("Humanoid")
			local targetRoot = targetCharacter and targetCharacter:FindFirstChild("HumanoidRootPart")
			local isEligible = targetHumanoid and targetHumanoid.Health > 0 and targetRoot and (not priorityRoot or targetRoot == priorityRoot)
			if isEligible then
				table.insert(aliveTargets, targetRoot)
				if type(firetouchinterest) ~= "function" and not killHitboxOriginals[targetRoot] then
					killHitboxOriginals[targetRoot] = {
						Size = targetRoot.Size, Transparency = targetRoot.Transparency,
						CanCollide = targetRoot.CanCollide, CanTouch = targetRoot.CanTouch, Massless = targetRoot.Massless,
					}
					targetRoot.Size = Vector3.new(18, 18, 18)
					targetRoot.Transparency = 1
					targetRoot.CanCollide = false
					targetRoot.CanTouch = true
					targetRoot.Massless = true
				end
			end
		end
	end

	local now = os.clock()
	if now - lastKnifeSwing >= 0.1 then
		lastKnifeSwing = now
		pcall(function() knife:Activate() end)
		if #aliveTargets > 0 then
			stabTargetIndex = (stabTargetIndex % #aliveTargets) + 1
			local targetRoot = aliveTargets[stabTargetIndex]
			local knifeHandle = knife:FindFirstChild("Handle") or knife:FindFirstChildWhichIsA("BasePart")
			if knifeHandle and type(firetouchinterest) == "function" then
				task.spawn(function()
					pcall(function()
						firetouchinterest(knifeHandle, targetRoot, 0)
						task.wait(0.03)
						firetouchinterest(knifeHandle, targetRoot, 1)
					end)
				end)
			end
		end
		local localRoot = character and character:FindFirstChild("HumanoidRootPart")
		if localRoot then
			localRoot.AssemblyAngularVelocity = Vector3.zero
			if localRoot.AssemblyLinearVelocity.Magnitude > 80 then
				localRoot.AssemblyLinearVelocity = localRoot.AssemblyLinearVelocity.Unit * 18
			end
			SetRootUpright(localRoot, localRoot.CFrame, localRoot.Position)
		end
	end
end)

-- Auto Shoot: equips the Gun (only fires while you're the sheriff, only at the murderer),
-- predictive-leads the target using smoothed velocity, raycasts for a clear line, then
-- double-checks the shot is still valid right before actually firing.
local autoShootEnabled = false
local lastGunFired = 0
local shotPending = false
local AutoShootConfirmWindow = 0.018
local AutoShootVisibleHold = 0.045
local AutoShootMinLeadTime = 0.055
local AutoShootMaxLeadTime = 0.145
local autoShootMotion = {}
local autoShootClearTarget = nil
local autoShootClearSince = nil

local function GetLocalGun()
	local character = Player.Character
	local backpack = Player:FindFirstChild("Backpack")
	local gun = character and character:FindFirstChild("Gun")
	if not gun and backpack then gun = backpack:FindFirstChild("Gun") end
	return gun and gun:IsA("Tool") and gun or nil
end

local function HasClearGunLine(originPosition, targetCharacter, targetPart, aimPosition)
	local ignoreList = {Player.Character}
	for _, passthrough in ipairs(CollectionService:GetTagged("WeaponPassthrough")) do
		table.insert(ignoreList, passthrough)
	end
	local raycastParams = RaycastParams.new()
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	raycastParams.IgnoreWater = true
	raycastParams.FilterDescendantsInstances = ignoreList
	local direction = (aimPosition or targetPart.Position) - originPosition

	for _ = 1, 6 do
		local result = workspace:Raycast(originPosition, direction, raycastParams)
		if not result then return true end
		if result.Instance and result.Instance:IsDescendantOf(targetCharacter) then return true end
		if result.Instance and result.Instance.Transparency == 1 then
			table.insert(ignoreList, result.Instance)
			raycastParams.FilterDescendantsInstances = ignoreList
		else
			return false
		end
	end
	return false
end

local function GetAutoShootPart(targetCharacter)
	if not targetCharacter then return nil end
	return targetCharacter:FindFirstChild("UpperTorso") or targetCharacter:FindFirstChild("HumanoidRootPart")
		or targetCharacter:FindFirstChild("Torso") or targetCharacter:FindFirstChild("Head")
end

local function GetAutoShootParts(targetCharacter, preferredPart)
	local parts = {}
	local added = {}
	local function add(part)
		if part and part:IsA("BasePart") and not added[part] then
			added[part] = true
			table.insert(parts, part)
		end
	end
	add(preferredPart)
	add(targetCharacter and targetCharacter:FindFirstChild("UpperTorso"))
	add(targetCharacter and targetCharacter:FindFirstChild("Torso"))
	add(targetCharacter and targetCharacter:FindFirstChild("HumanoidRootPart"))
	add(targetCharacter and targetCharacter:FindFirstChild("LowerTorso"))
	add(targetCharacter and targetCharacter:FindFirstChild("Head"))
	return parts
end

local function GetSmoothedTargetVelocity(targetPlayer, targetPart, now)
	if not targetPlayer or not targetPart then return Vector3.zero end
	local entry = autoShootMotion[targetPlayer]
	if not entry then
		entry = {}
		autoShootMotion[targetPlayer] = entry
	end
	local position = targetPart.Position
	local rawVelocity = targetPart.AssemblyLinearVelocity
	if entry.Position and entry.Time then
		local dt = math.max(now - entry.Time, 1 / 240)
		local measuredVelocity = (position - entry.Position) / dt
		if measuredVelocity.Magnitude < 220 then
			rawVelocity = rawVelocity:Lerp(measuredVelocity, 0.65)
		end
	end
	entry.SmoothedVelocity = entry.SmoothedVelocity and entry.SmoothedVelocity:Lerp(rawVelocity, 0.55) or rawVelocity
	entry.Position = position
	entry.Time = now
	return entry.SmoothedVelocity
end

local function GetAutoShootAimPosition(originPosition, targetPart, targetVelocity)
	local currentPosition = targetPart.Position
	local distance = (currentPosition - originPosition).Magnitude
	local leadTime = math.clamp(distance / 650, AutoShootMinLeadTime, AutoShootMaxLeadTime)
	local leadVelocity = Vector3.new(targetVelocity.X, math.clamp(targetVelocity.Y, -10, 14), targetVelocity.Z)
	local leadOffset = leadVelocity * leadTime
	if leadOffset.Magnitude > 12 then leadOffset = leadOffset.Unit * 12 end
	local aimPosition = currentPosition + leadOffset
	if targetPart.Name == "HumanoidRootPart" then
		aimPosition = aimPosition + Vector3.new(0, 1.25, 0)
	elseif targetPart.Name == "Head" then
		aimPosition = aimPosition + Vector3.new(0, -0.2, 0)
	else
		aimPosition = aimPosition + Vector3.new(0, 0.25, 0)
	end
	return aimPosition
end

local function SelectAutoShootAimPosition(originPosition, targetCharacter, preferredPart, targetVelocity)
	local horizontalVelocity = Vector3.new(targetVelocity.X, 0, targetVelocity.Z)
	local sideOffset = Vector3.zero
	if horizontalVelocity.Magnitude > 1 then
		sideOffset = horizontalVelocity.Unit:Cross(Vector3.new(0, 1, 0))
		if sideOffset.Magnitude > 0 then sideOffset = sideOffset.Unit * 0.85 end
	end
	local softOffsets = {Vector3.zero, Vector3.new(0, 0.7, 0), Vector3.new(0, -0.55, 0), sideOffset, sideOffset * -1}
	for _, part in ipairs(GetAutoShootParts(targetCharacter, preferredPart)) do
		local baseAim = GetAutoShootAimPosition(originPosition, part, targetVelocity)
		if HasClearGunLine(originPosition, targetCharacter, part, baseAim) then
			for _, offset in ipairs(softOffsets) do
				local candidate = baseAim + offset
				if HasClearGunLine(originPosition, targetCharacter, part, candidate) then
					return candidate
				end
			end
		end
	end
	return nil
end

AutoShootToggle.MouseButton1Click:Connect(function()
	autoShootEnabled = not autoShootEnabled
	AutoShootToggle.Text = autoShootEnabled and "On" or "Off"
end)

RunService.Heartbeat:Connect(function()
	if not ScreenGui.Parent then return end
	if not autoShootEnabled then return end
	local shootNow = os.clock()
	if CurrentSheriff ~= Player or not CurrentMurderer or CurrentMurderer == Player then return end
	if autoShootClearTarget ~= CurrentMurderer then
		autoShootClearTarget = CurrentMurderer
		autoShootClearSince = nil
	end

	local gun = GetLocalGun()
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local targetCharacter = CurrentMurderer.Character
	local targetHumanoid = targetCharacter and targetCharacter:FindFirstChildOfClass("Humanoid")
	local targetPart = GetAutoShootPart(targetCharacter)
	if not gun or not humanoid or humanoid.Health <= 0 or not targetHumanoid or targetHumanoid.Health <= 0 or not targetPart then return end
	if gun.Enabled == false then return end
	if gun.Parent ~= character then
		pcall(function() humanoid:EquipTool(gun) end)
		return
	end
	if shotPending or shootNow - lastGunFired < 0.2 then return end

	local localRoot = character:FindFirstChild("HumanoidRootPart")
	local raycastAttachment = localRoot and localRoot:FindFirstChild("GunRaycastAttachment")
	local shootRemote = gun:FindFirstChild("Shoot")
	if not shootRemote or not shootRemote:IsA("RemoteEvent") then return end
	local shotOrigin = raycastAttachment and raycastAttachment.WorldCFrame or nil
	if not shotOrigin then return end

	local firstVelocity = GetSmoothedTargetVelocity(CurrentMurderer, targetPart, shootNow)
	local firstAimPosition = SelectAutoShootAimPosition(shotOrigin.Position, targetCharacter, targetPart, firstVelocity)
	if not firstAimPosition then
		autoShootClearSince = nil
		return
	end
	if not autoShootClearSince then autoShootClearSince = shootNow end
	local requiredHold = firstVelocity.Magnitude > 55 and (AutoShootVisibleHold + 0.02) or AutoShootVisibleHold
	if shootNow - autoShootClearSince < requiredHold then return end

	local confirmedMurderer = CurrentMurderer
	local firstPosition = targetPart.Position
	shotPending = true
	task.delay(AutoShootConfirmWindow, function()
		shotPending = false
		if not autoShootEnabled or CurrentSheriff ~= Player or CurrentMurderer ~= confirmedMurderer then return end

		local freshCharacter = Player.Character
		local freshHumanoid = freshCharacter and freshCharacter:FindFirstChildOfClass("Humanoid")
		local freshTargetCharacter = confirmedMurderer and confirmedMurderer.Character
		local freshTargetHumanoid = freshTargetCharacter and freshTargetCharacter:FindFirstChildOfClass("Humanoid")
		local freshTargetPart = GetAutoShootPart(freshTargetCharacter)
		local freshGun = GetLocalGun()
		if not freshCharacter or not freshHumanoid or freshHumanoid.Health <= 0 or not freshTargetHumanoid or freshTargetHumanoid.Health <= 0 or not freshTargetPart or not freshGun then return end
		if freshGun.Parent ~= freshCharacter then return end
		if freshGun.Enabled == false then return end

		local freshRoot = freshCharacter:FindFirstChild("HumanoidRootPart")
		local freshAttachment = freshRoot and freshRoot:FindFirstChild("GunRaycastAttachment")
		local freshRemote = freshGun:FindFirstChild("Shoot")
		local freshOrigin = freshAttachment and freshAttachment.WorldCFrame
		if not freshOrigin or not freshRemote or not freshRemote:IsA("RemoteEvent") then return end

		local currentPosition = freshTargetPart.Position
		local currentVelocity = GetSmoothedTargetVelocity(confirmedMurderer, freshTargetPart, os.clock())
		local expectedPosition = firstPosition + firstVelocity * AutoShootConfirmWindow
		local movementError = (currentPosition - expectedPosition).Magnitude
		local velocityChange = (currentVelocity - firstVelocity).Magnitude
		if movementError > 16.0 or velocityChange > 180 then return end

		local aimPosition = SelectAutoShootAimPosition(freshOrigin.Position, freshTargetCharacter, freshTargetPart, currentVelocity)
		if not aimPosition then return end
		lastGunFired = os.clock()
		autoShootClearSince = nil
		pcall(function() freshRemote:FireServer(freshOrigin, CFrame.new(aimPosition)) end)
	end)
end)

-- Minimize: shrinks to just the header, matching Serenity's own minimize behavior. Every
-- row lives inside ContentScroll now, so hiding that one frame is enough.
local minimized = false
local function ToggleMinimize()
	minimized = not minimized
	HeaderDivider.Visible = not minimized
	ContentScroll.Visible = not minimized
	PanelFrame.Size = UDim2.new(0, 280, 0, minimized and MINI_HEIGHT or FULL_HEIGHT)
	MinimizeButton.Text = minimized and "+" or "-"
end
MinimizeButton.MouseButton1Click:Connect(ToggleMinimize)

CloseButton.MouseButton1Click:Connect(function()
	coinFarmEnabled = false
	autoGunEnabled = false
	SetUnderground(false)
	RestoreKillHitboxes()
	ClearGunDropESP()
	ClearAllRoleHighlights()
	ScreenGui:Destroy()
end)

-- Dragging
local dragging = false
local dragStart = nil
local startPos = nil
PanelFrame.InputBegan:Connect(function(input)
	if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
	dragging = true
	dragStart = input.Position
	startPos = PanelFrame.Position
	input.Changed:Connect(function()
		if input.UserInputState == Enum.UserInputState.End then
			dragging = false
		end
	end)
end)
UserInputService.InputChanged:Connect(function(input)
	if not dragging or (input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch) then return end
	local delta = input.Position - dragStart
	PanelFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end)

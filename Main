local function ApplyESPColor()
	ESPColorButton.BackgroundColor3 = ESPColor
	for _, highlight in pairs(OutlineHighlights) do
		if highlight then
			highlight.FillColor = ESPColor
			highlight.OutlineColor = ESPColor
		end
	end
	for _, adornments in pairs(BoxAdornments) do
		for _, adornment in pairs(adornments) do
			if adornment then adornment.Color3 = ESPColor end
		end
	end
	-- ESP Labels reads ESPColor directly on its own throttled refresh, so it doesn't
	-- need updating here.
end

local function SetESPColor(color)
	ESPColor = color
	SaveFeatureColor("ESPColor", ESPColor)
	ApplyESPColor()
end

-- Color picker: an SV square + hue bar + a 5-slot saved-color palette, ported from the
-- old feature-rich hub's theme picker but restyled plain and flat to match Serenity's
-- rows instead of that hub's accent-heavy chrome. Docks to the left of MainFrame and
-- tracks it while dragged. ESP is the only picker target here, so this skips all of the
-- old hub's per-target (Accent/Frame/ESP) plumbing.
local PickerH, PickerS, PickerV = Color3.toHSV(ESPColor)
local DraggingSV = false
local DraggingHue = false

local ESP_COLOR_PICKER_WIDTH = 130

local ESPColorPicker = Instance.new("Frame")
ESPColorPicker.Name = "ESPColorPicker"
ESPColorPicker.Size = UDim2.new(0, ESP_COLOR_PICKER_WIDTH, 0, 196)
ESPColorPicker.AnchorPoint = Vector2.new(0, 0)
ESPColorPicker.BackgroundColor3 = FrameColor
ESPColorPicker.BorderSizePixel = 0
ESPColorPicker.Visible = false
ESPColorPicker.ZIndex = 50
ESPColorPicker.Parent = ScreenGui
Instance.new("UICorner", ESPColorPicker).CornerRadius = UDim.new(0, 10)
local ESPColorPickerStroke = Instance.new("UIStroke")
ESPColorPickerStroke.Color = Color3.fromRGB(0, 0, 0)
ESPColorPickerStroke.Thickness = 1
ESPColorPickerStroke.Parent = ESPColorPicker

-- Docked to the ESP Color button itself (right edge aligned, sitting just below it) --
-- like the keybind-clear prompt -- rather than to the window's left edge: docking off
-- the side of the whole window meant it could land off-screen entirely depending on
-- window position and viewport width, which is almost certainly why it read as
-- "invisible." Anchoring to a button that's already guaranteed to be on-screen fixes
-- that outright.
local function UpdateESPColorPickerPosition()
	ESPColorPicker.Position = UDim2.fromOffset(
		ESPColorButton.AbsolutePosition.X + ESPColorButton.AbsoluteSize.X - ESP_COLOR_PICKER_WIDTH,
		ESPColorButton.AbsolutePosition.Y + ESPColorButton.AbsoluteSize.Y + 6
	)
end
MainFrame:GetPropertyChangedSignal("AbsolutePosition"):Connect(UpdateESPColorPickerPosition)
MainFrame:GetPropertyChangedSignal("AbsoluteSize"):Connect(UpdateESPColorPickerPosition)
UpdateESPColorPickerPosition()


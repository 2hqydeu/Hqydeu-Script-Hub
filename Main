				Instance.new("UICorner", editButton).CornerRadius = UDim.new(0, 5)

				local clickButton = Instance.new("TextButton")
				clickButton.Size = UDim2.new(1, -58, 1, 0)
				clickButton.BackgroundTransparency = 1
				clickButton.Text = ""
				clickButton.ZIndex = 32
				clickButton.Parent = row
				clickButton.MouseButton1Click:Connect(function()
					PlayClick()
					local waypointCFrame = GetWaypointCFrame(waypoint)
					local character = Player.Character
					local root = character and character:FindFirstChild("HumanoidRootPart")
					if waypointCFrame and root then
						root.CFrame = waypoint.Kind == "Position" and waypointCFrame or waypointCFrame * CFrame.new(0, 3, 0)
					end
				end)

				editButton.MouseButton1Click:Connect(function()
					PlayClick()
					nameLabel.Visible = false
					kindLabel.Visible = false
					editButton.Visible = false
					clickButton.Visible = false
					local editBox = Instance.new("TextBox")
					editBox.Size = UDim2.new(1, -64, 1, -6)
					editBox.Position = UDim2.new(0, 6, 0, 3)
					editBox.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
					editBox.BackgroundTransparency = 0.2
					editBox.BorderSizePixel = 0
					editBox.Text = waypointName
					editBox.ClearTextOnFocus = false
					editBox.Font = UIFont
					editBox.TextSize = 10
					editBox.TextColor3 = Color3.fromRGB(255, 255, 255)
					editBox.ZIndex = 32
					editBox.Parent = row
					Instance.new("UICorner", editBox).CornerRadius = UDim.new(0, 5)
					editBox.FocusLost:Connect(function()
						local newName = editBox.Text:match("^%s*(.-)%s*$")
						if newName and newName ~= "" then waypoint.Name = string.sub(newName, 1, 32) end
						SaveWaypoints()
						BroadcastWaypointsChanged()
					end)
					task.defer(function() editBox:CaptureFocus() end)
				end)

				deleteButton.MouseButton1Click:Connect(function()
					PlayClick()
					table.remove(Waypoints, index)
					SaveWaypoints()
					BroadcastWaypointsChanged()
				end)
			end
		end
		PopupWaypointList.CanvasSize = UDim2.new(0, 0, 0, PopupWaypointListLayout.AbsoluteContentSize.Y + 4)
	end
	table.insert(WaypointRefreshCallbacks, RefreshPopupWaypointList)

	local PopupActiveTab = "Players"
	local function ShowPopupTab(tabName)
		PopupActiveTab = tabName
		local showingWaypoints = tabName == "Waypoints"
		PopupPlayerSearch.Visible = not showingWaypoints
		PopupPlayerList.Visible = not showingWaypoints
		PopupWaypointSearch.Visible = showingWaypoints
		PopupWaypointList.Visible = showingWaypoints
		PopupPlayersTab.BackgroundTransparency = showingWaypoints and 0.5 or 0.2
		PopupWaypointsTab.BackgroundTransparency = showingWaypoints and 0.2 or 0.5
		if showingWaypoints then RefreshPopupWaypointList() else RefreshPopupPlayerList() end
	end

	PopupPlayersTab.MouseButton1Click:Connect(function() PlayClick() ShowPopupTab("Players") end)
	PopupWaypointsTab.MouseButton1Click:Connect(function() PlayClick() ShowPopupTab("Waypoints") end)
	PopupPlayerSearch:GetPropertyChangedSignal("Text"):Connect(RefreshPopupPlayerList)
	PopupWaypointSearch:GetPropertyChangedSignal("Text"):Connect(RefreshPopupWaypointList)
	table.insert(looseConnections, Players.PlayerAdded:Connect(function()
		if PopupFrame.Visible and PopupActiveTab == "Players" then RefreshPopupPlayerList() end
	end))
	table.insert(looseConnections, Players.PlayerRemoving:Connect(function()
		if PopupFrame.Visible and PopupActiveTab == "Players" then RefreshPopupPlayerList() end
	end))

	local function SetPopupVisible(visible)
		PopupFrame.Visible = visible
		PopupToggleButton.Text = visible and "Open" or "Closed"
		if visible then ShowPopupTab(PopupActiveTab) end
	end
	local function TogglePopup()
		SetPopupVisible(not PopupFrame.Visible)
	end
	-- Wired here (not up where the button was created) since PopupFrame/SetPopupVisible
	-- only exist from this point onward -- straightforward direct wiring, no forward
	-- reference for the click to fall through silently.
	PopupToggleButton.MouseButton1Click:Connect(function()
		PlayClick()
		TogglePopup()
	end)
	PopupClose.MouseButton1Click:Connect(function() PlayClick() SetPopupVisible(false) end)
	table.insert(looseConnections, UserInputService.InputBegan:Connect(function(input, processed)
		if processed or UserInputService:GetFocusedTextBox() or bindingInProgress then return end
		if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
		if PopupKeybind ~= Enum.KeyCode.Unknown and input.KeyCode == PopupKeybind then TogglePopup() end
	end))

	-- Dragging, same pattern as MainFrame.
	local dragging = false
	local dragStart, startPos
	PopupHeader.InputBegan:Connect(function(input)
		if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
		dragging = true
		dragStart = input.Position
		startPos = PopupFrame.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then dragging = false end
		end)
	end)
	table.insert(looseConnections, UserInputService.InputChanged:Connect(function(input)
		if not dragging or (input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch) then return end
		local delta = input.Position - dragStart
		PopupFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end))
end

-- Scripts tab: launches the separate game modules (loadstring + HttpGet, same as the
-- old hub). Each module only ever gets fetched once per execution.
local ScriptsPage = CreateTab("Scripts", 5, "79977771810097", true)

-- Caches the fetched source per game so re-running it (see below) never re-hits the
-- network, but still actually executes the chunk again each time -- these game modules
-- are built to detect their own already-built UI and reopen it instead of rebuilding
-- from scratch, so re-running is how you get it back after closing it.
-- Buttons/ActiveGame track which single game is considered "open" so opening a
-- different one resets whichever was previously open back to Execute. Note: this can't
-- reach into that other game's own script to actually close its live UI -- none of these
-- modules expose a close hook back to the hub -- it only stops treating it as open here.
local ScriptRunner = {Sources = {}, Buttons = {}, ActiveGame = nil, Busy = false}
local function RunScriptOnce(key, url)
	local source = ScriptRunner.Sources[key]
	if not source then
		local fetched, fetchedSource = pcall(function() return game:HttpGet(url) end)
		if not fetched or type(fetchedSource) ~= "string" or fetchedSource == "" then return false end
		source = fetchedSource
		ScriptRunner.Sources[key] = source
	end
	if type(loadstring) ~= "function" then return false end
	local chunk = loadstring(source)
	if not chunk then return false end
	return pcall(chunk)
end

local function CreateGameRow(parent, y, gameTitle, url)
	local row = Instance.new("Frame")
	row.Name = gameTitle:gsub("%s+", "") .. "Row"
	row.Size = UDim2.new(1, 0, 0, 44)
	row.Position = UDim2.new(0, 0, 0, y)
	row.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
	row.BackgroundTransparency = RowTransparencyValue / 100
	row.BorderSizePixel = 0
	row.Parent = parent
	Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)
	table.insert(RowTransparencyTargets, row)

	local titleLabel = Instance.new("TextLabel")
	titleLabel.Name = "TitleLabel"
	titleLabel.Size = UDim2.new(0, 240, 1, 0)
	titleLabel.Position = UDim2.new(0, 16, 0, 0)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Text = gameTitle
	titleLabel.Font = UIFont
	titleLabel.TextSize = 15
	titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.TextYAlignment = Enum.TextYAlignment.Center
	titleLabel.Parent = row

	local executeBtn = Instance.new("TextButton")
	executeBtn.Name = "ExecuteButton"
	executeBtn.Size = UDim2.new(0, 90, 0, 32)
	executeBtn.Position = UDim2.new(1, -106, 0.5, -16)
	executeBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
	executeBtn.BackgroundTransparency = 0.2
	executeBtn.BorderSizePixel = 0
	executeBtn.Text = "Execute"
	executeBtn.Font = UIFont
	executeBtn.TextSize = 15
	executeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	executeBtn.Parent = row
	Instance.new("UICorner", executeBtn).CornerRadius = UDim.new(0, 6)
	ScriptRunner.Buttons[gameTitle] = executeBtn

	executeBtn.MouseButton1Click:Connect(function()
		PlayClick()
		if ScriptRunner.Busy then return end -- debounce: ignore double-clicks mid-launch
		ScriptRunner.Busy = true

		-- Only one game counts as "open" at a time -- opening a different one resets
		-- whichever was previously open back to Execute and drops its cached source, so
		-- it does a full reload (not a quick reopen) if picked again later.
		if ScriptRunner.ActiveGame and ScriptRunner.ActiveGame ~= gameTitle then
			local previousButton = ScriptRunner.Buttons[ScriptRunner.ActiveGame]
			if previousButton then previousButton.Text = "Execute" end
			ScriptRunner.Sources[ScriptRunner.ActiveGame] = nil
		end

		-- No "already loaded, do nothing" guard -- once it's run once, this re-runs the
		-- cached source every click, which lets a closed game UI be reopened. "Open"
		-- (not "Loaded") reflects that it stays clickable afterward instead of going dead.
		local reopening = ScriptRunner.Sources[gameTitle] ~= nil
		executeBtn.Text = reopening and "Opening..." or "Loading..."
		local ok = RunScriptOnce(gameTitle, url)
		executeBtn.Text = ok and "Open" or "Execute"
		ScriptRunner.ActiveGame = ok and gameTitle or nil
		ScriptRunner.Busy = false
	end)

	return row
end

CreateGameRow(ScriptsPage, 8, "Undead Expedition", "https://raw.githubusercontent.com/2hqydeu/Hqydeu-Script-Hub/refs/heads/main/UE")
CreateGameRow(ScriptsPage, 60, "Quiet or Die", "https://raw.githubusercontent.com/2hqydeu/Hqydeu-Script-Hub/refs/heads/main/QOD")
CreateGameRow(ScriptsPage, 112, "Murder Mystery 2", "https://raw.githubusercontent.com/2hqydeu/Hqydeu-Script-Hub/refs/heads/main/MM2")

-- Infinite Yield / Dex Explorer: standalone utility scripts (not per-game modules), so
-- unlike CreateGameRow above they get their own row with a separate Destroy button --
-- same idea as the old hub's Infinite Yield destroy button, simplified from its old
-- connection-snapshot/baseline system to a before/after CoreGui diff, since these are just
-- external tools this hub doesn't need to track any deeper state for. Destroy removes
-- whatever GUI the load created and resets Execute so it can be loaded fresh again.
local function CreateUtilityRow(parent, y, title, url)
	local row = Instance.new("Frame")
	row.Name = title:gsub("%s+", "") .. "Row"
	row.Size = UDim2.new(1, 0, 0, 44)
	row.Position = UDim2.new(0, 0, 0, y)
	row.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
	row.BackgroundTransparency = RowTransparencyValue / 100
	row.BorderSizePixel = 0
	row.Parent = parent
	Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)
	table.insert(RowTransparencyTargets, row)

	local titleLabel = Instance.new("TextLabel")
	titleLabel.Name = "TitleLabel"
	titleLabel.Size = UDim2.new(0, 200, 1, 0)
	titleLabel.Position = UDim2.new(0, 16, 0, 0)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Text = title
	titleLabel.Font = UIFont
	titleLabel.TextSize = 15
	titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.TextYAlignment = Enum.TextYAlignment.Center
	titleLabel.Parent = row

	local destroyBtn = Instance.new("TextButton")
	destroyBtn.Name = "DestroyButton"
	destroyBtn.Size = UDim2.new(0, 74, 0, 32)
	destroyBtn.Position = UDim2.new(1, -188, 0.5, -16)
	destroyBtn.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
	destroyBtn.BackgroundTransparency = 0.2
	destroyBtn.BorderSizePixel = 0
	destroyBtn.Text = "Destroy"
	destroyBtn.Font = UIFont
	destroyBtn.TextSize = 14
	destroyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	destroyBtn.Visible = false
	destroyBtn.Parent = row
	Instance.new("UICorner", destroyBtn).CornerRadius = UDim.new(0, 6)

	local executeBtn = Instance.new("TextButton")
	executeBtn.Name = "ExecuteButton"
	executeBtn.Size = UDim2.new(0, 90, 0, 32)
	executeBtn.Position = UDim2.new(1, -106, 0.5, -16)
	executeBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
	executeBtn.BackgroundTransparency = 0.2
	executeBtn.BorderSizePixel = 0
	executeBtn.Text = "Execute"
	executeBtn.Font = UIFont
	executeBtn.TextSize = 15
	executeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	executeBtn.Parent = row
	Instance.new("UICorner", executeBtn).CornerRadius = UDim.new(0, 6)

	local trackedInstances = {}
	local busy = false

	local function DestroyLoaded()
		for _, inst in ipairs(trackedInstances) do
			if inst and inst.Parent then pcall(function() inst:Destroy() end) end
		end
		trackedInstances = {}
		destroyBtn.Visible = false
		executeBtn.Text = "Execute"
	end

	executeBtn.MouseButton1Click:Connect(function()
		PlayClick()
		if busy then return end
		busy = true
		executeBtn.Text = "Loading..."
		local before = {}
		for _, inst in ipairs(CoreGui:GetChildren()) do before[inst] = true end
		local ok = pcall(function()
			local source = game:HttpGet(url)
			local chunk = loadstring(source)
			if chunk then chunk() end
		end)
		task.wait(0.5)
		trackedInstances = {}
		for _, inst in ipairs(CoreGui:GetChildren()) do
			if not before[inst] then table.insert(trackedInstances, inst) end
		end
		executeBtn.Text = ok and "Open" or "Execute"
		destroyBtn.Visible = ok and #trackedInstances > 0
		busy = false
	end)

	destroyBtn.MouseButton1Click:Connect(function()
		PlayClick()
		DestroyLoaded()
	end)

	return row
end

CreateUtilityRow(ScriptsPage, 164, "Infinite Yield", "https://raw.githubusercontent.com/EdgeIY/infiniteyield/master/source")
CreateUtilityRow(ScriptsPage, 216, "Dex Explorer", "https://github.com/AZYsGithub/DexPlusPlus/releases/latest/download/out.lua")


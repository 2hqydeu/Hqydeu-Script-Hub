FOVInput.FocusLost:Connect(function()
	local value = tonumber(FOVInput.Text)
	if value then FOVValue = math.clamp(value, 20, 120) end
	FOVInput.Text = tostring(math.floor(FOVValue + 0.5))
	local camera = workspace.CurrentCamera
	if camera then camera.FieldOfView = FOVValue end
end)

FOVResetButton.MouseButton1Click:Connect(function()
	PlayClick()
	FOVValue = DEFAULT_FOV
	FOVInput.Text = tostring(DEFAULT_FOV)
	if workspace.CurrentCamera then workspace.CurrentCamera.FieldOfView = DEFAULT_FOV end
end)

local function ClearFreeCamSelfESP()
	if FreeCamSelfHighlight then FreeCamSelfHighlight:Destroy() FreeCamSelfHighlight = nil end
	if FreeCamSelfLabel then FreeCamSelfLabel:Destroy() FreeCamSelfLabel = nil end
	FreeCamSelfAdornee = nil
end

local function UpdateFreeCamSelfESP()
	if not FreeCamEnabled then
		ClearFreeCamSelfESP()
		return
	end
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local head = character and character:FindFirstChild("Head")
	local root = character and (character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso"))
	if not character or not humanoid or humanoid.Health <= 0 or not root then
		ClearFreeCamSelfESP()
		return
	end
	if FreeCamSelfAdornee ~= character then
		ClearFreeCamSelfESP()
		local highlight = Instance.new("Highlight")
		highlight.Name = "SerenityFreeCamSelfHighlight"
		highlight.Adornee = character
		highlight.FillColor = FreeCamSelfColor
		highlight.OutlineColor = FreeCamSelfColor
		highlight.FillTransparency = 0.82
		highlight.OutlineTransparency = 0
		highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		highlight.Parent = ScreenGui
		FreeCamSelfHighlight = highlight

		local label = Instance.new("BillboardGui")
		label.Name = "SerenityFreeCamSelfLabel"
		label.Adornee = head or root
		label.Size = UDim2.new(0, 70, 0, 24)
		label.StudsOffsetWorldSpace = Vector3.new(0, 2.8, 0)
		label.AlwaysOnTop = true
		label.Parent = ScreenGui
		local text = Instance.new("TextLabel")
		text.Size = UDim2.new(1, 0, 1, 0)
		text.BackgroundTransparency = 1
		text.Text = "You"
		text.Font = UIFont
		text.TextSize = 12
		text.TextColor3 = FreeCamSelfColor
		text.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
		text.TextStrokeTransparency = 0.15
		text.Parent = label
		FreeCamSelfLabel = label
		FreeCamSelfAdornee = character
	elseif FreeCamSelfLabel then
		FreeCamSelfLabel.Adornee = head or root
	end
end

local function EnableFreeCam()
	if FreeCamEnabled then return end
	local camera = workspace.CurrentCamera
	if not camera then return end
	FreeCamEnabled = true
	FreeCamOriginalType = camera.CameraType
	FreeCamOriginalSubject = camera.CameraSubject
	FreeCamOriginalCFrame = camera.CFrame
	FreeCamOriginalFocus = camera.Focus
	FreeCamPosition = camera.CFrame.Position
	FreeCamPitch, FreeCamYaw = camera.CFrame:ToOrientation()
	camera.CameraType = Enum.CameraType.Scriptable
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if humanoid then humanoid:Move(Vector3.zero) end
	if root then root.AssemblyLinearVelocity = Vector3.zero root.AssemblyAngularVelocity = Vector3.zero end
	FreeCamToggle.Text = "On"
	UpdateFreeCamSelfESP()
	ContextActionService:BindActionAtPriority(
		"SerenityFreeCamSink",
		function() return Enum.ContextActionResult.Sink end,
		false,
		Enum.ContextActionPriority.High.Value + 100,
		Enum.KeyCode.W, Enum.KeyCode.A, Enum.KeyCode.S, Enum.KeyCode.D,
		Enum.KeyCode.Q, Enum.KeyCode.E, Enum.KeyCode.LeftShift
	)
end

local function DisableFreeCam()
	if not FreeCamEnabled then return end
	FreeCamEnabled = false
	ContextActionService:UnbindAction("SerenityFreeCamSink")
	-- Always release the RMB camera lock. Restoring a captured LockCenter state can
	-- leave the cursor pinned after Free Cam is turned off.
	UserInputService.MouseBehavior = Enum.MouseBehavior.Default
	UserInputService.MouseIconEnabled = true
	ClearFreeCamSelfESP()
	local camera = workspace.CurrentCamera
	if camera then
		camera.CameraType = FreeCamOriginalType or Enum.CameraType.Custom
		local character = Player.Character
		local humanoid = character and character:FindFirstChildOfClass("Humanoid")
		camera.CameraSubject = humanoid or FreeCamOriginalSubject
		if FreeCamOriginalCFrame then camera.CFrame = FreeCamOriginalCFrame end
		if FreeCamOriginalFocus then camera.Focus = FreeCamOriginalFocus end
	end
	FreeCamToggle.Text = "Off"
	task.defer(function()
		if not FreeCamEnabled then
			UserInputService.MouseBehavior = Enum.MouseBehavior.Default
			UserInputService.MouseIconEnabled = true
		end
	end)
end

local function ToggleFreeCam()
	if FreeCamEnabled then DisableFreeCam() else EnableFreeCam() end
end
FreeCamToggle.MouseButton1Click:Connect(function() PlayClick() ToggleFreeCam() end)

local freeCamRenderConnection = RunService.RenderStepped:Connect(function(deltaTime)
	if not FreeCamEnabled then return end
	local camera = workspace.CurrentCamera
	if not camera then return end
	UpdateFreeCamSelfESP()
	local focusedTextBox
	pcall(function() focusedTextBox = UserInputService:GetFocusedTextBox() end)
	if focusedTextBox then
		UserInputService.MouseBehavior = Enum.MouseBehavior.Default
		return
	end
	if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
		UserInputService.MouseBehavior = Enum.MouseBehavior.LockCurrentPosition
		local mouseDelta = UserInputService:GetMouseDelta()
		FreeCamYaw = FreeCamYaw - mouseDelta.X * 0.01
		FreeCamPitch = math.clamp(FreeCamPitch - mouseDelta.Y * 0.01, math.rad(-89), math.rad(89))
	else
		UserInputService.MouseBehavior = Enum.MouseBehavior.Default
	end
	local rotation = CFrame.fromOrientation(FreeCamPitch, FreeCamYaw, 0)
	local movement = Vector3.zero
	if UserInputService:IsKeyDown(Enum.KeyCode.W) then movement += rotation.LookVector end
	if UserInputService:IsKeyDown(Enum.KeyCode.S) then movement -= rotation.LookVector end
	if UserInputService:IsKeyDown(Enum.KeyCode.D) then movement += rotation.RightVector end
	if UserInputService:IsKeyDown(Enum.KeyCode.A) then movement -= rotation.RightVector end
	if UserInputService:IsKeyDown(Enum.KeyCode.E) then movement += Vector3.new(0, 1, 0) end
	if UserInputService:IsKeyDown(Enum.KeyCode.Q) then movement -= Vector3.new(0, 1, 0) end
	local speed = UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and 120 or 40
	if movement.Magnitude > 0 then FreeCamPosition = FreeCamPosition + movement.Unit * speed * deltaTime end
	local cameraCFrame = CFrame.new(FreeCamPosition) * rotation
	camera.CFrame = cameraCFrame
	camera.Focus = cameraCFrame * CFrame.new(0, 0, -512)
end)

-- Teleport tab (blank for now)
local TeleportPage = CreateTab("Teleport", 4, "90261647722333", true)

-- Scripts tab: launches the separate game modules (loadstring + HttpGet, same as the
-- old hub). Each module only ever gets fetched once per execution.
local ScriptsPage = CreateTab("Scripts", 5, "77194728508403", true)

-- Caches the fetched source per game so re-running it (see below) never re-hits the
-- network, but still actually executes the chunk again each time -- these game modules
-- are built to detect their own already-built UI and reopen it instead of rebuilding
-- from scratch, so re-running is how you get it back after closing it.
-- Buttons/ActiveGame track which single game is considered "open" so opening a
-- different one resets whichever was previously open back to Execute. Note: this can't
-- reach into that other game's own script to actually close its live UI -- none of these
-- modules expose a close hook back to the hub -- it only stops treating it as open here.
local ScriptRunner = {Sources = {}, Buttons = {}, ActiveGame = nil, Busy = false}
local function RunScriptOnce(key, url)
	local source = ScriptRunner.Sources[key]
	if not source then
		local fetched, fetchedSource = pcall(function() return game:HttpGet(url) end)
		if not fetched or type(fetchedSource) ~= "string" or fetchedSource == "" then return false end
		source = fetchedSource
		ScriptRunner.Sources[key] = source
	end
	if type(loadstring) ~= "function" then return false end
	local chunk = loadstring(source)
	if not chunk then return false end
	return pcall(chunk)
end

local function CreateGameRow(parent, y, gameTitle, url)
	local row = Instance.new("Frame")
	row.Name = gameTitle:gsub("%s+", "") .. "Row"
	row.Size = UDim2.new(1, 0, 0, 44)
	row.Position = UDim2.new(0, 0, 0, y)
	row.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
	row.BackgroundTransparency = 0.5
	row.BorderSizePixel = 0
	row.Parent = parent
	Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)

	local titleLabel = Instance.new("TextLabel")
	titleLabel.Name = "TitleLabel"
	titleLabel.Size = UDim2.new(0, 240, 1, 0)
	titleLabel.Position = UDim2.new(0, 16, 0, 0)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Text = gameTitle
	titleLabel.Font = UIFont
	titleLabel.TextSize = 15
	titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.TextYAlignment = Enum.TextYAlignment.Center
	titleLabel.Parent = row

	local executeBtn = Instance.new("TextButton")
	executeBtn.Name = "ExecuteButton"
	executeBtn.Size = UDim2.new(0, 90, 0, 32)
	executeBtn.Position = UDim2.new(1, -106, 0.5, -16)
	executeBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
	executeBtn.BackgroundTransparency = 0.2
	executeBtn.BorderSizePixel = 0
	executeBtn.Text = "Execute"
	executeBtn.Font = UIFont
	executeBtn.TextSize = 15
	executeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	executeBtn.Parent = row
	Instance.new("UICorner", executeBtn).CornerRadius = UDim.new(0, 6)
	ScriptRunner.Buttons[gameTitle] = executeBtn

	executeBtn.MouseButton1Click:Connect(function()
		PlayClick()
		if ScriptRunner.Busy then return end -- debounce: ignore double-clicks mid-launch
		ScriptRunner.Busy = true

		-- Only one game counts as "open" at a time -- opening a different one resets
		-- whichever was previously open back to Execute and drops its cached source, so
		-- it does a full reload (not a quick reopen) if picked again later.
		if ScriptRunner.ActiveGame and ScriptRunner.ActiveGame ~= gameTitle then
			local previousButton = ScriptRunner.Buttons[ScriptRunner.ActiveGame]
			if previousButton then previousButton.Text = "Execute" end
			ScriptRunner.Sources[ScriptRunner.ActiveGame] = nil
		end

		-- No "already loaded, do nothing" guard -- once it's run once, this re-runs the
		-- cached source every click, which lets a closed game UI be reopened. "Open"
		-- (not "Loaded") reflects that it stays clickable afterward instead of going dead.
		local reopening = ScriptRunner.Sources[gameTitle] ~= nil
		executeBtn.Text = reopening and "Opening..." or "Loading..."
		local ok = RunScriptOnce(gameTitle, url)
		executeBtn.Text = ok and "Open" or "Execute"
		ScriptRunner.ActiveGame = ok and gameTitle or nil
		ScriptRunner.Busy = false
	end)

	return row
end

CreateGameRow(ScriptsPage, 8, "Undead Expedition", "https://raw.githubusercontent.com/2hqydeu/Hqydeu-Script-Hub/refs/heads/main/UE")
ScriptsPage.CanvasSize = UDim2.new(0, 0, 0, 60)

SelectTab("Home")

-- Minimize: hardcoded to Left Control, not user-configurable. Everything below the
-- header (dividers, tabs, content) is explicitly hidden while minimized so nothing
-- peeks past the clipped frame. Minimizing snaps the pill to the nearest screen edge,
-- and restores to wherever the window was before minimizing.
local MinimizeKeybind = Enum.KeyCode.LeftControl
local minimized = false
local preMinimizePosition = nil

local function GetSnappedMinimizedPosition()
	local camera = workspace.CurrentCamera
	local viewportSize = (camera and camera.ViewportSize) or Vector2.new(1920, 1080)
	local miniWidth = MINI_SIZE.X.Offset
	local miniHeight = MINI_SIZE.Y.Offset
	local currentAbsPos = MainFrame.AbsolutePosition
	local currentAbsSize = MainFrame.AbsoluteSize
	local centerX = currentAbsPos.X + (currentAbsSize.X / 2)
	local snappedX = (centerX < viewportSize.X / 2) and 8 or (viewportSize.X - miniWidth - 8)
	local snappedY = math.clamp(currentAbsPos.Y, 8, math.max(8, viewportSize.Y - miniHeight - 8))
	return UDim2.new(0, snappedX, 0, snappedY)
end

local function ToggleGUI()
	minimized = not minimized
	HeaderDivider.Visible = not minimized
	TabBar.Visible = not minimized
	TabDivider.Visible = not minimized
	ContentArea.Visible = not minimized
	if minimized then
		preMinimizePosition = MainFrame.Position
		-- Both popups anchor to controls that are about to shrink/disappear -- rather
		-- than have them awkwardly follow a minimizing window, just close them.
		CloseKeybindClearPrompt()
		CloseESPColorPicker()
	end
	local targetPosition = minimized and GetSnappedMinimizedPosition() or (preMinimizePosition or WINDOW_POSITION)
	TweenService:Create(MainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Size = minimized and MINI_SIZE or FULL_SIZE,
		Position = targetPosition,
	}):Play()
	MiniButton.Text = minimized and "+" or "-"
end
MiniButton.MouseButton1Click:Connect(function() PlayClick() ToggleGUI() end)

-- Silent unbind-able destroy key (Right Control) -- no button, no prompt, no sound.
-- Reverses every active effect (Speed/Jump/Fly, whichever mode) before tearing down, so
-- nothing lingers on the character no matter what was toggled on when this fires.
local DestroyKeybind = Enum.KeyCode.RightControl
local mainInputConnection
local dragChangedConnection

local function DestroyGui()
	if mainInputConnection then mainInputConnection:Disconnect() end
	if dragChangedConnection then dragChangedConnection:Disconnect() end
	if characterAddedConnection then characterAddedConnection:Disconnect() end
	if speedRenderConnection then speedRenderConnection:Disconnect() end
	if flyRenderConnection then flyRenderConnection:Disconnect() end
	if freeCamRenderConnection then freeCamRenderConnection:Disconnect() end

	SpeedEnabled = false
	JumpEnabled = false
	FlyEnabled = false
	if FlyBodyVelocity then FlyBodyVelocity:Destroy() FlyBodyVelocity = nil end
	if FlyBodyGyro then FlyBodyGyro:Destroy() FlyBodyGyro = nil end
	DisableFreeCam()
	if workspace.CurrentCamera then workspace.CurrentCamera.FieldOfView = DEFAULT_FOV end
	OutlineESPEnabled = false
	BoxESPEnabled = false
	ESPLabelsEnabled = false
	for plr in pairs(OutlineHighlights) do RemoveOutlineHighlight(plr) end
	for plr in pairs(BoxAdornments) do RemoveBoxAdornments(plr) end
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr.Character then RemoveESPLabel(plr.Character) end
	end

	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if humanoid then
		humanoid.WalkSpeed = DEFAULT_WALKSPEED
		if JumpOriginal then
			humanoid.UseJumpPower = JumpOriginal.UseJumpPower
			humanoid.JumpPower = JumpOriginal.JumpPower
			humanoid.JumpHeight = JumpOriginal.JumpHeight
		end
	end

	ScreenGui:Destroy()
end

mainInputConnection = UserInputService.InputBegan:Connect(function(input, processed)
	if processed or UserInputService:GetFocusedTextBox() or bindingInProgress then return end
	if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
	if input.KeyCode == DestroyKeybind then
		DestroyGui()
		return
	end
	if input.KeyCode == MinimizeKeybind then ToggleGUI() return end
	-- Independent ifs, not elseif -- multiple features can share the same keybind, and
	-- all of them should fire on that single keypress instead of just the first match.
	if SpeedKeybind ~= Enum.KeyCode.Unknown and input.KeyCode == SpeedKeybind then ToggleSpeed() end
	if JumpKeybind ~= Enum.KeyCode.Unknown and input.KeyCode == JumpKeybind then ToggleJump() end
	if FlyKeybind ~= Enum.KeyCode.Unknown and input.KeyCode == FlyKeybind then ToggleFly() end
	if FreeCamKeybind ~= Enum.KeyCode.Unknown and input.KeyCode == FreeCamKeybind then ToggleFreeCam() end
	if OutlineESPKeybind ~= Enum.KeyCode.Unknown and input.KeyCode == OutlineESPKeybind then ToggleOutlineESP() end
	if BoxESPKeybind ~= Enum.KeyCode.Unknown and input.KeyCode == BoxESPKeybind then ToggleBoxESP() end
	if ESPLabelsKeybind ~= Enum.KeyCode.Unknown and input.KeyCode == ESPLabelsKeybind then ToggleESPLabels() end
end)

-- Dragging
local dragging = false
local dragStart = nil
local startPos = nil
MainFrame.InputBegan:Connect(function(input)
	if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
	dragging = true
	dragStart = input.Position
	startPos = MainFrame.Position
	input.Changed:Connect(function()
		if input.UserInputState == Enum.UserInputState.End then
			dragging = false
			-- Only the minimized pill snaps to an edge; a full-size window stays
			-- wherever it's dropped.
			if minimized then
				TweenService:Create(MainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
					Position = GetSnappedMinimizedPosition(),
				}):Play()
			end
		end
	end)
end)
dragChangedConnection = UserInputService.InputChanged:Connect(function(input)
	if not dragging or (input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch) then return end
	local delta = input.Position - dragStart
	MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end)

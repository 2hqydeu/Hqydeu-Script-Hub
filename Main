-- Right-click a keybind button to clear it: a small "Remove keybind?" popup with
-- Remove/Cancel, ported from the old feature-rich hub. Singleton -- opening a new one
-- closes whichever is already open. Tracks the button it's anchored to so it stays
-- attached if the window gets dragged, and CloseKeybindClearPrompt lets the minimize
-- handler force it shut instead of leaving it stranded over a shrunk window.
local ActiveKeybindClearPrompt = nil
local ActiveKeybindClearButton = nil

local function CloseKeybindClearPrompt()
	if ActiveKeybindClearPrompt then ActiveKeybindClearPrompt:Destroy() end
	ActiveKeybindClearPrompt = nil
	ActiveKeybindClearButton = nil
end

local function RepositionKeybindClearPrompt()
	if not (ActiveKeybindClearPrompt and ActiveKeybindClearButton) then return end
	ActiveKeybindClearPrompt.Position = UDim2.fromOffset(
		ActiveKeybindClearButton.AbsolutePosition.X,
		ActiveKeybindClearButton.AbsolutePosition.Y + ActiveKeybindClearButton.AbsoluteSize.Y + 6
	)
end
MainFrame:GetPropertyChangedSignal("AbsolutePosition"):Connect(RepositionKeybindClearPrompt)

local function ShowKeybindClearPrompt(button, onCleared)
	CloseKeybindClearPrompt()

	local prompt = Instance.new("Frame")
	prompt.Name = "KeybindClearPrompt"
	prompt.Size = UDim2.new(0, 160, 0, 74)
	prompt.Position = UDim2.fromOffset(button.AbsolutePosition.X, button.AbsolutePosition.Y + button.AbsoluteSize.Y + 6)
	prompt.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
	prompt.BorderSizePixel = 0
	prompt.ZIndex = 50
	prompt.Parent = ScreenGui
	Instance.new("UICorner", prompt).CornerRadius = UDim.new(0, 10)
	local promptStroke = Instance.new("UIStroke")
	promptStroke.Color = Color3.fromRGB(0, 0, 0)
	promptStroke.Thickness = 1
	promptStroke.Parent = prompt
	ActiveKeybindClearPrompt = prompt
	ActiveKeybindClearButton = button

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, -16, 0, 28)
	label.Position = UDim2.new(0, 8, 0, 6)
	label.BackgroundTransparency = 1
	label.Text = "Remove keybind?"
	label.Font = UIFont
	label.TextSize = 13
	label.TextColor3 = Color3.fromRGB(255, 255, 255)
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.ZIndex = 51
	label.Parent = prompt

	local removeBtn = Instance.new("TextButton")
	removeBtn.Size = UDim2.new(0, 68, 0, 26)
	removeBtn.Position = UDim2.new(0, 8, 0, 38)
	removeBtn.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
	removeBtn.BorderSizePixel = 0
	removeBtn.Text = "Remove"
	removeBtn.Font = UIFont
	removeBtn.TextSize = 13
	removeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	removeBtn.ZIndex = 51
	removeBtn.Parent = prompt
	Instance.new("UICorner", removeBtn).CornerRadius = UDim.new(0, 6)

	local cancelBtn = Instance.new("TextButton")
	cancelBtn.Size = UDim2.new(0, 68, 0, 26)
	cancelBtn.Position = UDim2.new(0, 84, 0, 38)
	cancelBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
	cancelBtn.BorderSizePixel = 0
	cancelBtn.Text = "Cancel"
	cancelBtn.Font = UIFont
	cancelBtn.TextSize = 13
	cancelBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	cancelBtn.ZIndex = 51
	cancelBtn.Parent = prompt
	Instance.new("UICorner", cancelBtn).CornerRadius = UDim.new(0, 6)

	removeBtn.MouseButton1Click:Connect(function()
		PlayClick()
		onCleared()
		CloseKeybindClearPrompt()
	end)
	cancelBtn.MouseButton1Click:Connect(function()
		PlayClick()
		CloseKeybindClearPrompt()
	end)
end

-- A rebindable keybind button: click, press a key, it saves to the settings file and
-- calls onKeybindChanged with the new KeyCode so the caller can update its own state.
-- Right-click clears it via ShowKeybindClearPrompt above.
local function CreateKeybindButton(parent, storageKey, onKeybindChanged)
	local btn = Instance.new("TextButton")
	btn.Name = "KeybindButton"
	btn.Size = UDim2.new(0, 80, 0, 30)
	btn.Position = UDim2.new(1, -176, 0.5, -15)
	btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
	btn.BackgroundTransparency = 0.2
	btn.BorderSizePixel = 0
	btn.Font = UIFont
	btn.TextSize = 16
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	btn.Parent = parent
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

	local loadedKey = LoadFeatureKeybind(storageKey)
	btn.Text = KeybindText(loadedKey)
	onKeybindChanged(loadedKey)

	btn.MouseButton1Click:Connect(function()
		PlayClick()
		btn.Text = "..."
		bindingInProgress = true
		local capture
		capture = UserInputService.InputBegan:Connect(function(input, processed)
			if processed then return end
			if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
			local selectedKey = input.KeyCode
			if selectedKey == Enum.KeyCode.Backspace or selectedKey == Enum.KeyCode.Delete then
				selectedKey = Enum.KeyCode.Unknown
			end
			SaveFeatureKeybind(storageKey, selectedKey)
			btn.Text = KeybindText(selectedKey)
			onKeybindChanged(selectedKey)
			capture:Disconnect()
			-- Deferred so this input event finishes dispatching to every listener
			-- (including the global toggle-key handler below) before the guard drops --
			-- otherwise the same keypress that sets the bind could also fire the toggle.
			task.defer(function() bindingInProgress = false end)
		end)
	end)

	btn.MouseButton2Click:Connect(function()
		ShowKeybindClearPrompt(btn, function()
			SaveFeatureKeybind(storageKey, Enum.KeyCode.Unknown)
			btn.Text = "..."
			onKeybindChanged(Enum.KeyCode.Unknown)
		end)
	end)

	return btn
end

-- On/Off toggle plus its keybind button, in their own row below the strength row.
-- labelText overrides the row's own label (defaults to "Toggle" for rows that already
-- have their feature name shown above, e.g. via CreateStrengthRow).
local function CreateToggleRow(parent, y, storageKey, onKeybindChanged, labelText)
	local row = Instance.new("Frame")
	row.Name = "ToggleRow"
	row.Size = UDim2.new(1, 0, 0, 40)
	row.Position = UDim2.new(0, 0, 0, y)
	row.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
	row.BackgroundTransparency = 0.5
	row.BorderSizePixel = 0
	row.Parent = parent
	Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)

	local rowLabel = Instance.new("TextLabel")
	rowLabel.Name = "RowLabel"
	rowLabel.Size = UDim2.new(0, 200, 1, 0)
	rowLabel.Position = UDim2.new(0, 16, 0, 0)
	rowLabel.BackgroundTransparency = 1
	rowLabel.Text = labelText or "Toggle"
	rowLabel.Font = UIFont
	rowLabel.TextSize = 15
	rowLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	rowLabel.TextXAlignment = Enum.TextXAlignment.Left
	rowLabel.TextYAlignment = Enum.TextYAlignment.Center
	rowLabel.Parent = row

	local toggle = Instance.new("TextButton")
	toggle.Name = "Toggle"
	toggle.Size = UDim2.new(0, 80, 0, 30)
	toggle.Position = UDim2.new(1, -88, 0.5, -15)
	toggle.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
	toggle.BackgroundTransparency = 0.2
	toggle.BorderSizePixel = 0
	toggle.Text = "Off"
	toggle.Font = UIFont
	toggle.TextSize = 16
	toggle.TextColor3 = Color3.fromRGB(255, 255, 255)
	toggle.Parent = row
	Instance.new("UICorner", toggle).CornerRadius = UDim.new(0, 6)

	local keybindBtn = CreateKeybindButton(row, storageKey, onKeybindChanged)

	return toggle, keybindBtn
end

local DEFAULT_WALKSPEED = 16
local SECTION_GAP = 16

-- Speed/Jump/Fly state and connections that DestroyGui and the keybind dispatcher (both
-- far below) need to reach by name have to stay true top-level locals; everything else
-- for this section is scoped inside the do block below so its registers free up
-- afterward (see the Home tab comment above for why that matters).
local SpeedEnabled, SpeedKeybind
local JumpEnabled, JumpKeybind, JumpOriginal
local FlyEnabled, FlyKeybind, FlyBodyVelocity, FlyBodyGyro
local ToggleSpeed, ToggleJump, ToggleFly
local speedRenderConnection, flyRenderConnection, characterAddedConnection

do
	-- Speed
	SpeedEnabled = false
	local SpeedValue = 3
	local SpeedMode = "CFrame" -- "CFrame" (old hub's root-nudge movement) or "WalkSpeed"
	SpeedKeybind = Enum.KeyCode.Unknown

	CreateSectionHeading(PlayerPage, 8, "Speed")
	local SpeedInput = CreateStrengthRow(PlayerPage, 38, "Speed Strength", SpeedValue)
	local SpeedToggle = CreateToggleRow(PlayerPage, 86, "SpeedKeybind", function(k) SpeedKeybind = k end)

	local SpeedModeButton = Instance.new("TextButton")
	SpeedModeButton.Name = "SpeedModeButton"
	SpeedModeButton.Size = UDim2.new(1, 0, 0, 36)
	SpeedModeButton.Position = UDim2.new(0, 0, 0, 134)
	SpeedModeButton.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
	SpeedModeButton.BackgroundTransparency = 0.5
	SpeedModeButton.BorderSizePixel = 0
	SpeedModeButton.Text = "Mode: CFrame Movement"
	SpeedModeButton.Font = UIFont
	SpeedModeButton.TextSize = 14
	SpeedModeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
	SpeedModeButton.Parent = PlayerPage
	Instance.new("UICorner", SpeedModeButton).CornerRadius = UDim.new(0, 8)

	local function ApplySpeed()
		local character = Player.Character
		local humanoid = character and character:FindFirstChildOfClass("Humanoid")
		if not humanoid then return end
		if SpeedMode == "WalkSpeed" then
			humanoid.WalkSpeed = SpeedEnabled and SpeedValue or DEFAULT_WALKSPEED
		else
			-- CFrame mode drives movement itself every frame below; keep WalkSpeed normal
			-- so the two approaches never stack.
			humanoid.WalkSpeed = DEFAULT_WALKSPEED
		end
	end

	speedRenderConnection = RunService.RenderStepped:Connect(function()
		if not (SpeedEnabled and SpeedMode == "CFrame") then return end
		local character = Player.Character
		local rootPart = character and character:FindFirstChild("HumanoidRootPart")
		local humanoid = character and character:FindFirstChildOfClass("Humanoid")
		if not (rootPart and humanoid) then return end
		local moveDir = humanoid.MoveDirection
		if moveDir.Magnitude > 0 then
			rootPart.CFrame = rootPart.CFrame + (moveDir * (SpeedValue / 10))
		end
	end)

	ToggleSpeed = function()
		SpeedEnabled = not SpeedEnabled
		SpeedToggle.Text = SpeedEnabled and "On" or "Off"
		ApplySpeed()
	end
	SpeedToggle.MouseButton1Click:Connect(function() PlayClick() ToggleSpeed() end)

	SpeedInput.FocusLost:Connect(function()
		local value = tonumber(SpeedInput.Text)
		if value then SpeedValue = value end
		SpeedInput.Text = tostring(SpeedValue)
		ApplySpeed()
	end)

	SpeedModeButton.MouseButton1Click:Connect(function()
		PlayClick()
		SpeedMode = SpeedMode == "CFrame" and "WalkSpeed" or "CFrame"
		SpeedModeButton.Text = SpeedMode == "CFrame" and "Mode: CFrame Movement" or "Mode: WalkSpeed"
		ApplySpeed()
	end)

	local SPEED_SECTION_BOTTOM = 134 + 36 -- heading(8) + strength(38..78) + toggle(86..126) + mode(134..170)

	-- Jump
	JumpEnabled = false
	local JumpValue = 50
	JumpOriginal = nil -- captured Humanoid jump settings, restored exactly when toggled off
	JumpKeybind = Enum.KeyCode.Unknown

	local JUMP_TOP = SPEED_SECTION_BOTTOM + SECTION_GAP
	CreateSectionHeading(PlayerPage, JUMP_TOP, "Jump")
	local JumpInput = CreateStrengthRow(PlayerPage, JUMP_TOP + 30, "Jump Strength", JumpValue)
	local JumpToggle = CreateToggleRow(PlayerPage, JUMP_TOP + 78, "JumpKeybind", function(k) JumpKeybind = k end)
	local JUMP_SECTION_BOTTOM = JUMP_TOP + 78 + 40

	local function ApplyJump()
		local character = Player.Character
		local humanoid = character and character:FindFirstChildOfClass("Humanoid")
		if not humanoid then return end
		if JumpEnabled then
			if not JumpOriginal then
				JumpOriginal = {
					UseJumpPower = humanoid.UseJumpPower,
					JumpPower = humanoid.JumpPower,
					JumpHeight = humanoid.JumpHeight,
				}
			end
			humanoid.UseJumpPower = true
			humanoid.JumpPower = JumpValue
		elseif JumpOriginal then
			humanoid.UseJumpPower = JumpOriginal.UseJumpPower
			humanoid.JumpPower = JumpOriginal.JumpPower
			humanoid.JumpHeight = JumpOriginal.JumpHeight
		end
	end

	-- Continuously re-asserts JumpPower while enabled, in case anything else (the game's own
	-- scripts, a respawn, etc.) overwrites it -- a one-time set wasn't holding reliably.
	RunService.Heartbeat:Connect(function()
		if not JumpEnabled then return end
		local character = Player.Character
		local humanoid = character and character:FindFirstChildOfClass("Humanoid")
		if not humanoid then return end
		if not JumpOriginal then
			JumpOriginal = {
				UseJumpPower = humanoid.UseJumpPower,
				JumpPower = humanoid.JumpPower,
				JumpHeight = humanoid.JumpHeight,
			}
		end
		if not humanoid.UseJumpPower then humanoid.UseJumpPower = true end
		if humanoid.JumpPower ~= JumpValue then humanoid.JumpPower = JumpValue end
	end)

	ToggleJump = function()
		JumpEnabled = not JumpEnabled
		JumpToggle.Text = JumpEnabled and "On" or "Off"
		ApplyJump()
	end
	JumpToggle.MouseButton1Click:Connect(function() PlayClick() ToggleJump() end)

	JumpInput.FocusLost:Connect(function()
		local value = tonumber(JumpInput.Text)
		if value then JumpValue = value end
		JumpInput.Text = tostring(JumpValue)
		if JumpEnabled then ApplyJump() end
	end)

	-- Fly (ported from the old feature-rich hub): BodyVelocity locks the root part's
	-- velocity at zero -- acting as a zero-G anchor against gravity -- while a BodyGyro
	-- keeps it upright and turned to the camera's yaw each frame. Actual movement is still
	-- a direct CFrame nudge, same as Speed, but the BodyGyro means the character no longer
	-- tumbles while airborne.
	FlyEnabled = false
	local FlyValue = 10
	FlyKeybind = Enum.KeyCode.Unknown
	FlyBodyVelocity = nil
	FlyBodyGyro = nil

	local FLY_TOP = JUMP_SECTION_BOTTOM + SECTION_GAP
	CreateSectionHeading(PlayerPage, FLY_TOP, "Fly")
	local FlyInput = CreateStrengthRow(PlayerPage, FLY_TOP + 30, "Fly Strength", FlyValue)
	local FlyToggle = CreateToggleRow(PlayerPage, FLY_TOP + 78, "FlyKeybind", function(k) FlyKeybind = k end)
	local FLY_SECTION_BOTTOM = FLY_TOP + 78 + 40

	local function UprightCFrame(sourceCFrame, position)
		local _, yaw = sourceCFrame:ToOrientation()
		return CFrame.new(position or sourceCFrame.Position) * CFrame.Angles(0, yaw, 0)
	end

	ToggleFly = function()
		FlyEnabled = not FlyEnabled
		FlyToggle.Text = FlyEnabled and "On" or "Off"
		local character = Player.Character
		local rootPart = character and character:FindFirstChild("HumanoidRootPart")
		if FlyEnabled then
			if rootPart then
				FlyBodyVelocity = Instance.new("BodyVelocity")
				FlyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
				FlyBodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
				FlyBodyVelocity.Parent = rootPart
				FlyBodyGyro = Instance.new("BodyGyro")
				FlyBodyGyro.P = 9e4
				FlyBodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
				FlyBodyGyro.CFrame = rootPart.CFrame
				FlyBodyGyro.Parent = rootPart
			end
		else
			if FlyBodyVelocity then FlyBodyVelocity:Destroy() FlyBodyVelocity = nil end
			if FlyBodyGyro then FlyBodyGyro:Destroy() FlyBodyGyro = nil end
			if rootPart then
				rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
				rootPart.CFrame = UprightCFrame(rootPart.CFrame, rootPart.Position)
				rootPart.AssemblyAngularVelocity = Vector3.zero
			end
		end
	end
	FlyToggle.MouseButton1Click:Connect(function() PlayClick() ToggleFly() end)

	FlyInput.FocusLost:Connect(function()
		local value = tonumber(FlyInput.Text)
		if value then FlyValue = value end
		FlyInput.Text = tostring(FlyValue)
	end)

	flyRenderConnection = RunService.RenderStepped:Connect(function()
		if not FlyEnabled then return end
		local character = Player.Character
		local rootPart = character and character:FindFirstChild("HumanoidRootPart")
		local camera = workspace.CurrentCamera
		if not (rootPart and FlyBodyGyro and camera) then return end
		local moveDir = Vector3.new(0, 0, 0)
		if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir += camera.CFrame.LookVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir -= camera.CFrame.LookVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir -= camera.CFrame.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir += camera.CFrame.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir += Vector3.new(0, 1, 0) end
		if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveDir -= Vector3.new(0, 1, 0) end
		if moveDir.Magnitude > 0 then
			rootPart.CFrame = rootPart.CFrame + (moveDir * (FlyValue / 50))
		end
		local _, yaw = camera.CFrame:ToOrientation()
		FlyBodyGyro.CFrame = CFrame.new(rootPart.Position) * CFrame.Angles(0, yaw, 0)
		rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
		rootPart.AssemblyAngularVelocity = Vector3.zero
	end)

	PlayerPage.CanvasSize = UDim2.new(0, 0, 0, FLY_SECTION_BOTTOM + 16)

	-- Re-apply active effects whenever the character (re)spawns.
	characterAddedConnection = Player.CharacterAdded:Connect(function()
		task.wait(0.1)
		ApplySpeed()
		JumpOriginal = nil
		if JumpEnabled then ApplyJump() end
	end)
end

-- Visuals tab: Outline ESP, Body ESP (per-limb boxes, Infinite Yield-style, ported from
-- the old feature-rich hub), ESP Labels (name/health/distance), and Camera (Free Cam +
-- FOV, also ported). All three ESP effects share one color, set from the ESP Color row's
-- picker below the feature rows.
local VisualsPage = CreateTab("Visuals", 3, "90467794700971", true)

local ESPDefaultColor = Color3.fromRGB(100, 255, 100)
local ESPColor = LoadFeatureColor("ESPColor", ESPDefaultColor)

-- Box/label adornments live under this folder instead of the character itself, so they
-- keep rendering even if something else on the character (e.g. a local transparency
-- effect) tries to hide its own children.
local ESPAdornmentRoot = Instance.new("Folder")
ESPAdornmentRoot.Name = "SerenityESPAdornments"
ESPAdornmentRoot.Parent = ScreenGui

local OutlineESPEnabled = false
local OutlineESPKeybind = Enum.KeyCode.Unknown
local OutlineHighlights = {} -- [Player] = Highlight

local BoxESPEnabled = false
local BoxESPKeybind = Enum.KeyCode.Unknown
local BoxAdornments = {} -- [Player] = {[part] = BoxHandleAdornment}

local ESPLabelsEnabled = false
local ESPLabelsKeybind = Enum.KeyCode.Unknown

-- Keyed by Player rather than Character: a Player persists across deaths/respawns, so
-- tracking by Player (matching the old feature-rich hub) means a stale highlight or box
-- set from a previous life is always reachable to clear, even after its Character is
-- long gone.
local function RemoveOutlineHighlight(plr)
	local highlight = OutlineHighlights[plr]
	if highlight then highlight:Destroy() end
	OutlineHighlights[plr] = nil
end

local function AddOutlineHighlight(plr, character)
	if OutlineHighlights[plr] then return end
	local highlight = Instance.new("Highlight")
	highlight.Name = "SerenityOutlineESP"
	highlight.FillColor = ESPColor
	highlight.FillTransparency = 0.72
	highlight.OutlineColor = ESPColor
	highlight.OutlineTransparency = 0
	highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	highlight.Parent = character
	OutlineHighlights[plr] = highlight
end

-- Body-part names covered by Body ESP, matching both R15 and R6 rigs.
local BodyESPPartNames = {
	HumanoidRootPart = true, Head = true, Torso = true, UpperTorso = true, LowerTorso = true,
	LeftUpperArm = true, LeftLowerArm = true, LeftHand = true,
	RightUpperArm = true, RightLowerArm = true, RightHand = true,
	LeftUpperLeg = true, LeftLowerLeg = true, LeftFoot = true,
	RightUpperLeg = true, RightLowerLeg = true, RightFoot = true,
	["Left Arm"] = true, ["Right Arm"] = true, ["Left Leg"] = true, ["Right Leg"] = true,
}

local function IsBodyESPPart(part, character)
	return part:IsA("BasePart") and part.Parent == character and BodyESPPartNames[part.Name] == true
end

local function RemoveBoxAdornments(plr)
	local adornments = BoxAdornments[plr]
	if not adornments then return end
	for _, adornment in pairs(adornments) do
		if adornment then adornment:Destroy() end
	end
	BoxAdornments[plr] = nil
end

-- Per-limb boxes rather than one box around the root. A BoxHandleAdornment tracks its
-- Adornee's position/size automatically, so this only needs to run once per character
-- instead of every frame.
local function AddBoxAdornments(plr, character)
	local adornments = BoxAdornments[plr]
	if not adornments then
		adornments = {}
		BoxAdornments[plr] = adornments
	end
	for _, part in ipairs(character:GetChildren()) do
		if IsBodyESPPart(part, character) and not adornments[part] then
			local adornment = Instance.new("BoxHandleAdornment")
			adornment.Name = "SerenityBoxESP"
			adornment.Adornee = part
			adornment.Size = part.Size
			adornment.Color3 = ESPColor
			adornment.Transparency = 0.5
			adornment.AlwaysOnTop = true
			adornment.ZIndex = 10
			adornment.Parent = ESPAdornmentRoot
			adornments[part] = adornment
		end
	end
end

local function RemoveESPLabel(character)
	local head = character:FindFirstChild("Head")
	local root = character:FindFirstChild("HumanoidRootPart")
	if head and head:FindFirstChild("SerenityESPLabel") then head.SerenityESPLabel:Destroy() end
	if root and root:FindFirstChild("SerenityESPLabel") then root.SerenityESPLabel:Destroy() end
end

local function RefreshOutlineESP()
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= Player and plr.Character then
			if OutlineESPEnabled then AddOutlineHighlight(plr, plr.Character) else RemoveOutlineHighlight(plr) end
		end
	end
end

local function RefreshBoxESP()
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= Player and plr.Character then
			if BoxESPEnabled then AddBoxAdornments(plr, plr.Character) else RemoveBoxAdornments(plr) end
		end
	end
end

local function RefreshESPLabels()
	if ESPLabelsEnabled then return end
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= Player and plr.Character then RemoveESPLabel(plr.Character) end
	end
end

-- Continuously clears Outline/Body ESP for anyone who's died or lost their character,
-- so ESP never lingers on a corpse or an empty slot -- the same maintenance-loop
-- approach the old feature-rich hub used, since a one-time apply-on-toggle plus
-- apply-on-respawn (below) has no way to notice a death in between.
local ESPMaintenanceInterval = 0.15
local lastESPMaintenance = 0
RunService.Heartbeat:Connect(function()
	if not (OutlineESPEnabled or BoxESPEnabled or next(OutlineHighlights) or next(BoxAdornments)) then return end
	local now = os.clock()
	if now - lastESPMaintenance < ESPMaintenanceInterval then return end
	lastESPMaintenance = now
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= Player then
			local character = plr.Character
			local humanoid = character and character:FindFirstChildOfClass("Humanoid")
			if not character or not humanoid or humanoid.Health <= 0 then
				RemoveOutlineHighlight(plr)
				RemoveBoxAdornments(plr)
			end
		end
	end
end)

-- Name / health / distance billboard, throttled instead of updated every frame -- the
-- text only needs to look live, not actually be per-frame. Already self-cleans on death
-- (the else branch below) since it's parented straight to the character's own body part.
local ESPLabelUpdateInterval = 0.15
local lastESPLabelUpdate = 0
RunService.Heartbeat:Connect(function()
	if not ESPLabelsEnabled then return end
	local now = os.clock()
	if now - lastESPLabelUpdate < ESPLabelUpdateInterval then return end
	lastESPLabelUpdate = now
	local myRoot = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= Player and plr.Character then
			local character = plr.Character
			local humanoid = character:FindFirstChildOfClass("Humanoid")
			local root = character:FindFirstChild("HumanoidRootPart")
			local labelPart = character:FindFirstChild("Head") or root
			if humanoid and root and labelPart and humanoid.Health > 0 then
				local espGui = labelPart:FindFirstChild("SerenityESPLabel")
				if not espGui then
					espGui = Instance.new("BillboardGui")
					espGui.Name = "SerenityESPLabel"
					-- Taller to fit three stacked lines (name / health / distance)
					-- instead of two.
					espGui.Size = UDim2.new(0, 200, 0, 52)
					-- Well clear of the head -- Outline ESP's highlight was reaching high
					-- enough that the old, smaller offset let it poke up into the label
					-- text and make it hard to read.
					espGui.StudsOffset = Vector3.new(0, 4.75, 0)
					espGui.AlwaysOnTop = true
					espGui.Parent = labelPart
					local text = Instance.new("TextLabel")
					text.Name = "Label"
					text.Size = UDim2.new(1, 0, 1, 0)
					text.BackgroundTransparency = 1
					-- Bold Gotham instead of the menu's Ubuntu -- a floating world-space
					-- label needs to read clearly at a distance, and the menu font looked
					-- out of place rendered in 3D space.
					text.Font = Enum.Font.GothamBold
					text.TextSize = 12
					text.TextStrokeTransparency = 0
					text.Parent = espGui
				end
				local dist = myRoot and (myRoot.Position - root.Position).Magnitude or 0
				local label = espGui.Label
				label.TextColor3 = ESPColor
				-- Name, health, distance -- one per line instead of crammed onto two.
				label.Text = string.format("%s\nHP: %d\n%d studs away", plr.DisplayName, math.floor(humanoid.Health), math.floor(dist))
			else
				RemoveESPLabel(character)
			end
		end
	end
end)

local function HookOtherPlayerCharacters(plr)
	if plr == Player then return end
	plr.CharacterAdded:Connect(function(character)
		task.wait(0.1)
		-- Clear anything left over from the previous life before re-applying, in case
		-- the maintenance loop hasn't caught up yet.
		RemoveOutlineHighlight(plr)
		RemoveBoxAdornments(plr)
		if OutlineESPEnabled then AddOutlineHighlight(plr, character) end
		if BoxESPEnabled then AddBoxAdornments(plr, character) end
	end)
end
for _, plr in ipairs(Players:GetPlayers()) do
	HookOtherPlayerCharacters(plr)
end
Players.PlayerAdded:Connect(HookOtherPlayerCharacters)
Players.PlayerRemoving:Connect(function(leavingPlayer)
	RemoveOutlineHighlight(leavingPlayer)
	RemoveBoxAdornments(leavingPlayer)
	if leavingPlayer.Character then RemoveESPLabel(leavingPlayer.Character) end
end)

CreateSectionHeading(VisualsPage, 8, "ESP")


-- Serenity: minimal UI shell. The old feature-rich hub has been set aside (full copy
-- kept in Main_Legacy_Full.lua) in favor of a clean rebuild -- blank slate with window
-- chrome (title, minimize, drag), a Home tab, and a Player tab with just Speed so far.
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")

local Player = Players.LocalPlayer
local FrameColor = Color3.fromRGB(0x28, 0x28, 0x28)
local AccentColor = Color3.fromRGB(255, 255, 255)
local UIFont = Enum.Font.Ubuntu

-- Main Container
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "Serenity"
ScreenGui.Parent = CoreGui
ScreenGui.ResetOnSpawn = false

-- Sound Effects
local StartupSound = Instance.new("Sound")
StartupSound.SoundId = "rbxassetid://111102990253594"
StartupSound.Volume = 0.8
StartupSound.Parent = ScreenGui
StartupSound:Play()

local ClickSound = Instance.new("Sound")
ClickSound.SoundId = "rbxassetid://88442833509532"
ClickSound.Volume = 0.5
ClickSound.Parent = ScreenGui

local function PlayClick() ClickSound:Play() end


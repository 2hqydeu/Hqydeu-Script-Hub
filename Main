	toggle.TextColor3 = Color3.fromRGB(255, 255, 255)
	toggle.Parent = row
	Instance.new("UICorner", toggle).CornerRadius = UDim.new(0, 6)

	return toggle, swatch, keybindBtn
end

local DEFAULT_WALKSPEED = 16
local SECTION_GAP = 16

-- Speed
local SpeedEnabled = false
local SpeedValue = 3
local SpeedMode = "CFrame" -- "CFrame" (old hub's root-nudge movement) or "WalkSpeed"
local SpeedKeybind = Enum.KeyCode.Unknown

CreateSectionHeading(PlayerPage, 8, "Speed")
local SpeedInput = CreateStrengthRow(PlayerPage, 38, "Speed Strength", SpeedValue)
local SpeedToggle = CreateToggleRow(PlayerPage, 86, "SpeedKeybind", function(k) SpeedKeybind = k end)

local SpeedModeButton = Instance.new("TextButton")
SpeedModeButton.Name = "SpeedModeButton"
SpeedModeButton.Size = UDim2.new(1, 0, 0, 36)
SpeedModeButton.Position = UDim2.new(0, 0, 0, 134)
SpeedModeButton.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
SpeedModeButton.BackgroundTransparency = 0.5
SpeedModeButton.BorderSizePixel = 0
SpeedModeButton.Text = "Mode: CFrame Movement"
SpeedModeButton.Font = UIFont
SpeedModeButton.TextSize = 14
SpeedModeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
SpeedModeButton.Parent = PlayerPage
Instance.new("UICorner", SpeedModeButton).CornerRadius = UDim.new(0, 8)

local function ApplySpeed()
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end
	if SpeedMode == "WalkSpeed" then
		humanoid.WalkSpeed = SpeedEnabled and SpeedValue or DEFAULT_WALKSPEED
	else
		-- CFrame mode drives movement itself every frame below; keep WalkSpeed normal
		-- so the two approaches never stack.
		humanoid.WalkSpeed = DEFAULT_WALKSPEED
	end
end

local speedRenderConnection = RunService.RenderStepped:Connect(function()
	if not (SpeedEnabled and SpeedMode == "CFrame") then return end
	local character = Player.Character
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not (rootPart and humanoid) then return end
	local moveDir = humanoid.MoveDirection
	if moveDir.Magnitude > 0 then
		rootPart.CFrame = rootPart.CFrame + (moveDir * (SpeedValue / 10))
	end
end)

local function ToggleSpeed()
	SpeedEnabled = not SpeedEnabled
	SpeedToggle.Text = SpeedEnabled and "On" or "Off"
	ApplySpeed()
end
SpeedToggle.MouseButton1Click:Connect(function() PlayClick() ToggleSpeed() end)

SpeedInput.FocusLost:Connect(function()
	local value = tonumber(SpeedInput.Text)
	if value then SpeedValue = value end
	SpeedInput.Text = tostring(SpeedValue)
	ApplySpeed()
end)

SpeedModeButton.MouseButton1Click:Connect(function()
	PlayClick()
	SpeedMode = SpeedMode == "CFrame" and "WalkSpeed" or "CFrame"
	SpeedModeButton.Text = SpeedMode == "CFrame" and "Mode: CFrame Movement" or "Mode: WalkSpeed"
	ApplySpeed()
end)

local SPEED_SECTION_BOTTOM = 134 + 36 -- heading(8) + strength(38..78) + toggle(86..126) + mode(134..170)

-- Jump
local JumpEnabled = false
local JumpValue = 50
local JumpOriginal = nil -- captured Humanoid jump settings, restored exactly when toggled off
local JumpKeybind = Enum.KeyCode.Unknown

local JUMP_TOP = SPEED_SECTION_BOTTOM + SECTION_GAP
CreateSectionHeading(PlayerPage, JUMP_TOP, "Jump")
local JumpInput = CreateStrengthRow(PlayerPage, JUMP_TOP + 30, "Jump Strength", JumpValue)
local JumpToggle = CreateToggleRow(PlayerPage, JUMP_TOP + 78, "JumpKeybind", function(k) JumpKeybind = k end)
local JUMP_SECTION_BOTTOM = JUMP_TOP + 78 + 40

local function ApplyJump()
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end
	if JumpEnabled then
		if not JumpOriginal then
			JumpOriginal = {
				UseJumpPower = humanoid.UseJumpPower,
				JumpPower = humanoid.JumpPower,
				JumpHeight = humanoid.JumpHeight,
			}
		end
		humanoid.UseJumpPower = true
		humanoid.JumpPower = JumpValue
	elseif JumpOriginal then
		humanoid.UseJumpPower = JumpOriginal.UseJumpPower
		humanoid.JumpPower = JumpOriginal.JumpPower
		humanoid.JumpHeight = JumpOriginal.JumpHeight
	end
end

-- Continuously re-asserts JumpPower while enabled, in case anything else (the game's own
-- scripts, a respawn, etc.) overwrites it -- a one-time set wasn't holding reliably.
RunService.Heartbeat:Connect(function()
	if not JumpEnabled then return end
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end
	if not JumpOriginal then
		JumpOriginal = {
			UseJumpPower = humanoid.UseJumpPower,
			JumpPower = humanoid.JumpPower,
			JumpHeight = humanoid.JumpHeight,
		}
	end
	if not humanoid.UseJumpPower then humanoid.UseJumpPower = true end
	if humanoid.JumpPower ~= JumpValue then humanoid.JumpPower = JumpValue end
end)

local function ToggleJump()
	JumpEnabled = not JumpEnabled
	JumpToggle.Text = JumpEnabled and "On" or "Off"
	ApplyJump()
end
JumpToggle.MouseButton1Click:Connect(function() PlayClick() ToggleJump() end)

JumpInput.FocusLost:Connect(function()
	local value = tonumber(JumpInput.Text)
	if value then JumpValue = value end
	JumpInput.Text = tostring(JumpValue)
	if JumpEnabled then ApplyJump() end
end)

-- Fly (ported from the old feature-rich hub): BodyVelocity locks the root part's
-- velocity at zero -- acting as a zero-G anchor against gravity -- while a BodyGyro
-- keeps it upright and turned to the camera's yaw each frame. Actual movement is still
-- a direct CFrame nudge, same as Speed, but the BodyGyro means the character no longer
-- tumbles while airborne.
local FlyEnabled = false
local FlyValue = 10
local FlyKeybind = Enum.KeyCode.Unknown
local FlyBodyVelocity = nil
local FlyBodyGyro = nil

local FLY_TOP = JUMP_SECTION_BOTTOM + SECTION_GAP
CreateSectionHeading(PlayerPage, FLY_TOP, "Fly")
local FlyInput = CreateStrengthRow(PlayerPage, FLY_TOP + 30, "Fly Strength", FlyValue)
local FlyToggle = CreateToggleRow(PlayerPage, FLY_TOP + 78, "FlyKeybind", function(k) FlyKeybind = k end)
local FLY_SECTION_BOTTOM = FLY_TOP + 78 + 40

local function UprightCFrame(sourceCFrame, position)
	local _, yaw = sourceCFrame:ToOrientation()
	return CFrame.new(position or sourceCFrame.Position) * CFrame.Angles(0, yaw, 0)
end

local function ToggleFly()
	FlyEnabled = not FlyEnabled
	FlyToggle.Text = FlyEnabled and "On" or "Off"
	local character = Player.Character
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	if FlyEnabled then
		if rootPart then
			FlyBodyVelocity = Instance.new("BodyVelocity")
			FlyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
			FlyBodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
			FlyBodyVelocity.Parent = rootPart
			FlyBodyGyro = Instance.new("BodyGyro")
			FlyBodyGyro.P = 9e4
			FlyBodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
			FlyBodyGyro.CFrame = rootPart.CFrame
			FlyBodyGyro.Parent = rootPart
		end
	else
		if FlyBodyVelocity then FlyBodyVelocity:Destroy() FlyBodyVelocity = nil end
		if FlyBodyGyro then FlyBodyGyro:Destroy() FlyBodyGyro = nil end
		if rootPart then
			rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
			rootPart.CFrame = UprightCFrame(rootPart.CFrame, rootPart.Position)
			rootPart.AssemblyAngularVelocity = Vector3.zero
		end
	end
end
FlyToggle.MouseButton1Click:Connect(function() PlayClick() ToggleFly() end)

FlyInput.FocusLost:Connect(function()
	local value = tonumber(FlyInput.Text)
	if value then FlyValue = value end
	FlyInput.Text = tostring(FlyValue)
end)

local flyRenderConnection = RunService.RenderStepped:Connect(function()
	if not FlyEnabled then return end
	local character = Player.Character
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	local camera = workspace.CurrentCamera
	if not (rootPart and FlyBodyGyro and camera) then return end
	local moveDir = Vector3.new(0, 0, 0)
	if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir += camera.CFrame.LookVector end
	if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir -= camera.CFrame.LookVector end
	if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir -= camera.CFrame.RightVector end
	if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir += camera.CFrame.RightVector end
	if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir += Vector3.new(0, 1, 0) end
	if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveDir -= Vector3.new(0, 1, 0) end
	if moveDir.Magnitude > 0 then
		rootPart.CFrame = rootPart.CFrame + (moveDir * (FlyValue / 50))
	end
	local _, yaw = camera.CFrame:ToOrientation()
	FlyBodyGyro.CFrame = CFrame.new(rootPart.Position) * CFrame.Angles(0, yaw, 0)
	rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
	rootPart.AssemblyAngularVelocity = Vector3.zero
end)

-- Camera (ported from the old feature-rich hub): Free Cam detaches the camera from the
-- character (right-click-drag to look, WASD/Q/E to move, Shift to go faster) and sinks
-- the movement keys so the character doesn't also walk. Since you can't see your own
-- screen-space body anymore, it highlights + labels your own character while active.
-- FOV is unrelated to Free Cam -- just a direct camera.FieldOfView setter with a reset.
local FreeCamEnabled = false
local FreeCamKeybind = Enum.KeyCode.Unknown
local FreeCamPosition = Vector3.new()
local FreeCamPitch, FreeCamYaw = 0, 0
local FreeCamOriginalType, FreeCamOriginalSubject, FreeCamOriginalCFrame, FreeCamOriginalFocus
local FreeCamSelfColor = Color3.fromRGB(34, 139, 34)
local FreeCamSelfHighlight, FreeCamSelfLabel, FreeCamSelfAdornee

local CAMERA_TOP = FLY_SECTION_BOTTOM + SECTION_GAP
CreateSectionHeading(PlayerPage, CAMERA_TOP, "Camera")
local FreeCamToggle = CreateToggleRow(PlayerPage, CAMERA_TOP + 30, "FreeCamKeybind", function(k) FreeCamKeybind = k end)

local DEFAULT_FOV = 70
local FOVValue = (workspace.CurrentCamera and workspace.CurrentCamera.FieldOfView) or DEFAULT_FOV

local FOVRow = Instance.new("Frame")
FOVRow.Name = "FOVRow"
FOVRow.Size = UDim2.new(1, 0, 0, 40)
FOVRow.Position = UDim2.new(0, 0, 0, CAMERA_TOP + 78)
FOVRow.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
FOVRow.BackgroundTransparency = 0.5
FOVRow.BorderSizePixel = 0
FOVRow.Parent = PlayerPage
Instance.new("UICorner", FOVRow).CornerRadius = UDim.new(0, 8)

local FOVRowLabel = Instance.new("TextLabel")
FOVRowLabel.Name = "RowLabel"
FOVRowLabel.Size = UDim2.new(0, 200, 1, 0)
FOVRowLabel.Position = UDim2.new(0, 16, 0, 0)
FOVRowLabel.BackgroundTransparency = 1
FOVRowLabel.Text = "FOV"
FOVRowLabel.Font = UIFont
FOVRowLabel.TextSize = 15
FOVRowLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
FOVRowLabel.TextXAlignment = Enum.TextXAlignment.Left
FOVRowLabel.TextYAlignment = Enum.TextYAlignment.Center
FOVRowLabel.Parent = FOVRow

local FOVInput = Instance.new("TextBox")
FOVInput.Name = "Input"
FOVInput.Size = UDim2.new(0, 70, 0, 30)
FOVInput.Position = UDim2.new(1, -86, 0.5, -15)
FOVInput.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
FOVInput.BackgroundTransparency = 0.2
FOVInput.BorderSizePixel = 0
FOVInput.ClearTextOnFocus = false
FOVInput.Text = tostring(math.floor(FOVValue + 0.5))
FOVInput.Font = UIFont
FOVInput.TextSize = 16
FOVInput.TextColor3 = Color3.fromRGB(255, 255, 255)
FOVInput.Parent = FOVRow
Instance.new("UICorner", FOVInput).CornerRadius = UDim.new(0, 6)

local FOVResetButton = Instance.new("TextButton")
FOVResetButton.Name = "ResetButton"
FOVResetButton.Size = UDim2.new(0, 80, 0, 30)
FOVResetButton.Position = UDim2.new(1, -174, 0.5, -15)
FOVResetButton.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
FOVResetButton.BackgroundTransparency = 0.2
FOVResetButton.BorderSizePixel = 0
FOVResetButton.Text = "Reset"
FOVResetButton.Font = UIFont
FOVResetButton.TextSize = 16
FOVResetButton.TextColor3 = Color3.fromRGB(255, 255, 255)
FOVResetButton.Parent = FOVRow
Instance.new("UICorner", FOVResetButton).CornerRadius = UDim.new(0, 6)

local CAMERA_SECTION_BOTTOM = CAMERA_TOP + 78 + 40

FOVInput.FocusLost:Connect(function()
	local value = tonumber(FOVInput.Text)
	if value then FOVValue = math.clamp(value, 20, 120) end
	FOVInput.Text = tostring(math.floor(FOVValue + 0.5))
	local camera = workspace.CurrentCamera
	if camera then camera.FieldOfView = FOVValue end
end)

FOVResetButton.MouseButton1Click:Connect(function()
	PlayClick()
	FOVValue = DEFAULT_FOV
	FOVInput.Text = tostring(DEFAULT_FOV)
	if workspace.CurrentCamera then workspace.CurrentCamera.FieldOfView = DEFAULT_FOV end
end)

local function ClearFreeCamSelfESP()
	if FreeCamSelfHighlight then FreeCamSelfHighlight:Destroy() FreeCamSelfHighlight = nil end
	if FreeCamSelfLabel then FreeCamSelfLabel:Destroy() FreeCamSelfLabel = nil end
	FreeCamSelfAdornee = nil
end

local function UpdateFreeCamSelfESP()
	if not FreeCamEnabled then
		ClearFreeCamSelfESP()
		return
	end
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local head = character and character:FindFirstChild("Head")
	local root = character and (character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso"))
	if not character or not humanoid or humanoid.Health <= 0 or not root then
		ClearFreeCamSelfESP()
		return
	end
	if FreeCamSelfAdornee ~= character then
		ClearFreeCamSelfESP()
		local highlight = Instance.new("Highlight")
		highlight.Name = "SerenityFreeCamSelfHighlight"
		highlight.Adornee = character
		highlight.FillColor = FreeCamSelfColor
		highlight.OutlineColor = FreeCamSelfColor
		highlight.FillTransparency = 0.82
		highlight.OutlineTransparency = 0
		highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		highlight.Parent = ScreenGui
		FreeCamSelfHighlight = highlight

		local label = Instance.new("BillboardGui")
		label.Name = "SerenityFreeCamSelfLabel"
		label.Adornee = head or root
		label.Size = UDim2.new(0, 70, 0, 24)
		label.StudsOffsetWorldSpace = Vector3.new(0, 2.8, 0)
		label.AlwaysOnTop = true
		label.Parent = ScreenGui
		local text = Instance.new("TextLabel")
		text.Size = UDim2.new(1, 0, 1, 0)
		text.BackgroundTransparency = 1
		text.Text = "You"
		text.Font = UIFont
		text.TextSize = 12
		text.TextColor3 = FreeCamSelfColor
		text.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
		text.TextStrokeTransparency = 0.15
		text.Parent = label
		FreeCamSelfLabel = label
		FreeCamSelfAdornee = character
	elseif FreeCamSelfLabel then
		FreeCamSelfLabel.Adornee = head or root
	end
end

local function EnableFreeCam()
	if FreeCamEnabled then return end
	local camera = workspace.CurrentCamera
	if not camera then return end
	FreeCamEnabled = true
	FreeCamOriginalType = camera.CameraType
	FreeCamOriginalSubject = camera.CameraSubject
	FreeCamOriginalCFrame = camera.CFrame
	FreeCamOriginalFocus = camera.Focus
	FreeCamPosition = camera.CFrame.Position
	FreeCamPitch, FreeCamYaw = camera.CFrame:ToOrientation()
	camera.CameraType = Enum.CameraType.Scriptable
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if humanoid then humanoid:Move(Vector3.zero) end
	if root then root.AssemblyLinearVelocity = Vector3.zero root.AssemblyAngularVelocity = Vector3.zero end
	FreeCamToggle.Text = "On"
	UpdateFreeCamSelfESP()
	ContextActionService:BindActionAtPriority(
		"SerenityFreeCamSink",
		function() return Enum.ContextActionResult.Sink end,
		false,
		Enum.ContextActionPriority.High.Value + 100,
		Enum.KeyCode.W, Enum.KeyCode.A, Enum.KeyCode.S, Enum.KeyCode.D,
		Enum.KeyCode.Q, Enum.KeyCode.E, Enum.KeyCode.LeftShift
	)
end

local function DisableFreeCam()
	if not FreeCamEnabled then return end
	FreeCamEnabled = false
	ContextActionService:UnbindAction("SerenityFreeCamSink")
	-- Always release the RMB camera lock. Restoring a captured LockCenter state can
	-- leave the cursor pinned after Free Cam is turned off.
	UserInputService.MouseBehavior = Enum.MouseBehavior.Default
	UserInputService.MouseIconEnabled = true
	ClearFreeCamSelfESP()
	local camera = workspace.CurrentCamera
	if camera then
		camera.CameraType = FreeCamOriginalType or Enum.CameraType.Custom
		local character = Player.Character
		local humanoid = character and character:FindFirstChildOfClass("Humanoid")
		camera.CameraSubject = humanoid or FreeCamOriginalSubject
		if FreeCamOriginalCFrame then camera.CFrame = FreeCamOriginalCFrame end
		if FreeCamOriginalFocus then camera.Focus = FreeCamOriginalFocus end
	end
	FreeCamToggle.Text = "Off"
	task.defer(function()
		if not FreeCamEnabled then
			UserInputService.MouseBehavior = Enum.MouseBehavior.Default
			UserInputService.MouseIconEnabled = true
		end
	end)
end

local function ToggleFreeCam()
	if FreeCamEnabled then DisableFreeCam() else EnableFreeCam() end
end
FreeCamToggle.MouseButton1Click:Connect(function() PlayClick() ToggleFreeCam() end)

local freeCamRenderConnection = RunService.RenderStepped:Connect(function(deltaTime)
	if not FreeCamEnabled then return end
	local camera = workspace.CurrentCamera
	if not camera then return end
	UpdateFreeCamSelfESP()
	local focusedTextBox
	pcall(function() focusedTextBox = UserInputService:GetFocusedTextBox() end)
	if focusedTextBox then
		UserInputService.MouseBehavior = Enum.MouseBehavior.Default
		return
	end
	if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
		UserInputService.MouseBehavior = Enum.MouseBehavior.LockCurrentPosition
		local mouseDelta = UserInputService:GetMouseDelta()
		FreeCamYaw = FreeCamYaw - mouseDelta.X * 0.01
		FreeCamPitch = math.clamp(FreeCamPitch - mouseDelta.Y * 0.01, math.rad(-89), math.rad(89))
	else
		UserInputService.MouseBehavior = Enum.MouseBehavior.Default
	end
	local rotation = CFrame.fromOrientation(FreeCamPitch, FreeCamYaw, 0)
	local movement = Vector3.zero
	if UserInputService:IsKeyDown(Enum.KeyCode.W) then movement += rotation.LookVector end
	if UserInputService:IsKeyDown(Enum.KeyCode.S) then movement -= rotation.LookVector end
	if UserInputService:IsKeyDown(Enum.KeyCode.D) then movement += rotation.RightVector end
	if UserInputService:IsKeyDown(Enum.KeyCode.A) then movement -= rotation.RightVector end
	if UserInputService:IsKeyDown(Enum.KeyCode.E) then movement += Vector3.new(0, 1, 0) end
	if UserInputService:IsKeyDown(Enum.KeyCode.Q) then movement -= Vector3.new(0, 1, 0) end
	local speed = UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and 120 or 40
	if movement.Magnitude > 0 then FreeCamPosition = FreeCamPosition + movement.Unit * speed * deltaTime end
	local cameraCFrame = CFrame.new(FreeCamPosition) * rotation
	camera.CFrame = cameraCFrame
	camera.Focus = cameraCFrame * CFrame.new(0, 0, -512)
end)

PlayerPage.CanvasSize = UDim2.new(0, 0, 0, CAMERA_SECTION_BOTTOM + 16)

-- Re-apply active effects whenever the character (re)spawns.
local characterAddedConnection = Player.CharacterAdded:Connect(function()
	task.wait(0.1)
	ApplySpeed()
	JumpOriginal = nil
	if JumpEnabled then ApplyJump() end
end)

-- Visuals tab: Outline ESP, Body ESP (per-limb boxes, Infinite Yield-style, ported from
-- the old feature-rich hub), and ESP Labels (name/health/distance). Color swatches are
-- placeholders only -- no picker wired up yet, just a static outlined square.
local VisualsPage = CreateTab("Visuals", 3, "90467794700971", true)

local ESPDefaultColor = Color3.fromRGB(100, 255, 100)

-- Box/label adornments live under this folder instead of the character itself, so they
-- keep rendering even if something else on the character (e.g. a local transparency
-- effect) tries to hide its own children.
local ESPAdornmentRoot = Instance.new("Folder")
ESPAdornmentRoot.Name = "SerenityESPAdornments"
ESPAdornmentRoot.Parent = ScreenGui

local OutlineESPEnabled = false
local OutlineESPKeybind = Enum.KeyCode.Unknown
local OutlineESPColor = ESPDefaultColor
local OutlineHighlights = {}

local BoxESPEnabled = false
local BoxESPKeybind = Enum.KeyCode.Unknown
local BoxESPColor = ESPDefaultColor
local BoxAdornments = {} -- [character] = {[part] = BoxHandleAdornment}

local ESPLabelsEnabled = false
local ESPLabelsKeybind = Enum.KeyCode.Unknown
local ESPLabelsColor = ESPDefaultColor

local function RemoveOutlineHighlight(character)
	local highlight = OutlineHighlights[character]
	if highlight then highlight:Destroy() end
	OutlineHighlights[character] = nil
end

local function AddOutlineHighlight(character)
	if OutlineHighlights[character] then return end
	local highlight = Instance.new("Highlight")
	highlight.Name = "SerenityOutlineESP"
	highlight.FillColor = OutlineESPColor
	highlight.FillTransparency = 0.72
	highlight.OutlineColor = OutlineESPColor
	highlight.OutlineTransparency = 0
	highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	highlight.Parent = character
	OutlineHighlights[character] = highlight
end

-- Body-part names covered by Body ESP, matching both R15 and R6 rigs.
local BodyESPPartNames = {
	HumanoidRootPart = true, Head = true, Torso = true, UpperTorso = true, LowerTorso = true,
	LeftUpperArm = true, LeftLowerArm = true, LeftHand = true,
	RightUpperArm = true, RightLowerArm = true, RightHand = true,
	LeftUpperLeg = true, LeftLowerLeg = true, LeftFoot = true,
	RightUpperLeg = true, RightLowerLeg = true, RightFoot = true,
	["Left Arm"] = true, ["Right Arm"] = true, ["Left Leg"] = true, ["Right Leg"] = true,
}

local function IsBodyESPPart(part, character)
	return part:IsA("BasePart") and part.Parent == character and BodyESPPartNames[part.Name] == true
end

local function RemoveBoxAdornments(character)
	local adornments = BoxAdornments[character]
	if not adornments then return end
	for _, adornment in pairs(adornments) do
		if adornment then adornment:Destroy() end
	end
	BoxAdornments[character] = nil
end

-- Per-limb boxes rather than one box around the root. A BoxHandleAdornment tracks its
-- Adornee's position/size automatically, so this only needs to run once per character
-- instead of every frame.
local function AddBoxAdornments(character)
	local adornments = BoxAdornments[character]
	if not adornments then
		adornments = {}
		BoxAdornments[character] = adornments
	end
	for _, part in ipairs(character:GetChildren()) do
		if IsBodyESPPart(part, character) and not adornments[part] then
			local adornment = Instance.new("BoxHandleAdornment")
			adornment.Name = "SerenityBoxESP"
			adornment.Adornee = part
			adornment.Size = part.Size
			adornment.Color3 = BoxESPColor
			adornment.Transparency = 0.5
			adornment.AlwaysOnTop = true
			adornment.ZIndex = 10
			adornment.Parent = ESPAdornmentRoot
			adornments[part] = adornment
		end
	end
end

local function RemoveESPLabel(character)
	local head = character:FindFirstChild("Head")
	local root = character:FindFirstChild("HumanoidRootPart")
	if head and head:FindFirstChild("SerenityESPLabel") then head.SerenityESPLabel:Destroy() end
	if root and root:FindFirstChild("SerenityESPLabel") then root.SerenityESPLabel:Destroy() end
end

local function RefreshOutlineESP()
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= Player and plr.Character then
			if OutlineESPEnabled then AddOutlineHighlight(plr.Character) else RemoveOutlineHighlight(plr.Character) end
		end
	end
end

local function RefreshBoxESP()
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= Player and plr.Character then
			if BoxESPEnabled then AddBoxAdornments(plr.Character) else RemoveBoxAdornments(plr.Character) end
		end
	end
end

local function RefreshESPLabels()
	if ESPLabelsEnabled then return end
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= Player and plr.Character then RemoveESPLabel(plr.Character) end
	end
end

-- Name / health / distance billboard, throttled instead of updated every frame -- the
-- text only needs to look live, not actually be per-frame.
local ESPLabelUpdateInterval = 0.15
local lastESPLabelUpdate = 0
RunService.Heartbeat:Connect(function()
	if not ESPLabelsEnabled then return end
	local now = os.clock()
	if now - lastESPLabelUpdate < ESPLabelUpdateInterval then return end
	lastESPLabelUpdate = now
	local myRoot = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= Player and plr.Character then
			local character = plr.Character
			local humanoid = character:FindFirstChildOfClass("Humanoid")
			local root = character:FindFirstChild("HumanoidRootPart")
			local labelPart = character:FindFirstChild("Head") or root
			if humanoid and root and labelPart and humanoid.Health > 0 then
				local espGui = labelPart:FindFirstChild("SerenityESPLabel")
				if not espGui then
					espGui = Instance.new("BillboardGui")
					espGui.Name = "SerenityESPLabel"
					espGui.Size = UDim2.new(0, 200, 0, 36)
					espGui.StudsOffset = Vector3.new(0, 2.5, 0)
					espGui.AlwaysOnTop = true
					espGui.Parent = labelPart
					local text = Instance.new("TextLabel")
					text.Name = "Label"
					text.Size = UDim2.new(1, 0, 1, 0)
					text.BackgroundTransparency = 1
					text.Font = UIFont
					text.TextSize = 13
					text.TextStrokeTransparency = 0
					text.Parent = espGui
				end
				local dist = myRoot and (myRoot.Position - root.Position).Magnitude or 0
				local label = espGui.Label
				label.TextColor3 = ESPLabelsColor
				label.Text = string.format("%s\nHP: %d | %d Studs", plr.DisplayName, math.floor(humanoid.Health), math.floor(dist))
			else
				RemoveESPLabel(character)
			end
		end
	end
end)

local function HookOtherPlayerCharacters(plr)
	if plr == Player then return end
	plr.CharacterAdded:Connect(function(character)
		task.wait(0.1)
		if OutlineESPEnabled then AddOutlineHighlight(character) end
		if BoxESPEnabled then AddBoxAdornments(character) end
	end)
end
for _, plr in ipairs(Players:GetPlayers()) do
	HookOtherPlayerCharacters(plr)
end
Players.PlayerAdded:Connect(HookOtherPlayerCharacters)
Players.PlayerRemoving:Connect(function(leavingPlayer)
	if leavingPlayer.Character then
		RemoveBoxAdornments(leavingPlayer.Character)
		RemoveESPLabel(leavingPlayer.Character)
	end
end)

CreateSectionHeading(VisualsPage, 8, "ESP")

local OutlineESPToggle, OutlineESPSwatch = CreateESPRow(VisualsPage, 38, "Outline ESP", OutlineESPColor, "OutlineESPKeybind", function(k) OutlineESPKeybind = k end)
local BoxESPToggle, BoxESPSwatch = CreateESPRow(VisualsPage, 86, "Box ESP", BoxESPColor, "BoxESPKeybind", function(k) BoxESPKeybind = k end)
local ESPLabelsToggle, ESPLabelsSwatch = CreateESPRow(VisualsPage, 134, "ESP Labels", ESPLabelsColor, "ESPLabelsKeybind", function(k) ESPLabelsKeybind = k end)

VisualsPage.CanvasSize = UDim2.new(0, 0, 0, 190)

local function ToggleOutlineESP()
	OutlineESPEnabled = not OutlineESPEnabled
	OutlineESPToggle.Text = OutlineESPEnabled and "On" or "Off"
	RefreshOutlineESP()
end
OutlineESPToggle.MouseButton1Click:Connect(function() PlayClick() ToggleOutlineESP() end)


-- Serenity: minimal UI shell. The old feature-rich hub has been set aside (full copy
-- kept in Main_Legacy_Full.lua) in favor of a clean rebuild -- blank slate with window
-- chrome (title, minimize, drag), a Home tab, and a Player tab (Speed / Jump / Fly).
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local ContextActionService = game:GetService("ContextActionService")

local Player = Players.LocalPlayer
local FrameColor = Color3.fromRGB(0x1E, 0x1E, 0x1E)
local AccentColor = Color3.fromRGB(255, 255, 255)
local UIFont = Enum.Font.Ubuntu

-- Feature keybinds (Speed/Jump/Fly only -- minimize stays hardcoded to Left Control)
-- persist across executions via a small settings file; the toggle *state* does not, so
-- every feature still starts Off each run and has to be turned on again.
local KeybindStorageFile = "Serenity_Keybinds.json"
local SavedKeybinds = {}
local CanPersistKeybinds = type(isfile) == "function" and type(readfile) == "function" and type(writefile) == "function"
local function LoadSettingsFromGenv()
	if type(getgenv) == "function" then
		local globalSettings = getgenv().Serenity_Settings
		if type(globalSettings) == "table" then SavedKeybinds = globalSettings end
	end
end
LoadSettingsFromGenv()
if CanPersistKeybinds then
	pcall(function()
		if isfile(KeybindStorageFile) then
			local decoded = HttpService:JSONDecode(readfile(KeybindStorageFile))
			if type(decoded) == "table" then SavedKeybinds = decoded end
		end
	end)
end
LoadSettingsFromGenv()

local function SavePersistentSettings()
	if type(getgenv) == "function" then
		getgenv().Serenity_Settings = SavedKeybinds
	end
	if CanPersistKeybinds then
		pcall(function() writefile(KeybindStorageFile, HttpService:JSONEncode(SavedKeybinds)) end)
	end
end

local function DecodeKeybind(savedName)
	if type(savedName) == "string" then
		local success, keyCode = pcall(function() return Enum.KeyCode[savedName] end)
		if success and keyCode then return keyCode end
	end
	return Enum.KeyCode.Unknown
end

local function LoadFeatureKeybind(storageKey)
	return DecodeKeybind(SavedKeybinds[storageKey])
end

local function SaveFeatureKeybind(storageKey, keyCode)
	SavedKeybinds[storageKey] = keyCode.Name
	SavePersistentSettings()
end

-- Colors aren't JSON-serializable, so they're packed to/from plain {R,G,B} tables --
-- same trick as keybinds, stored in the same settings file.
local function PackColor(color)
	return {
		R = math.floor(color.R * 255 + 0.5),
		G = math.floor(color.G * 255 + 0.5),
		B = math.floor(color.B * 255 + 0.5),
	}
end

local function UnpackColor(saved, fallback)
	if type(saved) == "table" and tonumber(saved.R) and tonumber(saved.G) and tonumber(saved.B) then
		return Color3.fromRGB(saved.R, saved.G, saved.B)
	end
	return fallback
end

local function LoadFeatureColor(storageKey, fallback)
	return UnpackColor(SavedKeybinds[storageKey], fallback)
end

local function SaveFeatureColor(storageKey, color)
	SavedKeybinds[storageKey] = PackColor(color)
	SavePersistentSettings()
end

local function KeybindText(keyCode)
	if keyCode == Enum.KeyCode.Unknown then return "..." end
	if keyCode == Enum.KeyCode.LeftControl then return "L Ctrl" end
	if keyCode == Enum.KeyCode.RightControl then return "R Ctrl" end
	if keyCode == Enum.KeyCode.LeftShift then return "L Shift" end
	return keyCode.Name
end

-- True while any keybind rebind capture is in progress, so the global toggle-listener
-- below doesn't also react to whatever key gets pressed to set the bind.
local bindingInProgress = false

-- Main Container
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "Serenity"
ScreenGui.Parent = CoreGui
ScreenGui.ResetOnSpawn = false

-- Sound Effects
local StartupSound = Instance.new("Sound")
StartupSound.SoundId = "rbxassetid://111102990253594"
StartupSound.Volume = 0.8
StartupSound.Parent = ScreenGui
StartupSound:Play()


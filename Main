	ESPLabelsEnabled = not ESPLabelsEnabled
	ESPLabelsToggle.Text = ESPLabelsEnabled and "On" or "Off"
	RefreshESPLabels()
end
ESPLabelsToggle.MouseButton1Click:Connect(function() PlayClick() ToggleESPLabels() end)


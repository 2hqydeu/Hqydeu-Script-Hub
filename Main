LoadingTrack.Position = UDim2.new(0.5, 0, 0, 315)
LoadingTrack.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
LoadingTrack.BorderSizePixel = 0
LoadingTrack.Parent = SplashFrame
Instance.new("UICorner", LoadingTrack).CornerRadius = UDim.new(1, 0)

local LoadingFill = Instance.new("Frame")
LoadingFill.Name = "LoadingFill"
LoadingFill.Size = UDim2.new(0, 0, 1, 0)
LoadingFill.BackgroundColor3 = AccentColor
LoadingFill.BorderSizePixel = 0
LoadingFill.Parent = LoadingTrack
Instance.new("UICorner", LoadingFill).CornerRadius = UDim.new(1, 0)

local FakeLoadingMessages = {
	"Loading assets...",
	"Loading scripts...",
	"Initializing modules...",
	"Compiling shaders...",
	"Fetching configuration...",
	"Optimizing textures...",
	"Establishing connection...",
	"Warming up cache...",
	"Resolving dependencies...",
	"Finalizing setup...",
}

local function RunFakeLoading(totalDuration)
	local stepCount = math.random(9, 13)
	local progressWeights, durationWeights = {}, {}
	local progressSum, durationSum = 0, 0
	for i = 1, stepCount do
		progressWeights[i] = math.random(4, 20)
		durationWeights[i] = math.random(4, 20)
		progressSum += progressWeights[i]
		durationSum += durationWeights[i]
	end
	local cumulativeProgress = 0
	for i = 1, stepCount do
		local stepDuration = (durationWeights[i] / durationSum) * totalDuration
		cumulativeProgress = math.min(1, cumulativeProgress + (progressWeights[i] / progressSum))
		LoadingLabel.Text = FakeLoadingMessages[math.random(1, #FakeLoadingMessages)]
		TweenService:Create(LoadingFill, TweenInfo.new(math.min(stepDuration, 0.2), Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Size = UDim2.new(cumulativeProgress, 0, 1, 0),
		}):Play()
		task.wait(stepDuration)
	end
	LoadingFill.Size = UDim2.new(1, 0, 1, 0)
end

task.spawn(function()
	local spinIn = TweenService:Create(SplashImage, TweenInfo.new(0.7, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Size = UDim2.new(0, 220, 0, 220),
		Rotation = 0,
		ImageTransparency = 0,
	})
	spinIn:Play()
	spinIn.Completed:Wait()

	RunFakeLoading(4.5)
	task.wait(0.25)

	local fadeOut = TweenService:Create(SplashFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		GroupTransparency = 1,
	})
	fadeOut:Play()
	fadeOut.Completed:Wait()
	SplashFrame:Destroy()
	MainFrame.Visible = true
end)

local SavedColorButtons = {}
for index = 1, 5 do
	local swatch = Instance.new("TextButton")
	swatch.Name = "SavedColorSlot" .. index
	swatch.Size = UDim2.new(0, 18, 0, 18)
	swatch.Position = UDim2.new(0, 8 + ((index - 1) * 24), 0, 138)
	swatch.BackgroundColor3 = Color3.fromRGB(60, 60, 60)

FOVRow.BackgroundTransparency = RowTransparencyValue / 100
FOVRow.BorderSizePixel = 0
FOVRow.Parent = VisualsPage
Instance.new("UICorner", FOVRow).CornerRadius = UDim.new(0, 8)

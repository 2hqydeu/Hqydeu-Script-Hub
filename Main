local BoxESPToggle = CreateToggleRow(VisualsPage, 86, "BoxESPKeybind", function(k) BoxESPKeybind = k end, "Box ESP")
local ESPLabelsToggle = CreateToggleRow(VisualsPage, 134, "ESPLabelsKeybind", function(k) ESPLabelsKeybind = k end, "ESP Labels")


	PlayClick()
	SpeedEnabled = not SpeedEnabled
	SpeedToggle.Text = SpeedEnabled and "On" or "Off"
	ApplySpeed()
end)

SpeedInput.FocusLost:Connect(function()
	local value = tonumber(SpeedInput.Text)
	if value then
		SpeedValue = value
	end
	SpeedInput.Text = tostring(SpeedValue)
	ApplySpeed()
end)

SpeedModeButton.MouseButton1Click:Connect(function()
	PlayClick()
	SpeedMode = SpeedMode == "CFrame" and "WalkSpeed" or "CFrame"
	SpeedModeButton.Text = SpeedMode == "CFrame" and "Mode: CFrame Movement" or "Mode: WalkSpeed"
	ApplySpeed()
end)

SelectTab("Home")

-- Minimize: hardcoded to Left Control, not user-configurable. Everything below the
-- header (divider, tabs, content) is explicitly hidden while minimized so nothing peeks
-- past the clipped frame.
local MinimizeKeybind = Enum.KeyCode.LeftControl
local minimized = false

local function ToggleGUI()
	minimized = not minimized
	Divider.Visible = not minimized
	TabBar.Visible = not minimized
	ContentArea.Visible = not minimized
	TweenService:Create(MainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Size = minimized and MINI_SIZE or FULL_SIZE,
	}):Play()
	MiniButton.Text = minimized and "+" or "-"
end
MiniButton.MouseButton1Click:Connect(function() PlayClick() ToggleGUI() end)

-- Silent unbind-able destroy key (Right Control) -- no button, no prompt, no sound.
local DestroyKeybind = Enum.KeyCode.RightControl
local mainInputConnection
local dragChangedConnection

local function DestroyGui()
	if mainInputConnection then mainInputConnection:Disconnect() end
	if dragChangedConnection then dragChangedConnection:Disconnect() end
	ScreenGui:Destroy()
end

mainInputConnection = UserInputService.InputBegan:Connect(function(input, processed)
	if processed or UserInputService:GetFocusedTextBox() then return end
	if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
	if input.KeyCode == DestroyKeybind then
		DestroyGui()
		return
	end
	if input.KeyCode == MinimizeKeybind then ToggleGUI() end
end)

-- Dragging
local dragging = false
local dragStart = nil
local startPos = nil
MainFrame.InputBegan:Connect(function(input)
	if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
	dragging = true
	dragStart = input.Position
	startPos = MainFrame.Position
	input.Changed:Connect(function()
		if input.UserInputState == Enum.UserInputState.End then
			dragging = false
		end
	end)
end)
dragChangedConnection = UserInputService.InputChanged:Connect(function(input)
	if not dragging or (input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch) then return end
	local delta = input.Position - dragStart
	MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end)

-- Title sequence: the real UI (MainFrame) stays invisible the entire time -- this is a
-- fully separate panel occupying the same spot, so nothing underneath is built-but-
-- hidden, it just doesn't exist visually yet. Emblem spins + grows + fades into the
-- center (matching the old hub's intro), then a fake ~4.5s "loading" runs with a status
-- line that cycles through nonsense messages and a progress bar that fills unevenly.
local SplashFrame = Instance.new("CanvasGroup")

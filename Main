local ContentArea = Instance.new("Frame")
ContentArea.Name = "ContentArea"
ContentArea.Size = UDim2.new(1, -32, 1, -(CONTENT_TOP + 16))
ContentArea.Position = UDim2.new(0, 16, 0, CONTENT_TOP)
ContentArea.BackgroundTransparency = 1
ContentArea.Parent = MainFrame

local Tabs = {}
local function SelectTab(name)
	for tabName, entry in pairs(Tabs) do
		local isSelected = tabName == name
		entry.Page.Visible = isSelected
		entry.Button.BackgroundTransparency = isSelected and 0.85 or 1
	end
end

-- Icon + label are grouped as one horizontally-centered unit (via a nested UIListLayout)
-- so they read as a single "logo + wordmark," not two separately-positioned pieces.
local function CreateTab(name, order, iconId, scrolling)
	local button = Instance.new("TextButton")
	button.Name = name .. "Tab"
	button.LayoutOrder = order
	button.Size = UDim2.new(0, 126, 0, 32)
	button.BackgroundColor3 = AccentColor
	button.BackgroundTransparency = 1
	button.BorderSizePixel = 0
	button.AutoButtonColor = false
	button.Text = ""
	button.Parent = TabBar
	Instance.new("UICorner", button).CornerRadius = UDim.new(0, 8)

	local content = Instance.new("Frame")
	content.Name = "Content"
	content.Size = UDim2.new(1, 0, 1, 0)
	content.BackgroundTransparency = 1
	content.Parent = button

	local contentLayout = Instance.new("UIListLayout")
	contentLayout.FillDirection = Enum.FillDirection.Horizontal
	contentLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	contentLayout.VerticalAlignment = Enum.VerticalAlignment.Center
	contentLayout.Padding = UDim.new(0, 6)
	contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
	contentLayout.Parent = content

	local icon = Instance.new("ImageLabel")
	icon.Name = "Icon"
	icon.LayoutOrder = 1
	icon.Size = UDim2.new(0, 24, 0, 24)
	icon.BackgroundTransparency = 1
	if iconId then icon.Image = "rbxassetid://" .. iconId end
	icon.Parent = content

	local label = Instance.new("TextLabel")
	label.Name = "Label"
	label.LayoutOrder = 2
	label.AutomaticSize = Enum.AutomaticSize.X
	label.Size = UDim2.new(0, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.Text = name
	label.Font = UIFont
	label.TextSize = 13
	label.TextColor3 = Color3.fromRGB(255, 255, 255)
	label.Parent = content

	local page
	if scrolling then
		page = Instance.new("ScrollingFrame")
		page.ScrollBarThickness = 3
		page.ScrollBarImageColor3 = AccentColor
		page.CanvasSize = UDim2.new(0, 0, 0, 0)
		page.ElasticBehavior = Enum.ElasticBehavior.Never
	else
		page = Instance.new("Frame")
	end
	page.Name = name .. "Page"
	page.Size = UDim2.new(1, 0, 1, 0)
	page.BackgroundTransparency = 1
	page.BorderSizePixel = 0
	page.Visible = false
	page.Parent = ContentArea

	Tabs[name] = {Button = button, Page = page}
	button.MouseButton1Click:Connect(function()
		PlayClick()
		SelectTab(name)
	end)
	return page
end

-- Home tab. Scoped in a do block (like every other tab section below): Luau caps a
-- single function -- and the whole top-level script counts as one -- at 200 live locals,
-- and this file's now well past that between every tab's UI elements. Blocks let the
-- compiler free a section's locals once it ends instead of holding them all open for the
-- rest of the script; nothing here is referenced outside this block.
do
	local HomePage = CreateTab("Home", 1, "96269089530329")

	local AvatarImage = Instance.new("ImageLabel")
	AvatarImage.Name = "Avatar"
	AvatarImage.Size = UDim2.new(0, 96, 0, 96)
	AvatarImage.Position = UDim2.new(0.5, -48, 0, 24)
	AvatarImage.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
	AvatarImage.BorderSizePixel = 0
	AvatarImage.Parent = HomePage
	Instance.new("UICorner", AvatarImage).CornerRadius = UDim.new(1, 0)
	task.spawn(function()
		local success, content = pcall(function()
			return Players:GetUserThumbnailAsync(Player.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
		end)
		if success then AvatarImage.Image = content end
	end)

	local WelcomeLabel = Instance.new("TextLabel")
	WelcomeLabel.Name = "WelcomeLabel"
	WelcomeLabel.Size = UDim2.new(1, 0, 0, 40)
	WelcomeLabel.Position = UDim2.new(0, 0, 0, 136)
	WelcomeLabel.BackgroundTransparency = 1
	WelcomeLabel.Text = "Welcome " .. Player.DisplayName .. "!"
	WelcomeLabel.Font = UIFont
	WelcomeLabel.TextSize = 26
	WelcomeLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	WelcomeLabel.TextXAlignment = Enum.TextXAlignment.Center
	WelcomeLabel.TextYAlignment = Enum.TextYAlignment.Center
	WelcomeLabel.Parent = HomePage
end


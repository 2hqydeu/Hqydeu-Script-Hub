-- Shared row builder: a heading label plus a full-width "<Name> Strength" row holding a
-- numeric input and an On/Off toggle. Returns the row's controls so callers can wire up
-- their own logic.
local function CreateStrengthSection(parent, headingText, rowLabelText, y, defaultValue)
	local heading = Instance.new("TextLabel")
	heading.Name = headingText .. "Heading"
	heading.Size = UDim2.new(1, 0, 0, 22)
	heading.Position = UDim2.new(0, 0, 0, y)
	heading.BackgroundTransparency = 1
	heading.Text = headingText
	heading.Font = UIFont
	heading.TextSize = 16
	heading.TextColor3 = Color3.fromRGB(255, 255, 255)
	heading.TextXAlignment = Enum.TextXAlignment.Left
	heading.Parent = parent

	local row = Instance.new("Frame")
	row.Name = headingText .. "StrengthRow"
	row.Size = UDim2.new(1, 0, 0, 40)
	row.Position = UDim2.new(0, 0, 0, y + 28)
	row.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
	row.BackgroundTransparency = 0.5
	row.BorderSizePixel = 0
	row.Parent = parent
	Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)

	local rowLabel = Instance.new("TextLabel")
	rowLabel.Name = "RowLabel"
	rowLabel.Size = UDim2.new(0, 160, 1, 0)
	rowLabel.Position = UDim2.new(0, 16, 0, 0)
	rowLabel.BackgroundTransparency = 1
	rowLabel.Text = rowLabelText
	rowLabel.Font = UIFont
	rowLabel.TextSize = 15
	rowLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	rowLabel.TextXAlignment = Enum.TextXAlignment.Left
	rowLabel.TextYAlignment = Enum.TextYAlignment.Center
	rowLabel.Parent = row

	local input = Instance.new("TextBox")
	input.Name = "Input"
	input.Size = UDim2.new(0, 70, 0, 30)
	input.Position = UDim2.new(1, -176, 0.5, -15)
	input.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
	input.BackgroundTransparency = 0.2
	input.BorderSizePixel = 0
	input.ClearTextOnFocus = false
	input.Text = tostring(defaultValue)
	input.Font = UIFont
	input.TextSize = 16
	input.TextColor3 = Color3.fromRGB(255, 255, 255)
	input.Parent = row
	Instance.new("UICorner", input).CornerRadius = UDim.new(0, 6)

	local toggle = Instance.new("TextButton")
	toggle.Name = "Toggle"
	toggle.Size = UDim2.new(0, 80, 0, 30)
	toggle.Position = UDim2.new(1, -96, 0.5, -15)
	toggle.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
	toggle.BackgroundTransparency = 0.2
	toggle.BorderSizePixel = 0
	toggle.Text = "Off"
	toggle.Font = UIFont
	toggle.TextSize = 16
	toggle.TextColor3 = Color3.fromRGB(255, 255, 255)
	toggle.Parent = row
	Instance.new("UICorner", toggle).CornerRadius = UDim.new(0, 6)

	return input, toggle
end

local DEFAULT_WALKSPEED = 16

-- Speed
local SpeedEnabled = false
local SpeedValue = 3
local SpeedMode = "CFrame" -- "CFrame" (old hub's root-nudge movement) or "WalkSpeed"

local SpeedInput, SpeedToggle = CreateStrengthSection(PlayerPage, "Speed", "Speed Strength", 0, SpeedValue)

local SpeedModeButton = Instance.new("TextButton")
SpeedModeButton.Name = "SpeedModeButton"
SpeedModeButton.Size = UDim2.new(1, 0, 0, 36)
SpeedModeButton.Position = UDim2.new(0, 0, 0, 74)
SpeedModeButton.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
SpeedModeButton.BackgroundTransparency = 0.5
SpeedModeButton.BorderSizePixel = 0
SpeedModeButton.Text = "Mode: CFrame Movement"
SpeedModeButton.Font = UIFont
SpeedModeButton.TextSize = 14
SpeedModeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
SpeedModeButton.Parent = PlayerPage
Instance.new("UICorner", SpeedModeButton).CornerRadius = UDim.new(0, 8)

local function ApplySpeed()
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end
	if SpeedMode == "WalkSpeed" then
		humanoid.WalkSpeed = SpeedEnabled and SpeedValue or DEFAULT_WALKSPEED
	else
		-- CFrame mode drives movement itself every frame below; keep WalkSpeed normal
		-- so the two approaches never stack.
		humanoid.WalkSpeed = DEFAULT_WALKSPEED
	end
end

local speedRenderConnection = RunService.RenderStepped:Connect(function()
	if not (SpeedEnabled and SpeedMode == "CFrame") then return end
	local character = Player.Character
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not (rootPart and humanoid) then return end
	local moveDir = humanoid.MoveDirection
	if moveDir.Magnitude > 0 then
		rootPart.CFrame = rootPart.CFrame + (moveDir * (SpeedValue / 10))
	end
end)

SpeedToggle.MouseButton1Click:Connect(function()
	PlayClick()
	SpeedEnabled = not SpeedEnabled
	SpeedToggle.Text = SpeedEnabled and "On" or "Off"
	ApplySpeed()
end)

SpeedInput.FocusLost:Connect(function()
	local value = tonumber(SpeedInput.Text)
	if value then SpeedValue = value end
	SpeedInput.Text = tostring(SpeedValue)
	ApplySpeed()
end)

SpeedModeButton.MouseButton1Click:Connect(function()
	PlayClick()
	SpeedMode = SpeedMode == "CFrame" and "WalkSpeed" or "CFrame"
	SpeedModeButton.Text = SpeedMode == "CFrame" and "Mode: CFrame Movement" or "Mode: WalkSpeed"
	ApplySpeed()
end)

-- Jump
local JumpEnabled = false
local JumpValue = 50
local JumpOriginal = nil -- captured Humanoid jump settings, restored exactly when toggled off

local JumpInput, JumpToggle = CreateStrengthSection(PlayerPage, "Jump", "Jump Strength", 122, JumpValue)

local function ApplyJump()
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end
	if JumpEnabled then
		if not JumpOriginal then
			JumpOriginal = {
				UseJumpPower = humanoid.UseJumpPower,
				JumpPower = humanoid.JumpPower,
				JumpHeight = humanoid.JumpHeight,
			}
		end
		humanoid.UseJumpPower = true
		humanoid.JumpPower = JumpValue
	elseif JumpOriginal then
		humanoid.UseJumpPower = JumpOriginal.UseJumpPower
		humanoid.JumpPower = JumpOriginal.JumpPower
		humanoid.JumpHeight = JumpOriginal.JumpHeight
	end
end

JumpToggle.MouseButton1Click:Connect(function()
	PlayClick()
	JumpEnabled = not JumpEnabled
	JumpToggle.Text = JumpEnabled and "On" or "Off"
	ApplyJump()
end)

JumpInput.FocusLost:Connect(function()
	local value = tonumber(JumpInput.Text)
	if value then JumpValue = value end
	JumpInput.Text = tostring(JumpValue)
	if JumpEnabled then ApplyJump() end
end)

-- Fly
local FlyEnabled = false
local FlyValue = 3
local FlyGyro = nil

local FlyInput, FlyToggle = CreateStrengthSection(PlayerPage, "Fly", "Fly Strength", 202, FlyValue)

local function StopFly()
	if FlyGyro then
		FlyGyro:Destroy()
		FlyGyro = nil
	end
end

local function StartFly()
	local character = Player.Character
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	if not rootPart then return end
	StopFly()
	local gyro = Instance.new("BodyGyro")
	gyro.Name = "SerenityFlyGyro"
	gyro.MaxTorque = Vector3.new(400000, 400000, 400000)
	gyro.P = 10000
	gyro.CFrame = rootPart.CFrame
	gyro.Parent = rootPart
	FlyGyro = gyro
end

local flyRenderConnection = RunService.RenderStepped:Connect(function()
	if not (FlyEnabled and FlyGyro and FlyGyro.Parent) then return end
	local character = Player.Character
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	local camera = workspace.CurrentCamera
	if not (rootPart and camera) then return end
	local moveDir = Vector3.new(0, 0, 0)
	if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir += camera.CFrame.LookVector end
	if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir -= camera.CFrame.LookVector end
	if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir -= camera.CFrame.RightVector end
	if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir += camera.CFrame.RightVector end
	if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir += Vector3.new(0, 1, 0) end
	if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveDir -= Vector3.new(0, 1, 0) end
	if moveDir.Magnitude > 0 then
		rootPart.CFrame = rootPart.CFrame + (moveDir * (FlyValue / 50))
	end
	local _, yaw = camera.CFrame:ToOrientation()
	FlyGyro.CFrame = CFrame.new(rootPart.Position) * CFrame.Angles(0, yaw, 0)
	rootPart.Velocity = Vector3.new(0, 0, 0)
	rootPart.AssemblyAngularVelocity = Vector3.zero
end)

FlyToggle.MouseButton1Click:Connect(function()
	PlayClick()
	FlyEnabled = not FlyEnabled
	FlyToggle.Text = FlyEnabled and "On" or "Off"
	if FlyEnabled then StartFly() else StopFly() end
end)

FlyInput.FocusLost:Connect(function()
	local value = tonumber(FlyInput.Text)
	if value then FlyValue = value end
	FlyInput.Text = tostring(FlyValue)
end)

-- Re-apply active effects whenever the character (re)spawns.
local characterAddedConnection = Player.CharacterAdded:Connect(function()
	task.wait(0.1)
	ApplySpeed()
	JumpOriginal = nil
	if JumpEnabled then ApplyJump() end
	if FlyEnabled then StartFly() end
end)

SelectTab("Home")

-- Minimize: hardcoded to Left Control, not user-configurable. Everything below the
-- header (dividers, tabs, content) is explicitly hidden while minimized so nothing
-- peeks past the clipped frame.
local MinimizeKeybind = Enum.KeyCode.LeftControl
local minimized = false

local function ToggleGUI()
	minimized = not minimized
	HeaderDivider.Visible = not minimized
	TabBar.Visible = not minimized
	TabDivider.Visible = not minimized
	ContentArea.Visible = not minimized
	TweenService:Create(MainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Size = minimized and MINI_SIZE or FULL_SIZE,
	}):Play()
	MiniButton.Text = minimized and "+" or "-"
end
MiniButton.MouseButton1Click:Connect(function() PlayClick() ToggleGUI() end)

-- Silent unbind-able destroy key (Right Control) -- no button, no prompt, no sound.
-- Reverses every active effect (Speed/Jump/Fly, whichever mode) before tearing down, so
-- nothing lingers on the character no matter what was toggled on when this fires.
local DestroyKeybind = Enum.KeyCode.RightControl
local mainInputConnection
local dragChangedConnection

local function DestroyGui()
	if mainInputConnection then mainInputConnection:Disconnect() end
	if dragChangedConnection then dragChangedConnection:Disconnect() end
	if characterAddedConnection then characterAddedConnection:Disconnect() end
	if speedRenderConnection then speedRenderConnection:Disconnect() end
	if flyRenderConnection then flyRenderConnection:Disconnect() end

	SpeedEnabled = false
	JumpEnabled = false
	FlyEnabled = false
	StopFly()

	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if humanoid then
		humanoid.WalkSpeed = DEFAULT_WALKSPEED
		if JumpOriginal then
			humanoid.UseJumpPower = JumpOriginal.UseJumpPower
			humanoid.JumpPower = JumpOriginal.JumpPower
			humanoid.JumpHeight = JumpOriginal.JumpHeight
		end
	end

	ScreenGui:Destroy()
end

mainInputConnection = UserInputService.InputBegan:Connect(function(input, processed)
	if processed or UserInputService:GetFocusedTextBox() then return end
	if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
	if input.KeyCode == DestroyKeybind then
		DestroyGui()
		return
	end
	if input.KeyCode == MinimizeKeybind then ToggleGUI() end
end)

-- Dragging
local dragging = false
local dragStart = nil
local startPos = nil
MainFrame.InputBegan:Connect(function(input)
	if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
	dragging = true
	dragStart = input.Position
	startPos = MainFrame.Position
	input.Changed:Connect(function()
		if input.UserInputState == Enum.UserInputState.End then
			dragging = false
		end
	end)
end)
dragChangedConnection = UserInputService.InputChanged:Connect(function(input)
	if not dragging or (input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch) then return end
	local delta = input.Position - dragStart
	MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end)

-- Title sequence: the real UI (MainFrame) stays invisible the entire time -- this is a
-- fully separate panel occupying the same spot, so nothing underneath is built-but-
-- hidden, it just doesn't exist visually yet. Emblem spins + grows + fades into the
-- center (matching the old hub's intro), then a fake ~4.5s "loading" runs with a status
-- line that cycles through nonsense messages and a progress bar that fills unevenly.

-- Serenity: minimal UI shell. The old feature-rich hub has been set aside (full copy
-- kept in Main_Legacy_Full.lua) in favor of a clean rebuild -- this is intentionally a
-- blank slate with just window chrome: title, minimize (default Left Control), drag.
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local HttpService = game:GetService("HttpService")

local KeybindStorageFile = "Serenity_Keybinds.json"
local SavedKeybinds = {}
local CanPersistKeybinds = type(isfile) == "function" and type(readfile) == "function" and type(writefile) == "function"
local function LoadSettingsFromGenv()
	if type(getgenv) == "function" then
		local globalSettings = getgenv().Serenity_Settings
		if type(globalSettings) == "table" then SavedKeybinds = globalSettings end
	end
end
LoadSettingsFromGenv()
if CanPersistKeybinds then
	pcall(function()
		if isfile(KeybindStorageFile) then
			local decoded = HttpService:JSONDecode(readfile(KeybindStorageFile))
			if type(decoded) == "table" then SavedKeybinds = decoded end
		end
	end)
end
LoadSettingsFromGenv()

local function SavePersistentSettings()
	if type(getgenv) == "function" then
		getgenv().Serenity_Settings = SavedKeybinds
	end
	if CanPersistKeybinds then
		pcall(function() writefile(KeybindStorageFile, HttpService:JSONEncode(SavedKeybinds)) end)
	end
end

local function DecodeKeybind(savedName)
	if type(savedName) == "string" then
		local success, keyCode = pcall(function() return Enum.KeyCode[savedName] end)
		if success and keyCode then return keyCode end
	end
	return nil
end

-- Minimize defaults to Left Control on a fresh save file. Checking the raw saved value
-- (rather than the decoded result) lets a deliberate clear stick instead of reverting
-- back to the default on the next load.
local function LoadMinimizeKeybind()
	if SavedKeybinds.MinimizeGUI == nil then
		return Enum.KeyCode.LeftControl
	end
	return DecodeKeybind(SavedKeybinds.MinimizeGUI) or Enum.KeyCode.LeftControl
end

local function SaveMinimizeKeybind(keyCode)
	SavedKeybinds.MinimizeGUI = keyCode.Name
	SavePersistentSettings()
end

local function KeybindText(keyCode)
	if keyCode == Enum.KeyCode.Unknown then return "..." end
	if keyCode == Enum.KeyCode.LeftControl then return "L Ctrl" end
	if keyCode == Enum.KeyCode.RightControl then return "R Ctrl" end
	return keyCode.Name
end

local FrameColor = Color3.fromRGB(0x5B, 0x5B, 0x5B)
local AccentColor = Color3.fromRGB(255, 255, 255)

-- Main Container
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "Serenity"
ScreenGui.Parent = CoreGui
ScreenGui.ResetOnSpawn = false

-- Sound Effects
local StartupSound = Instance.new("Sound")
StartupSound.SoundId = "rbxassetid://111102990253594"
StartupSound.Volume = 0.8
StartupSound.Parent = ScreenGui
StartupSound:Play()

local ClickSound = Instance.new("Sound")
ClickSound.SoundId = "rbxassetid://88442833509532"
ClickSound.Volume = 0.5
ClickSound.Parent = ScreenGui

local function PlayClick() ClickSound:Play() end

-- Main Window
local FULL_SIZE = UDim2.new(0, 720, 0, 480)
local MINI_SIZE = UDim2.new(0, 220, 0, 44)

local MainFrame = Instance.new("Frame")
MainFrame.Name = "MainFrame"
MainFrame.Size = FULL_SIZE
MainFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
MainFrame.AnchorPoint = Vector2.new(0.5, 0.5)
MainFrame.BackgroundColor3 = FrameColor
MainFrame.BorderSizePixel = 0
MainFrame.ClipsDescendants = true
MainFrame.Active = true
MainFrame.Visible = true
MainFrame.Parent = ScreenGui

local MainCorner = Instance.new("UICorner")
MainCorner.CornerRadius = UDim.new(0, 14)
MainCorner.Parent = MainFrame

local TitleLabel = Instance.new("TextLabel")
TitleLabel.Name = "TitleLabel"
TitleLabel.Size = UDim2.new(0, 300, 0, 28)
TitleLabel.Position = UDim2.new(0, 18, 0, 14)
TitleLabel.BackgroundTransparency = 1
TitleLabel.Text = "Serenity"
TitleLabel.Font = Enum.Font.GothamMedium
TitleLabel.TextSize = 20
TitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
TitleLabel.Parent = MainFrame

local MiniButton = Instance.new("TextButton")
MiniButton.Name = "MiniButton"
MiniButton.Size = UDim2.new(0, 26, 0, 26)
MiniButton.Position = UDim2.new(1, -38, 0, 12)
MiniButton.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
MiniButton.BackgroundTransparency = 0.4
MiniButton.BorderSizePixel = 0
MiniButton.Text = "-"
MiniButton.Font = Enum.Font.Gotham
MiniButton.TextSize = 18
MiniButton.TextColor3 = Color3.fromRGB(255, 255, 255)
MiniButton.Parent = MainFrame
Instance.new("UICorner", MiniButton).CornerRadius = UDim.new(0, 7)

local MinimizeKeybindBtn = Instance.new("TextButton")
MinimizeKeybindBtn.Name = "MinimizeKeybindBtn"
MinimizeKeybindBtn.Size = UDim2.new(0, 56, 0, 26)
MinimizeKeybindBtn.Position = UDim2.new(1, -100, 0, 12)
MinimizeKeybindBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
MinimizeKeybindBtn.BackgroundTransparency = 0.4
MinimizeKeybindBtn.BorderSizePixel = 0
MinimizeKeybindBtn.Font = Enum.Font.Gotham
MinimizeKeybindBtn.TextSize = 12
MinimizeKeybindBtn.TextColor3 = AccentColor
MinimizeKeybindBtn.Parent = MainFrame
Instance.new("UICorner", MinimizeKeybindBtn).CornerRadius = UDim.new(0, 7)
local MinimizeKeybindStroke = Instance.new("UIStroke")
MinimizeKeybindStroke.Name = "ControlOutline"
MinimizeKeybindStroke.Color = Color3.fromRGB(0, 0, 0)
MinimizeKeybindStroke.Thickness = 1
MinimizeKeybindStroke.Parent = MinimizeKeybindBtn

local HubState = {}
HubState.MinimizeKeybind = LoadMinimizeKeybind()
HubState.minimized = false
HubState.IsBindingMinimize = false
MinimizeKeybindBtn.Text = KeybindText(HubState.MinimizeKeybind)

local function ToggleGUI()
	HubState.minimized = not HubState.minimized
	TweenService:Create(MainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Size = HubState.minimized and MINI_SIZE or FULL_SIZE,
	}):Play()
	MiniButton.Text = HubState.minimized and "+" or "-"
end
MiniButton.MouseButton1Click:Connect(function() PlayClick() ToggleGUI() end)

MinimizeKeybindBtn.MouseButton1Click:Connect(function()
	PlayClick()
	MinimizeKeybindBtn.Text = "..."
	HubState.IsBindingMinimize = true
	local rebindConnection
	rebindConnection = UserInputService.InputBegan:Connect(function(input, processed)
		if processed then return end
		if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
		local selectedKey = input.KeyCode
		if selectedKey == Enum.KeyCode.Backspace or selectedKey == Enum.KeyCode.Delete then
			selectedKey = Enum.KeyCode.Unknown
		end
		HubState.MinimizeKeybind = selectedKey
		SaveMinimizeKeybind(selectedKey)
		MinimizeKeybindBtn.Text = KeybindText(selectedKey)
		HubState.IsBindingMinimize = false
		rebindConnection:Disconnect()
	end)
end)

-- Silent unbind-able destroy key (Right Control) -- no button, no prompt, no sound.
local DestroyKeybind = Enum.KeyCode.RightControl
local mainInputConnection
local dragChangedConnection

local function DestroyGui()
	if mainInputConnection then mainInputConnection:Disconnect() end
	if dragChangedConnection then dragChangedConnection:Disconnect() end
	ScreenGui:Destroy()
end

mainInputConnection = UserInputService.InputBegan:Connect(function(input, processed)
	if processed or HubState.IsBindingMinimize or UserInputService:GetFocusedTextBox() then return end
	if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
	if input.KeyCode == DestroyKeybind then
		DestroyGui()
		return
	end
	if input.KeyCode == HubState.MinimizeKeybind then ToggleGUI() end
end)

-- Dragging
HubState.dragging = false
HubState.dragStart = nil
HubState.startPos = nil
MainFrame.InputBegan:Connect(function(input)
	if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
	HubState.dragging = true
	HubState.dragStart = input.Position
	HubState.startPos = MainFrame.Position
	input.Changed:Connect(function()
		if input.UserInputState == Enum.UserInputState.End then
			HubState.dragging = false
		end
	end)
end)
dragChangedConnection = UserInputService.InputChanged:Connect(function(input)
	if not HubState.dragging or (input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch) then return end
	local delta = input.Position - HubState.dragStart
	MainFrame.Position = UDim2.new(HubState.startPos.X.Scale, HubState.startPos.X.Offset + delta.X, HubState.startPos.Y.Scale, HubState.startPos.Y.Offset + delta.Y)
end)

-- A rebindable keybind button: click, press a key, it saves to the settings file and
-- calls onKeybindChanged with the new KeyCode so the caller can update its own state.
local function CreateKeybindButton(parent, storageKey, onKeybindChanged)
	local btn = Instance.new("TextButton")
	btn.Name = "KeybindButton"
	btn.Size = UDim2.new(0, 80, 0, 30)
	btn.Position = UDim2.new(1, -176, 0.5, -15)
	btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
	btn.BackgroundTransparency = 0.2
	btn.BorderSizePixel = 0
	btn.Font = UIFont
	btn.TextSize = 16
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	btn.Parent = parent
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

	local loadedKey = LoadFeatureKeybind(storageKey)
	btn.Text = KeybindText(loadedKey)
	onKeybindChanged(loadedKey)

	btn.MouseButton1Click:Connect(function()
		PlayClick()
		btn.Text = "..."
		bindingInProgress = true
		local capture
		capture = UserInputService.InputBegan:Connect(function(input, processed)
			if processed then return end
			if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
			local selectedKey = input.KeyCode
			if selectedKey == Enum.KeyCode.Backspace or selectedKey == Enum.KeyCode.Delete then
				selectedKey = Enum.KeyCode.Unknown
			end
			SaveFeatureKeybind(storageKey, selectedKey)
			btn.Text = KeybindText(selectedKey)
			onKeybindChanged(selectedKey)
			capture:Disconnect()
			-- Deferred so this input event finishes dispatching to every listener
			-- (including the global toggle-key handler below) before the guard drops --
			-- otherwise the same keypress that sets the bind could also fire the toggle.
			task.defer(function() bindingInProgress = false end)
		end)
	end)

	return btn
end

-- On/Off toggle plus its keybind button, in their own row below the strength row.
local function CreateToggleRow(parent, y, storageKey, onKeybindChanged)
	local row = Instance.new("Frame")
	row.Name = "ToggleRow"
	row.Size = UDim2.new(1, 0, 0, 40)
	row.Position = UDim2.new(0, 0, 0, y)
	row.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
	row.BackgroundTransparency = 0.5
	row.BorderSizePixel = 0
	row.Parent = parent
	Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)

	local rowLabel = Instance.new("TextLabel")
	rowLabel.Name = "RowLabel"
	rowLabel.Size = UDim2.new(0, 200, 1, 0)
	rowLabel.Position = UDim2.new(0, 16, 0, 0)
	rowLabel.BackgroundTransparency = 1
	rowLabel.Text = "Toggle"
	rowLabel.Font = UIFont
	rowLabel.TextSize = 15
	rowLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	rowLabel.TextXAlignment = Enum.TextXAlignment.Left
	rowLabel.TextYAlignment = Enum.TextYAlignment.Center
	rowLabel.Parent = row

	local toggle = Instance.new("TextButton")
	toggle.Name = "Toggle"
	toggle.Size = UDim2.new(0, 80, 0, 30)
	toggle.Position = UDim2.new(1, -88, 0.5, -15)
	toggle.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
	toggle.BackgroundTransparency = 0.2
	toggle.BorderSizePixel = 0
	toggle.Text = "Off"
	toggle.Font = UIFont
	toggle.TextSize = 16
	toggle.TextColor3 = Color3.fromRGB(255, 255, 255)
	toggle.Parent = row
	Instance.new("UICorner", toggle).CornerRadius = UDim.new(0, 6)

	local keybindBtn = CreateKeybindButton(row, storageKey, onKeybindChanged)

	return toggle, keybindBtn
end

-- Single-row ESP control: label, then (left to right) a color swatch, a keybind button,
-- and the On/Off toggle -- one merged row per feature instead of a separate color row
-- stacked on top of a separate toggle row. The swatch is still a placeholder -- it shows
-- the current ESP color but isn't wired up to an actual picker yet.

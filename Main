	Backdrop.BackgroundColor3 = FrameColor
	Backdrop.BorderSizePixel = 0
	Backdrop.Image = "rbxassetid://110269599012494"
	Backdrop.ScaleType = Enum.ScaleType.Crop
	Backdrop.Parent = MainFrame
	local backdropCorner = Instance.new("UICorner")
	backdropCorner.CornerRadius = UDim.new(0, 14)
	backdropCorner.Parent = Backdrop
end


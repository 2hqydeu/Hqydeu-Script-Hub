	local function RefreshPopupPlayerList()
		for _, child in ipairs(PopupPlayerList:GetChildren()) do
			if child:IsA("Frame") then child:Destroy() end
		end
		local filter = PopupPlayerSearch.Text:lower()
		local candidates = {}
		for _, targetPlayer in ipairs(Players:GetPlayers()) do
			if targetPlayer ~= Player then
				local displayText = targetPlayer.DisplayName or targetPlayer.Name
				if filter == "" or displayText:lower():find(filter, 1, true) or targetPlayer.Name:lower():find(filter, 1, true) then
					local isFriend = false
					pcall(function() isFriend = Player:IsFriendsWith(targetPlayer.UserId) end)
					table.insert(candidates, {Player = targetPlayer, DisplayText = displayText, IsFriend = isFriend})
				end
			end
		end
		table.sort(candidates, function(a, b)
			if a.IsFriend ~= b.IsFriend then return a.IsFriend end
			return false
		end)
		for _, candidate in ipairs(candidates) do
			local targetPlayer = candidate.Player
			local row = Instance.new("Frame")
			row.Size = UDim2.new(1, 0, 0, 30)
			row.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
			row.BackgroundTransparency = 0.5
			row.BorderSizePixel = 0
			row.ZIndex = 31
			row.Parent = PopupPlayerList
			Instance.new("UICorner", row).CornerRadius = UDim.new(0, 5)

			local nameLabel = Instance.new("TextLabel")
			nameLabel.Size = UDim2.new(1, -12, 0, 16)
			nameLabel.Position = UDim2.new(0, 8, 0, 1)
			nameLabel.BackgroundTransparency = 1
			nameLabel.Text = candidate.IsFriend and ("\226\152\133 " .. candidate.DisplayText) or candidate.DisplayText
			nameLabel.Font = UIFont
			nameLabel.TextSize = 11
			nameLabel.TextColor3 = candidate.IsFriend and Color3.fromRGB(255, 210, 90) or Color3.fromRGB(255, 255, 255)
			nameLabel.TextXAlignment = Enum.TextXAlignment.Left
			nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
			nameLabel.ZIndex = 32
			nameLabel.Parent = row

			local userLabel = Instance.new("TextLabel")
			userLabel.Size = UDim2.new(1, -12, 0, 12)
			userLabel.Position = UDim2.new(0, 8, 0, 16)
			userLabel.BackgroundTransparency = 1
			userLabel.Text = "@" .. targetPlayer.Name
			userLabel.Font = UIFont
			userLabel.TextSize = 8
			userLabel.TextColor3 = Color3.fromRGB(170, 170, 170)
			userLabel.TextXAlignment = Enum.TextXAlignment.Left
			userLabel.ZIndex = 32
			userLabel.Parent = row

			local clickButton = Instance.new("TextButton")
			clickButton.Size = UDim2.new(1, 0, 1, 0)
			clickButton.BackgroundTransparency = 1
			clickButton.Text = ""
			clickButton.ZIndex = 32
			clickButton.Parent = row
			clickButton.MouseButton1Click:Connect(function()
				PlayClick()
				local targetCharacter = targetPlayer.Character
				local targetRoot = targetCharacter and targetCharacter:FindFirstChild("HumanoidRootPart")
				local character = Player.Character
				local root = character and character:FindFirstChild("HumanoidRootPart")
				if targetRoot and root then root.CFrame = targetRoot.CFrame * CFrame.new(0, 0, 3) end
			end)
		end
		PopupPlayerList.CanvasSize = UDim2.new(0, 0, 0, PopupPlayerListLayout.AbsoluteContentSize.Y + 4)
	end


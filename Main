-- Player tab
local PlayerPage = CreateTab("Player", 2, "108208886963013")

-- Speed: the same CFrame-nudge approach the old hub used (RenderStepped, moves the root
-- part along the humanoid's current move direction), not a WalkSpeed swap.
local SpeedEnabled = false
local SpeedValue = 3

RunService.RenderStepped:Connect(function()
	if not SpeedEnabled then return end
	local character = Player.Character
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not (rootPart and humanoid) then return end
	local moveDir = humanoid.MoveDirection
	if moveDir.Magnitude > 0 then
		rootPart.CFrame = rootPart.CFrame + (moveDir * (SpeedValue / 10))
	end
end)

local SpeedLabel = Instance.new("TextLabel")
SpeedLabel.Name = "SpeedLabel"
SpeedLabel.Size = UDim2.new(0, 70, 0, 28)
SpeedLabel.Position = UDim2.new(0, 0, 0, 0)
SpeedLabel.BackgroundTransparency = 1
SpeedLabel.Text = "Speed"
SpeedLabel.Font = UIFont
SpeedLabel.TextSize = 14
SpeedLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
SpeedLabel.TextXAlignment = Enum.TextXAlignment.Left
SpeedLabel.Parent = PlayerPage

local SpeedInput = Instance.new("TextBox")
SpeedInput.Name = "SpeedInput"
SpeedInput.Size = UDim2.new(0, 60, 0, 28)
SpeedInput.Position = UDim2.new(0, 90, 0, 0)
SpeedInput.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
SpeedInput.BackgroundTransparency = 0.3
SpeedInput.BorderSizePixel = 0
SpeedInput.ClearTextOnFocus = false
SpeedInput.Text = tostring(SpeedValue)
SpeedInput.Font = UIFont
SpeedInput.TextSize = 13
SpeedInput.TextColor3 = Color3.fromRGB(255, 255, 255)
SpeedInput.Parent = PlayerPage
Instance.new("UICorner", SpeedInput).CornerRadius = UDim.new(0, 6)

local SpeedToggle = Instance.new("TextButton")
SpeedToggle.Name = "SpeedToggle"
SpeedToggle.Size = UDim2.new(0, 70, 0, 28)
SpeedToggle.Position = UDim2.new(0, 162, 0, 0)
SpeedToggle.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
SpeedToggle.BackgroundTransparency = 0.3
SpeedToggle.BorderSizePixel = 0
SpeedToggle.Text = "Off"
SpeedToggle.Font = UIFont
SpeedToggle.TextSize = 13
SpeedToggle.TextColor3 = Color3.fromRGB(255, 255, 255)
SpeedToggle.Parent = PlayerPage
Instance.new("UICorner", SpeedToggle).CornerRadius = UDim.new(0, 6)

SpeedToggle.MouseButton1Click:Connect(function()
	PlayClick()
	SpeedEnabled = not SpeedEnabled
	SpeedToggle.Text = SpeedEnabled and "On" or "Off"
end)

SpeedInput.FocusLost:Connect(function()
	local value = tonumber(SpeedInput.Text)
	if value then
		SpeedValue = value
	end
	SpeedInput.Text = tostring(SpeedValue)
end)

SelectTab("Home")

-- Minimize: hardcoded to Left Control, not user-configurable. Everything below the
-- header (divider, tabs, content) is explicitly hidden while minimized so nothing peeks
-- past the clipped frame.
local MinimizeKeybind = Enum.KeyCode.LeftControl
local minimized = false

local function ToggleGUI()
	minimized = not minimized
	Divider.Visible = not minimized
	TabBar.Visible = not minimized
	ContentArea.Visible = not minimized
	TweenService:Create(MainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Size = minimized and MINI_SIZE or FULL_SIZE,
	}):Play()
	MiniButton.Text = minimized and "+" or "-"
end
MiniButton.MouseButton1Click:Connect(function() PlayClick() ToggleGUI() end)

-- Silent unbind-able destroy key (Right Control) -- no button, no prompt, no sound.
local DestroyKeybind = Enum.KeyCode.RightControl
local mainInputConnection
local dragChangedConnection

local function DestroyGui()
	if mainInputConnection then mainInputConnection:Disconnect() end
	if dragChangedConnection then dragChangedConnection:Disconnect() end
	ScreenGui:Destroy()
end

mainInputConnection = UserInputService.InputBegan:Connect(function(input, processed)
	if processed or UserInputService:GetFocusedTextBox() then return end
	if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
	if input.KeyCode == DestroyKeybind then
		DestroyGui()
		return
	end
	if input.KeyCode == MinimizeKeybind then ToggleGUI() end
end)

-- Dragging
local dragging = false
local dragStart = nil
local startPos = nil
MainFrame.InputBegan:Connect(function(input)
	if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
	dragging = true
	dragStart = input.Position
	startPos = MainFrame.Position
	input.Changed:Connect(function()
		if input.UserInputState == Enum.UserInputState.End then
			dragging = false
		end
	end)
end)
dragChangedConnection = UserInputService.InputChanged:Connect(function(input)
	if not dragging or (input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch) then return end
	local delta = input.Position - dragStart
	MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end)

	row.BorderSizePixel = 0
	row.Parent = parent
	Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)

	local rowLabel = Instance.new("TextLabel")
	rowLabel.Name = "RowLabel"
	rowLabel.Size = UDim2.new(0, 200, 1, 0)
	rowLabel.Position = UDim2.new(0, 16, 0, 0)
	rowLabel.BackgroundTransparency = 1
	rowLabel.Text = rowLabelText
	rowLabel.Font = UIFont
	rowLabel.TextSize = 15
	rowLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	rowLabel.TextXAlignment = Enum.TextXAlignment.Left
	rowLabel.TextYAlignment = Enum.TextYAlignment.Center
	rowLabel.Parent = row

	local swatch = Instance.new("TextButton")
	swatch.Name = "ColorSwatch"
	swatch.Size = UDim2.new(0, 30, 0, 30)
	swatch.Position = UDim2.new(1, -214, 0.5, -15)
	swatch.BackgroundColor3 = defaultColor
	swatch.AutoButtonColor = false
	swatch.BorderSizePixel = 0
	swatch.Text = ""
	swatch.Parent = row
	Instance.new("UICorner", swatch).CornerRadius = UDim.new(0, 6)
	local swatchStroke = Instance.new("UIStroke")
	swatchStroke.Color = Color3.fromRGB(0, 0, 0)
	swatchStroke.Thickness = 1
	swatchStroke.Parent = swatch

	-- CreateKeybindButton's default position (1, -176, 0.5, -15) already sits directly
	-- left of the toggle button below, so it needs no repositioning here.
	local keybindBtn = CreateKeybindButton(row, storageKey, onKeybindChanged)

	local toggle = Instance.new("TextButton")
	toggle.Name = "Toggle"
	toggle.Size = UDim2.new(0, 80, 0, 30)
	toggle.Position = UDim2.new(1, -88, 0.5, -15)
	toggle.BackgroundColor3 = Color3.fromRGB(60, 60, 60)

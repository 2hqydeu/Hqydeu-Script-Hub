-- Belt-and-suspenders, matching the old hub exactly: force every descendant to the same
-- high ZIndex so nothing about sibling ordering inside the picker is left ambiguous.
for _, pickerObject in ipairs(ESPColorPicker:GetDescendants()) do
	if pickerObject:IsA("GuiObject") then pickerObject.ZIndex = 51 end
end

local function RefreshPickerMarkers()
	SVSquare.BackgroundColor3 = Color3.fromHSV(PickerH, 1, 1)
	SVMarker.Position = UDim2.new(PickerS, 0, 1 - PickerV, 0)
	HueMarker.Position = UDim2.new(0, -2, PickerH, -1)
end

local function RefreshSavedColorButtons()
	local savedColors = type(SavedKeybinds.ESPSavedColors) == "table" and SavedKeybinds.ESPSavedColors or {}
	for index, swatch in ipairs(SavedColorButtons) do
		local color = UnpackColor(savedColors[index], nil)
		swatch.BackgroundColor3 = color or Color3.fromRGB(60, 60, 60)
		swatch.Text = color and "" or "+"
	end
end

local function ApplyPickerColor()
	SetESPColor(Color3.fromHSV(PickerH, PickerS, PickerV))
	RefreshPickerMarkers()
end

local function UpdateSVFromPosition(position)
	local x = math.clamp((position.X - SVInput.AbsolutePosition.X) / SVInput.AbsoluteSize.X, 0, 1)
	local y = math.clamp((position.Y - SVInput.AbsolutePosition.Y) / SVInput.AbsoluteSize.Y, 0, 1)
	PickerS = x
	PickerV = 1 - y
	ApplyPickerColor()
end

local function UpdateHueFromPosition(position)
	PickerH = math.clamp((position.Y - HueInput.AbsolutePosition.Y) / HueInput.AbsoluteSize.Y, 0, 1)
	ApplyPickerColor()
end

SVInput.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		DraggingSV = true
		UpdateSVFromPosition(input.Position)
	end
end)
HueInput.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		DraggingHue = true
		UpdateHueFromPosition(input.Position)
	end
end)
UserInputService.InputChanged:Connect(function(input)
	if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then return end
	if DraggingSV then
		UpdateSVFromPosition(input.Position)
	elseif DraggingHue then
		UpdateHueFromPosition(input.Position)
	end
end)
UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		DraggingSV = false
		DraggingHue = false
	end
end)

SaveColorButton.MouseButton1Click:Connect(function()
	PlayClick()
	local savedColors = type(SavedKeybinds.ESPSavedColors) == "table" and SavedKeybinds.ESPSavedColors or {}
	table.insert(savedColors, 1, PackColor(ESPColor))
	while #savedColors > 5 do table.remove(savedColors) end
	SavedKeybinds.ESPSavedColors = savedColors
	SavePersistentSettings()
	RefreshSavedColorButtons()
end)

for index, swatch in ipairs(SavedColorButtons) do
	swatch.MouseButton1Click:Connect(function()
		PlayClick()
		local savedColors = type(SavedKeybinds.ESPSavedColors) == "table" and SavedKeybinds.ESPSavedColors or {}
		local color = UnpackColor(savedColors[index], nil)
		if not color then return end
		PickerH, PickerS, PickerV = Color3.toHSV(color)
		ApplyPickerColor()
	end)
end

local function CloseESPColorPicker()
	ESPColorPicker.Visible = false
end

ESPColorButton.MouseButton1Click:Connect(function()
	PlayClick()
	if ESPColorPicker.Visible then
		CloseESPColorPicker()
		return
	end
	-- Recompute position on open rather than relying only on the AbsolutePosition-changed
	-- signal from setup: that signal may have fired once before Roblox finished laying
	-- out the freshly-built GUI, leaving MainFrame.AbsolutePosition read as (0,0) and the
	-- picker parked off the left edge of the screen -- functional but invisible. By the
	-- time someone has clicked this button, layout has long since settled.
	UpdateESPColorPickerPosition()
	PickerH, PickerS, PickerV = Color3.toHSV(ESPColor)
	RefreshPickerMarkers()
	RefreshSavedColorButtons()
	ESPColorPicker.Visible = true
end)

RefreshPickerMarkers()


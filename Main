		WaypointList.CanvasSize = UDim2.new(0, 0, 0, WaypointListLayout.AbsoluteContentSize.Y + 4)
	end
	table.insert(WaypointRefreshCallbacks, RefreshWaypointList)

	local function AddWaypoint(part)
		if not part or not part:IsA("BasePart") then return end
		local segments = GetWaypointSegments(part)
		local components = {part.CFrame:GetComponents()}
		local signature = table.concat(components, ",")
		for _, waypoint in ipairs(Waypoints) do
			if table.concat(waypoint.CFrame or {}, ",") == signature then return end
		end
		table.insert(Waypoints, {Segments = segments, CFrame = components, Name = part.Name})
		SaveWaypoints()
		BroadcastWaypointsChanged()
	end

	-- Select-part tool: click "Select Part", then click any BasePart in the world to save
	-- it as a waypoint. A highlight follows the mouse while selecting.
	local Mouse = Player:GetMouse()
	local Selecting = false
	local SelectStarted = 0
	local HoverHighlight = Instance.new("Highlight")
	HoverHighlight.Name = "WaypointHoverHighlight"
	HoverHighlight.FillTransparency = 0.7
	HoverHighlight.OutlineColor = AccentColor
	HoverHighlight.FillColor = AccentColor
	HoverHighlight.Enabled = false
	HoverHighlight.Parent = ScreenGui

	local function EndWaypointSelection()
		Selecting = false
		HoverHighlight.Enabled = false
		HoverHighlight.Adornee = nil
		AddWaypointButton.Text = "Select Part"
	end

	local function BeginWaypointSelection()
		Selecting = true
		SelectStarted = os.clock()
		AddWaypointButton.Text = "Cancel"
	end

	AddWaypointButton.MouseButton1Click:Connect(function()
		PlayClick()
		if Selecting then EndWaypointSelection() else BeginWaypointSelection() end
	end)

	SetHereButton.MouseButton1Click:Connect(function()
		PlayClick()
		if Selecting then EndWaypointSelection() end
		local character = Player.Character
		local root = character and character:FindFirstChild("HumanoidRootPart")
		if not root then return end
		local components = {root.CFrame:GetComponents()}
		local signature = table.concat(components, ",")
		for _, waypoint in ipairs(Waypoints) do
			if table.concat(waypoint.CFrame or {}, ",") == signature then return end
		end
		table.insert(Waypoints, {Segments = {}, CFrame = components, Name = "Current Position", Kind = "Position"})
		SaveWaypoints()
		BroadcastWaypointsChanged()
	end)

	table.insert(looseConnections, RunService.RenderStepped:Connect(function()
		if not Selecting then return end
		local target = Mouse.Target
		HoverHighlight.Adornee = target
		HoverHighlight.Enabled = target ~= nil and target:IsA("BasePart")
	end))

	table.insert(looseConnections, UserInputService.InputBegan:Connect(function(input, processed)
		if processed or input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
		if not Selecting or os.clock() - SelectStarted < 0.2 then return end
		local target = Mouse.Target
		if not target or not target:IsA("BasePart") then return end
		EndWaypointSelection()
		AddWaypoint(target)
	end))

	-- Sub-tab switching
	local ActiveTeleportTab = "Players"
	local function ShowTeleportTab(tabName)
		ActiveTeleportTab = tabName
		local showingWaypoints = tabName == "Waypoints"
		PlayerSearch.Visible = not showingWaypoints
		PlayerList.Visible = not showingWaypoints
		AddWaypointButton.Visible = showingWaypoints
		SetHereButton.Visible = showingWaypoints
		WaypointSearch.Visible = showingWaypoints
		WaypointList.Visible = showingWaypoints
		PlayersTabButton.BackgroundTransparency = showingWaypoints and 0.5 or 0.2
		WaypointsTabButton.BackgroundTransparency = showingWaypoints and 0.2 or 0.5
		if showingWaypoints then RefreshWaypointList() else RefreshPlayerList() end
	end

	PlayersTabButton.MouseButton1Click:Connect(function() PlayClick() ShowTeleportTab("Players") end)
	WaypointsTabButton.MouseButton1Click:Connect(function() PlayClick() ShowTeleportTab("Waypoints") end)
	PlayerSearch:GetPropertyChangedSignal("Text"):Connect(RefreshPlayerList)
	WaypointSearch:GetPropertyChangedSignal("Text"):Connect(RefreshWaypointList)
	table.insert(looseConnections, Players.PlayerAdded:Connect(function()
		if ActiveTeleportTab == "Players" then RefreshPlayerList() end
	end))
	table.insert(looseConnections, Players.PlayerRemoving:Connect(function()
		if ActiveTeleportTab == "Players" then RefreshPlayerList() end
	end))

	ShowTeleportTab("Players")
end


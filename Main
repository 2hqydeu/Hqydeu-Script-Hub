-- Main Window
local HEADER_HEIGHT = 58
local FULL_SIZE = UDim2.new(0, 560, 0, 430)
local MINI_SIZE = UDim2.new(0, 220, 0, HEADER_HEIGHT)
local WINDOW_POSITION = UDim2.new(0.5, -280, 0.5, -215)

-- MainFrame gets built below, but the loading bar needs to run first -- before any of the
-- (invisible-until-ready) tab/feature construction -- so it appears the instant the script
-- executes instead of only after the whole GUI has finished building. Forward-declared so
-- this section's closure can set MainFrame.Visible once construction (further down)
-- actually assigns it. Runs on its own thread (task.spawn) so it doesn't block that
-- construction from happening at the same time -- whichever finishes first, the "if
-- MainFrame then" check below handles the race safely either way.
local MainFrame
task.spawn(function()
	local LoadingTrack = Instance.new("Frame")
	LoadingTrack.Name = "LoadingTrack"
	LoadingTrack.AnchorPoint = Vector2.new(0.5, 0.5)
	LoadingTrack.Size = UDim2.new(0, 300, 0, 6)
	LoadingTrack.Position = UDim2.new(0.5, 0, 0.5, 0)
	LoadingTrack.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
	LoadingTrack.BorderSizePixel = 0
	LoadingTrack.Parent = ScreenGui
	Instance.new("UICorner", LoadingTrack).CornerRadius = UDim.new(1, 0)

	local LoadingFill = Instance.new("Frame")
	LoadingFill.Name = "LoadingFill"
	LoadingFill.Size = UDim2.new(0, 0, 1, 0)
	LoadingFill.BackgroundColor3 = AccentColor
	LoadingFill.BorderSizePixel = 0
	LoadingFill.Parent = LoadingTrack
	Instance.new("UICorner", LoadingFill).CornerRadius = UDim.new(1, 0)

	local fillTween = TweenService:Create(LoadingFill, TweenInfo.new(2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 1, 0)})
	fillTween:Play()
	fillTween.Completed:Wait()

	local fadeOutTweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	TweenService:Create(LoadingTrack, fadeOutTweenInfo, {BackgroundTransparency = 1}):Play()
	local fillFadeOut = TweenService:Create(LoadingFill, fadeOutTweenInfo, {BackgroundTransparency = 1})
	fillFadeOut:Play()
	fillFadeOut.Completed:Wait()
	LoadingTrack:Destroy()
	if MainFrame then MainFrame.Visible = true end
end)

MainFrame = Instance.new("Frame")
MainFrame.Name = "MainFrame"
MainFrame.Size = FULL_SIZE
MainFrame.Position = WINDOW_POSITION
MainFrame.AnchorPoint = Vector2.new(0, 0)
MainFrame.BackgroundColor3 = FrameColor
MainFrame.BackgroundTransparency = 0
MainFrame.BorderSizePixel = 0
MainFrame.ClipsDescendants = true
MainFrame.Active = true
MainFrame.Visible = false
MainFrame.Parent = ScreenGui

local MainCorner = Instance.new("UICorner")

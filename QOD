RunService.Heartbeat:Connect(function()
	if not ScreenGui.Parent then return end
	if not farmState.Enabled or not IsQuietOrDieSurvivor() then return end
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if not humanoid or humanoid.Health <= 0 or not root then return end
	if farmState.SafePlace and farmState.DroppedCharacter ~= character then
		farmState.DroppedCharacter = character
		SetRootUpright(root, root.CFrame, BASE_SAFE_POSITION)
		root.AssemblyLinearVelocity = Vector3.new(0, -3, 0)
	end
	local now = os.clock()
	if farmState.LastEmote ~= 0 and now - farmState.LastEmote < farmState.TauntDelay then return end
	local fired = false
	for _ = 1, farmState.TauntBurst do
		if TriggerQuietOrDieTaunt() then fired = true end
	end
	if fired then farmState.LastEmote = now end
end)


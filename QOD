-- panel's row list); pass a different one (e.g. a popup's own row list) to place it there
-- instead. order sets LayoutOrder (rows stack in creation order if not given one).
local nextRowOrder = 1
local function CreateFeatureRow(order, labelText, parent)
	local row = Instance.new("Frame")
	row.Name = labelText:gsub("%s+", "") .. "Row"
	row.LayoutOrder = order or nextRowOrder
	nextRowOrder = math.max(nextRowOrder, row.LayoutOrder) + 1
	row.Size = UDim2.new(1, 0, 0, 36)
	row.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
	row.BackgroundTransparency = GameRowTransparency
	row.BorderSizePixel = 0
	row.Parent = parent or ContentScroll
	Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)

	local label = Instance.new("TextLabel")
	label.Name = "Label"
	label.Size = UDim2.new(0, 140, 1, 0)
	label.Position = UDim2.new(0, 12, 0, 0)
	label.BackgroundTransparency = 1
	label.Text = labelText
	label.Font = UIFont

RunService.Heartbeat:Connect(function()
	if not ScreenGui.Parent then return end
	if not revealState.Enabled then return end
	if revealState.LastFire ~= 0 and os.clock() - revealState.LastFire < 0.5 then return end
	local playerGui = Player:FindFirstChildOfClass("PlayerGui")
	local inGameGui = playerGui and playerGui:FindFirstChild("InGameGui")
	local killerFrame = inGameGui and inGameGui:FindFirstChild("KillerFrameGame2")
	if killerFrame and killerFrame.Visible then
		pcall(function()
			VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
			task.delay(0.03, function()

	SetAudioMuted(muteAudioEnabled)
end)

-- Auto Revive: fires every nearby, enabled RevivePrompt using fireproximityprompt.
local reviveState = {Enabled = false, LastCheck = 0, Triggered = {}}
ReviveToggle.MouseButton1Click:Connect(function()
	reviveState.Enabled = not reviveState.Enabled
	reviveState.Triggered = {}
	ReviveToggle.Text = reviveState.Enabled and "On" or "Off"
end)

RunService.Heartbeat:Connect(function()
	if not ScreenGui.Parent then return end
	if not reviveState.Enabled or os.clock() - reviveState.LastCheck < 0.01 then return end
	reviveState.LastCheck = os.clock()
	local playersFolder = workspace:FindFirstChild("PlayersFolder")
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not playersFolder or not humanoid or humanoid.Health <= 0 then return end

	local now = os.clock()
	for prompt, lastTriggered in pairs(reviveState.Triggered) do
		if not prompt.Parent or now - lastTriggered > 0.5 then reviveState.Triggered[prompt] = nil end
	end
	for _, targetCharacter in ipairs(playersFolder:GetChildren()) do
		if targetCharacter ~= character and targetCharacter:IsA("Model") then
			local targetRoot = targetCharacter:FindFirstChild("HumanoidRootPart")
			local attachment = (targetRoot and targetRoot:FindFirstChild("ReviveAttachment")) or targetCharacter:FindFirstChild("ReviveAttachment", true)
			local prompt = attachment and attachment:FindFirstChild("RevivePrompt", true)
			if prompt and prompt:IsA("ProximityPrompt") and prompt.Enabled
				and (not reviveState.Triggered[prompt] or now - reviveState.Triggered[prompt] >= 0.02) then
				reviveState.Triggered[prompt] = now
				if type(fireproximityprompt) == "function" then
					local originalHoldDuration = prompt.HoldDuration
					local originalRequiresLineOfSight = prompt.RequiresLineOfSight
					pcall(function()
						prompt.HoldDuration = 0
						prompt.RequiresLineOfSight = false
					end)
					pcall(function() fireproximityprompt(prompt) end)
					task.delay(0.05, function()
						if prompt and prompt.Parent then
							pcall(function()
								prompt.HoldDuration = originalHoldDuration
								prompt.RequiresLineOfSight = originalRequiresLineOfSight
							end)
						end
					end)
				end
			end
		end
	end
end)

-- Auto Event: walks toward the nearest EventItem in the EventSpawns folder, skipping any
-- item that's taken too long to reach (probably unreachable/already claimed).
local eventState = {Enabled = false, LastMove = 0, Current = nil, Started = 0, Skipped = {}}
EventToggle.MouseButton1Click:Connect(function()
	eventState.Enabled = not eventState.Enabled
	eventState.Current = nil
	eventState.Started = 0
	EventToggle.Text = eventState.Enabled and "On" or "Off"
end)

RunService.Heartbeat:Connect(function()
	if not ScreenGui.Parent then return end
	if not eventState.Enabled then return end
	if IsQuietOrDieKiller() then eventState.Current = nil return end
	if os.clock() - eventState.LastMove < 0.06 then return end
	eventState.LastMove = os.clock()
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local root = character and character:FindFirstChild("HumanoidRootPart")
	local eventFolder = workspace:FindFirstChild("EventSpawns")
	if not humanoid or humanoid.Health <= 0 or not root or not eventFolder then return end

	local now = os.clock()
	for item, expiresAt in pairs(eventState.Skipped) do
		if not item.Parent or expiresAt <= now then eventState.Skipped[item] = nil end
	end

	local target = eventState.Current
	if not target or not target.Parent or eventState.Skipped[target] then
		target = nil
		local closestDistance = math.huge
		for _, item in ipairs(eventFolder:GetChildren()) do
			if item.Name:match("^EventItem%d+$") and not eventState.Skipped[item] then
				local part = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart", true)
				if part then
					local distance = (root.Position - part.Position).Magnitude
					if distance < closestDistance then
						closestDistance = distance
						target = item
					end
				end
			end
		end
		eventState.Current = target
		eventState.Started = now
	elseif now - eventState.Started > 1.5 then
		eventState.Skipped[target] = now + 2
		eventState.Current = nil
		return
	end

	if target and target.Parent then
		local targetPart = target:IsA("BasePart") and target or target:FindFirstChildWhichIsA("BasePart", true)
		if targetPart then
			SetRootUpright(root, root.CFrame, targetPart.Position + Vector3.new(0, -3.5, 0))
		end
	end
end)

-- ESP: labels whoever's currently the killer -- "Killer" floating over their head, same
-- idea as the old hub's reveal, but shown as a world label instead of firing the ability.
local espEnabled = false
local killerLabels = {}

local function ClearKillerLabel(targetPlayer)
	local label = killerLabels[targetPlayer]
	if label then
		label:Destroy()
		killerLabels[targetPlayer] = nil
	end
end

local function ClearAllKillerLabels()
	for targetPlayer in pairs(killerLabels) do
		ClearKillerLabel(targetPlayer)
	end
end

ESPToggle.MouseButton1Click:Connect(function()
	espEnabled = not espEnabled
	ESPToggle.Text = espEnabled and "On" or "Off"
	if not espEnabled then ClearAllKillerLabels() end
end)

RunService.Heartbeat:Connect(function()
	if not ScreenGui.Parent then return end
	if not espEnabled then
		return
	end
	for _, targetPlayer in ipairs(Players:GetPlayers()) do
		local character = targetPlayer.Character
		local head = character and character:FindFirstChild("Head")
		if character and head and IsPlayerKiller(targetPlayer) then
			local existing = killerLabels[targetPlayer]
			if not existing or not existing.Parent then
				local billboard = Instance.new("BillboardGui")
				billboard.Name = "QODKillerLabel"
				billboard.Size = UDim2.new(0, 90, 0, 24)
				billboard.StudsOffset = Vector3.new(0, 2.2, 0)
				billboard.AlwaysOnTop = true
				billboard.Adornee = head
				billboard.Parent = head
				local text = Instance.new("TextLabel")
				text.Size = UDim2.new(1, 0, 1, 0)
				text.BackgroundTransparency = 1
				text.Text = "Killer"
				text.Font = UIFont
				text.TextSize = 16
				text.TextColor3 = Color3.fromRGB(255, 70, 70)
				text.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
				text.TextStrokeTransparency = 0.2
				text.Parent = billboard
				killerLabels[targetPlayer] = billboard
			end
		else
			ClearKillerLabel(targetPlayer)
		end
	end
	for targetPlayer in pairs(killerLabels) do
		if not targetPlayer.Parent then ClearKillerLabel(targetPlayer) end
	end
end)

-- Minimize: shrinks to just the header, matching Serenity's own minimize behavior. Every
-- row lives inside ContentScroll now, so hiding that one frame is enough.
local minimized = false
local function ToggleMinimize()
	minimized = not minimized
	HeaderDivider.Visible = not minimized
	ContentScroll.Visible = not minimized
	PanelFrame.Size = UDim2.new(0, 280, 0, minimized and MINI_HEIGHT or FULL_HEIGHT)
	MinimizeButton.Text = minimized and "+" or "-"
end
MinimizeButton.MouseButton1Click:Connect(ToggleMinimize)

CloseButton.MouseButton1Click:Connect(function()
	SetAudioMuted(false)
	ClearAllKillerLabels()
	ScreenGui:Destroy()
end)

-- Dragging
local dragging = false
local dragStart = nil
local startPos = nil
PanelFrame.InputBegan:Connect(function(input)
	if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
	dragging = true
	dragStart = input.Position
	startPos = PanelFrame.Position
	input.Changed:Connect(function()
		if input.UserInputState == Enum.UserInputState.End then
			dragging = false
		end
	end)
end)
UserInputService.InputChanged:Connect(function(input)
	if not dragging or (input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch) then return end
	local delta = input.Position - dragStart
	PanelFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end)

	if not abilityEvent or not abilityEvent:IsA("RemoteEvent") then return end
	if pcall(function() abilityEvent:FireServer(3) end) then
		revealState.LastFire = os.clock()
	end
end)

-- Live Coins/Wins readout, plus session gain (how much earned since this was executed).
local statsState = {LastUpdate = 0, LastCoins = nil, SessionCoins = 0, LastWins = nil, SessionWins = 0}
RunService.Heartbeat:Connect(function()
	if not ScreenGui.Parent then return end
	if os.clock() - statsState.LastUpdate < 0.2 then return end
	statsState.LastUpdate = os.clock()
	local leaderstats = Player:FindFirstChild("leaderstats")
	local coins = leaderstats and leaderstats:FindFirstChild("Coins")
	local wins = leaderstats and leaderstats:FindFirstChild("Wins")
	if not coins and not wins then
		StatsLabel.Text = "Coins: N/A    Wins: N/A"
		return
	end
	if coins then
		local currentCoins = math.floor(tonumber(coins.Value) or 0)
		if statsState.LastCoins ~= nil and currentCoins > statsState.LastCoins then
			statsState.SessionCoins = statsState.SessionCoins + (currentCoins - statsState.LastCoins)
		end
		statsState.LastCoins = currentCoins
	end
	if wins then
		local currentWins = math.floor(tonumber(wins.Value) or 0)
		if statsState.LastWins ~= nil and currentWins > statsState.LastWins then
			statsState.SessionWins = statsState.SessionWins + (currentWins - statsState.LastWins)
		end
		statsState.LastWins = currentWins
	end
	StatsLabel.Text = string.format(
		"Coins: %s (+%d)    Wins: %s (+%d)",
		coins and tostring(coins.Value) or "N/A", statsState.SessionCoins,
		wins and tostring(wins.Value) or "N/A", statsState.SessionWins
	)
end)

-- Minimize: shrinks to just the header, matching Serenity's own minimize behavior.
local minimized = false
local function ToggleMinimize()
	minimized = not minimized
	HeaderDivider.Visible = not minimized
	StatsLabel.Visible = not minimized
	for _, child in ipairs(PanelFrame:GetChildren()) do
		if child:IsA("Frame") and child.Name:match("Row$") then
			child.Visible = not minimized
		end
	end
	PanelFrame.Size = UDim2.new(0, 280, 0, minimized and MINI_HEIGHT or FULL_HEIGHT)
	MinimizeButton.Text = minimized and "+" or "-"
end
MinimizeButton.MouseButton1Click:Connect(ToggleMinimize)


-- Mute Audio: mutes every Sound found under the places the old hub watched (emote, character,
-- player gui, camera, SoundService, workspace), tracking original volumes to restore on toggle.
local mutedSounds = {}
local audioConnections = {}
local muteAudioEnabled = false

local function MuteQuietOrDieSound(sound)
	if not muteAudioEnabled or not sound or not sound:IsA("Sound") then return end
	if mutedSounds[sound] == nil then mutedSounds[sound] = sound.Volume end
	sound.Volume = 0
end

local function SetAudioMuted(enabled)
	for _, connection in ipairs(audioConnections) do connection:Disconnect() end
	audioConnections = {}
	if not enabled then
		for sound, originalVolume in pairs(mutedSounds) do
			if sound and sound.Parent then sound.Volume = originalVolume end
		end
		mutedSounds = {}
		return
	end

	local pendingSounds = {}
	local processing = false
	local function queueSound(sound)
		if sound and sound:IsA("Sound") then table.insert(pendingSounds, sound) end
		if processing then return end
		processing = true
		task.spawn(function()
			while #pendingSounds > 0 and muteAudioEnabled do
				for _ = 1, 8 do
					local nextSound = table.remove(pendingSounds, 1)
					if not nextSound then break end
					MuteQuietOrDieSound(nextSound)
				end
				task.wait()
			end
			processing = false
		end)
	end
	local function watchRoot(rootObject, scanExisting)
		if not rootObject then return end
		if rootObject:IsA("Sound") then queueSound(rootObject) end
		if scanExisting then
			task.spawn(function()
				local stack = rootObject:GetChildren()
				local scanned = 0
				while #stack > 0 and muteAudioEnabled do
					local object = table.remove(stack)
					if not muteAudioEnabled then break end
					if object:IsA("Sound") then queueSound(object) end
					for _, child in ipairs(object:GetChildren()) do
						table.insert(stack, child)
					end
					scanned = scanned + 1
					if scanned % 60 == 0 then task.wait() end
				end
			end)
		end
		table.insert(audioConnections, rootObject.DescendantAdded:Connect(function(object)
			if object:IsA("Sound") then queueSound(object) end
		end))
	end

	local roots = {Player:FindFirstChild("Emote"), Player.Character, Player:FindFirstChildOfClass("PlayerGui"), workspace.CurrentCamera, SoundService, workspace}
	for _, rootObject in ipairs(roots) do
		watchRoot(rootObject, true)
	end
	table.insert(audioConnections, Player.ChildAdded:Connect(function(object)
		if object.Name == "Emote" then watchRoot(object, true) end
	end))
	table.insert(audioConnections, Player.CharacterAdded:Connect(function(character)
		watchRoot(character, true)
	end))
end

MuteToggle.MouseButton1Click:Connect(function()
	muteAudioEnabled = not muteAudioEnabled
	MuteToggle.Text = muteAudioEnabled and "On" or "Off"
	SetAudioMuted(muteAudioEnabled)
end)

-- Auto Revive: fires every nearby, enabled RevivePrompt using fireproximityprompt.
local reviveState = {Enabled = false, LastCheck = 0, Triggered = {}}
ReviveToggle.MouseButton1Click:Connect(function()
	reviveState.Enabled = not reviveState.Enabled
	reviveState.Triggered = {}
	ReviveToggle.Text = reviveState.Enabled and "On" or "Off"
end)

RunService.Heartbeat:Connect(function()
	if not ScreenGui.Parent then return end
	if not reviveState.Enabled or os.clock() - reviveState.LastCheck < 0.01 then return end
	reviveState.LastCheck = os.clock()
	local playersFolder = workspace:FindFirstChild("PlayersFolder")
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not playersFolder or not humanoid or humanoid.Health <= 0 then return end

	local now = os.clock()
	for prompt, lastTriggered in pairs(reviveState.Triggered) do
		if not prompt.Parent or now - lastTriggered > 0.5 then reviveState.Triggered[prompt] = nil end
	end
	for _, targetCharacter in ipairs(playersFolder:GetChildren()) do
		if targetCharacter ~= character and targetCharacter:IsA("Model") then
			local targetRoot = targetCharacter:FindFirstChild("HumanoidRootPart")
			local attachment = (targetRoot and targetRoot:FindFirstChild("ReviveAttachment")) or targetCharacter:FindFirstChild("ReviveAttachment", true)
			local prompt = attachment and attachment:FindFirstChild("RevivePrompt", true)
			if prompt and prompt:IsA("ProximityPrompt") and prompt.Enabled
				and (not reviveState.Triggered[prompt] or now - reviveState.Triggered[prompt] >= 0.02) then
				reviveState.Triggered[prompt] = now
				if type(fireproximityprompt) == "function" then
					local originalHoldDuration = prompt.HoldDuration
					local originalRequiresLineOfSight = prompt.RequiresLineOfSight
					pcall(function()
						prompt.HoldDuration = 0
						prompt.RequiresLineOfSight = false
					end)
					pcall(function() fireproximityprompt(prompt) end)
					task.delay(0.05, function()
						if prompt and prompt.Parent then
							pcall(function()
								prompt.HoldDuration = originalHoldDuration
								prompt.RequiresLineOfSight = originalRequiresLineOfSight
							end)
						end
					end)
				end
			end
		end
	end
end)

-- Auto Event: walks toward the nearest EventItem in the EventSpawns folder, skipping any
-- item that's taken too long to reach (probably unreachable/already claimed).
local eventState = {Enabled = false, LastMove = 0, Current = nil, Started = 0, Skipped = {}}
EventToggle.MouseButton1Click:Connect(function()
	eventState.Enabled = not eventState.Enabled
	eventState.Current = nil
	eventState.Started = 0
	EventToggle.Text = eventState.Enabled and "On" or "Off"
end)

RunService.Heartbeat:Connect(function()
	if not ScreenGui.Parent then return end
	if not eventState.Enabled then return end
	if IsQuietOrDieKiller() then eventState.Current = nil return end
	if os.clock() - eventState.LastMove < 0.06 then return end
	eventState.LastMove = os.clock()
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local root = character and character:FindFirstChild("HumanoidRootPart")
	local eventFolder = workspace:FindFirstChild("EventSpawns")
	if not humanoid or humanoid.Health <= 0 or not root or not eventFolder then return end

	local now = os.clock()
	for item, expiresAt in pairs(eventState.Skipped) do
		if not item.Parent or expiresAt <= now then eventState.Skipped[item] = nil end
	end

	local target = eventState.Current
	if not target or not target.Parent or eventState.Skipped[target] then
		target = nil
		local closestDistance = math.huge
		for _, item in ipairs(eventFolder:GetChildren()) do
			if item.Name:match("^EventItem%d+$") and not eventState.Skipped[item] then
				local part = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart", true)
				if part then
					local distance = (root.Position - part.Position).Magnitude
					if distance < closestDistance then
						closestDistance = distance
						target = item
					end
				end
			end
		end
		eventState.Current = target
		eventState.Started = now
	elseif now - eventState.Started > 1.5 then
		eventState.Skipped[target] = now + 2
		eventState.Current = nil
		return
	end

	if target and target.Parent then
		local targetPart = target:IsA("BasePart") and target or target:FindFirstChildWhichIsA("BasePart", true)
		if targetPart then
			SetRootUpright(root, root.CFrame, targetPart.Position + Vector3.new(0, -3.5, 0))
		end
	end
end)


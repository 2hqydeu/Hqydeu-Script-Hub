local UIFont = Enum.Font.Ubuntu
-- Reads the main hub's Settings-tab Transparency slider (if it's been set) so every
-- row here matches, instead of always defaulting to 50%.
local GameRowTransparency = ((type(getgenv) == "function" and tonumber(getgenv().Serenity_RowTransparency)) or 50) / 100

-- Sets a root's position while keeping it upright (zeroing pitch/roll, keeping the current
-- facing direction) -- used by Auto Farm's Safe Place drop and Auto Event's approach.
local function SetRootUpright(root, currentCFrame, targetPosition)
	local _, yRotation = currentCFrame:ToOrientation()
	root.CFrame = CFrame.new(targetPosition) * CFrame.Angles(0, yRotation, 0)
end

local function IsQuietOrDieSurvivor()
	local playerGui = Player:FindFirstChildOfClass("PlayerGui")
	local inGameGui = playerGui and playerGui:FindFirstChild("InGameGui")
	local playerFrame = inGameGui and inGameGui:FindFirstChild("PlayerFrameGame")
	return playerFrame ~= nil and playerFrame.Visible and Player:FindFirstChild("InHit") == nil
end

-- Generalized so ESP can check ANY player, not just the local one -- the killer-frame GUI
-- check only ever applies to the local player (other players' PlayerGuis aren't readable).
local function IsPlayerKiller(targetPlayer)
	targetPlayer = targetPlayer or Player
	local killerFolder = workspace:FindFirstChild("KillerFolder")
	if killerFolder and killerFolder:FindFirstChild(targetPlayer.Name) then return true end
	local function containerSaysKiller(container)
		if not container then return false end
		for _, attributeName in ipairs({"Role", "CurrentRole", "RoundRole"}) do
			local value = container:GetAttribute(attributeName)
			if type(value) == "string" and value:lower():find("killer", 1, true) then return true end
		end
		for _, attributeName in ipairs({"IsKiller", "Killer"}) do
			if container:GetAttribute(attributeName) == true then return true end
		end
		for _, valueName in ipairs({"Role", "CurrentRole", "RoundRole"}) do
			local valueObject = container:FindFirstChild(valueName)
			if valueObject and valueObject:IsA("StringValue") and valueObject.Value:lower():find("killer", 1, true) then return true end
		end
		for _, valueName in ipairs({"IsKiller", "Killer"}) do
			local valueObject = container:FindFirstChild(valueName)
			if valueObject and valueObject:IsA("BoolValue") and valueObject.Value then return true end
		end
		return false
	end
	if containerSaysKiller(targetPlayer) or containerSaysKiller(targetPlayer.Character) then return true end
	if targetPlayer.Team and targetPlayer.Team.Name:lower():find("killer", 1, true) then return true end
	if targetPlayer == Player then
		local playerGui = Player:FindFirstChildOfClass("PlayerGui")
		local inGameGui = playerGui and playerGui:FindFirstChild("InGameGui")
		if inGameGui then
			for _, frameName in ipairs({"KillerFrameGame2", "KillerFrameGame", "KillerFrame", "KillerGui"}) do
				local frame = inGameGui:FindFirstChild(frameName, true)
				if frame and frame:IsA("GuiObject") and frame.Visible then return true end
			end
		end
	end
	return false
end

local function IsQuietOrDieKiller()
	return IsPlayerKiller(Player)
end


local function getRoot()
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if not humanoid or humanoid.Health <= 0 or not root then return nil end
	return root
end

local function getObjectPart(object)
	if not object then return nil end
	if object:IsA("BasePart") then return object end
	if object:IsA("Model") then
		return object.PrimaryPart or object:FindFirstChildWhichIsA("BasePart", true)
	end
	return object:FindFirstChildWhichIsA("BasePart", true)
end

local function getObjectCFrame(object)
	local part = getObjectPart(object)
	if part then return part.CFrame end
	if object and object:IsA("Model") then return object:GetPivot() end
	return nil
end

local function getShapeFolder()
	return workspace:FindFirstChild("Parts")
end

local function getSellerObject()
	local map = workspace:FindFirstChild("Map")
	local buildingParts = map and map:FindFirstChild("BuildingParts")
	local seller = buildingParts and buildingParts:FindFirstChild("Seller")
	if seller and seller:FindFirstChild("Sell") then
		return seller:FindFirstChild("Sell")
	end
	local looseParts = workspace:FindFirstChild("BuildingParts")
	local looseSeller = looseParts and looseParts:FindFirstChild("Seller")
	return looseSeller and looseSeller:FindFirstChild("Sell")
end

local function getQuantifyNetwork()
	local remotes = ReplicatedStorage:FindFirstChild("Remotes")
	return remotes and remotes:FindFirstChild("Network")
end

local function isCarryableShape(object)
	if not object or not object.Parent then return false end
	if object:GetAttribute("sold") or object:GetAttribute("destroyed") then return false end
	if object:IsA("Model") then
		if object:GetAttribute("type") == "part" then return true end
		local ok, tags = pcall(function() return CollectionService:GetTags(object) end)
		if ok and table.find(tags, "carryable") then return true end
	end
	return false
end

local function getInteractable(object)
	if not object then return nil end
	local clickDetector = object:FindFirstChildWhichIsA("ClickDetector", true)
	if clickDetector then return clickDetector end
	local prompt = object:FindFirstChildWhichIsA("ProximityPrompt", true)
	if prompt then return prompt end
	return nil
end

local function cameraClickPart(part)
	if not part or not workspace.CurrentCamera then return false end
	local camera = workspace.CurrentCamera
	local oldType = camera.CameraType
	local oldCFrame = camera.CFrame
	local oldFocus = camera.Focus
	local lookPosition = part.Position
	camera.CameraType = Enum.CameraType.Scriptable
	camera.CFrame = CFrame.new(lookPosition + Vector3.new(0, 3, 8), lookPosition)
	camera.Focus = CFrame.new(lookPosition)
	RunService.RenderStepped:Wait()
	local screenPosition, onScreen = camera:WorldToViewportPoint(lookPosition)
	if onScreen then
		pcall(function()
			VirtualInputManager:SendMouseButtonEvent(screenPosition.X, screenPosition.Y, 0, true, game, 0)
			VirtualInputManager:SendMouseButtonEvent(screenPosition.X, screenPosition.Y, 0, false, game, 0)
		end)
	end
	camera.CameraType = oldType
	camera.CFrame = oldCFrame
	camera.Focus = oldFocus
	return onScreen
end

local function interactWithObject(object)
	if not object or not object.Parent then return false end
	local interactable = getInteractable(object)
	if interactable and interactable:IsA("ClickDetector") and type(fireclickdetector) == "function" then
		local ok = pcall(function() fireclickdetector(interactable) end)
		if ok then return true end
	end
	if interactable and interactable:IsA("ProximityPrompt") and type(fireproximityprompt) == "function" then
		local ok = pcall(function() fireproximityprompt(interactable) end)
		if ok then return true end
	end

	local part = getObjectPart(object)
	local root = getRoot()
	if part and root then
		local originalCFrame = root.CFrame
		root.CFrame = part.CFrame + Vector3.new(0, 2.5, 0)
		root.AssemblyLinearVelocity = Vector3.zero
		root.AssemblyAngularVelocity = Vector3.zero
		task.wait(0.04)
		local clicked = cameraClickPart(part)
		task.wait(0.03)
		if root and root.Parent then
			root.CFrame = originalCFrame
			root.AssemblyLinearVelocity = Vector3.zero
			root.AssemblyAngularVelocity = Vector3.zero
		end
		return clicked
	end
	return false
end

local function moveRootNearPart(root, part, height)
	if not root or not root.Parent or not part then return false end
	root.CFrame = part.CFrame + Vector3.new(0, height or 2.5, 0)
	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero
	return true
end

local function pivotObjectTo(object, cframe)
	if not object or not object.Parent or not cframe then return false end
	if object:IsA("Model") then
		if not object.PrimaryPart then
			local part = object:FindFirstChildWhichIsA("BasePart", true)
			if part then
				pcall(function() object.PrimaryPart = part end)
			end
		end
		local ok = pcall(function() object:PivotTo(cframe) end)
		if ok then return true end
	end
	local part = getObjectPart(object)
	if part then
		local ok = pcall(function()
			part.CFrame = cframe
			part.AssemblyLinearVelocity = Vector3.zero
			part.AssemblyAngularVelocity = Vector3.zero
		end)
		return ok
	end
	return false
end

local function touchSeller(shape, sellerPart)
	if not shape or not sellerPart or type(firetouchinterest) ~= "function" then return end
	local parts = {}
	if shape:IsA("BasePart") then
		table.insert(parts, shape)
	else
		for _, part in ipairs(shape:GetDescendants()) do
			if part:IsA("BasePart") then
				table.insert(parts, part)
			end
		end
	end
	for _, part in ipairs(parts) do
		pcall(function()
			firetouchinterest(part, sellerPart, 0)
			task.wait()
			firetouchinterest(part, sellerPart, 1)
		end)
	end
end

local function triggerObjectClick(object)
	if not object or not object.Parent then return false end
	local interactable = getInteractable(object)
	if interactable and interactable:IsA("ClickDetector") and type(fireclickdetector) == "function" then
		local ok = pcall(function() fireclickdetector(interactable) end)
		if ok then return true end
	end
	if interactable and interactable:IsA("ProximityPrompt") and type(fireproximityprompt) == "function" then
		local ok = pcall(function() fireproximityprompt(interactable) end)
		if ok then return true end
	end
	local part = getObjectPart(object)
	return part and cameraClickPart(part) or false
end

local function pickUpAndSellShape(shape, sellerObject)
	local root = getRoot()
	local shapePart = getObjectPart(shape)
	local sellerPart = getObjectPart(sellerObject)
	local network = getQuantifyNetwork()
	if not root or not shapePart or not sellerPart or not network then return false end

	local originalCFrame = root.CFrame
	moveRootNearPart(root, shapePart, 2.6)
	for _ = 1, 5 do
		pcall(function() network:FireServer("pickup", shape) end)
		task.wait(0.04)
	end

	moveRootNearPart(root, sellerPart, 2.8)
	local targetCFrame = sellerPart.CFrame + Vector3.new(0, math.max(2, sellerPart.Size.Y * 0.5 + 1.5), 0)
	local sold = false
	for _ = 1, 18 do
		if not shape.Parent or shape:GetAttribute("sold") then
			sold = true
			break
		end
		pivotObjectTo(shape, targetCFrame)
		pcall(function() network:FireServer("general", shape) end)
		pcall(function() network:FireServer("general", shape, targetCFrame) end)
		touchSeller(shape, sellerPart)
		task.wait(0.05)
	end
	pcall(function() network:FireServer("drop", shape) end)
	task.wait(0.15)
	if not shape.Parent or shape:GetAttribute("sold") then
		sold = true
	end
	if root and root.Parent then
		root.CFrame = originalCFrame
		root.AssemblyLinearVelocity = Vector3.zero
		root.AssemblyAngularVelocity = Vector3.zero
	end
	return sold
end

local function addShapeCandidate(candidates, seen, object)
	if not object or seen[object] then return end
	if object:IsA("BasePart") and object.Parent and object.Parent:IsA("Model") then
		object = object.Parent
	end
	if seen[object] then return end
	if not getObjectPart(object) then return end
	if not isCarryableShape(object) then return end
	seen[object] = true
	table.insert(candidates, object)
end

local function getShapeName(object)
	return tostring((object and object:GetAttribute("name")) or (object and object.Name) or "Shape")
end

local function getShapeValue(object)
	local value = object and object:GetAttribute("value")
	if typeof(value) == "number" then return value end
	return 0
end

local function shapePassesFilter(object)
	local filter = ShapeFilters[HubState.Quantify.ShapeFilterIndex] or "Any"
	if filter == "Any" then return true end
	local name = string.upper(getShapeName(object))
	return string.find(name, string.upper(filter), 1, true) ~= nil
end

local function getShapeCandidates()
	local partsFolder = getShapeFolder()
	if not partsFolder then return {} end
	local candidates = {}
	local seen = {}
	for _, shapeFolder in ipairs(partsFolder:GetChildren()) do
		local namedShape = shapeFolder:FindFirstChild(shapeFolder.Name)
		if namedShape then
			addShapeCandidate(candidates, seen, namedShape)
		end
		for _, child in ipairs(shapeFolder:GetChildren()) do
			if child ~= namedShape and (child:IsA("Model") or child:IsA("BasePart")) then
				addShapeCandidate(candidates, seen, child)
			end
		end
	end
	for i = #candidates, 1, -1 do
		if not shapePassesFilter(candidates[i]) then
			table.remove(candidates, i)
		end
	end
	local root = getRoot()
	if root then
		table.sort(candidates, function(a, b)
			local aCFrame = getObjectCFrame(a)
			local bCFrame = getObjectCFrame(b)
			local aDistance = aCFrame and (root.Position - aCFrame.Position).Magnitude or math.huge
			local bDistance = bCFrame and (root.Position - bCFrame.Position).Magnitude or math.huge
			if ShapeModes[HubState.Quantify.ShapeModeIndex] == "Value" then
				local aValue = getShapeValue(a)
				local bValue = getShapeValue(b)
				if aValue ~= bValue then
					return aValue > bValue
				end
			end
			return aDistance < bDistance
		end)
	end
	return candidates
end

local function runAutoShapeStep()
	if HubState.Quantify.AutoShapesBusy then return end
	HubState.Quantify.AutoShapesBusy = true
	local sellerObject = getSellerObject()
	if not sellerObject or not getObjectPart(sellerObject) then
		setShapesStatus("Missing Seller/Sell")
		HubState.Quantify.AutoShapesBusy = false
		return
	end
	if not getQuantifyNetwork() then
		setShapesStatus("Missing Network remote")
		HubState.Quantify.AutoShapesBusy = false
		return
	end

	local candidates = getShapeCandidates()
	if #candidates == 0 then
		setShapesStatus("No shapes found")
		HubState.Quantify.AutoShapesBusy = false
		return
	end

	local shape = candidates[1]
	setShapesStatus("Picking " .. tostring(shape.Name))
	local sold = pickUpAndSellShape(shape, sellerObject)
	if sold then
		setShapesStatus("Sold " .. tostring(shape.Name))
		task.wait(0.12)
	else
		setShapesStatus("Sell failed")
		task.wait(0.25)
	end
	HubState.Quantify.AutoShapesBusy = false
end


local function formatNumber(value)
	value = tonumber(value) or 0
	if math.abs(value) >= 1000000000 then
		return string.format("%.1fB", value / 1000000000)
	elseif math.abs(value) >= 1000000 then
		return string.format("%.1fM", value / 1000000)
	elseif math.abs(value) >= 1000 then
		return string.format("%.1fK", value / 1000)
	end
	return tostring(math.floor(value))
end

local function getQuota()
	local map = workspace:FindFirstChild("Map")
	if map then
		for _, attributeName in ipairs({ "Quota", "quota", "Goal", "CashGoal" }) do
			local value = map:GetAttribute(attributeName)
			if typeof(value) == "number" then return value end
		end
	end
	local sharedFolder = ReplicatedStorage:FindFirstChild("Shared")
	local gameModule = sharedFolder and sharedFolder:FindFirstChild("Game")
	if gameModule and gameModule:IsA("ModuleScript") then
		local ok, gameData = pcall(require, gameModule)
		if ok and gameData and gameData.data then
			local quota = gameData.data.quota
			if typeof(quota) == "number" then return quota end
		end
	end
	return nil
end

local function updateTracker()
	local cash = Player:GetAttribute("Cash")
	if typeof(cash) ~= "number" then cash = 0 end
	local quota = getQuota()
	if quota and quota > 0 then
		trackerText.Text = formatNumber(cash) .. " / " .. formatNumber(quota)
		trackerText.TextColor3 = cash >= quota and Color3.fromRGB(70, 255, 145) or AccentColor
	else
		trackerText.Text = "$" .. formatNumber(cash)
		trackerText.TextColor3 = AccentColor
	end
end


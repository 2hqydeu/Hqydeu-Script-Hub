local function refreshShapeESP()
	if not HubState.Quantify.ShapeESPEnabled then
		clearAdornments(HubState.Quantify.ShapeESPObjects)
		return
	end
	local current = {}
	for _, shape in ipairs(getShapeCandidates()) do
		current[shape] = true
		if not HubState.Quantify.ShapeESPObjects[shape] then
			local part = getObjectPart(shape)
			if part then
				local value = getShapeValue(shape)
				local text = getShapeName(shape)
				if value > 0 then text = text .. " $" .. formatNumber(value) end
				HubState.Quantify.ShapeESPObjects[shape] = {
					Highlight = makeHighlight(shape, AccentColor),
					Label = makeBillboard(shape, part, text, AccentColor),
				}
			end
		end
	end
	for shape, adornments in pairs(HubState.Quantify.ShapeESPObjects) do
		if not current[shape] or not shape.Parent or shape:GetAttribute("sold") or shape:GetAttribute("destroyed") then
			if adornments.Highlight then adornments.Highlight:Destroy() end
			if adornments.Label then adornments.Label:Destroy() end
			HubState.Quantify.ShapeESPObjects[shape] = nil
		end
	end
end

local function getBuildAssistColor(object)
	local name = string.lower(object.Name)
	if string.find(name, "seller", 1, true) then return Color3.fromRGB(70, 255, 145), "Seller" end
	if string.find(name, "conveyor", 1, true) then return Color3.fromRGB(0, 210, 255), "Conveyor" end
	if string.find(name, "dropper", 1, true) then return Color3.fromRGB(255, 190, 70), "Dropper" end
	if string.find(name, "crafter", 1, true) then return Color3.fromRGB(190, 130, 255), "Crafter" end
	return nil, nil
end

local function refreshBuildAssist()
	if not HubState.Quantify.BuildAssistEnabled then
		clearAdornments(HubState.Quantify.BuildAssistObjects)
		return
	end
	local current = {}
	local folders = {}
	local map = workspace:FindFirstChild("Map")
	if map and map:FindFirstChild("BuildingParts") then table.insert(folders, map.BuildingParts) end
	if workspace:FindFirstChild("BuildingParts") then table.insert(folders, workspace.BuildingParts) end
	for _, folder in ipairs(folders) do
		for _, object in ipairs(folder:GetChildren()) do
			local color, labelText = getBuildAssistColor(object)
			local part = color and getObjectPart(object)
			if part then
				current[object] = true
				if not HubState.Quantify.BuildAssistObjects[object] then
					HubState.Quantify.BuildAssistObjects[object] = {
						Highlight = makeHighlight(object, color),
						Label = makeBillboard(object, part, labelText, color),
					}
				end
			end
		end
	end
	for object, adornments in pairs(HubState.Quantify.BuildAssistObjects) do
		if not current[object] or not object.Parent then
			if adornments.Highlight then adornments.Highlight:Destroy() end
			if adornments.Label then adornments.Label:Destroy() end
			HubState.Quantify.BuildAssistObjects[object] = nil
		end
	end
end


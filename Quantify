local function getRoot()
	local character = Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if not humanoid or humanoid.Health <= 0 or not root then return nil end
	return root
end

local function getObjectPart(object)
	if not object then return nil end
	if object:IsA("BasePart") then return object end
	if object:IsA("Model") then
		return object.PrimaryPart or object:FindFirstChildWhichIsA("BasePart", true)
	end
	return object:FindFirstChildWhichIsA("BasePart", true)
end

local function getObjectCFrame(object)
	local part = getObjectPart(object)
	if part then return part.CFrame end
	if object and object:IsA("Model") then return object:GetPivot() end
	return nil
end

local function getShapeFolder()
	return workspace:FindFirstChild("Parts")
end

local function getSellerObject()
	local map = workspace:FindFirstChild("Map")
	local buildingParts = map and map:FindFirstChild("BuildingParts")
	local seller = buildingParts and buildingParts:FindFirstChild("Seller")
	return seller and seller:FindFirstChild("Sell")
end

local function getInteractable(object)
	if not object then return nil end
	local clickDetector = object:FindFirstChildWhichIsA("ClickDetector", true)
	if clickDetector then return clickDetector end
	local prompt = object:FindFirstChildWhichIsA("ProximityPrompt", true)
	if prompt then return prompt end
	return nil
end

local function cameraClickPart(part)
	if not part or not workspace.CurrentCamera then return false end
	local camera = workspace.CurrentCamera
	local oldType = camera.CameraType
	local oldCFrame = camera.CFrame
	local oldFocus = camera.Focus
	local lookPosition = part.Position
	camera.CameraType = Enum.CameraType.Scriptable
	camera.CFrame = CFrame.new(lookPosition + Vector3.new(0, 3, 8), lookPosition)
	camera.Focus = CFrame.new(lookPosition)
	RunService.RenderStepped:Wait()
	local screenPosition, onScreen = camera:WorldToViewportPoint(lookPosition)
	if onScreen then
		pcall(function()
			VirtualInputManager:SendMouseButtonEvent(screenPosition.X, screenPosition.Y, 0, true, game, 0)
			VirtualInputManager:SendMouseButtonEvent(screenPosition.X, screenPosition.Y, 0, false, game, 0)
		end)
	end
	camera.CameraType = oldType
	camera.CFrame = oldCFrame
	camera.Focus = oldFocus
	return onScreen
end

local function interactWithObject(object)
	if not object or not object.Parent then return false end
	local interactable = getInteractable(object)
	if interactable and interactable:IsA("ClickDetector") and type(fireclickdetector) == "function" then
		local ok = pcall(function() fireclickdetector(interactable) end)
		if ok then return true end
	end
	if interactable and interactable:IsA("ProximityPrompt") and type(fireproximityprompt) == "function" then
		local ok = pcall(function() fireproximityprompt(interactable) end)
		if ok then return true end
	end

	local part = getObjectPart(object)
	local root = getRoot()
	if part and root then
		local originalCFrame = root.CFrame
		root.CFrame = part.CFrame + Vector3.new(0, 2.5, 0)
		root.AssemblyLinearVelocity = Vector3.zero
		root.AssemblyAngularVelocity = Vector3.zero
		task.wait(0.04)
		local clicked = cameraClickPart(part)
		task.wait(0.03)
		if root and root.Parent then
			root.CFrame = originalCFrame
			root.AssemblyLinearVelocity = Vector3.zero
			root.AssemblyAngularVelocity = Vector3.zero
		end
		return clicked
	end
	return false
end

local function addShapeCandidate(candidates, seen, object)
	if not object or seen[object] then return end
	if not getObjectPart(object) then return end
	seen[object] = true
	table.insert(candidates, object)
end

local function getShapeCandidates()
	local partsFolder = getShapeFolder()
	if not partsFolder then return {} end
	local candidates = {}
	local seen = {}
	for _, shapeFolder in ipairs(partsFolder:GetChildren()) do
		local namedShape = shapeFolder:FindFirstChild(shapeFolder.Name)
		if namedShape then
			addShapeCandidate(candidates, seen, namedShape)
		end
		if getInteractable(shapeFolder) then
			addShapeCandidate(candidates, seen, shapeFolder)
		end
		for _, child in ipairs(shapeFolder:GetChildren()) do
			if child ~= namedShape and (getInteractable(child) or child:IsA("BasePart") or child:IsA("Model")) then
				addShapeCandidate(candidates, seen, child)
			end
		end
	end
	local root = getRoot()
	if root then
		table.sort(candidates, function(a, b)
			local aCFrame = getObjectCFrame(a)
			local bCFrame = getObjectCFrame(b)
			local aDistance = aCFrame and (root.Position - aCFrame.Position).Magnitude or math.huge
			local bDistance = bCFrame and (root.Position - bCFrame.Position).Magnitude or math.huge
			return aDistance < bDistance
		end)
	end
	return candidates
end

local function runAutoShapeStep()
	if HubState.Quantify.AutoShapesBusy then return end
	HubState.Quantify.AutoShapesBusy = true
	local sellerObject = getSellerObject()
	if not sellerObject or not getObjectPart(sellerObject) then
		setShapesStatus("Missing Seller/Sell")
		HubState.Quantify.AutoShapesBusy = false
		return
	end

	local candidates = getShapeCandidates()
	if #candidates == 0 then
		setShapesStatus("No shapes found")
		HubState.Quantify.AutoShapesBusy = false
		return
	end

	local shape = candidates[1]
	setShapesStatus("Picking " .. tostring(shape.Name))
	local picked = interactWithObject(shape)
	task.wait(0.16)
	if picked then
		setShapesStatus("Dropping")
		interactWithObject(sellerObject)
		task.wait(0.12)
	else
		setShapesStatus("Click failed")
		task.wait(0.25)
	end
	HubState.Quantify.AutoShapesBusy = false
end

local function setAutoShapes(enabled)
	HubState.Quantify.AutoShapesEnabled = enabled == true
	shapesToggle.Text = HubState.Quantify.AutoShapesEnabled and "On" or "Off"
	shapesTitle.TextColor3 = HubState.Quantify.AutoShapesEnabled and AccentColor or InactiveTextColor()
	setShapesStatus(HubState.Quantify.AutoShapesEnabled and "Scanning" or "Waiting")
end

shapesToggle.MouseButton1Click:Connect(function()
	PlayClick()
	setAutoShapes(not HubState.Quantify.AutoShapesEnabled)
end)

if ThemeObjects.AddFeatureKeybind then
	ThemeObjects.AddFeatureKeybind({
		Name = "Auto Pick Up",
		Storage = "QuantifyAutoShapes",
		Button = shapesBind,
		Get = function() return HubState.Quantify.ShapeKeybind end,
		Set = function(key)
			HubState.Quantify.ShapeKeybind = key
			SaveKeybind("QuantifyAutoShapes", key)
			if shapesBind then shapesBind.Text = KeybindText(key) end
		end,
		Action = function()
			setAutoShapes(not HubState.Quantify.AutoShapesEnabled)
		end,
	})
else
	shapesBind.MouseButton1Click:Connect(function()
		PlayClick()
		shapesBind.Text = "..."
		local connection
		connection = UserInputService.InputBegan:Connect(function(input, processed)
			if processed then return end
			if input.UserInputType == Enum.UserInputType.Keyboard then
				HubState.Quantify.ShapeKeybind = input.KeyCode
				SaveKeybind("QuantifyAutoShapes", input.KeyCode)
				shapesBind.Text = KeybindText(input.KeyCode)
				if connection then connection:Disconnect() end
			end
		end)
	end)
end

HubState.Connections.QuantifyAutoShapes = RunService.Heartbeat:Connect(function()
	if not HubState.Quantify.AutoShapesEnabled then return end
	local now = os.clock()
	if now - (HubState.Quantify.LastShapeAction or 0) < 0.42 then return end
	HubState.Quantify.LastShapeAction = now
	task.spawn(runAutoShapeStep)
end)


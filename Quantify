local function teleportRootTo(cframe)
	local root = getRoot()
	if not root or not cframe then return false end
	if ThemeObjects.SetRootUpright then
		ThemeObjects.SetRootUpright(root, root.CFrame, cframe.Position)
	else
		root.CFrame = cframe
	end
	root.AssemblyLinearVelocity = Vector3.zero
	root.AssemblyAngularVelocity = Vector3.zero
	return true
end


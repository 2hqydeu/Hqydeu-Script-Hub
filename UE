local function CollectToolHitParts(tool)
	local parts = {}
	local seen = {}
	local function add(part)
		if part and part:IsA("BasePart") and not seen[part] then
			seen[part] = true
			table.insert(parts, part)
		end
	end
	for _, weapon in ipairs(CollectActiveWeaponObjects(tool)) do
		add(weapon)
		for _, name in ipairs({"Hitbox", "HitBox", "Blade", "Sword", "Handle", "Tip", "Diamond"}) do
			add(weapon:FindFirstChild(name, true))
		end
		for _, part in ipairs(weapon:GetDescendants()) do
			if #parts >= 24 then break end
			if part:IsA("BasePart") then add(part) end
		end
		if #parts >= 24 then break end
	end
	local character = Player and Player.Character
	if character then
		for _, name in ipairs({"RightHand", "Right Arm", "RightLowerArm", "RightUpperArm", "HumanoidRootPart"}) do
			if #parts >= 28 then break end
			add(character:FindFirstChild(name))
		end
	end
	return parts
end

local function CollectEnemyHitParts(enemy)

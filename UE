	-- Structure Alerts: fading on-screen lines (up to 3 at once) plus a floating "!"
	-- marker over the structure itself for a few seconds.
	local STRUCTURE_ALERT_SLOTS = 3
	local STRUCTURE_ALERT_DURATION = 4.5
	local STRUCTURE_ALERT_FADE = 0.5
	local markerFolder = Instance.new("Folder")
	markerFolder.Name = "UndeadExpeditionStructureMarkers"
	markerFolder.Parent = ScreenGui

	local structureNotificationLabels = {}
	for slotIndex = 1, STRUCTURE_ALERT_SLOTS do
		local label = Instance.new("TextLabel")
		label.Name = "Alert" .. slotIndex
		label.Size = UDim2.new(0, 400, 0, 32)
		label.Position = UDim2.new(0.5, -200, 0, 90 + (slotIndex - 1) * 36)
		label.BackgroundTransparency = 1
		label.Text = ""
		label.RichText = true
		label.Font = Enum.Font.GothamBlack
		label.TextSize = 19
		label.TextColor3 = Color3.fromRGB(255, 255, 255)
		label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
		label.TextStrokeTransparency = 1
		label.TextTransparency = 1
		label.TextXAlignment = Enum.TextXAlignment.Center
		label.TextTruncate = Enum.TextTruncate.AtEnd
		label.ZIndex = 210
		label.Visible = false
		label.Parent = ScreenGui
		structureNotificationLabels[slotIndex] = label
	end

	local structureAlertEntries = {}
	local structureAlertTokenCounter = 0
	local lastStructureName, lastStructureCount = nil, 0

	local function RenderStructureAlerts()
		for slotIndex = 1, STRUCTURE_ALERT_SLOTS do
			local label = structureNotificationLabels[slotIndex]
			local entry = structureAlertEntries[slotIndex]
			if entry then
				local suffix = entry.Count > 1 and (" x" .. tostring(entry.Count)) or ""
				label.Text = ("A <font color=\"#%s\">%s</font> has generated%s"):format(entry.Color:ToHex(), entry.Name, suffix)
				label.Visible = true
				label.TextTransparency = 0
				label.TextStrokeTransparency = 0.16
			else
				label.TextTransparency = 1
				label.TextStrokeTransparency = 1
				label.Visible = false
			end
		end
	end

	local function ExpireStructureAlertEntry(token)
		for slotIndex, entry in ipairs(structureAlertEntries) do
			if entry.Token == token then
				local label = structureNotificationLabels[slotIndex]
				local tween = TweenService:Create(label, TweenInfo.new(STRUCTURE_ALERT_FADE, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
					TextTransparency = 1,
					TextStrokeTransparency = 1,
				})
				tween:Play()
				tween.Completed:Connect(function()
					for slotIndex2, entry2 in ipairs(structureAlertEntries) do
						if entry2.Token == token then
							table.remove(structureAlertEntries, slotIndex2)
							RenderStructureAlerts()
							break
						end
					end
				end)
				return
			end
		end
	end

	PushStructureAlert = function(name, color)
		if not StructureNotificationsEnabled then return end
		for _, entry in ipairs(structureAlertEntries) do
			if entry.Name == name then
				entry.Count = entry.Count + 1
				entry.Color = color
				structureAlertTokenCounter = structureAlertTokenCounter + 1
				entry.Token = structureAlertTokenCounter
				local token = entry.Token
				RenderStructureAlerts()
				task.delay(STRUCTURE_ALERT_DURATION, function() ExpireStructureAlertEntry(token) end)
				return
			end
		end
		structureAlertTokenCounter = structureAlertTokenCounter + 1
		local token = structureAlertTokenCounter
		table.insert(structureAlertEntries, 1, {Name = name, Count = 1, Color = color, Token = token})
		while #structureAlertEntries > STRUCTURE_ALERT_SLOTS do
			table.remove(structureAlertEntries)
		end
		RenderStructureAlerts()
		task.delay(STRUCTURE_ALERT_DURATION, function() ExpireStructureAlertEntry(token) end)
	end

	SetStructureMessage = function(name)
		name = CleanStructureName(name)
		if lastStructureName == name then
			lastStructureCount = lastStructureCount + 1
		else
			lastStructureName = name
			lastStructureCount = 1
		end
		PushStructureAlert(name, GetStructureColor(StructureFilterKey(name)))
	end


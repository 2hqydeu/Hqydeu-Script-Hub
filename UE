local function NormalizeStructureTimerText(text)
	text = tostring(text or ""):gsub("%s+", " "):gsub("^%s+", ""):gsub("%s+$", "")
	local upper = string.upper(text)
	local clock = text:match("%d+:%d%d:%d%d") or text:match("%d+:%d%d")
	if clock and upper:find("GUARANTEED", 1, true) and upper:find("STRUCTURE", 1, true) then
		if upper:find("BOSS", 1, true) then
			return "BOSS: " .. clock
		elseif upper:find("SPECIAL", 1, true) then
			return "SPECIAL: " .. clock
		end
	end
	return nil
end

local function LooksLikeStructureTimerText(text)
	local upper = string.upper(tostring(text or ""))
	return upper:find("GUARANTEED", 1, true) ~= nil
		or upper:find("STRUCTURE", 1, true) ~= nil
		or upper:find("SPECIAL", 1, true) ~= nil
		or upper:find("BOSS", 1, true) ~= nil
		or upper:find("%d+:%d%d") ~= nil
end

local function ReadStructureTimerFromLabel(label)
	if not label or not (label:IsA("TextLabel") or label:IsA("TextButton") or label:IsA("TextBox")) then return nil end
	local ownText = tostring(label.Text or "")
	if not LooksLikeStructureTimerText(ownText) then return nil end
	local text = NormalizeStructureTimerText(ownText)
	if text then return text end
	local parent = label.Parent
	if parent then
		local pieces = {ownText}
		for _, child in ipairs(parent:GetChildren()) do
			if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("TextBox") then
				local childText = tostring(child.Text or "")
				if childText ~= "" then table.insert(pieces, childText) end
			end
		end
		return NormalizeStructureTimerText(table.concat(pieces, " "))
	end
	return nil
end

local function FindStructureTimerText(force)
	local now = os.clock()
	local cachedLabel = state.StructureTimerTextLabel
	if cachedLabel and cachedLabel.Parent and (cachedLabel:IsA("TextLabel") or cachedLabel:IsA("TextButton") or cachedLabel:IsA("TextBox")) then
		local text = ReadStructureTimerFromLabel(cachedLabel)
		if text then
			state.LastStructureTimerText = text
			return text
		end
	end
	local scanInterval = force and STRUCTURE_TIMER_FORCE_SCAN_INTERVAL or STRUCTURE_TIMER_SCAN_INTERVAL
	if now - (state.LastStructureTimerTextScan or 0) < scanInterval then
		return state.LastStructureTimerText
	end
	state.LastStructureTimerTextScan = now
	local playerGui = Player and Player:FindFirstChildOfClass("PlayerGui")
	if playerGui then
		for _, obj in ipairs(playerGui:GetDescendants()) do
			if (obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox")) and (not ScreenGui or not obj:IsDescendantOf(ScreenGui)) then
				local rawText = tostring(obj.Text or "")
				if LooksLikeStructureTimerText(rawText) then
					local text = ReadStructureTimerFromLabel(obj)
					if text then
						state.StructureTimerTextLabel = obj
						state.LastStructureTimerText = text
						return text
					end
				end
			end
		end
	end
	state.StructureTimerTextLabel = nil
	state.LastStructureTimerText = nil
	return nil
end

local function RefreshStructureTimerDisplay(force)

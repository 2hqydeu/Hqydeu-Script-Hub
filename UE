	Instance.new("UICorner", button).CornerRadius = UDim.new(0, 5)
	EnsureControlOutline(button)
	table.insert(filterButtons, {Button = button, Kind = kind, Value = value})
	button.MouseButton1Click:Connect(function()
		PlayClick()
		if kind == "Enemy" then
			state.SelectedEnemyTypes[value] = not (state.SelectedEnemyTypes[value] ~= false)
		else
			state.SelectedLootRarities[value] = not (state.SelectedLootRarities[value] ~= false)
		end
		RefreshButtons()
		UpdateTheme(true)
	end)
end

local function FilterButtonSelected(entry)
	if entry.Kind == "Enemy" then
		return state.SelectedEnemyTypes[entry.Value] ~= false
	end
	return state.SelectedLootRarities[entry.Value] ~= false
end

local function UpdateFilterButtonText()
	for _, entry in ipairs(filterButtons) do
		local selected = FilterButtonSelected(entry)
		entry.Button.Text = (selected and "ESP " or "NO ") .. entry.Value
		entry.Button.BackgroundColor3 = selected and Green or Red
		entry.Button.BackgroundTransparency = 0
	end
end

local function RefreshFilterDock()
	filterDock.Visible = (state.EnemyFiltersOpen or state.LootFiltersOpen) and IsUEPageActive()
	if not filterDock.Visible then return end
	local mode = state.EnemyFiltersOpen and "Enemy" or "Loot"
	local options = mode == "Enemy" and SortedEnemyFilterOptions() or LootRarityOptions
	filterHeader.Text = mode == "Enemy" and "Enemy Filters" or "Loot Filters"
	local signature = mode .. ":" .. table.concat(options, "|")
	if signature ~= lastFilterSignature then
		lastFilterSignature = signature
		filterButtons = {}
		filterScroll:ClearAllChildren()
		CreateFilterLabel(mode == "Enemy" and "Enemies" or "Rarities", 0)
		local y = 16
		for index, option in ipairs(options) do
			local column = (index - 1) % 3
			local row = math.floor((index - 1) / 3)
			CreateFilterButton(mode, option, column * 82, y + row * 23)
		end
		filterScroll.CanvasSize = UDim2.new(0, 0, 0, y + math.ceil(#options / 3) * 23 + 6)
	end
	UpdateFilterButtonText()
	UpdateFilterDockPosition()
end

local function WorkspaceContainer(name)
	local container = workspace:FindFirstChild(name)
	if container then return container end
	return nil
end

local function IsInsideWorkspaceContainer(instance, name)
	local container = WorkspaceContainer(name)
	return container and instance and (instance == container or instance:IsDescendantOf(container))
end

local function ForContainerDescendants(name, callback)
	local container = WorkspaceContainer(name)
	if not container then return false end
	callback(container)
	for _, obj in ipairs(container:GetDescendants()) do
		callback(obj)
	end
	return true
end

local function IsPlayerCharacter(model)
	for _, player in ipairs(Players:GetPlayers()) do
		if player.Character == model then return true end
	end
	return false
end

local enemyNameHints = {
	zombie = true,
	undead = true,
	enemy = true,
	enemies = true,
	monster = true,
	mob = true,
	npc = true,
	walker = true,
	runner = true,
	boss = true,
}

local function HasEnemyNameHint(instance)
	local current = instance
	while current and current ~= workspace do
		local lower = string.lower(current.Name or "")
		for hint in pairs(enemyNameHints) do
			if lower:find(hint, 1, true) then return true end
		end
		current = current.Parent
	end
	return false
end

local function EnemyRoot(model)
	return model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
end

local function IsEnemyModel(model)
	if not model or not model:IsA("Model") then return false end
	if not IsInsideWorkspaceContainer(model, ENEMY_CONTAINER_NAME) then return false end
	if IsPlayerCharacter(model) then return false end
	local humanoid = model:FindFirstChildOfClass("Humanoid")
	if not humanoid or humanoid.Health <= 0 then return false end
	if not EnemyRoot(model) then return false end
	if model:IsDescendantOf(MainFrame) or (ScreenGui and model:IsDescendantOf(ScreenGui)) then return false end
	if HasEnemyNameHint(model) then return true end
	return humanoid.DisplayDistanceType ~= Enum.HumanoidDisplayDistanceType.None
end

local function EnemyDisplayName(model)
	local humanoid = model:FindFirstChildOfClass("Humanoid")
	local name = humanoid and humanoid.DisplayName and humanoid.DisplayName ~= "" and humanoid.DisplayName or model.Name
	return tostring(name or "Enemy")
end

local function EnemyFilterName(model)
	return RegisterEnemyFilterOption(EnemyDisplayName(model))
end

local function EnemyAllowed(model)
	return state.SelectedEnemyTypes[EnemyFilterName(model)] ~= false
end

local RemoveESP

local function RemoveCandidate(model)
	state.CandidateModels[model] = nil
	local connections = state.CandidateConnections[model]
	if connections then
		for _, connection in ipairs(connections) do
			if connection then connection:Disconnect() end
		end
	end
	state.CandidateConnections[model] = nil
end

local function AddCandidate(model)
	if not model or not model:IsA("Model") or state.CandidateModels[model] then return end
	local humanoid = model:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end
	EnemyFilterName(model)
	state.CandidateModels[model] = true
	state.CandidateConnections[model] = {
		humanoid.Died:Connect(function()
			RemoveESP(model)
			RemoveCandidate(model)
		end),
		model.AncestryChanged:Connect(function(_, parent)
			if not parent then
				RemoveESP(model)
				RemoveCandidate(model)
			end
		end),
	}
end

local function AddCandidateFromDescendant(obj)
	if obj:IsA("Humanoid") and obj.Parent and obj.Parent:IsA("Model") then
		AddCandidate(obj.Parent)
	elseif obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") then
		AddCandidate(obj)
	end
end


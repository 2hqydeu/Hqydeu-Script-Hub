	if now - (state.LastFarmTargetScan or 0) < FARM_TARGET_CACHE_INTERVAL then
		return state.CachedFarmTargets or {}
	end
	state.LastFarmTargetScan = now
	local targets = {}
	for _, box in ipairs(CollectLootBoxes()) do
		if BoxType(box) ~= "Hunter Trap" and BoxRoot(box) then
			table.insert(targets, box)
		end

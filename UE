-- Feature row layout: label left, toggle right. Reused for ESP / Auto Farm (not wired up
-- yet) and Full Bright (wired up below).
local function CreateFeatureRow(y, labelText)
	local row = Instance.new("Frame")
	row.Name = labelText:gsub("%s+", "") .. "Row"
	row.Size = UDim2.new(1, -32, 0, 36)
	row.Position = UDim2.new(0, 16, 0, y)
	row.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
	row.BackgroundTransparency = 0.5
	row.BorderSizePixel = 0
	row.Parent = PanelFrame
	Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)

	local label = Instance.new("TextLabel")
	label.Name = "Label"
	label.Size = UDim2.new(0, 140, 1, 0)
	label.Position = UDim2.new(0, 12, 0, 0)
	label.BackgroundTransparency = 1
	label.Text = labelText
	label.Font = UIFont
	label.TextSize = 14
	label.TextColor3 = Color3.fromRGB(255, 255, 255)
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextYAlignment = Enum.TextYAlignment.Center
	label.Parent = row

	local toggle = Instance.new("TextButton")
	toggle.Name = "Toggle"
	toggle.Size = UDim2.new(0, 64, 0, 26)
	toggle.Position = UDim2.new(1, -74, 0.5, -13)
	toggle.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
	toggle.BackgroundTransparency = 0.2
	toggle.BorderSizePixel = 0
	toggle.Text = "Off"
	toggle.Font = UIFont
	toggle.TextSize = 14
	toggle.TextColor3 = Color3.fromRGB(255, 255, 255)
	toggle.Parent = row
	Instance.new("UICorner", toggle).CornerRadius = UDim.new(0, 6)

	return row, toggle
end


local function FireToolCombatRemotes(tool, enemy)
	if not tool or not enemy then return end
	local enemyRoot = EnemyRoot(enemy)
	local humanoid = EnemyHumanoid(enemy)
	for _, weapon in ipairs(CollectActiveWeaponObjects(tool)) do
		local sent = 0
		for _, remote in ipairs(weapon:GetDescendants()) do
			if remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction") then
				sent += 1
				local function send(...)
					if remote:IsA("RemoteEvent") then
						remote:FireServer(...)
					else
						remote:InvokeServer(...)
					end
				end
				pcall(send, enemy)
				pcall(send, enemyRoot)
				pcall(send, humanoid)
				pcall(send, enemy, enemyRoot)
				pcall(send, {Target = enemy, Hit = enemyRoot, Humanoid = humanoid})
				if LooksLikeCombatRemote(remote) then
					pcall(send, enemyRoot and enemyRoot.Position, enemyRoot)
					pcall(send, enemy, enemyRoot and enemyRoot.Position)
				end
				if sent >= 8 then break end
			end
		end
	end
end

local function AttackHunterTrapEnemy(enemy, trapPosition, runId)
	if not IsAutoTrapRunActive(runId) then return false end
	local enemyRoot = EnemyRoot(enemy)
	local playerRoot = PlayerRoot()
	if not enemyRoot or not playerRoot then return false end
	local tool = EquipCombatWeapon()
	local distance = (playerRoot.Position - enemyRoot.Position).Magnitude
	if distance > 14 and os.clock() - (state.LastHunterTrapApproachAt or 0) >= HUNTER_TRAP_APPROACH_INTERVAL then
		state.LastHunterTrapApproachAt = os.clock()
		local approach = enemyRoot.CFrame.LookVector
		if approach.Magnitude < 0.5 then approach = Vector3.new(0, 0, -1) end
		local attackPosition = enemyRoot.Position - approach.Unit * 8 + Vector3.new(0, 2, 0)
		if not IsAutoTrapRunActive(runId) then return false end
		StableTeleport(CFrame.new(attackPosition, enemyRoot.Position))
		playerRoot = PlayerRoot()
	end
	tool = tool and tool.Parent and tool or EquipCombatWeapon()
	for _ = 1, 3 do
		if not IsAutoTrapRunActive(runId) or not enemyRoot.Parent then break end
		UseCombatWeapon(tool)
		TouchWeaponToEnemy(tool, enemy)
		FireToolCombatRemotes(tool, enemy)
		task.wait(0.04)
	end
	playerRoot = PlayerRoot()
	if playerRoot then
		pcall(function()
			playerRoot.AssemblyAngularVelocity = Vector3.zero
			if playerRoot.AssemblyLinearVelocity.Magnitude > 80 then
				playerRoot.AssemblyLinearVelocity = playerRoot.AssemblyLinearVelocity.Unit * 18
			end
		end)
	end
	return true
end

local function TryClearHunterTrapEnemies(position, runId, includeAll, radius)
	if not IsAutoTrapRunActive(runId) then return 0 end
	local enemies = CollectEnemiesNear(position, radius or HUNTER_TRAP_ENEMY_RADIUS, includeAll)
	if #enemies <= 0 then
		RestoreHunterTrapHitboxes()
		return 0
	end
	ExpandHunterTrapEnemyHitboxes(enemies, includeAll and STRUCTURE_TRAP_HITBOX_SIZE or HUNTER_TRAP_HITBOX_SIZE)
	local now = os.clock()
	if not state.HunterTrapAttackBusy and now - (state.LastHunterTrapAttack or 0) >= HUNTER_TRAP_ATTACK_INTERVAL then
		state.LastHunterTrapAttack = now
		state.HunterTrapAttackBusy = true
		local targetEnemy = enemies[1]
		task.spawn(function()
			pcall(function()
				AttackHunterTrapEnemy(targetEnemy, position, runId)
			end)
			if runId == state.AutoTrapRunId then
				state.HunterTrapAttackBusy = false
			end
		end)
	end
	return #enemies
end

local function PickupRoot(instance)
	if not instance then return nil end
	if instance:IsA("BasePart") then return instance end
	if instance:IsA("Model") then return instance.PrimaryPart or instance:FindFirstChildWhichIsA("BasePart", true) end
	if instance:IsA("Tool") then return instance:FindFirstChild("Handle") or instance:FindFirstChildWhichIsA("BasePart", true) end
	local part = instance:FindFirstAncestorWhichIsA("BasePart")
	if part then return part end
	local model = instance:FindFirstAncestorOfClass("Model")
	return model and (model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart", true)) or nil
end

local function PickupContainer(instance)
	if not instance then return nil end
	if instance:IsA("Tool") or instance:IsA("Model") or instance:IsA("BasePart") then return instance end
	return instance:FindFirstAncestorOfClass("Tool")
		or instance:FindFirstAncestorOfClass("Model")
		or instance:FindFirstAncestorWhichIsA("BasePart")
end

local function HasPickupText(value)
	local lower = string.lower(tostring(value or ""))
	for _, term in ipairs({"drop", "loot", "item", "coin", "gold", "cash", "gem", "crystal", "scrap", "bone", "fang", "essence", "shard", "reward", "bag", "pouch"}) do
		if lower:find(term, 1, true) then return true end
	end
	return false
end

local function IsIgnoredPickupCandidate(instance, container)
	local character = Player and Player.Character
	local enemies = workspace:FindFirstChild("Enemies")
	if character and instance:IsDescendantOf(character) then return true end
	if enemies and instance:IsDescendantOf(enemies) then return true end
	if HasHunterTrapText(instance.Name) or (container and HasHunterTrapText(container.Name)) then return true end
	if container and BoxType(container) then return true end
	return false
end

local function IsHunterDropCandidate(instance)
	local container = PickupContainer(instance)
	if not container or IsIgnoredPickupCandidate(instance, container) then return false end
	if container:IsA("Tool") then return true end
	if instance:IsA("ProximityPrompt") or instance:IsA("ClickDetector") then return true end
	if instance:IsA("TouchTransmitter") then
		return HasPickupText(instance.Name) or HasPickupText(container.Name) or (instance.Parent and HasPickupText(instance.Parent.Name))
	end
	return HasPickupText(instance.Name) or HasPickupText(container.Name)
end

local function CollectHunterDropsNear(position, radius)
	local drops = {}
	local seen = {}
	for _, instance in ipairs(workspace:GetDescendants()) do
		if IsHunterDropCandidate(instance) then
			local container = PickupContainer(instance)
			local root = PickupRoot(container or instance)
			if root and (root.Position - position).Magnitude <= radius and not seen[container or root] then
				seen[container or root] = true
				table.insert(drops, container or root)
			end
		end
	end
	table.sort(drops, function(a, b)
		local rootA = PickupRoot(a)
		local rootB = PickupRoot(b)
		local distanceA = rootA and (rootA.Position - position).Magnitude or math.huge
		local distanceB = rootB and (rootB.Position - position).Magnitude or math.huge
		return distanceA < distanceB
	end)
	return drops
end

local function TriggerPickupObject(object, runId)
	if not IsAutoTrapRunActive(runId) then return false end
	local root = PickupRoot(object)
	local playerRoot = PlayerRoot()
	if not root or not playerRoot then return false end
	if not IsAutoTrapRunActive(runId) then return false end
	StableTeleport(CFrame.new(root.Position + Vector3.new(0, 2.25, 0), root.Position))
	playerRoot = PlayerRoot()
	if not playerRoot or not IsAutoTrapRunActive(runId) then return false end
	FireTouch(playerRoot, root)
	PressPickupKey()
	local holder = object
	if not holder.GetDescendants then holder = root end
	for _, instance in ipairs(holder:GetDescendants()) do
		if not IsAutoTrapRunActive(runId) then return false end
		if instance:IsA("ProximityPrompt") and typeof(fireproximityprompt) == "function" then
			pcall(function() fireproximityprompt(instance) end)
			PressPickupKey()
		elseif instance:IsA("ClickDetector") and typeof(fireclickdetector) == "function" then
			pcall(function() fireclickdetector(instance) end)
		elseif instance:IsA("BasePart") then
			FireTouch(playerRoot, instance)
		end
	end
	PressPickupKey()
	return true
end

local function SweepHunterTrapDrops(position, runId)
	if not IsAutoTrapRunActive(runId) then return end
	local now = os.clock()
	if now - (state.LastHunterTrapLootSweep or 0) < HUNTER_TRAP_LOOT_INTERVAL then return end
	state.LastHunterTrapLootSweep = now
	local drops = CollectHunterDropsNear(position, HUNTER_TRAP_LOOT_RADIUS)
	local picked = 0
	for _, drop in ipairs(drops) do
		if not IsAutoTrapRunActive(runId) then return end
		TriggerPickupObject(drop, runId)
		picked += 1
		if picked >= 4 then break end
	end
end

local function DirectTrapPart(trap)
	if not trap then return nil end
	if trap:IsA("BasePart") then return trap end
	if trap:IsA("Model") then return trap.PrimaryPart or trap:FindFirstChildWhichIsA("BasePart", true) end
	return trap:FindFirstChildWhichIsA("BasePart", true)
end

local function IsDirectStructureTrap(structure)
	if not structure then return false end
	local lowerName = string.lower(tostring(structure.Name or ""))
	if lowerName == "graveyard" or lowerName:find("graveyard", 1, true) then return true end
	if lowerName:find("ancient", 1, true) then return true end
	local loot = structure:FindFirstChild("Loot")
	return loot and loot:FindFirstChild("AncientChest") ~= nil
end

local function FindNearestHunterTrapRoot(skipVisited)
	local folder = StructuresFolder()
	local playerRoot = PlayerRoot()
	if not folder or not playerRoot then return nil end
	local closestRoot
	local closestDistance = math.huge
	local closestNeedsAllEnemies = false
	local function considerRoot(root, needsAllEnemies)
		if not root then return end
		if skipVisited and state.AutoTrapVisited and state.AutoTrapVisited[root] then return end
		local distance = (root.Position - playerRoot.Position).Magnitude
		if distance < closestDistance then
			closestDistance = distance
			closestRoot = root
			closestNeedsAllEnemies = needsAllEnemies == true
		end
	end
	local function consider(candidate)
		if not candidate or BoxType(candidate) ~= "Hunter Trap" then return end
		local root = BoxRoot(candidate)
		considerRoot(root, false)
	end
	local function considerDirectStructure(structure)
		if not IsDirectStructureTrap(structure) then return end
		considerRoot(DirectTrapPart(structure:FindFirstChild("Trap")), true)
	end
	for _, structure in ipairs(folder:GetChildren()) do
		consider(structure)
		for _, candidate in ipairs(structure:GetDescendants()) do
			if HasHunterTrapText(candidate.Name) then
				consider(candidate)
			end
		end
		considerDirectStructure(structure)
	end
	state.AutoTrapTargetAnyEnemies = closestNeedsAllEnemies
	return closestRoot
end

local function TeleportToHunterTrapRoot(trapRoot, directTouch)
	if not trapRoot then return false end
	local playerRoot = PlayerRoot()
	if directTouch then
		local targetPosition = trapRoot.Position + Vector3.new(0, 3, 0)
		local ok = StableTeleport(CFrame.new(targetPosition, trapRoot.Position + trapRoot.CFrame.LookVector))
		playerRoot = PlayerRoot()
		if playerRoot then FireTouch(playerRoot, trapRoot) end
		return ok
	end
	local offset = playerRoot and (playerRoot.Position - trapRoot.Position) or -trapRoot.CFrame.LookVector
	local flatOffset = Vector3.new(offset.X, 0, offset.Z)
	if flatOffset.Magnitude < 1 then
		local fallback = -trapRoot.CFrame.LookVector
		flatOffset = Vector3.new(fallback.X, 0, fallback.Z)
	end
	if flatOffset.Magnitude < 1 then flatOffset = Vector3.new(0, 0, 1) end
	local sideDistance = HUNTER_TRAP_SIDE_DISTANCE
	if trapRoot:IsA("BasePart") then
		sideDistance = math.clamp((math.max(trapRoot.Size.X, trapRoot.Size.Z) * 0.5) + 4, HUNTER_TRAP_SIDE_DISTANCE, 10)
	end
	local targetPosition = trapRoot.Position + flatOffset.Unit * sideDistance + Vector3.new(0, 3, 0)
	return StableTeleport(CFrame.new(targetPosition, trapRoot.Position))
end

local function AutoHunterTrapStep()
	if not state.AutoHunterTrap then return end
	local runId = state.AutoTrapRunId
	if not IsAutoTrapRunActive(runId) then return end
	local now = os.clock()
	local target = state.AutoTrapTarget
	if target and (not target.Parent) then
		state.AutoTrapTarget = nil
		state.AutoTrapTargetAnyEnemies = false
		state.AutoTrapPhase = "seeking"
		state.AutoTrapLootStartedAt = nil
		state.LastHunterTrapSearchAt = 0
		state.AutoTrapCombatStartedAt = nil
		state.AutoTrapLastEnemyCount = nil
		state.AutoTrapLastEnemyChangeAt = nil
		RestoreHunterTrapHitboxes()
		RestoreAutoTrapFacing()
		target = nil
	end

	if not target then
		local scanInterval = state.AutoTrapPhase == "base_wait" and HUNTER_TRAP_BASE_SCAN_INTERVAL or HUNTER_TRAP_SEEK_INTERVAL
		if now - (state.LastHunterTrapSearchAt or 0) < scanInterval then
			return
		end
		state.LastHunterTrapSearchAt = now
		local nextTrap = FindNearestHunterTrapRoot(true)
		if nextTrap then
			local targetAnyEnemies = state.AutoTrapTargetAnyEnemies == true
			state.AutoTrapTarget = nextTrap
			state.AutoTrapTargetAnyEnemies = targetAnyEnemies
			state.AutoTrapPhase = "waiting_spawn"
			state.AutoTrapStartedAt = now
			state.AutoTrapLootStartedAt = nil
			state.AutoTrapBaseWaitTeleported = false
			state.LastHunterTrapUseAt = 0
			state.LastHunterTrapStrafeAt = 0
			state.LastStructureTrapStrafeAt = 0
			state.LastStructureTrapTouchAt = 0
			state.AutoTrapCombatStartedAt = nil
			state.AutoTrapLastEnemyCount = nil
			state.AutoTrapLastEnemyChangeAt = nil
			state.LastAutoTrapCombatClickAt = 0
			state.HunterTrapAttackBusy = false
			state.LastHunterTrapSearchAt = 0
			RestoreHunterTrapHitboxes()
			if not IsAutoTrapRunActive(runId) then return end
			TeleportToHunterTrapRoot(nextTrap, targetAnyEnemies)
		else
			state.AutoTrapPhase = "base_wait"
			state.AutoTrapTargetAnyEnemies = false
			state.AutoTrapLootStartedAt = nil
			RestoreHunterTrapHitboxes()
			RestoreAutoTrapFacing()
			if not state.AutoTrapBaseWaitTeleported then
				state.AutoTrapBaseWaitTeleported = true
				TeleportToBase()
			end
		end
		return
	end

	local targetAnyEnemies = state.AutoTrapTargetAnyEnemies == true
	local enemyRadius = targetAnyEnemies and STRUCTURE_TRAP_ENEMY_RADIUS or HUNTER_TRAP_ENEMY_RADIUS
	local enemies = CountEnemiesNear(target.Position, enemyRadius, targetAnyEnemies)
	if state.AutoTrapPhase == "waiting_spawn" then
		if enemies > 0 then
			state.AutoTrapPhase = "activating_tool"
			state.AutoTrapLootStartedAt = nil
			state.LastHunterTrapUseAt = 0
			state.LastHunterTrapStrafeAt = 0
			state.LastStructureTrapStrafeAt = 0
			state.LastStructureTrapTouchAt = 0
			state.AutoTrapCombatStartedAt = now
			state.AutoTrapLastEnemyCount = enemies
			state.AutoTrapLastEnemyChangeAt = now
			state.LastAutoTrapCombatClickAt = 0
		elseif now - (state.AutoTrapStartedAt or now) >= HUNTER_TRAP_SPAWN_TIMEOUT then
			state.AutoTrapVisited = state.AutoTrapVisited or {}
			state.AutoTrapVisited[target] = true
			state.AutoTrapTarget = nil
			state.AutoTrapTargetAnyEnemies = false
			state.AutoTrapPhase = "seeking"
			state.AutoTrapLootStartedAt = nil
			state.LastHunterTrapSearchAt = 0
			state.LastStructureTrapStrafeAt = 0
			state.LastStructureTrapTouchAt = 0
			state.AutoTrapCombatStartedAt = nil
			state.AutoTrapLastEnemyCount = nil
			state.AutoTrapLastEnemyChangeAt = nil
			RestoreHunterTrapHitboxes()
			RestoreAutoTrapFacing()
			if targetAnyEnemies then
				state.LastHunterTrapSearchAt = now
				TeleportToBase()
				return
			end
			if IsAutoTrapRunActive(runId) then AutoHunterTrapStep() end
		end
	elseif state.AutoTrapPhase == "activating_tool" then
		if state.AutoTrapLastEnemyCount ~= enemies then
			state.AutoTrapLastEnemyCount = enemies
			state.AutoTrapLastEnemyChangeAt = now
		end
		local clearTimeout = targetAnyEnemies and STRUCTURE_TRAP_CLEAR_TIMEOUT or HUNTER_TRAP_CLEAR_TIMEOUT
		local combatStartedAt = state.AutoTrapCombatStartedAt or now
		local lastEnemyChangeAt = state.AutoTrapLastEnemyChangeAt or combatStartedAt
		if enemies > 0 and (now - combatStartedAt >= clearTimeout or now - lastEnemyChangeAt >= AUTO_TRAP_STUCK_ENEMY_TIMEOUT) then
			state.AutoTrapVisited = state.AutoTrapVisited or {}
			state.AutoTrapVisited[target] = true
			state.AutoTrapTarget = nil
			state.AutoTrapTargetAnyEnemies = false
			state.AutoTrapPhase = "seeking"
			state.AutoTrapLootStartedAt = nil
			state.LastHunterTrapSearchAt = 0
			state.LastStructureTrapStrafeAt = 0
			state.LastStructureTrapTouchAt = 0
			state.AutoTrapCombatStartedAt = nil
			state.AutoTrapLastEnemyCount = nil
			state.AutoTrapLastEnemyChangeAt = nil
			RestoreHunterTrapHitboxes()
			RestoreAutoTrapFacing()
			if targetAnyEnemies then
				state.LastHunterTrapSearchAt = now
				TeleportToBase()
				return
			end
			if IsAutoTrapRunActive(runId) then AutoHunterTrapStep() end
			return
		end
		if enemies <= 0 then
			state.AutoTrapVisited = state.AutoTrapVisited or {}
			state.AutoTrapVisited[target] = true
			state.AutoTrapTarget = nil
			state.AutoTrapTargetAnyEnemies = false
			state.AutoTrapPhase = "seeking"
			state.AutoTrapLootStartedAt = nil
			state.LastHunterTrapSearchAt = 0
			state.LastStructureTrapStrafeAt = 0
			state.LastStructureTrapTouchAt = 0
			state.AutoTrapCombatStartedAt = nil
			state.AutoTrapLastEnemyCount = nil
			state.AutoTrapLastEnemyChangeAt = nil
			RestoreHunterTrapHitboxes()
			RestoreAutoTrapFacing()
			if targetAnyEnemies then
				state.LastHunterTrapSearchAt = now
				TeleportToBase()
				return
			end
			if IsAutoTrapRunActive(runId) then AutoHunterTrapStep() end
		elseif now - (state.LastHunterTrapUseAt or 0) >= HUNTER_TRAP_ATTACK_INTERVAL then
			state.LastHunterTrapUseAt = now
			if targetAnyEnemies then
				StrafeNearestHunterNear(target.Position, enemyRadius, runId, true)
				UseCurrentEquippedTool(true)
			else
				StrafeNearestHunterNear(target.Position, enemyRadius, runId, false)
				UseCurrentEquippedTool(true)
			end
		else
			FaceNearestHunterNear(target.Position, enemyRadius, targetAnyEnemies)
		end
	else
		state.AutoTrapPhase = "seeking"
		state.AutoTrapLootStartedAt = nil
		state.AutoTrapTargetAnyEnemies = false
		state.LastStructureTrapStrafeAt = 0
		state.LastStructureTrapTouchAt = 0
		state.AutoTrapCombatStartedAt = nil
		state.AutoTrapLastEnemyCount = nil
		state.AutoTrapLastEnemyChangeAt = nil
		RestoreHunterTrapHitboxes()
		RestoreAutoTrapFacing()
	end
end

local function TeleportNearMobRoot(enemy, mobRoot)
	if not mobRoot then return false end
	local playerRoot = PlayerRoot()
	local offset = playerRoot and (playerRoot.Position - mobRoot.Position) or -mobRoot.CFrame.LookVector
	local flatOffset = Vector3.new(offset.X, 0, offset.Z)
	if flatOffset.Magnitude < 1 then
		local fallback = -mobRoot.CFrame.LookVector
		flatOffset = Vector3.new(fallback.X, 0, fallback.Z)
	end
	if flatOffset.Magnitude < 1 then flatOffset = Vector3.new(0, 0, 1) end
	local position = mobRoot.Position + flatOffset.Unit * MobFarmAttackDistance(enemy, mobRoot) + Vector3.new(0, 2, 0)
	return StableTeleport(CFrame.new(position, mobRoot.Position))
end

local function AutoMobFarmStep()
	if not state.AutoMobFarm then return end
	local runId = state.AutoMobRunId
	if not IsAutoMobRunActive(runId) then return end
	local now = os.clock()
	local target = state.AutoMobTarget
	if target and (not target.Parent or not IsLiveMob(target)) then
		RestoreMobFarmHitboxes()
		state.AutoMobTarget = nil
		state.AutoMobPhase = "seeking"
		state.MobFarmRangedEnemy = nil
		state.MobFarmRangedValue = nil
		target = nil
	end
	if not target then
		local mob, root = NearestMobRoot(PlayerRoot() and PlayerRoot().Position or nil, MOB_FARM_SCAN_RADIUS)
		if not mob or not root then
			state.AutoMobPhase = "waiting"
			RestoreMobFarmHitboxes()
			RestoreAutoTrapFacing()
			return
		end
		state.AutoMobTarget = mob
		state.AutoMobPhase = "attacking"
		state.LastMobFarmUseAt = 0
		state.LastMobFarmStrafeAt = 0
		state.LastMobFarmStrongAttackAt = 0
		state.MobFarmRangedEnemy = nil
		state.MobFarmRangedValue = nil
		if not IsAutoMobRunActive(runId) then return end
		ExpandMobFarmTargetHitbox(mob)
		TeleportNearMobRoot(mob, root)
		return
	end
	local targetRoot = EnemyRoot(target)
	if not targetRoot then
		RestoreMobFarmHitboxes()
		state.AutoMobTarget = nil
		state.AutoMobPhase = "seeking"
		state.MobFarmRangedEnemy = nil
		state.MobFarmRangedValue = nil
		return
	end
	if state.AutoMobPhase == "attacking" then
		ExpandMobFarmTargetHitbox(target)
		StrafeAroundMobRoot(target, targetRoot, runId)
		if now - (state.LastMobFarmUseAt or 0) >= MOB_FARM_ATTACK_INTERVAL then
			state.LastMobFarmUseAt = now
			local tool = EquipCombatWeapon()
			UseCombatWeapon(tool)
			if now - (state.LastMobFarmStrongAttackAt or 0) >= MOB_FARM_STRONG_ATTACK_INTERVAL then
				state.LastMobFarmStrongAttackAt = now
				TouchWeaponToEnemy(tool, target)
				FireToolCombatRemotes(tool, target)
			end
		end
	else
		state.AutoMobPhase = "seeking"
	end
end


	local scroll = Instance.new("ScrollingFrame")
	scroll.Size = UDim2.new(1, -16, 1, -38)
	scroll.Position = UDim2.new(0, 8, 0, 34)
	scroll.BackgroundTransparency = 1
	scroll.BorderSizePixel = 0
	scroll.ScrollBarThickness = 3
	scroll.ScrollBarImageColor3 = AccentColor
	scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
	scroll.ZIndex = 41
	scroll.Parent = dock
	SmoothScroll(scroll)

	local scrollLayout = Instance.new("UIListLayout")
	scrollLayout.Padding = UDim.new(0, 10)
	scrollLayout.SortOrder = Enum.SortOrder.LayoutOrder
	scrollLayout.Parent = scroll
	-- This line used to be "scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y" -- the wrong
	-- enum entirely (AutomaticSize is for GuiObject.AutomaticSize, not a ScrollingFrame's
	-- CanvasSize), a real type-mismatch error every time this ran. Manual sizing instead.
	scrollLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		scroll.CanvasSize = UDim2.new(0, 0, 0, scrollLayout.AbsoluteContentSize.Y + 12)
	end)

	local function UpdatePosition()
		dock.Position = UDim2.fromOffset(PanelFrame.AbsolutePosition.X - (width + 8), PanelFrame.AbsolutePosition.Y)
	end
	PanelFrame:GetPropertyChangedSignal("AbsolutePosition"):Connect(UpdatePosition)
	UpdatePosition()

	table.insert(ManagedPopups, dock)
	local function Toggle()
		UpdatePosition()
		ToggleManagedPopup(dock)
	end

	return dock, scroll, Toggle
end


local function RemoveLootCandidate(target)
	state.LootCandidates[target] = nil
	local connection = state.LootCandidateConnections[target]
	if connection then connection:Disconnect() end
	state.LootCandidateConnections[target] = nil
end

local function AddLootCandidateFromDescendant(instance)
	local target = LootTargetFromDescendant(instance)
	if not target or state.LootCandidates[target] then return end
	if not LootRoot(target) then return end
	state.LootCandidates[target] = true
	state.LootCandidateConnections[target] = target.AncestryChanged:Connect(function(_, parent)
		if not parent then
			if RemoveLootESP then RemoveLootESP(target) end
			RemoveLootCandidate(target)
		end
	end)
end


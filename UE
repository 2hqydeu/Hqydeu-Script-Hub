TrackConnection("UndeadExpeditionLightingHeartbeat", RunService.Heartbeat:Connect(function()
	if not uePage.Parent then return end
	local now = os.clock()
	if state.NoDarkness and now - (state.LastLightingApply or 0) >= 1.5 then
		state.LastLightingApply = now
		ApplyNoDarkness()
	end
	if now - (state.LastStructureWatchAt or 0) >= 1 then
		state.LastStructureWatchAt = now
		WatchStructures()
	end
	if state.BoxESP then
		RefreshBoxDistances()
	end
	local autoTrapInterval = state.AutoTrapPhase == "base_wait" and HUNTER_TRAP_BASE_WAIT_INTERVAL or HUNTER_TRAP_INTERVAL
	if state.AutoHunterTrap and now - (state.LastHunterTrapMove or 0) >= autoTrapInterval then
		state.LastHunterTrapMove = now
		AutoHunterTrapStep()
	end
	if state.AutoMobFarm and now - (state.LastMobFarmMove or 0) >= MOB_FARM_INTERVAL then
		state.LastMobFarmMove = now
		AutoMobFarmStep()
	end
	if state.BoxESP and now - (state.LastBoxScan or 0) >= BOX_SCAN_INTERVAL then
		state.LastBoxScan = now
		UpdateBoxESP()
		RefreshButtons()
	end
end))

task.spawn(function()

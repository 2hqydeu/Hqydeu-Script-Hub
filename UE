local function SafeGet(instance, property)
	local ok, value = pcall(function()
		return instance[property]
	end)
	if ok then return value end
	return nil
end

local function SafeSet(instance, property, value)
	pcall(function()
		instance[property] = value
	end)
end

local function IsPlayerOwned(instance)
	if not instance then return true end
	if instance:IsDescendantOf(MainFrame) or (ScreenGui and instance:IsDescendantOf(ScreenGui)) then return true end
	for _, otherPlayer in ipairs(Players:GetPlayers()) do
		if otherPlayer.Character and instance:IsDescendantOf(otherPlayer.Character) then return true end
	end
	if Player then
		if Player:FindFirstChildOfClass("Backpack") and instance:IsDescendantOf(Player:FindFirstChildOfClass("Backpack")) then return true end
		if Player:FindFirstChildOfClass("PlayerGui") and instance:IsDescendantOf(Player:FindFirstChildOfClass("PlayerGui")) then return true end
	end
	return false
end

local function NormalizeRarity(value)
	if value == nil then return nil end
	local raw = tostring(value)
	if raw == "" then return nil end
	local lower = string.lower(raw)
	for _, definition in ipairs(rarityDefinitions) do
		if lower:find(definition.Key, 1, true) then return definition.Name end
	end
	if tonumber(raw) then
		local number = tonumber(raw)
		if number <= 1 then return "Common" end
		if number == 2 then return "Uncommon" end
		if number == 3 then return "Rare" end
		if number == 4 then return "Epic" end
		if number == 5 then return "Legendary" end
		return "Mythic"
	end
	return nil
end

local function RarityColor(rarity)
	local lower = string.lower(tostring(rarity or ""))
	for _, definition in ipairs(rarityDefinitions) do
		if lower == string.lower(definition.Name) then return definition.Color end
	end
	return Color3.fromRGB(255, 255, 255)
end

local rarityAttributes = {"Rarity", "rarity", "Tier", "tier", "Quality", "quality", "ItemRarity", "DropRarity"}

local function ReadRarityFrom(instance)
	if not instance then return nil end
	for _, attributeName in ipairs(rarityAttributes) do
		local rarity = NormalizeRarity(instance:GetAttribute(attributeName))
		if rarity then return rarity end
	end
	for _, child in ipairs(instance:GetChildren()) do
		if child:IsA("StringValue") or child:IsA("IntValue") or child:IsA("NumberValue") then
			local lower = string.lower(child.Name or "")
			if lower:find("rarity", 1, true) or lower:find("tier", 1, true) or lower:find("quality", 1, true) then
				local rarity = NormalizeRarity(child.Value)
				if rarity then return rarity end
			end
		end
	end
	return nil
end

local function LootRarity(instance)
	local current = instance
	while current and current ~= workspace do
		local rarity = ReadRarityFrom(current)
		if rarity then return rarity end
		local lower = string.lower(current.Name or "")
		for _, definition in ipairs(rarityDefinitions) do
			if lower:find(definition.Key, 1, true) then return definition.Name end
		end
		current = current.Parent
	end
	return "Loot"
end

local function LootAllowed(target)
	local rarity = LootRarity(target)
	if state.SelectedLootRarities[rarity] == nil then
		state.SelectedLootRarities[rarity] = true
	end
	return state.SelectedLootRarities[rarity] ~= false
end

local function HasLootNameHint(instance)
	local current = instance
	while current and current ~= workspace do
		local lower = string.lower(current.Name or "")
		for hint in pairs(lootNameHints) do
			if lower:find(hint, 1, true) then return true end
		end
		current = current.Parent
	end
	return false
end

local function LooksLikeLoot(instance)
	if not instance or IsPlayerOwned(instance) then return false end
	if not IsInsideWorkspaceContainer(instance, LOOT_CONTAINER_NAME) then return false end
	if ReadRarityFrom(instance) then return true end
	if instance:IsA("ProximityPrompt") then
		local text = string.lower(tostring(instance.ActionText or "") .. " " .. tostring(instance.ObjectText or ""))
		for hint in pairs(lootNameHints) do
			if text:find(hint, 1, true) then return true end
		end
	end
	if instance:IsA("BasePart") or instance:IsA("Model") or instance:IsA("Tool") or instance:IsA("ProximityPrompt") then
		return HasLootNameHint(instance)
	end
	return false
end

local function LootTargetFromDescendant(instance)
	if not LooksLikeLoot(instance) then return nil end
	local target = instance:IsA("ProximityPrompt") and instance.Parent or instance
	local tool = target and (target:IsA("Tool") and target or target:FindFirstAncestorOfClass("Tool"))
	if tool and not IsPlayerOwned(tool) then return tool end
	local model = target and (target:IsA("Model") and target or target:FindFirstAncestorOfClass("Model"))
	if model and model ~= workspace and not IsPlayerCharacter(model) and not IsPlayerOwned(model) then return model end
	if target and target:IsA("BasePart") and not IsPlayerOwned(target) then return target end
	return nil
end

local function LootRoot(target)
	if not target then return nil end
	if target:IsA("BasePart") then return target end
	if target:IsA("Tool") then return target:FindFirstChild("Handle") or target:FindFirstChildWhichIsA("BasePart") end
	if target:IsA("Model") then return target.PrimaryPart or target:FindFirstChildWhichIsA("BasePart") end
	return nil
end

local function LootDisplayName(target)
	if not target then return "Loot" end
	local displayName = target:GetAttribute("DisplayName") or target:GetAttribute("ItemName") or target:GetAttribute("Name")
	if displayName and tostring(displayName) ~= "" then return tostring(displayName) end
	if target.Name == "Handle" and target.Parent then return tostring(target.Parent.Name) end
	return tostring(target.Name or "Loot")
end


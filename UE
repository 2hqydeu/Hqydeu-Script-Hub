local function TouchWeaponToEnemy(tool, enemy)
	local hitParts = CollectToolHitParts(tool)
	local enemyParts = CollectEnemyHitParts(enemy)
	local touches = 0
	for _, hitPart in ipairs(hitParts) do
		for _, enemyPart in ipairs(enemyParts) do
			FireTouch(hitPart, enemyPart)
			touches += 1
			if touches >= 80 then return touches end
		end
	end
	return touches
end


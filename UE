local function GetStructureColor(name)
	local key = StructureFilterKey(name)
	local index = state.StructureColorAssignments[key]
	if not index then
		index = state.StructureColorNextIndex
		state.StructureColorAssignments[key] = index
		state.StructureColorNextIndex = index + 1
	end
	return STRUCTURE_COLOR_PALETTE[((index - 1) % #STRUCTURE_COLOR_PALETTE) + 1]
end


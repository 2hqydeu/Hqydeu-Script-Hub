local lightingEffectProperties = {
	Atmosphere = {"Density", "Offset", "Color", "Decay", "Glare", "Haze"},
	ColorCorrectionEffect = {"Enabled", "Brightness", "Contrast", "Saturation", "TintColor"},
	BloomEffect = {"Enabled", "Intensity", "Size", "Threshold"},
	BlurEffect = {"Enabled", "Size"},
	DepthOfFieldEffect = {"Enabled", "FarIntensity", "FocusDistance", "InFocusRadius", "NearIntensity"},
	SunRaysEffect = {"Enabled", "Intensity", "Spread"},
}

local function LightingEffectClass(instance)
	for className in pairs(lightingEffectProperties) do
		if instance:IsA(className) then return className end
	end
	return nil
end

local function CaptureLightingEffectDefaults(effect, original)
	local className = LightingEffectClass(effect)
	if not className then return end
	original.Effects = original.Effects or {}
	if original.Effects[effect] then return end
	local saved = {}
	for _, property in ipairs(lightingEffectProperties[className]) do
		local value = SafeGet(effect, property)
		if value ~= nil then saved[property] = value end
	end
	original.Effects[effect] = saved
end

local function SaveLightingDefaults()
	if not state.OriginalLighting then
		state.OriginalLighting = {
			ClockTime = Lighting.ClockTime,
			TimeOfDay = SafeGet(Lighting, "TimeOfDay"),
			Brightness = Lighting.Brightness,
			FogEnd = Lighting.FogEnd,
			FogStart = Lighting.FogStart,
			FogColor = Lighting.FogColor,
			Ambient = Lighting.Ambient,
			OutdoorAmbient = Lighting.OutdoorAmbient,
			ExposureCompensation = Lighting.ExposureCompensation,
			GlobalShadows = SafeGet(Lighting, "GlobalShadows"),
			Effects = {},
		}
	end
	for _, child in ipairs(Lighting:GetChildren()) do
		CaptureLightingEffectDefaults(child, state.OriginalLighting)
	end
end

local function ApplyNoDarkness()
	SaveLightingDefaults()
	SafeSet(Lighting, "ClockTime", 14)
	SafeSet(Lighting, "TimeOfDay", "14:00:00")
	SafeSet(Lighting, "Brightness", 4)
	SafeSet(Lighting, "FogStart", 0)
	SafeSet(Lighting, "FogEnd", 1000000)
	SafeSet(Lighting, "FogColor", Color3.fromRGB(255, 255, 255))
	SafeSet(Lighting, "Ambient", Color3.fromRGB(255, 255, 255))
	SafeSet(Lighting, "OutdoorAmbient", Color3.fromRGB(255, 255, 255))
	SafeSet(Lighting, "ExposureCompensation", 0.45)
	SafeSet(Lighting, "GlobalShadows", false)
	for _, child in ipairs(Lighting:GetChildren()) do
		CaptureLightingEffectDefaults(child, state.OriginalLighting)
		if child:IsA("Atmosphere") then
			SafeSet(child, "Density", 0)
			SafeSet(child, "Haze", 0)
			SafeSet(child, "Glare", 0)
			SafeSet(child, "Offset", 0)
			SafeSet(child, "Color", Color3.fromRGB(255, 255, 255))
			SafeSet(child, "Decay", Color3.fromRGB(255, 255, 255))
		elseif child:IsA("ColorCorrectionEffect") then
			SafeSet(child, "Enabled", false)
			SafeSet(child, "Brightness", 0)
			SafeSet(child, "Contrast", 0)
			SafeSet(child, "Saturation", 0)
			SafeSet(child, "TintColor", Color3.fromRGB(255, 255, 255))
		elseif child:IsA("BloomEffect") or child:IsA("BlurEffect") or child:IsA("DepthOfFieldEffect") or child:IsA("SunRaysEffect") then
			SafeSet(child, "Enabled", false)
		end
	end
end

local function RestoreLighting()
	local original = state.OriginalLighting
	if not original then return end
	for property, value in pairs(original) do
		if property ~= "Effects" then
			SafeSet(Lighting, property, value)
		end
	end
	for effect, properties in pairs(original.Effects or {}) do
		if typeof(effect) == "Instance" and effect.Parent then
			for property, value in pairs(properties) do
				SafeSet(effect, property, value)
			end
		end
	end
end

local function SetNoDarkness(enabled)
	state.NoDarkness = enabled == true
	if state.NoDarkness then
		ApplyNoDarkness()
	else
		RestoreLighting()
	end
end

local function TeleportToBase()
	local character = Player and Player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if not root then return end
	root.CFrame = CFrame.new(BASE_POSITION)
end

local function FullCandidateScan()
	for _, obj in ipairs(workspace:GetDescendants()) do
		AddCandidateFromDescendant(obj)
	end
end

local function PlayerRoot()
	local character = Player and Player.Character
	return character and character:FindFirstChild("HumanoidRootPart")
end

local function UpdateESP()
	if not state.EnemyESP then
		state.LastEnemyCount = 0
		state.LastShownCount = 0
		ClearESP()
		return
	end
	local now = os.clock()
	if now - (state.LastFullScan or 0) >= FULL_RESCAN_INTERVAL then
		state.LastFullScan = now
		FullCandidateScan()
	end

	local playerRoot = PlayerRoot()
	local candidates = {}
	for model in pairs(state.CandidateModels) do
		if model.Parent and IsEnemyModel(model) then
			local root = EnemyRoot(model)
			local distance = playerRoot and root and (root.Position - playerRoot.Position).Magnitude or 0
			table.insert(candidates, {Model = model, Distance = distance})
		else
			RemoveESP(model)
			RemoveCandidate(model)
		end
	end
	table.sort(candidates, function(a, b)
		return a.Distance < b.Distance
	end)

	local seen = {}
	local shown = 0
	for _, candidate in ipairs(candidates) do
		if shown >= MAX_ESP_OBJECTS then break end
		local model = candidate.Model
		seen[model] = true
		shown += 1
		local entry = state.ESPObjects[model]
		if not entry or not entry.Holder or not entry.Holder.Parent then
			entry = CreateESP(model)
			state.ESPObjects[model] = entry
		end
		if entry then
			local root = EnemyRoot(model)
			if root then entry.Billboard.Adornee = root end
			if now - (entry.LastLabelUpdate or 0) >= LABEL_UPDATE_INTERVAL then
				entry.LastLabelUpdate = now
				if root and playerRoot then
					entry.Label.Text = ("%s  [%dm]"):format(EnemyDisplayName(model), math.floor((root.Position - playerRoot.Position).Magnitude))
				else
					entry.Label.Text = EnemyDisplayName(model)
				end
			end
		end
	end

	for model in pairs(state.ESPObjects) do
		if not seen[model] then
			RemoveESP(model)
		end
	end
	state.LastEnemyCount = #candidates
	state.LastShownCount = shown
end

local function UpdateLootESP()
	if not state.LootESP then
		state.LastLootCount = 0
		state.LastLootShownCount = 0
		ClearLootESP()
		return
	end
	local now = os.clock()
	if now - (state.LastLootFullScan or 0) >= FULL_RESCAN_INTERVAL then
		state.LastLootFullScan = now
		FullLootScan()
	end

	local playerRoot = PlayerRoot()
	local candidates = {}
	for target in pairs(state.LootCandidates) do
		local root = LootRoot(target)
		if target.Parent and root and not IsPlayerOwned(target) then
			local distance = playerRoot and (root.Position - playerRoot.Position).Magnitude or 0
			table.insert(candidates, {Target = target, Root = root, Distance = distance})
		else
			RemoveLootESP(target)
			RemoveLootCandidate(target)
		end
	end
	table.sort(candidates, function(a, b)
		return a.Distance < b.Distance
	end)

	local seen = {}
	local shown = 0
	for _, candidate in ipairs(candidates) do
		if shown >= MAX_LOOT_OBJECTS then break end
		local target = candidate.Target
		seen[target] = true
		shown += 1
		local entry = state.LootObjects[target]
		if not entry or not entry.Holder or not entry.Holder.Parent then
			entry = CreateLootESP(target)
			state.LootObjects[target] = entry
		end
		if entry then
			local rarity = LootRarity(target)
			local color = RarityColor(rarity)
			entry.Billboard.Adornee = candidate.Root
			entry.Label.TextColor3 = color
			if entry.Highlight then
				entry.Highlight.Adornee = target
				entry.Highlight.FillColor = color
				entry.Highlight.OutlineColor = color
			end
			if now - (entry.LastLabelUpdate or 0) >= LABEL_UPDATE_INTERVAL then
				entry.LastLabelUpdate = now
				entry.Label.Text = ("%s  [%s]  [%dm]"):format(LootDisplayName(target), rarity, math.floor(candidate.Distance))
			end
		end
	end

	for target in pairs(state.LootObjects) do
		if not seen[target] then
			RemoveLootESP(target)
		end
	end
	state.LastLootCount = #candidates
	state.LastLootShownCount = shown
end

local function RefreshButtons()
	espToggle.Text = state.EnemyESP and "On" or "Off"
	lootToggle.Text = state.LootESP and "On" or "Off"
	darknessToggle.Text = state.NoDarkness and "On" or "Off"
	local found = state.LastEnemyCount or 0
	local shown = state.LastShownCount or 0
	local lootFound = state.LastLootCount or 0
	local lootShown = state.LastLootShownCount or 0
	espStatus.Text = state.EnemyESP and ("Shown: %d/%d"):format(shown, found) or "Shown: 0/0"
	lootStatus.Text = state.LootESP and ("Shown: %d/%d"):format(lootShown, lootFound) or "Shown: 0/0"
	espTitle.TextColor3 = state.EnemyESP and AccentColor or InactiveTextColor()
	lootTitle.TextColor3 = state.LootESP and AccentColor or InactiveTextColor()
	darknessTitle.TextColor3 = state.NoDarkness and AccentColor or InactiveTextColor()
	baseTitle.TextColor3 = InactiveTextColor()
	for _, obj in ipairs(uePage:GetDescendants()) do
		if obj:IsA("TextButton") then
			obj.ZIndex = 4
			EnsureControlOutline(obj)
			if obj.Name == "FeatureKeybindButton" then obj.TextColor3 = AccentColor end
		elseif obj:IsA("TextLabel") then
			obj.ZIndex = 4
		end
	end
end

local function ToggleEnemyESP()
	state.EnemyESP = not state.EnemyESP
	if state.EnemyESP then
		state.LastFullScan = 0
		FullCandidateScan()
		UpdateESP()
	else
		ClearESP()
	end
	RefreshButtons()
	UpdateTheme(true)
end

local function ToggleLootESP()
	state.LootESP = not state.LootESP
	if state.LootESP then
		state.LastLootFullScan = 0
		FullLootScan()
		UpdateLootESP()
	else
		ClearLootESP()
	end
	RefreshButtons()
	UpdateTheme(true)
end

local function ToggleNoDarkness()
	SetNoDarkness(not state.NoDarkness)
	RefreshButtons()
	UpdateTheme(true)
end


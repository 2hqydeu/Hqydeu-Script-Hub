TrackConnection("UEHeartbeat", RunService.Heartbeat:Connect(function()
	if not MainFrame.Parent then return end
	local now = os.clock()

	if state.NoDarkness and now - state.LastLightingApply > 1.5 then
		state.LastLightingApply = now
		ApplyNoDarkness()
	end

	if now - state.LastStructureWatchAt > 1 then
		state.LastStructureWatchAt = now
		WatchStructures()
	end

	if now - state.LastESPCategoryScan > BOX_SCAN_INTERVAL then
		state.LastESPCategoryScan = now
		if state.BoxESP then UpdateBoxESP() end
		UpdateMobsESP()
		UpdateStructuresESP()
		UpdateItemsESP()
	end
end))


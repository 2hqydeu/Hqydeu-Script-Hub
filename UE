local AlertFolder = Instance.new("Frame")
AlertFolder.Name = "AlertStack"
AlertFolder.AnchorPoint = Vector2.new(1, 0)
AlertFolder.Position = UDim2.new(1, -16, 0, 16)
AlertFolder.Size = UDim2.new(0, 280, 0, 200)
AlertFolder.BackgroundTransparency = 1
AlertFolder.ZIndex = 210
AlertFolder.Parent = ScreenGui

local alertEntries = {}

local function ExpireStructureAlertEntry(entry)
	for i, e in ipairs(alertEntries) do
		if e == entry then table.remove(alertEntries, i) break end
	end
	if entry.Label then
		local fade = TweenService:Create(entry.Label, TweenInfo.new(STRUCTURE_ALERT_FADE, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			TextTransparency = 1,
			BackgroundTransparency = 1,
		})
		fade:Play()
		fade.Completed:Connect(function() entry.Label:Destroy() end)
	end
end

local function RenderStructureAlerts()
	for index, entry in ipairs(alertEntries) do
		if entry.Label then
			entry.Label.Position = UDim2.new(0, 0, 0, (index - 1) * 40)
		end
	end
end

local function ClearStructureAlerts()
	for _, entry in ipairs(alertEntries) do
		if entry.Token then entry.Token:Disconnect() end
		if entry.Label then entry.Label:Destroy() end
	end
	alertEntries = {}
end

local function PushStructureAlert(name, color)
	if not state.StructureNotifications then return end
	for _, entry in ipairs(alertEntries) do
		if entry.Name == name and os.clock() - entry.CreatedAt < STRUCTURE_ALERT_DURATION then
			entry.Count = entry.Count + 1
			entry.CreatedAt = os.clock()
			local suffix = entry.Count > 1 and (" x" .. entry.Count) or ""
			entry.Label.Text = ("A <font color=\"#%s\">%s</font> has generated%s"):format(color:ToHex(), name, suffix)
			return
		end
	end

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, 0, 0, 34)
	label.BackgroundColor3 = FrameColor
	label.BackgroundTransparency = 0.15
	label.RichText = true
	label.Text = ("A <font color=\"#%s\">%s</font> has generated"):format(color:ToHex(), name)
	label.Font = UIFont
	label.TextSize = 13
	label.TextColor3 = Color3.fromRGB(255, 255, 255)
	label.TextWrapped = true
	label.ZIndex = 210
	label.Parent = AlertFolder
	Instance.new("UICorner", label).CornerRadius = UDim.new(0, 8)

	local entry = {Name = name, Count = 1, Label = label, CreatedAt = os.clock()}
	table.insert(alertEntries, 1, entry)
	while #alertEntries > STRUCTURE_ALERT_SLOTS do
		ExpireStructureAlertEntry(alertEntries[#alertEntries])
	end
	RenderStructureAlerts()

	task.delay(STRUCTURE_ALERT_DURATION, function()
		if entry.Label and entry.Label.Parent then ExpireStructureAlertEntry(entry) end
	end)
end

local function SetStructureMessage(name)
	if state.LastStructureName == name then
		state.LastStructureCount += 1
	else
		state.LastStructureName = name
		state.LastStructureCount = 1
	end
	local suffix = state.LastStructureCount > 1 and (" x" .. state.LastStructureCount) or ""
	state.LastStructureMessage = name .. suffix
	PushStructureAlert(name, GetStructureColor(StructureFilterKey(name)))
end

local function ShowStructureMarker(structure)

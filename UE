	local quietWins = HubState.PageHeader and HubState.PageHeader:FindFirstChild("QuietOrDieWinsDisplay")
	if quietWins then quietWins.Visible = false end
	local quietHistory = HubState.PageHeader and HubState.PageHeader:FindFirstChild("QuietOrDieHistoryButton")
	if quietHistory then quietHistory.Visible = false end
	local growSeason = HubState.PageHeader and HubState.PageHeader:FindFirstChild("GrowABeehiveSeasonDisplay")
	if growSeason then growSeason.Visible = false end
	local growHistory = HubState.PageHeader and HubState.PageHeader:FindFirstChild("GrowABeehiveHistoryButton")

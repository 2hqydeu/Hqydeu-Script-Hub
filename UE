local function UpdateESP()
	if not state.EnemyESP then
		state.LastEnemyCount = 0
		state.LastShownCount = 0
		ClearESP()
		return
	end
	local now = os.clock()
	if now - (state.LastFullScan or 0) >= FULL_RESCAN_INTERVAL then
		state.LastFullScan = now
		FullCandidateScan()
	end

	local playerRoot = PlayerRoot()
	local candidates = {}
	for model in pairs(state.CandidateModels) do
		if model.Parent and IsEnemyModel(model) then
			EnemyFilterName(model)
			local root = EnemyRoot(model)
			if EnemyAllowed(model) then
				local distance = playerRoot and root and (root.Position - playerRoot.Position).Magnitude or 0
				table.insert(candidates, {Model = model, Distance = distance})
			else
				RemoveESP(model)
			end
		else
			RemoveESP(model)
			RemoveCandidate(model)
		end
	end
	table.sort(candidates, function(a, b)
		return a.Distance < b.Distance
	end)

	local seen = {}
	local shown = 0
	for _, candidate in ipairs(candidates) do
		if shown >= MAX_ESP_OBJECTS then break end
		local model = candidate.Model
		seen[model] = true
		shown += 1
		local entry = state.ESPObjects[model]
		if not entry or not entry.Holder or not entry.Holder.Parent then
			entry = CreateESP(model)
			state.ESPObjects[model] = entry
		end
		if entry then
			local root = EnemyRoot(model)
			if root then entry.Billboard.Adornee = root end
			if now - (entry.LastLabelUpdate or 0) >= LABEL_UPDATE_INTERVAL then
				entry.LastLabelUpdate = now
				if root and playerRoot then
					entry.Label.Text = ("%s  [%dm]"):format(EnemyDisplayName(model), math.floor((root.Position - playerRoot.Position).Magnitude))
				else
					entry.Label.Text = EnemyDisplayName(model)
				end
			end
		end
	end

	for model in pairs(state.ESPObjects) do
		if not seen[model] then
			RemoveESP(model)
		end
	end
	state.LastEnemyCount = #candidates
	state.LastShownCount = shown
end

local function UpdateLootESP()
	if not state.LootESP then
		state.LastLootCount = 0
		state.LastLootShownCount = 0
		ClearLootESP()
		return
	end
	local now = os.clock()
	if now - (state.LastLootFullScan or 0) >= FULL_RESCAN_INTERVAL then
		state.LastLootFullScan = now
		FullLootScan()
	end

	local playerRoot = PlayerRoot()
	local candidates = {}
	for target in pairs(state.LootCandidates) do
		local root = LootRoot(target)
		if target.Parent and root and not IsPlayerOwned(target) then
			if LootAllowed(target) then
				local distance = playerRoot and (root.Position - playerRoot.Position).Magnitude or 0
				table.insert(candidates, {Target = target, Root = root, Distance = distance})
			else
				RemoveLootESP(target)
			end
		else
			RemoveLootESP(target)
			RemoveLootCandidate(target)
		end
	end
	table.sort(candidates, function(a, b)
		return a.Distance < b.Distance
	end)

	local seen = {}
	local shown = 0
	for _, candidate in ipairs(candidates) do
		if shown >= MAX_LOOT_OBJECTS then break end
		local target = candidate.Target
		seen[target] = true
		shown += 1
		local entry = state.LootObjects[target]
		if not entry or not entry.Holder or not entry.Holder.Parent then
			entry = CreateLootESP(target)
			state.LootObjects[target] = entry
		end
		if entry then
			local rarity = LootRarity(target)
			local color = RarityColor(rarity)
			entry.Billboard.Adornee = candidate.Root
			entry.Label.TextColor3 = color
			if entry.Highlight then
				entry.Highlight.Adornee = target
				entry.Highlight.FillColor = color
				entry.Highlight.OutlineColor = color
			end
			if now - (entry.LastLabelUpdate or 0) >= LABEL_UPDATE_INTERVAL then
				entry.LastLabelUpdate = now
				entry.Label.Text = ("%s  [%s]  [%dm]"):format(LootDisplayName(target), rarity, math.floor(candidate.Distance))
			end
		end
	end

	for target in pairs(state.LootObjects) do
		if not seen[target] then
			RemoveLootESP(target)
		end
	end
	state.LastLootCount = #candidates
	state.LastLootShownCount = shown
end


----------------------------------------------------------------------
-- Auto-farm system (ported in full)
----------------------------------------------------------------------
-- FindFirstChild(name, true) is case-sensitive and returns nil if nothing matches exactly,
-- which used to make TriggerPart() give up on a structure the instant its part naming
-- didn't match byte-for-byte -- silently abandoning that encounter forever, since
-- HandleTrapStructureSpawn had already marked it Handled. This does a case-insensitive
-- scan and always falls back to the structure's own root so a trigger position is found.
local function FindNamedTriggerPart(structure, partName)
	local direct = structure:FindFirstChild(partName)
	if direct and direct:IsA("BasePart") then return direct end
	local lowerName = partName:lower()
	for _, child in ipairs(structure:GetDescendants()) do
		if child:IsA("BasePart") and child.Name:lower() == lowerName then
			return child
		end
	end
	return StructureRoot(structure)
end

local ENCOUNTERS = {
	{
		Key = "Hunter Trap",
		Matches = function(name) return HasHunterTrapText(name) end,
		TriggerPart = function(structure)
			local isVariant2 = tostring(structure.Name):find("2") ~= nil
			local partName = isVariant2 and "Trap" or "string"
			local part = FindNamedTriggerPart(structure, partName)
			if not part then return nil end
			local position = part.Position
			if isVariant2 then position += TRAP2_LAND_OFFSET end
			return position
		end,
		EnemyNames = {"hunter"},
		LootAttempts = 4,
	},
	{
		Key = "Graveyard",
		Matches = function(name) return tostring(name):lower():find("graveyard", 1, true) ~= nil end,
		TriggerPart = function(structure)
			local part = FindNamedTriggerPart(structure, "Trap")
			return part and part.Position
		end,
		EnemyNames = {"grounder"},
		LootAttempts = 6,
	},
	{
		Key = "Ancient Ruins",
		Matches = function(name) return tostring(name):lower():find("ancient", 1, true) ~= nil end,
		TriggerPart = function(structure)
			local part = FindNamedTriggerPart(structure, "Trap")
			return part and part.Position
		end,
		EnemyNames = {"pharaon", "mummy"},
		LootAttempts = 6,
	},
}

local function MatchEncounter(structure)
	local name = structure.Name
	for _, encounter in ipairs(ENCOUNTERS) do
		if encounter.Matches(name) then return encounter end
	end
	return nil
end

HandleTrapStructureSpawn = function(structure)
	if not state.AutoTrapEnabled then return end
	if state.AutoTrapHandled[structure] then return end
	local encounter = MatchEncounter(structure)
	if not encounter then return end
	state.AutoTrapHandled[structure] = true
	table.insert(state.AutoTrapQueue, {Structure = structure, Encounter = encounter})
end

local function ScanForExistingTrapStructures()
	local folder = StructuresFolder()
	if not folder then return end
	for _, structure in ipairs(folder:GetChildren()) do
		HandleTrapStructureSpawn(structure)
	end
end

local function PlayerRoot()
	local character = Player.Character
	return character and character:FindFirstChild("HumanoidRootPart")
end

local function StableTeleport(cframe)
	local character = Player and Player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not character or not root then return false end
	if humanoid then
		humanoid.Sit = false
		humanoid.PlatformStand = false
		humanoid.AutoRotate = true
		pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) end)
	end
	pcall(function()
		root.AssemblyLinearVelocity = Vector3.zero
		root.AssemblyAngularVelocity = Vector3.zero
	end)
	character:PivotTo(cframe)
	task.delay(0.08, function()
		if root and root.Parent then
			pcall(function()
				root.AssemblyLinearVelocity = Vector3.zero
				root.AssemblyAngularVelocity = Vector3.zero
			end)
		end
		if humanoid and humanoid.Parent then
			humanoid.Sit = false
			humanoid.PlatformStand = false
			pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.Running) end)
		end
	end)
	return true
end

local function TeleportToBase()
	return StableTeleport(CFrame.new(BASE_POSITION + Vector3.new(0, 4, 0)))
end

local function PressInteractKey(keyCode)
	if type(keypress) == "function" then
		local ok = pcall(keypress, keyCode)
		if ok then return true end
	end
	local ok = pcall(function() VirtualInputManager:SendKeyEvent(true, keyCode, false, game) end)
	return ok
end
local function ReleaseInteractKey(keyCode)
	if type(keyrelease) == "function" then
		local ok = pcall(keyrelease, keyCode)
		if ok then return true end
	end
	local ok = pcall(function() VirtualInputManager:SendKeyEvent(false, keyCode, false, game) end)
	return ok
end

local function FindKeyTool(keyName)
	local character = Player.Character
	local backpack = Player:FindFirstChildOfClass("Backpack")
	local inCharacter = character and character:FindFirstChild(keyName)
	if inCharacter and inCharacter:IsA("Tool") then return inCharacter end
	local inBackpack = backpack and backpack:FindFirstChild(keyName)
	if inBackpack and inBackpack:IsA("Tool") then return inBackpack end
	return nil
end

local function EquipKeyTool(keyName)
	local tool = FindKeyTool(keyName)
	if not tool then return false end
	local humanoid = Player.Character and Player.Character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return false end
	if tool.Parent ~= Player.Character then
		pcall(function() humanoid:EquipTool(tool) end)
	end
	return true
end

local function EquipAnyWeapon()
	local character = Player.Character
	if not character then return nil end
	for _, tool in ipairs(character:GetChildren()) do
		if tool:IsA("Tool") then
			local isKey = false
			for _, keyName in ipairs(KEY_TOOL_NAMES) do
				if tool.Name == keyName then isKey = true break end
			end
			if not isKey then return tool end
		end
	end
	local backpack = Player:FindFirstChildOfClass("Backpack")
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if backpack and humanoid then
		for _, tool in ipairs(backpack:GetChildren()) do
			if tool:IsA("Tool") then
				local isKey = false
				for _, keyName in ipairs(KEY_TOOL_NAMES) do
					if tool.Name == keyName then isKey = true break end
				end
				if not isKey then
					pcall(function() humanoid:EquipTool(tool) end)
					return tool
				end
			end
		end
	end
	return nil
end

local function FindOpenPrompt(target)
	local fallback = nil
	for _, descendant in ipairs(target:GetDescendants()) do
		if descendant:IsA("ProximityPrompt") then
			if not fallback then fallback = descendant end
			if tostring(descendant.ActionText):lower():find("open", 1, true) then return descendant end
		end
	end
	return fallback
end

local function AimCameraAtPrompt(anchorPosition)
	local camera = workspace.CurrentCamera
	if not camera then return end
	camera.CameraType = Enum.CameraType.Scriptable
	local character = Player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if root then
		camera.CFrame = CFrame.new(root.Position + Vector3.new(0, 3, 0), anchorPosition)
	end
end

local function RestoreCamera()
	local camera = workspace.CurrentCamera
	if not camera then return end
	camera.CameraType = Enum.CameraType.Custom
	local humanoid = Player.Character and Player.Character:FindFirstChildOfClass("Humanoid")
	if humanoid then camera.CameraSubject = humanoid end
end

local DRIFT_TOLERANCE = 4
local function HasDriftedAway(anchorPosition)
	local root = PlayerRoot()
	if not root then return true end
	return (root.Position - anchorPosition).Magnitude > DRIFT_TOLERANCE
end

-- Forward-declared so FindNearbyClaimPrompt (defined next) can reference it before it's
-- filled in, matching the old module's own forward-reference pattern.
local IsKeyDrop
function IsKeyDrop(part)
	for _, descendant in ipairs(part:GetDescendants()) do
		if descendant:IsA("TextLabel") or descendant:IsA("TextButton") then
			local text = tostring(descendant.Text)
			for _, keyName in ipairs(KEY_TOOL_NAMES) do
				if text == keyName then return true end
			end
		end
	end
	return false
end

local function HoldOnBox(target, options)
	options = options or {}
	local isEnabled = options.IsEnabled or function() return true end
	local boxType = BoxType(target)
	local requiredKey = boxType and BOX_TYPE_REQUIRED_KEY[boxType]
	if requiredKey then
		state.ToolInteractionActive = true
		if not EquipKeyTool(requiredKey) then
			state.ToolInteractionActive = false
			state.AutoTrapPhase = "Need " .. requiredKey
			return false
		end
	end

	local openPrompt = FindOpenPrompt(target)
	if not openPrompt then
		state.ToolInteractionActive = false
		return false
	end

	local promptPart = openPrompt.Parent
	local fallbackRoot = BoxRoot(target)
	local anchorBase = (promptPart and promptPart:IsA("BasePart") and promptPart.Position) or (fallbackRoot and fallbackRoot.Position) or Vector3.zero
	local anchorPosition = anchorBase + Vector3.new(0, 1, 0)
	StableTeleport(CFrame.new(anchorPosition))
	state.ToolInteractionActive = true
	AimCameraAtPrompt(anchorPosition)

	local waited = 0
	while waited < 1 and not openPrompt.Enabled do
		if HasDriftedAway(anchorPosition) then StableTeleport(CFrame.new(anchorPosition)) end
		task.wait(0.05)
		waited += 0.05
	end

	local keyCode = openPrompt.KeyboardKeyCode
	if not keyCode or keyCode == Enum.KeyCode.Unknown then keyCode = Enum.KeyCode.E end
	local holdDuration = openPrompt.HoldDuration > 0 and openPrompt.HoldDuration or BOX_OPEN_HOLD_DURATION
	local deadline = os.clock() + holdDuration + FARM_OPEN_SAFETY_BUFFER
	local pressed = false
	local usedFallback = false

	while isEnabled() and os.clock() < deadline and target.Parent and openPrompt.Parent do
		if HasDriftedAway(anchorPosition) then StableTeleport(CFrame.new(anchorPosition)) end
		AimCameraAtPrompt(anchorPosition)
		if not usedFallback then
			local ok = PressInteractKey(keyCode)
			pressed = ok
			if not ok then
				usedFallback = true
				if type(fireproximityprompt) == "function" then
					pcall(fireproximityprompt, openPrompt, holdDuration)
				end
			end
		end
		task.wait(FARM_MOVE_HOLD_INTERVAL)
		if not (target.Parent and BoxRoot(target)) then break end
	end

	if pressed then ReleaseInteractKey(keyCode) end
	RestoreCamera()
	state.ToolInteractionActive = false

	return not (target.Parent and BoxRoot(target))
end

local function FindNearbyClaimPrompt(position, radius)
	local best, bestDistance = nil, math.huge
	for _, descendant in ipairs(workspace:GetDescendants()) do
		if descendant:IsA("ProximityPrompt") and descendant.Enabled and tostring(descendant.ActionText):lower():find("claim", 1, true) then
			local part = descendant.Parent
			if part and part:IsA("BasePart") then
				local distance = (part.Position - position).Magnitude
				if distance <= radius and (IsKeyDrop(part) or IsRarityAllowed(GetDropRarity(part))) then
					if distance < bestDistance then
						best, bestDistance = descendant, distance
					end
				end
			end
		end
	end
	return best
end

local function ClaimNearbyDrop(boxPosition, options)
	options = options or {}
	local isEnabled = options.IsEnabled or function() return true end
	local deadline = os.clock() + FARM_CLAIM_SEARCH_TIMEOUT
	while isEnabled() and os.clock() < deadline do
		local prompt = FindNearbyClaimPrompt(boxPosition, FARM_CLAIM_SEARCH_RADIUS)
		if prompt then
			local part = prompt.Parent
			StableTeleport(CFrame.new(part.Position + Vector3.new(0, 1, 0)))
			task.wait(0.1)
			local keyCode = prompt.KeyboardKeyCode
			if not keyCode or keyCode == Enum.KeyCode.Unknown then keyCode = Enum.KeyCode.E end
			local pressed = PressInteractKey(keyCode)
			task.wait(0.3)
			if pressed then ReleaseInteractKey(keyCode) end
			if not pressed and type(fireproximityprompt) == "function" then
				pcall(fireproximityprompt, prompt)
			end
			task.wait(FARM_CLAIM_POST_FIRE_WAIT)
			if not prompt.Parent then return true end
		else
			return false
		end
	end
	return false
end

local function ClaimDropsNearArea(position, attempts, options)
	options = options or {}
	local isEnabled = options.IsEnabled or function() return true end
	task.wait(0.75)
	attempts = attempts or 6
	local misses = 0
	for _ = 1, attempts do
		if not isEnabled() then break end
		local claimed = ClaimNearbyDrop(position, {IsEnabled = isEnabled})
		if not claimed then
			misses += 1
			if misses >= 2 then break end
		else
			misses = 0
		end
	end
end

local function GetBackpackItemCount()
	local backpack = Player:FindFirstChildOfClass("Backpack")
	return backpack and #backpack:GetChildren() or 0
end

local function RunMissedItemSweep()
	local ok = pcall(function()
		local candidates = {}
		for _, part in ipairs(GetAllGroundItems()) do
			if part and part.Parent and (IsKeyDrop(part) or IsRarityAllowed(GetDropRarity(part))) then
				table.insert(candidates, part)
			end
		end
		if #candidates == 0 then return end

		local root = PlayerRoot()
		if root then
			table.sort(candidates, function(a, b)
				return (a.Position - root.Position).Magnitude < (b.Position - root.Position).Magnitude
			end)
		end

		state.AutoTrapPhase = "Sweeping missed items"
		state.AutoTrapPhaseStartedAt = os.clock()
		if RefreshButtons then RefreshButtons() end

		for index, part in ipairs(candidates) do
			if index > MAX_SWEEP_TARGETS then break end
			if not (state.AutoTrapEnabled and MainFrame.Parent) then break end
			if part and part.Parent then
				StableTeleport(CFrame.new(part.Position + Vector3.new(0, 3, 0)))
				task.wait(0.2)
				ClaimNearbyDrop(part.Position, {IsEnabled = function() return state.AutoTrapEnabled end})
			end
		end
	end)
	if not ok then
		warn("[UE Auto Trap] missed-item sweep failed, continuing")
	end
end

local function RunAutoSellStep()
	local backpack = Player:FindFirstChildOfClass("Backpack")
	if not backpack then return end

	state.ToolInteractionActive = true
	state.AutoTrapPhase = "Selling inventory"
	state.AutoTrapPhaseStartedAt = os.clock()
	if RefreshButtons then RefreshButtons() end

	local ok = pcall(function()
		local protectedTools = {}
		local character = Player.Character
		local equipped = character and character:FindFirstChildOfClass("Tool")
		if equipped then
			table.insert(protectedTools, {Tool = equipped, WasEquipped = true})
			equipped.Parent = nil
		end
		for _, tool in ipairs(backpack:GetChildren()) do
			for _, keyName in ipairs(KEY_TOOL_NAMES) do
				if tool.Name == keyName then
					table.insert(protectedTools, {Tool = tool, WasEquipped = false})
					tool.Parent = nil
				end
			end
		end

		StableTeleport(CFrame.new(SELLER_POSITION + Vector3.new(0, 2, 0)))
		task.wait(0.3)
		local sellerPart = workspace:FindFirstChild("Base") and workspace.Base:FindFirstChild("Seller")
		local prompt = sellerPart and sellerPart:FindFirstChildOfClass("ProximityPrompt")
		if prompt and type(fireproximityprompt) == "function" then
			pcall(fireproximityprompt, prompt)
		end
		local sellRemote = ReplicatedStorage:FindFirstChild("SellRemote")
		if sellRemote then pcall(function() sellRemote:FireServer("AllItems") end) end
		task.wait(AUTO_SELL_SETTLE_WAIT)

		for _, entry in ipairs(protectedTools) do
			pcall(function()
				if entry.Tool and entry.Tool.Parent == nil then
					local currentCharacter = Player.Character
					local currentBackpack = Player:FindFirstChildOfClass("Backpack")
					entry.Tool.Parent = (entry.WasEquipped and currentCharacter) or currentBackpack or currentCharacter
				end
			end)
		end
	end)
	if not ok then
		warn("[UE Auto Trap] auto-sell step failed, resuming normal operation")
	end

	state.ToolInteractionActive = false
	state.AutoTrapPhase = "Idle"
	if RefreshButtons then RefreshButtons() end
end

local function FightEnemies(targetPosition, enemyNames)
	state.AutoTrapPhase = "Fighting"
	local lastSeenAt = os.clock()
	while state.AutoTrapEnabled and MainFrame.Parent do
		local enemies = GetActiveEnemies(enemyNames)
		if #enemies == 0 then
			if os.clock() - lastSeenAt > TRAP_WAVE_CLEAR_GRACE then return end
		else
			lastSeenAt = os.clock()
			local root = PlayerRoot()
			if not root then
				task.wait(TRAP_RESPAWN_WAIT)
				root = PlayerRoot()
				if root then StableTeleport(CFrame.new(targetPosition + Vector3.new(0, 4, 0))) end
			else
				table.sort(enemies, function(a, b)
					local aRoot = a:FindFirstChild("HumanoidRootPart")
					local bRoot = b:FindFirstChild("HumanoidRootPart")
					if not aRoot then return false end
					if not bRoot then return true end
					return (aRoot.Position - root.Position).Magnitude < (bRoot.Position - root.Position).Magnitude
				end)
				local closest = enemies[1]
				local targetRoot = closest:FindFirstChild("HumanoidRootPart")
				if targetRoot then
					local direction = (root.Position - targetRoot.Position)
					direction = Vector3.new(direction.X, 0, direction.Z)
					if direction.Magnitude < 0.01 then direction = Vector3.new(1, 0, 0) end
					local standoff = targetRoot.Position + direction.Unit * TRAP_COMBAT_STANDOFF
					local facePosition = Vector3.new(standoff.X, targetRoot.Position.Y, standoff.Z)
					root.CFrame = CFrame.new(facePosition, targetRoot.Position)
					pcall(function()
						root.AssemblyLinearVelocity = Vector3.zero
						root.AssemblyAngularVelocity = Vector3.zero
					end)
					local tool = EquipAnyWeapon()
					local mouseClick = ReplicatedStorage:FindFirstChild("MouseClick")
					if tool and mouseClick then
						pcall(function() mouseClick:FireServer(tool.Name, CFrame.new(targetRoot.Position)) end)
					end
				end
			end
		end
		task.wait(TRAP_COMBAT_FIRE_INTERVAL)
	end
end

-- Idle-sweep candidates deliberately bypass state.SelectedBoxTypes (the Box ESP filter
-- checkboxes) -- that filter only controls what's highlighted, and defaults every type to
-- Off, so gating the farm loop on it silently starved crate-clearing. Also skips Hunter Trap
-- boxes and any structure with a still-pending encounter so the queue-driven trigger/fight
-- flow below isn't shortcut by grabbing its crate directly.
local function GetIdleSweepBoxTargets()
	local folder = StructuresFolder()
	if not folder then return {} end
	local targets = {}
	for _, structure in ipairs(folder:GetChildren()) do
		local isUnhandledEncounter = MatchEncounter(structure) and not state.AutoTrapHandled[structure]
		if not isUnhandledEncounter then
			local lootFolder = structure:FindFirstChild("Loot")
			if lootFolder then
				for _, box in ipairs(lootFolder:GetChildren()) do
					if BoxRoot(box) and BoxType(box) ~= "Hunter Trap" then
						table.insert(targets, box)
					end
				end
			end
			for _, child in ipairs(structure:GetChildren()) do
				if child.Name ~= "Loot" and BoxTypeFromName(child.Name) and BoxType(child) ~= "Hunter Trap" then
					table.insert(targets, child)
				end
			end
		end
	end
	return targets
end

local function RunAutoTrapStep()
	local isEnabledFn = function() return state.AutoTrapEnabled end
	if #state.AutoTrapQueue == 0 then
		-- Idle sweep: regular loot boxes not tied to a pending encounter.
		state.AutoTrapPhase = "Clearing crates"
		if RefreshButtons then RefreshButtons() end
		local boxes = GetIdleSweepBoxTargets()
		local root = PlayerRoot()
		if not root or #boxes == 0 then
			state.AutoTrapPhase = "Idle"
			return
		end
		local now = os.clock()
		local best, bestDistance = nil, math.huge
		for _, box in ipairs(boxes) do
			local cooldownUntil = state.AutoTrapSweepSkipped[box]
			if not (cooldownUntil and now < cooldownUntil) then
				local root2 = BoxRoot(box)
				if root2 then
					local distance = (root2.Position - root.Position).Magnitude
					if distance < bestDistance then best, bestDistance = box, distance end
				end
			end
		end
		if best then
			local success = HoldOnBox(best, {IsEnabled = isEnabledFn})
			if success then
				ClaimDropsNearArea(BoxRoot(best) and BoxRoot(best).Position or root.Position, 6, {IsEnabled = isEnabledFn})
			else
				state.AutoTrapSweepSkipped[best] = now + FARM_SKIP_COOLDOWN
			end
		end
		if state.AutoTrapEnabled and #state.AutoTrapQueue == 0 then
			state.AutoTrapPhase = "Idle"
			if RefreshButtons then RefreshButtons() end
		end
		return
	end

	local entry = table.remove(state.AutoTrapQueue, 1)
	local structure, encounter = entry.Structure, entry.Encounter
	if not structure.Parent then return end

	local triggerPosition = encounter.TriggerPart(structure)
	if not triggerPosition then
		warn("[UE Auto Trap] could not find a trigger part on " .. tostring(structure.Name) .. " (" .. encounter.Key .. ")")
		return
	end

	local foundEnemies = false
	for _ = 1, TRAP_TRIGGER_ATTEMPTS do
		if not state.AutoTrapEnabled then break end
		state.AutoTrapPhase = "Triggering " .. encounter.Key
		if RefreshButtons then RefreshButtons() end
		StableTeleport(CFrame.new(triggerPosition + Vector3.new(0, 4, 0)))
		task.wait(TRAP_TRIGGER_WAIT)
		state.AutoTrapPhase = "Waiting for enemies"
		if RefreshButtons then RefreshButtons() end
		local waited = 0
		while waited < TRAP_HUNTER_SCAN_WINDOW and state.AutoTrapEnabled do
			if #GetActiveEnemies(encounter.EnemyNames) > 0 then foundEnemies = true break end
			task.wait(0.25)
			waited += 0.25
		end
		if foundEnemies then break end
		warn("[UE Auto Trap] no enemies spawned for " .. encounter.Key .. ", retrying")
	end

	if not foundEnemies then
		warn("[UE Auto Trap] giving up on " .. tostring(structure.Name) .. " (" .. encounter.Key .. ") after " .. TRAP_TRIGGER_ATTEMPTS .. " attempts")
		state.AutoTrapPhase = "Idle"
		if RefreshButtons then RefreshButtons() end
		return
	end

	state.AutoTrapPhase = "Fighting"
	if RefreshButtons then RefreshButtons() end
	FightEnemies(triggerPosition, encounter.EnemyNames)

	if encounter.LootAttempts > 0 then
		state.AutoTrapPhase = "Looting " .. encounter.Key
		if RefreshButtons then RefreshButtons() end
		ClaimDropsNearArea(triggerPosition, encounter.LootAttempts, {IsEnabled = isEnabledFn})

		state.AutoTrapPhase = "Opening " .. encounter.Key .. " crate"
		if RefreshButtons then RefreshButtons() end
		local lootFolder = structure:FindFirstChild("Loot")
		if lootFolder then
			for _, box in ipairs(lootFolder:GetChildren()) do
				local boxType = BoxType(box)
				if boxType and BOX_TYPE_REQUIRED_KEY[boxType] then
					if HoldOnBox(box, {IsEnabled = isEnabledFn}) then
						ClaimDropsNearArea(BoxRoot(box) and BoxRoot(box).Position or triggerPosition, 6, {IsEnabled = isEnabledFn})
					end
				end
			end
		end
	end

	state.AutoTrapPhase = "Returning to base"
	if RefreshButtons then RefreshButtons() end
	local returnRoot = PlayerRoot()
	if returnRoot then TeleportToBase() end
	state.AutoTrapKilled += 1
	state.AutoTrapPhase = "Idle"
	if RefreshButtons then RefreshButtons() end
end

local function SetAutoTrapEnabled(enabled)
	state.AutoTrapEnabled = enabled == true
	if not state.AutoTrapEnabled then state.AutoTrapPhase = "Idle" end
end


TrackConnection("UndeadExpeditionCandidateAdded", workspace.DescendantAdded:Connect(function(obj)
	if not state.EnemyESP then return end
	AddCandidateFromDescendant(obj)
end))

TrackConnection("UndeadExpeditionESPHeartbeat", RunService.Heartbeat:Connect(function()
	if not uePage.Parent then return end
	local now = os.clock()
	if state.NoDarkness and now - (state.LastLightingApply or 0) >= 1.5 then
		state.LastLightingApply = now
		ApplyNoDarkness()
	end
	if now - (state.LastScan or 0) < 0.5 then return end
	state.LastScan = now
	UpdateESP()
	RefreshButtons()
end))


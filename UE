-- laying out filter sections inside it. Reused by both the Auto Farm pickup Filter popup
-- and the ESP Options popup further below, so both read as the same visual language
-- instead of two different one-off designs.
local Green = Color3.fromRGB(38, 190, 92)
local Red = Color3.fromRGB(220, 42, 58)

-- Smooths wheel-scrolling on a ScrollingFrame by tweening CanvasPosition toward a running
-- target instead of relying on Roblox's default instant per-notch jump. Trades away
-- scrollbar-thumb dragging (ScrollingEnabled has to be off so native handling doesn't
-- fight the tween) for wheel/touch scrolling that doesn't stutter.
-- Disabling native ScrollingEnabled to replace wheel input with a tween turned out to kill
-- scrolling entirely in-game (neither wheel nor the scrollbar worked) rather than just
-- losing thumb-drag as expected, so this is back to native scrolling. Left as a named
-- no-op (rather than ripping out the call site) in case a safer smoothing approach is
-- worth trying later.
local function SmoothScroll(_scrollFrame, _step)
end

-- Only one docked popup (Auto Farm's Pickup Filter, ESP's Options) is ever open at once --
-- opening one force-closes whichever other one was already open.
local ManagedPopups = {}
local function ToggleManagedPopup(dock)
	local opening = not dock.Visible
	for _, other in ipairs(ManagedPopups) do
		other.Visible = false
	end
	dock.Visible = opening
end


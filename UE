	pcall(function()
		firetouchinterest(partA, partB, 0)
		firetouchinterest(partA, partB, 1)
	end)
	pcall(function()
		firetouchinterest(partB, partA, 0)
		firetouchinterest(partB, partA, 1)
	end)
end


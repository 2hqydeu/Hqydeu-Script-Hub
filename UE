local function HasHunterTrapText(name)
	local lower = tostring(name or ""):lower()
	return lower:find("hunter", 1, true) and lower:find("trap", 1, true)
end

local function BoxTypeFromName(name)
	local lower = tostring(name or ""):lower()
	if HasHunterTrapText(lower) then return "Hunter Trap" end
	for _, boxType in ipairs(BOX_TYPES) do
		if lower:find(boxType:lower(), 1, true) then return boxType end
	end
	return nil
end

local function BoxType(box)
	local direct = BoxTypeFromName(box.Name)
	if direct then return direct end
	for _, descendant in ipairs(box:GetDescendants()) do
		if descendant:IsA("StringValue") or descendant:IsA("TextLabel") or descendant:IsA("TextButton") then
			local text = descendant:IsA("StringValue") and descendant.Value or descendant.Text
			local found = BoxTypeFromName(text)
			if found then return found end
		end
	end
	return nil
end

local function HunterTrapPart(box)
	if not box then return nil end
	if box:IsA("BasePart") and box.Name:lower() == "string" then return box end
	local direct = box:FindFirstChild("string")
	if direct and direct:IsA("BasePart") then return direct end
	for _, child in ipairs(box:GetDescendants()) do
		if child:IsA("BasePart") and child.Name:lower() == "string" then
			return child
		end
	end
	return nil
end

local function BoxRoot(box)
	if HasHunterTrapText(box.Name) then
		local part = HunterTrapPart(box)
		if part then return part end
	end
	if box:IsA("BasePart") then return box end
	return box.PrimaryPart or box:FindFirstChildWhichIsA("BasePart", true)
end

local function IsBoxAllowed(box)
	local boxType = BoxType(box)
	return boxType ~= nil and state.SelectedBoxTypes[boxType] ~= false
end

local function CollectLootBoxes()
	local folder = StructuresFolder()
	if not folder then return {} end
	local boxes = {}
	local seen = {}
	local function addCandidate(candidate)
		if not candidate or seen[candidate] then return end
		if BoxRoot(candidate) and IsBoxAllowed(candidate) then
			seen[candidate] = true
			table.insert(boxes, candidate)
		end
	end
	for _, structure in ipairs(folder:GetChildren()) do
		local lootFolder = structure:FindFirstChild("Loot")
		if lootFolder then
			for _, box in ipairs(lootFolder:GetChildren()) do
				addCandidate(box)
			end
		end
		for _, child in ipairs(structure:GetChildren()) do
			if child.Name ~= "Loot" and BoxTypeFromName(child.Name) then
				addCandidate(child)
			end
		end
		if state.SelectedBoxTypes["Hunter Trap"] ~= false then
			for _, descendant in ipairs(structure:GetDescendants()) do
				if HasHunterTrapText(descendant.Name) then
					addCandidate(descendant)
				end
			end
		end
	end
	return boxes
end

local function GetAllMobs()
	local folder = workspace:FindFirstChild("Enemies")
	if not folder then return {} end
	local mobs = {}
	for _, mob in ipairs(folder:GetChildren()) do
		local humanoid = mob:FindFirstChildOfClass("Humanoid")
		if humanoid and humanoid.Health > 0 then table.insert(mobs, mob) end
	end
	return mobs
end

local function GetAllGroundItems()
	local items = {}
	for _, descendant in ipairs(workspace:GetDescendants()) do
		if descendant:IsA("ProximityPrompt") and descendant.Enabled and tostring(descendant.ActionText):lower():find("claim", 1, true) then
			local part = descendant.Parent
			if part and part:IsA("BasePart") then table.insert(items, part) end
		end
	end
	return items
end

local function GetActiveEnemies(enemyNames)
	local results = {}
	for _, mob in ipairs(GetAllMobs()) do
		local lowerName = mob.Name:lower()
		for _, wanted in ipairs(enemyNames) do
			if lowerName:find(wanted, 1, true) then
				table.insert(results, mob)
				break
			end
		end
	end
	return results
end

----------------------------------------------------------------------
-- ESP rendering (ported, generic category renderer)
----------------------------------------------------------------------
local ESPFolder = Instance.new("Folder")
ESPFolder.Name = "SerenityUEESP"
ESPFolder.Parent = ScreenGui

local function ClearESPCategory(objects)
	for target, entry in pairs(objects) do
		if entry.Highlight then entry.Highlight:Destroy() end
		if entry.Billboard then entry.Billboard:Destroy() end
		objects[target] = nil
	end
end

local function RunESPCategory(objects, targets, colorFn, labelFn, maxObjects)
	local seen = {}
	local rootPos = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
	rootPos = rootPos and rootPos.Position

	if maxObjects and rootPos then
		table.sort(targets, function(a, b)
			local aRoot = StructureRoot(a) or a
			local bRoot = StructureRoot(b) or b
			local aPos = aRoot:IsA("BasePart") and aRoot.Position or Vector3.zero
			local bPos = bRoot:IsA("BasePart") and bRoot.Position or Vector3.zero
			return (aPos - rootPos).Magnitude < (bPos - rootPos).Magnitude
		end)
	end

	for index, target in ipairs(targets) do
		if maxObjects and index > maxObjects then break end
		local root = StructureRoot(target) or (target:IsA("BasePart") and target)
		if root then
			seen[target] = true
			local entry = objects[target]
			if not entry then
				local highlight = Instance.new("Highlight")
				highlight.FillTransparency = 0.9
				highlight.OutlineTransparency = 0.03
				highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
				highlight.Adornee = target
				highlight.Parent = ESPFolder

				local billboard = Instance.new("BillboardGui")
				billboard.Size = UDim2.new(0, 160, 0, 18)
				billboard.StudsOffset = Vector3.new(0, 2, 0)
				billboard.AlwaysOnTop = true
				billboard.Adornee = root
				billboard.Parent = ESPFolder

				local label = Instance.new("TextLabel")
				label.Size = UDim2.new(1, 0, 1, 0)
				label.BackgroundTransparency = 1
				label.Font = UIFont
				label.TextSize = 12
				label.TextStrokeTransparency = 0.4
				label.Parent = billboard

				entry = {Highlight = highlight, Billboard = billboard, Label = label}
				objects[target] = entry
			end
			local color = colorFn(target)
			entry.Highlight.FillColor = color
			entry.Highlight.OutlineColor = color
			entry.Label.TextColor3 = color
			local distance = rootPos and (root.Position - rootPos).Magnitude or 0
			entry.Label.Text = labelFn(target, math.floor(distance))
		end
	end

	for target in pairs(objects) do
		if not seen[target] then
			local entry = objects[target]
			if entry.Highlight then entry.Highlight:Destroy() end
			if entry.Billboard then entry.Billboard:Destroy() end
			objects[target] = nil
		end
	end
end

local function UpdateBoxESP()
	if not state.BoxESP then return end
	local boxes = CollectLootBoxes()
	RunESPCategory(state.BoxObjects, boxes, function(box)
		return BOX_TYPE_COLORS[BoxType(box)] or Color3.fromRGB(255, 255, 255)
	end, function(box, distance)
		return string.format("%s [%d Studs]", BoxType(box) or box.Name, distance)
	end, MAX_BOX_OBJECTS)
end

local function ClearBoxESP()
	ClearESPCategory(state.BoxObjects)
end

local function UpdateMobsESP()
	if not state.ESPMobsEnabled then
		ClearESPCategory(state.MobsESPObjects)
		return
	end
	RunESPCategory(state.MobsESPObjects, GetAllMobs(), function()
		return Color3.fromRGB(220, 60, 60)
	end, function(mob, distance)
		return string.format("%s [%d Studs]", mob.Name, distance)
	end, nil)
end

local function UpdateStructuresESP()
	if not IsAnyStructureTypeSelected() then
		ClearESPCategory(state.StructuresESPObjects)
		return
	end
	local folder = StructuresFolder()
	local targets = {}
	if folder then
		for _, structure in ipairs(folder:GetChildren()) do
			local displayName = StructureDisplayName(structure)
			if state.SelectedStructureTypes[StructureFilterKey(displayName)] then
				table.insert(targets, structure)
			end
		end
	end
	RunESPCategory(state.StructuresESPObjects, targets, function(structure)
		return GetStructureColor(StructureDisplayName(structure))
	end, function(structure, distance)
		return string.format("%s [%d Studs]", StructureDisplayName(structure), distance)
	end, nil)
end

local function UpdateItemsESP()
	if not IsAnyESPRaritySelected() then
		ClearESPCategory(state.ItemsESPObjects)
		return
	end
	local targets = {}
	for _, item in ipairs(GetAllGroundItems()) do
		local rarity = GetDropRarity(item)
		if rarity and state.ESPSelectedRarities[rarity] then table.insert(targets, item) end
	end
	RunESPCategory(state.ItemsESPObjects, targets, function(item)
		return GetRarityColor(GetDropRarity(item))
	end, function(item, distance)
		return string.format("%s [%d Studs]", GetDropRarity(item) or "Item", distance)
	end, nil)
end

----------------------------------------------------------------------
-- Lighting override (No Darkness) -- ported
----------------------------------------------------------------------
local function SafeGet(object, property)
	local ok, value = pcall(function() return object[property] end)
	if ok then return value end
	return nil
end
local function SafeSet(object, property, value)
	pcall(function() object[property] = value end)
end

local lightingEffectProperties = {
	Atmosphere = {"Density", "Offset", "Color", "Decay", "Glare", "Haze"},
	ColorCorrectionEffect = {"Enabled", "Brightness", "Contrast", "Saturation", "TintColor"},
	BloomEffect = {"Enabled", "Intensity", "Size", "Threshold"},
	BlurEffect = {"Enabled", "Size"},
	DepthOfFieldEffect = {"Enabled", "FarIntensity", "FocusDistance", "InFocusRadius", "NearIntensity"},
	SunRaysEffect = {"Enabled", "Intensity", "Spread"},
}

local function LightingEffectClass(instance)
	for className in pairs(lightingEffectProperties) do
		if instance:IsA(className) then return className end
	end
	return nil
end

local function CaptureLightingEffectDefaults(effect, original)
	local className = LightingEffectClass(effect)
	if not className then return end
	original.Effects = original.Effects or {}
	if original.Effects[effect] then return end
	local saved = {}
	for _, property in ipairs(lightingEffectProperties[className]) do
		local value = SafeGet(effect, property)
		if value ~= nil then saved[property] = value end
	end
	original.Effects[effect] = saved
end

local function IsNoDarknessLighting()
	return Lighting.Brightness >= 3.8
		and Lighting.FogEnd >= 900000
		and Lighting.Ambient.R > 0.95
		and Lighting.OutdoorAmbient.R > 0.95
end

local function BuildLightingSnapshot()
	local snapshot = {
		ClockTime = Lighting.ClockTime,
		TimeOfDay = SafeGet(Lighting, "TimeOfDay"),
		Brightness = Lighting.Brightness,
		FogEnd = Lighting.FogEnd,
		FogStart = Lighting.FogStart,
		FogColor = Lighting.FogColor,
		Ambient = Lighting.Ambient,
		OutdoorAmbient = Lighting.OutdoorAmbient,
		ExposureCompensation = Lighting.ExposureCompensation,
		GlobalShadows = SafeGet(Lighting, "GlobalShadows"),
		Effects = {},
	}
	for _, child in ipairs(Lighting:GetChildren()) do
		CaptureLightingEffectDefaults(child, snapshot)
	end
	return snapshot
end

local function SaveLightingDefaults()
	if not IsNoDarknessLighting() then
		state.OriginalLighting = BuildLightingSnapshot()
	end
end

local function ApplyNoDarkness()
	SaveLightingDefaults()
	SafeSet(Lighting, "ClockTime", 14)
	SafeSet(Lighting, "TimeOfDay", "14:00:00")
	SafeSet(Lighting, "Brightness", 4)
	SafeSet(Lighting, "FogStart", 0)
	SafeSet(Lighting, "FogEnd", 1000000)
	SafeSet(Lighting, "FogColor", Color3.fromRGB(255, 255, 255))
	SafeSet(Lighting, "Ambient", Color3.fromRGB(255, 255, 255))
	SafeSet(Lighting, "OutdoorAmbient", Color3.fromRGB(255, 255, 255))
	SafeSet(Lighting, "ExposureCompensation", 0.45)
	SafeSet(Lighting, "GlobalShadows", false)
	for _, child in ipairs(Lighting:GetChildren()) do
		CaptureLightingEffectDefaults(child, state.OriginalLighting)
		if child:IsA("Atmosphere") then
			SafeSet(child, "Density", 0)
			SafeSet(child, "Haze", 0)
			SafeSet(child, "Glare", 0)
			SafeSet(child, "Offset", 0)
			SafeSet(child, "Color", Color3.fromRGB(255, 255, 255))
			SafeSet(child, "Decay", Color3.fromRGB(255, 255, 255))
		elseif child:IsA("ColorCorrectionEffect") then
			SafeSet(child, "Enabled", false)
			SafeSet(child, "Brightness", 0)
			SafeSet(child, "Contrast", 0)
			SafeSet(child, "Saturation", 0)
			SafeSet(child, "TintColor", Color3.fromRGB(255, 255, 255))
		elseif child:IsA("BloomEffect") or child:IsA("BlurEffect") or child:IsA("DepthOfFieldEffect") or child:IsA("SunRaysEffect") then
			SafeSet(child, "Enabled", false)
		end
	end
end

local function RestoreLighting()
	local original = state.OriginalLighting
	if not original then
		SafeSet(Lighting, "ClockTime", 12)
		SafeSet(Lighting, "TimeOfDay", "12:00:00")
		SafeSet(Lighting, "Brightness", 2)
		SafeSet(Lighting, "FogStart", 0)
		SafeSet(Lighting, "FogEnd", 100000)
		SafeSet(Lighting, "Ambient", Color3.fromRGB(128, 128, 128))
		SafeSet(Lighting, "OutdoorAmbient", Color3.fromRGB(128, 128, 128))
		SafeSet(Lighting, "ExposureCompensation", 0)
		SafeSet(Lighting, "GlobalShadows", true)
		return
	end
	for property, value in pairs(original) do
		if property ~= "Effects" then SafeSet(Lighting, property, value) end
	end
	for effect, properties in pairs(original.Effects or {}) do
		if typeof(effect) == "Instance" and effect.Parent then
			for property, value in pairs(properties) do
				SafeSet(effect, property, value)
			end
		end
	end
end

local function SetNoDarkness(enabled)
	state.NoDarkness = enabled == true
	if state.NoDarkness then
		ApplyNoDarkness()
	else
		RestoreLighting()
		state.OriginalLighting = nil
	end
end


local function WatchWorkspaceContainer(name, handler)
	local container = WorkspaceContainer(name)
	if not container then return end
	local existing = state.ContainerWatchers[name]
	if existing and existing.Container == container then return end
	if existing and existing.Connection then existing.Connection:Disconnect() end
	state.ContainerWatchers[name] = {
		Container = container,
		Connection = container.DescendantAdded:Connect(handler),
	}
end


local function CleanStructureName(name)
	name = tostring(name or ""):gsub("^%s+", ""):gsub("%s+$", ""):gsub("%s+", " ")
	name = name:gsub("%s*%(%d+%)$", ""):gsub("[%s_%-%#]*%d+$", "")
	return name
end

local function StructureDisplayName(structure)
	local rawName = structure.Name
	if tostring(rawName):lower():find("cave", 1, true) then return "Cave" end
	local displayAttr = structure:GetAttribute("DisplayName") or structure:GetAttribute("StructureName") or structure:GetAttribute("Name")
	if displayAttr then return CleanStructureName(tostring(displayAttr)) end
	local nameValue = structure:FindFirstChild("Name")
	if nameValue and nameValue:IsA("StringValue") and nameValue.Value ~= "" then
		return CleanStructureName(nameValue.Value)
	end
	return CleanStructureName(rawName)
end

local function StructureRoot(structure)
	if structure:IsA("BasePart") then return structure end
	return structure.PrimaryPart or structure:FindFirstChildWhichIsA("BasePart", true)
end

local function RegisterKnownStructureType(displayName)
	local key = StructureFilterKey(displayName)
	for _, existing in ipairs(state.KnownStructureTypes) do
		if existing == key then return end
	end
	table.insert(state.KnownStructureTypes, key)
	if state.SelectedStructureTypes[key] == nil then state.SelectedStructureTypes[key] = false end
end

local function StructuresFolder()
	return workspace:FindFirstChild("Structures")
end


----------------------------------------------------------------------
-- Background loops: auto-farm stepper, watchdog, self-defense
----------------------------------------------------------------------
task.spawn(function()
	while MainFrame.Parent do
		if state.AutoTrapEnabled then
			local ok, err = pcall(function()
				if GetBackpackItemCount() >= AUTO_SELL_THRESHOLD then
					RunMissedItemSweep()
					RunAutoSellStep()
				else
					ScanForExistingTrapStructures()
					RunAutoTrapStep()
				end
			end)
			if not ok then
				warn("[UE Auto Trap] step error: " .. tostring(err))
				state.ToolInteractionActive = false
				state.AutoTrapPhase = "Idle"
			end
			RefreshButtons()
		end
		task.wait(TRAP_IDLE_WAIT)
	end
end)

task.spawn(function()
	while MainFrame.Parent do
		if state.AutoTrapEnabled then
			local phase = tostring(state.AutoTrapPhase or "")
			if phase == "Selling inventory" or phase == "Sweeping missed items" then
				local startedAt = tonumber(state.AutoTrapPhaseStartedAt) or 0
				if startedAt > 0 and os.clock() - startedAt > 20 then
					warn("[UE Auto Trap] watchdog: phase stuck on \"" .. phase .. "\" for 20s+, forcing reset")
					state.AutoTrapPhase = "Idle"
					state.ToolInteractionActive = false
					if RefreshButtons then RefreshButtons() end
				end
			end
		end
		task.wait(5)
	end
end)

task.spawn(function()
	while MainFrame.Parent do
		if state.AutoTrapEnabled and not state.ToolInteractionActive then
			local root = PlayerRoot()
			if root then
				local nearby = GetActiveEnemies({"hunter", "grounder", "pharaon", "mummy"})
				for _, mob in ipairs(nearby) do
					local mobRoot = mob:FindFirstChild("HumanoidRootPart")
					if mobRoot and (mobRoot.Position - root.Position).Magnitude <= SELF_DEFENSE_RADIUS then
						local tool = EquipAnyWeapon()
						local mouseClick = ReplicatedStorage:FindFirstChild("MouseClick")
						if tool and mouseClick then
							pcall(function() mouseClick:FireServer(tool.Name, CFrame.new(mobRoot.Position)) end)
						end
						task.wait(SELF_DEFENSE_FIRE_INTERVAL)
						break
					end
				end
			end
		end
		task.wait(0.25)
	end
end)


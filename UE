local function AddText(obj)
	table.insert(ThemeObjects.Texts, obj)
	return obj
end

local function AddBackground(obj)
	table.insert(ThemeObjects.Backgrounds, obj)
	return obj
end

local function EnsureControlOutline(obj)
	if not obj then return obj end
	local outline = obj:FindFirstChild("ControlOutline")
	if not outline then
		outline = Instance.new("UIStroke")
		outline.Name = "ControlOutline"
		outline.Parent = obj
	end
	if outline:IsA("UIStroke") then
		outline.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
		outline.Color = Color3.fromRGB(0, 0, 0)
		outline.Thickness = 1.25
		outline.Transparency = 0
	end
	return obj
end

local function CreateRow(name, y)
	local row = Instance.new("Frame")
	row.Name = name
	row.Size = UDim2.new(1, -24, 0, 38)
	row.Position = UDim2.new(0, 12, 0, y)
	row.BackgroundColor3 = Color3.fromRGB(65, 65, 67)
	row.BackgroundTransparency = 0.92
	row.BorderSizePixel = 0
	row.Parent = uePage
	AddBackground(row)
	Instance.new("UICorner", row).CornerRadius = UDim.new(0, 6)
	return row
end

local function CreateTitle(parent, text)
	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(0, 150, 0, 24)
	title.Position = UDim2.new(0, 12, 0, 7)
	title.BackgroundTransparency = 1
	title.Text = text
	title.Font = Enum.Font.GothamBold
	title.TextSize = 11
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.Parent = parent
	return AddText(title)
end

local function CreateButton(parent, name, text, xOffset, width)
	local button = Instance.new("TextButton")
	button.Name = name
	button.Size = UDim2.new(0, width, 0, 22)
	button.Position = UDim2.new(1, xOffset, 0, 8)
	button.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
	button.BackgroundTransparency = 0.8
	button.BorderSizePixel = 0
	button.Text = text
	button.Font = Enum.Font.GothamBold
	button.TextSize = 9
	button.Parent = parent
	AddBackground(button)
	AddText(button)
	Instance.new("UICorner", button).CornerRadius = UDim.new(0, 5)
	EnsureControlOutline(button)
	return button
end


local function WeaponRank(weapon)
	if not weapon then return -1 end
	local lower = string.lower(weapon.Name)
	local character = Player and Player.Character
	local rank = weapon.Parent == character and 3 or 0
	for _, term in ipairs({"sword", "blade", "katana", "knife", "axe", "scythe", "spear", "club", "bat", "mace", "hammer", "weapon", "gun", "bow"}) do
		if lower:find(term, 1, true) then
			rank += 100
			break
		end
	end
	if lower:find("sword", 1, true) or lower:find("blade", 1, true) or lower:find("katana", 1, true) then rank += 35 end
	if lower == "diamond" or lower == "diamondmodel" then rank += 160 end
	if lower:find("diamond", 1, true) then rank += 45 end
	for _, term in ipairs({"trap", "box", "crate", "potion", "food", "bait", "item", "key", "ancient"}) do
		if lower:find(term, 1, true) then
			rank -= 25
			break
		end
	end
	if weapon:IsA("Tool") then rank += 20 end
	if weapon:IsA("Model") then rank += 10 end
	if weapon:IsA("BasePart") then rank += 8 end
	if weapon:FindFirstChild("Handle", true) then rank += 4 end
	if weapon:FindFirstChildWhichIsA("BasePart", true) then rank += 2 end
	return rank
end

local function AddUnique(list, seen, instance)
	if instance and not seen[instance] then
		seen[instance] = true
		table.insert(list, instance)
	end
end

local function CollectCombatWeaponCandidates()
	local character = Player and Player.Character
	local backpack = Player and Player:FindFirstChild("Backpack")
	local candidates = {}
	local seen = {}
	local containers = {}
	if character then table.insert(containers, character) end
	if backpack then table.insert(containers, backpack) end
	for _, container in ipairs(containers) do
		for _, exactName in ipairs({"Diamond", "DiamondModel", "Diamond Sword", "DiamondSword"}) do
			AddUnique(candidates, seen, container:FindFirstChild(exactName))
		end
		for _, child in ipairs(container:GetChildren()) do
			if child:IsA("Tool") or child:IsA("Model") or child:IsA("BasePart") then
				AddUnique(candidates, seen, child)
			end
		end
	end
	return candidates
end

local function EquipCombatWeapon()
	local character = Player and Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not character or not humanoid or humanoid.Health <= 0 then return nil end
	local bestWeapon
	local bestRank = -1
	for _, candidate in ipairs(CollectCombatWeaponCandidates()) do
		local rank = WeaponRank(candidate)
		if rank > bestRank then
			bestRank = rank
			bestWeapon = candidate
		end
	end
	if bestWeapon and bestWeapon:IsA("Tool") and bestWeapon.Parent ~= character then
		pcall(function() humanoid:EquipTool(bestWeapon) end)
	end
	return bestWeapon
end

local function CollectActiveWeaponObjects(preferred)
	local weapons = {}
	local seen = {}
	AddUnique(weapons, seen, preferred)
	for _, candidate in ipairs(CollectCombatWeaponCandidates()) do
		if WeaponRank(candidate) >= 50 then
			AddUnique(weapons, seen, candidate)
		end
	end
	return weapons
end

local function FireTouch(partA, partB)

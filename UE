-- A compact filter checklist: one heading + a wrap of small pill toggles, one per entry
-- in `items` (a list of names). `getSelected`/`setSelected` read/write the backing
-- state table. Returns the section's total height so callers can stack sections.
local function CreateFilterSection(parent, y, headingText, items, getSelected, setSelected, onChanged)
	CreateSectionHeading(parent, y, headingText)
	local pillsPerRow = 3
	local pillWidth = 118
	local pillHeight = 26
	local gap = 6
	local rows = math.ceil(#items / pillsPerRow)
	for index, itemName in ipairs(items) do
		local col = (index - 1) % pillsPerRow
		local row = math.floor((index - 1) / pillsPerRow)
		local pill = Instance.new("TextButton")
		pill.Size = UDim2.new(0, pillWidth, 0, pillHeight)
		pill.Position = UDim2.new(0, col * (pillWidth + gap), 0, y + 26 + (row * (pillHeight + gap)))
		pill.BackgroundColor3 = getSelected(itemName) and AccentColor or Color3.fromRGB(60, 60, 60)
		pill.BackgroundTransparency = getSelected(itemName) and 0.75 or 0.2
		pill.BorderSizePixel = 0
		pill.Text = itemName
		pill.Font = UIFont
		pill.TextSize = 12
		pill.TextColor3 = Color3.fromRGB(255, 255, 255)
		pill.TextTruncate = Enum.TextTruncate.AtEnd
		pill.Parent = parent
		Instance.new("UICorner", pill).CornerRadius = UDim.new(0, 6)
		pill.MouseButton1Click:Connect(function()
			PlayClick()
			local newValue = not getSelected(itemName)
			setSelected(itemName, newValue)
			pill.BackgroundColor3 = newValue and AccentColor or Color3.fromRGB(60, 60, 60)
			pill.BackgroundTransparency = newValue and 0.75 or 0.2
			if onChanged then onChanged() end
		end)
	end
	return 26 + (rows * (pillHeight + gap))
end


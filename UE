local function IsUndeadExpeditionActive()
	return ThemeObjects.ActiveTabName == "Games" and HubState.SelectedGame == "Undead Expedition" and uePage.Parent ~= nil and uePage.Visible == true
end

local function IsPlayerCharacter(model)
	for _, player in ipairs(Players:GetPlayers()) do
		if player.Character == model then return true end
	end
	return false
end

local enemyNameHints = {
	zombie = true,
	undead = true,
	enemy = true,
	enemies = true,
	monster = true,
	mob = true,
	npc = true,
	walker = true,
	runner = true,
	boss = true,
}

local function HasEnemyNameHint(instance)
	local current = instance
	while current and current ~= workspace do
		local lower = string.lower(current.Name or "")
		for hint in pairs(enemyNameHints) do
			if lower:find(hint, 1, true) then return true end
		end
		current = current.Parent
	end
	return false
end

local function IsEnemyModel(model)
	if not model or not model:IsA("Model") then return false end
	if IsPlayerCharacter(model) then return false end
	local humanoid = model:FindFirstChildOfClass("Humanoid")
	if not humanoid or humanoid.Health <= 0 then return false end
	local root = model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
	if not root then return false end
	if model:IsDescendantOf(MainFrame) or (ScreenGui and model:IsDescendantOf(ScreenGui)) then return false end
	if HasEnemyNameHint(model) then return true end
	return humanoid.DisplayDistanceType ~= Enum.HumanoidDisplayDistanceType.None
end

local function EnemyRoot(model)
	return model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
end

local function EnemyDisplayName(model)
	local humanoid = model:FindFirstChildOfClass("Humanoid")
	local name = humanoid and humanoid.DisplayName and humanoid.DisplayName ~= "" and humanoid.DisplayName or model.Name
	return tostring(name or "Enemy")
end

local RemoveESP

local function RemoveCandidate(model)
	state.CandidateModels[model] = nil
	local connections = state.CandidateConnections[model]
	if connections then
		for _, connection in ipairs(connections) do
			if connection then connection:Disconnect() end
		end
	end
	state.CandidateConnections[model] = nil
end

local function AddCandidate(model)
	if not model or not model:IsA("Model") or state.CandidateModels[model] then return end
	local humanoid = model:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end
	state.CandidateModels[model] = true
	state.CandidateConnections[model] = {
		humanoid.Died:Connect(function()
			RemoveESP(model)
			RemoveCandidate(model)
		end),
		model.AncestryChanged:Connect(function(_, parent)
			if not parent then
				RemoveESP(model)
				RemoveCandidate(model)
			end
		end),
	}
end

local function AddCandidateFromDescendant(obj)
	if obj:IsA("Humanoid") and obj.Parent and obj.Parent:IsA("Model") then
		AddCandidate(obj.Parent)
	elseif obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") then
		AddCandidate(obj)
	end
end

local function CreateESP(model)
	local root = EnemyRoot(model)
	if not root then return nil end
	local holder = Instance.new("Folder")
	holder.Name = "ESP_" .. model.Name
	holder.Parent = espFolder

	local billboard = Instance.new("BillboardGui")
	billboard.Name = "EnemyBillboard"
	billboard.Adornee = root
	billboard.Size = UDim2.new(0, 118, 0, 24)
	billboard.StudsOffset = Vector3.new(0, 3.2, 0)
	billboard.AlwaysOnTop = true
	billboard.LightInfluence = 0
	billboard.MaxDistance = 900
	billboard.Parent = holder

	local label = Instance.new("TextLabel")
	label.Name = "EnemyLabel"
	label.Size = UDim2.new(1, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.Text = EnemyDisplayName(model)
	label.Font = Enum.Font.GothamBold
	label.TextSize = 10
	label.TextColor3 = AccentColor
	label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	label.TextStrokeTransparency = 0.2
	label.TextWrapped = true
	label.Parent = billboard

	return {Holder = holder, Billboard = billboard, Label = label}
end

function RemoveESP(model)
	local entry = state.ESPObjects[model]
	if entry and entry.Holder then entry.Holder:Destroy() end
	state.ESPObjects[model] = nil
end

local function ClearESP()
	for model in pairs(state.ESPObjects) do
		RemoveESP(model)
	end
	if espFolder then espFolder:ClearAllChildren() end
end

local function SaveLightingDefaults()
	if state.OriginalLighting then return end
	state.OriginalLighting = {
		ClockTime = Lighting.ClockTime,
		Brightness = Lighting.Brightness,
		FogEnd = Lighting.FogEnd,
		FogStart = Lighting.FogStart,
		FogColor = Lighting.FogColor,
		Ambient = Lighting.Ambient,
		OutdoorAmbient = Lighting.OutdoorAmbient,
		ExposureCompensation = Lighting.ExposureCompensation,
	}
end

local function ApplyNoDarkness()
	SaveLightingDefaults()
	Lighting.ClockTime = 14
	Lighting.Brightness = 3
	Lighting.FogStart = 0
	Lighting.FogEnd = 100000
	Lighting.FogColor = Color3.fromRGB(255, 255, 255)
	Lighting.Ambient = Color3.fromRGB(180, 180, 180)
	Lighting.OutdoorAmbient = Color3.fromRGB(180, 180, 180)
	Lighting.ExposureCompensation = 0.25
end

local function RestoreLighting()
	local original = state.OriginalLighting
	if not original then return end
	for property, value in pairs(original) do
		pcall(function()
			Lighting[property] = value
		end)
	end
end

local function SetNoDarkness(enabled)
	state.NoDarkness = enabled == true
	if state.NoDarkness then
		ApplyNoDarkness()
	else
		RestoreLighting()
	end
end

local function TeleportToBase()
	local character = Player and Player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	if not root then return end
	root.CFrame = CFrame.new(BASE_POSITION)
end

local function FullCandidateScan()
	for _, obj in ipairs(workspace:GetDescendants()) do
		AddCandidateFromDescendant(obj)
	end
end

local function PlayerRoot()
	local character = Player and Player.Character
	return character and character:FindFirstChild("HumanoidRootPart")
end

local function UpdateESP()
	if not state.EnemyESP then
		state.LastEnemyCount = 0
		state.LastShownCount = 0
		ClearESP()
		return
	end
	local now = os.clock()
	if now - (state.LastFullScan or 0) >= FULL_RESCAN_INTERVAL then
		state.LastFullScan = now
		FullCandidateScan()
	end

	local playerRoot = PlayerRoot()
	local candidates = {}
	for model in pairs(state.CandidateModels) do
		if model.Parent and IsEnemyModel(model) then
			local root = EnemyRoot(model)
			local distance = playerRoot and root and (root.Position - playerRoot.Position).Magnitude or 0
			table.insert(candidates, {Model = model, Distance = distance})
		else
			RemoveESP(model)
			RemoveCandidate(model)
		end
	end
	table.sort(candidates, function(a, b)
		return a.Distance < b.Distance
	end)

	local seen = {}
	local shown = 0
	for _, candidate in ipairs(candidates) do
		if shown >= MAX_ESP_OBJECTS then break end
		local model = candidate.Model
		seen[model] = true
		shown += 1
		local entry = state.ESPObjects[model]
		if not entry or not entry.Holder or not entry.Holder.Parent then
			entry = CreateESP(model)
			state.ESPObjects[model] = entry
		end
		if entry then
			local humanoid = model:FindFirstChildOfClass("Humanoid")
			local root = EnemyRoot(model)
			if root then entry.Billboard.Adornee = root end
			if now - (entry.LastLabelUpdate or 0) >= LABEL_UPDATE_INTERVAL then
				entry.LastLabelUpdate = now
				if root and playerRoot then
					entry.Label.Text = ("%s  [%dm]"):format(EnemyDisplayName(model), math.floor((root.Position - playerRoot.Position).Magnitude))
				elseif humanoid then
					entry.Label.Text = EnemyDisplayName(model)
				else
					entry.Label.Text = EnemyDisplayName(model)
				end
			end
		end
	end

	for model in pairs(state.ESPObjects) do
		if not seen[model] then
			RemoveESP(model)
		end
	end
	state.LastEnemyCount = #candidates
	state.LastShownCount = shown
end

local function RefreshButtons()
	espToggle.Text = state.EnemyESP and "On" or "Off"
	darknessToggle.Text = state.NoDarkness and "On" or "Off"
	local found = state.LastEnemyCount or 0
	local shown = state.LastShownCount or 0
	espStatus.Text = state.EnemyESP and ("Shown: %d/%d"):format(shown, found) or "Shown: 0/0"
	espTitle.TextColor3 = state.EnemyESP and AccentColor or InactiveTextColor()
	darknessTitle.TextColor3 = state.NoDarkness and AccentColor or InactiveTextColor()
	baseTitle.TextColor3 = InactiveTextColor()
	for _, obj in ipairs(uePage:GetDescendants()) do
		if obj:IsA("TextButton") then
			EnsureControlOutline(obj)
			if obj.Name == "FeatureKeybindButton" then obj.TextColor3 = AccentColor end
		end
	end
end

local function ToggleEnemyESP()
	state.EnemyESP = not state.EnemyESP
	if state.EnemyESP then
		state.LastFullScan = 0
		FullCandidateScan()
		UpdateESP()
	else
		ClearESP()
	end
	RefreshButtons()
	UpdateTheme(true)
end

local function ToggleNoDarkness()
	SetNoDarkness(not state.NoDarkness)
	RefreshButtons()
	UpdateTheme(true)
end


local function ShowStructureNotification(message)
	if not state.StructureNotifications or not structureNotification then return end
	state.StructureNotificationToken = (tonumber(state.StructureNotificationToken) or 0) + 1
	local token = state.StructureNotificationToken
	if state.StructureNotificationTween then
		pcall(function() state.StructureNotificationTween:Cancel() end)
	end
	structureNotification.Text = tostring(message or "")
	structureNotification.Visible = IsUEPageActive()
	structureNotification.TextTransparency = 0
	structureNotification.TextStrokeTransparency = 0.16
	task.delay(3, function()
		if token ~= state.StructureNotificationToken or not structureNotification or not structureNotification.Parent then return end
		local tween = TweenService:Create(structureNotification, TweenInfo.new(0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			TextTransparency = 1,
			TextStrokeTransparency = 1,
		})
		state.StructureNotificationTween = tween
		tween:Play()
		tween.Completed:Connect(function()
			if token == state.StructureNotificationToken and structureNotification then
				structureNotification.Visible = false
			end
		end)
	end)
end

local function SetStructureMessage(name)
	name = CleanStructureName(name)
	if state.LastStructureName == name then
		state.LastStructureCount = (tonumber(state.LastStructureCount) or 1) + 1
	else
		state.LastStructureName = name
		state.LastStructureCount = 1
	end
	local suffix = state.LastStructureCount > 1 and (" x" .. tostring(state.LastStructureCount)) or ""
	state.LastStructureMessage = ("%s Has Spawned%s"):format(name, suffix)
	structureStatus.Text = state.LastStructureMessage
	ShowStructureNotification(state.LastStructureMessage)
end


local function SafeGet(instance, property)
	local ok, value = pcall(function()
		return instance[property]
	end)
	if ok then return value end
	return nil
end

local function SafeSet(instance, property, value)
	pcall(function()
		instance[property] = value
	end)
end

local function CleanStructureName(name)
	name = tostring(name or "Structure")
	name = name:gsub("^%s+", ""):gsub("%s+$", ""):gsub("%s+", " ")
	name = name:gsub("%s*%(%d+%)$", ""):gsub("[%s_%-%#]*%d+$", "")
	name = name:gsub("^%s+", ""):gsub("%s+$", "")
	return name ~= "" and name or "Structure"
end

local function StructureDisplayName(structure)

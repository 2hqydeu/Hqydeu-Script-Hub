end

local function CollectEnemiesNear(position, radius, includeAll)
	local folder = workspace:FindFirstChild("Enemies")
	local enemies = {}
	if not folder then return enemies end
	for _, enemy in ipairs(folder:GetChildren()) do
		if (includeAll and IsLiveStructureTrapEnemyNear(enemy, position, radius)) or ((not includeAll) and IsLiveEnemyNear(enemy, position, radius)) then
			table.insert(enemies, enemy)
		end
	end
	table.sort(enemies, function(a, b)
		local rootA = EnemyRoot(a)
		local rootB = EnemyRoot(b)
		local distanceA = rootA and (rootA.Position - position).Magnitude or math.huge
		local distanceB = rootB and (rootB.Position - position).Magnitude or math.huge
		return distanceA < distanceB
	end)
	return enemies
end

local function CollectMobsNear(position, radius)
	local folder = workspace:FindFirstChild("Enemies")
	local mobs = {}
	if not folder then return mobs end
	for _, enemy in ipairs(folder:GetChildren()) do
		local root = EnemyRoot(enemy)
		if root and IsLiveMob(enemy) and (not position or (root.Position - position).Magnitude <= radius) then
			table.insert(mobs, enemy)
		end
	end
	table.sort(mobs, function(a, b)
		local playerRoot = PlayerRoot()
		local rootA = EnemyRoot(a)
		local rootB = EnemyRoot(b)
		local origin = playerRoot and playerRoot.Position or position
		local distanceA = origin and rootA and (rootA.Position - origin).Magnitude or math.huge
		local distanceB = origin and rootB and (rootB.Position - origin).Magnitude or math.huge
		return distanceA < distanceB
	end)
	return mobs
end

local function NearestMobRoot(position, radius)

	Instance.new("UICorner", row).CornerRadius = UDim.new(0, 8)

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0, 160, 1, 0)
	label.Position = UDim2.new(0, 16, 0, 0)
	label.BackgroundTransparency = 1
	label.Text = labelText
	label.Font = UIFont
	label.TextSize = 14
	label.TextColor3 = Color3.fromRGB(255, 255, 255)
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextYAlignment = Enum.TextYAlignment.Center
	label.Parent = row

	local toggle = Instance.new("TextButton")
	toggle.Size = UDim2.new(0, 70, 0, 28)
	toggle.Position = UDim2.new(1, -78, 0.5, -14)
	toggle.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
	toggle.BackgroundTransparency = 0.2
	toggle.BorderSizePixel = 0
	toggle.Text = "Off"
	toggle.Font = UIFont
	toggle.TextSize = 14
	toggle.TextColor3 = Color3.fromRGB(255, 255, 255)
	toggle.Parent = row
	Instance.new("UICorner", toggle).CornerRadius = UDim.new(0, 6)

	local keybindBtn
	if storageKey then
		toggle.Position = UDim2.new(1, -166, 0.5, -14)
		keybindBtn = Instance.new("TextButton")
		keybindBtn.Size = UDim2.new(0, 78, 0, 28)
		keybindBtn.Position = UDim2.new(1, -78, 0.5, -14)
		keybindBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
		keybindBtn.BackgroundTransparency = 0.2
		keybindBtn.BorderSizePixel = 0
		keybindBtn.Font = UIFont
		keybindBtn.TextSize = 14
		keybindBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		keybindBtn.Parent = row
		Instance.new("UICorner", keybindBtn).CornerRadius = UDim.new(0, 6)

		local loadedKey = LoadFeatureKeybind(storageKey)
		keybindBtn.Text = KeybindText(loadedKey)
		if onKeybindChanged then onKeybindChanged(loadedKey) end

		keybindBtn.MouseButton1Click:Connect(function()
			PlayClick()
			keybindBtn.Text = "..."
			bindingInProgress = true
			local capture
			capture = UserInputService.InputBegan:Connect(function(input, processed)
				if processed then return end
				if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
				local selectedKey = input.KeyCode
				if selectedKey == Enum.KeyCode.Backspace or selectedKey == Enum.KeyCode.Delete then
					selectedKey = Enum.KeyCode.Unknown
				end
				SaveFeatureKeybind(storageKey, selectedKey)
				keybindBtn.Text = KeybindText(selectedKey)
				if onKeybindChanged then onKeybindChanged(selectedKey) end
				capture:Disconnect()
				task.defer(function() bindingInProgress = false end)
			end)
		end)
	end

	return row, toggle, keybindBtn
end


	if HubState.GamesTabButton then HubState.GamesTabButton.Text = "Undead Expedition" end
	if HubState.MM2BackButton then HubState.MM2BackButton.Visible = true end
	for _, page in ipairs({
		HubState.MovementPage,
		HubState.CombatPage,
		ThemeObjects.CameraPage,
		HubState.TeleportPage,
		HubState.ScriptsPage,
		MainFrame:FindFirstChild("ExtrasPage"),
		HubState.GamesPage,
		HubState.MM2Page,
		MainFrame:FindFirstChild("QuietOrDiePage"),
		MainFrame:FindFirstChild("GrowABeehivePage"),
	}) do
		if page and page ~= uePage then
			page.Visible = false
			page.Position = UDim2.new(1.1, 0, 0, 54)
		end
	end
	local quietCoins = HubState.PageHeader and HubState.PageHeader:FindFirstChild("QuietOrDieCoinsDisplay")

	local function UpdateBoxEntryVisual(entry, box, root, playerRoot)
		if not entry or not box or not root then return end
		entry.Billboard.Adornee = root
		entry.Highlight.Adornee = BoxHighlightTarget(box, root)
		local boxColor = BoxColor(box)
		entry.Highlight.FillColor = boxColor
		entry.Highlight.OutlineColor = boxColor
		entry.Label.TextColor3 = boxColor
		local distance = playerRoot and math.floor((root.Position - playerRoot.Position).Magnitude) or 0
		entry.Label.Text = ("%s [%d Studs]"):format(BoxDisplayName(box), distance)
	end

	RefreshBoxDistances = function()
		if not IsAnyBoxTypeSelected() then return end
		local playerRoot = PlayerRoot()
		for box, entry in pairs(BoxObjects) do
			local root = BoxRoot(box)
			if root and entry and entry.Holder and entry.Holder.Parent then
				UpdateBoxEntryVisual(entry, box, root, playerRoot)
			else
				RemoveBoxESP(box)
			end
		end
	end

	UpdateBoxESP = function()
		if not IsAnyBoxTypeSelected() then
			for box in pairs(BoxObjects) do RemoveBoxESP(box) end
			return
		end
		local playerRoot = PlayerRoot()
		local boxes = CollectLootBoxes()
		table.sort(boxes, function(a, b)
			local rootA, rootB = BoxRoot(a), BoxRoot(b)
			local distA = playerRoot and rootA and (rootA.Position - playerRoot.Position).Magnitude or 0
			local distB = playerRoot and rootB and (rootB.Position - playerRoot.Position).Magnitude or 0
			return distA < distB
		end)
		local seen = {}
		local shown = 0
		for _, box in ipairs(boxes) do
			if shown >= MAX_BOX_OBJECTS then break end
			local root = BoxRoot(box)
			if root then
				seen[box] = true
				shown += 1
				local entry = BoxObjects[box]
				if not entry or not entry.Holder or not entry.Holder.Parent then
					entry = CreateBoxESP(box)
					BoxObjects[box] = entry
				end
			end
		end
		for box in pairs(BoxObjects) do
			if not seen[box] then RemoveBoxESP(box) end
		end
		RefreshBoxDistances()
	end


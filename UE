local function FaceNearestHunterNear(position, radius, includeAll)
	local playerRoot = PlayerRoot()
	local character = Player and Player.Character
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not playerRoot or not character then return nil end
	local nearestRoot
	local nearestDistance = math.huge
	for _, enemy in ipairs(CollectEnemiesNear(position, radius, includeAll)) do
		local root = EnemyRoot(enemy)
		if root then
			local distance = (root.Position - playerRoot.Position).Magnitude
			if distance < nearestDistance then
				nearestDistance = distance
				nearestRoot = root
			end
		end
	end
	if not nearestRoot then
		RestoreAutoTrapFacing()
		return nil
	end
	if humanoid then humanoid.AutoRotate = false end
	local lookAt = Vector3.new(nearestRoot.Position.X, playerRoot.Position.Y, nearestRoot.Position.Z)
	if (lookAt - playerRoot.Position).Magnitude > 0.25 then
		pcall(function()
			playerRoot.AssemblyAngularVelocity = Vector3.zero
			if playerRoot.AssemblyLinearVelocity.Magnitude > 35 then
				playerRoot.AssemblyLinearVelocity = playerRoot.AssemblyLinearVelocity.Unit * 12
			end
			character:PivotTo(CFrame.new(playerRoot.Position, lookAt))
		end)
	end
	return nearestRoot
end

local function StrafeNearestHunterNear(position, radius, runId, includeAll)
	if not IsAutoTrapRunActive(runId) then return nil end
	local hunterRoot = FaceNearestHunterNear(position, radius, includeAll)
	if not hunterRoot then return nil end
	local now = os.clock()
	local strafeKey = includeAll and "LastStructureTrapStrafeAt" or "LastHunterTrapStrafeAt"
	local strafeInterval = includeAll and STRUCTURE_TRAP_STRAFE_INTERVAL or HUNTER_TRAP_STRAFE_INTERVAL
	if now - (state[strafeKey] or 0) < strafeInterval then
		return hunterRoot
	end
	state[strafeKey] = now
	local character = Player and Player.Character
	local playerRoot = PlayerRoot()
	if not character or not playerRoot then return hunterRoot end
	local offset = playerRoot.Position - hunterRoot.Position
	local flatOffset = Vector3.new(offset.X, 0, offset.Z)
	if flatOffset.Magnitude < 1 then
		local fallback = -hunterRoot.CFrame.LookVector
		flatOffset = Vector3.new(fallback.X, 0, fallback.Z)
	end
	if flatOffset.Magnitude < 1 then flatOffset = Vector3.new(0, 0, 1) end
	local radial = flatOffset.Unit
	state.HunterTrapStrafeDirection = -(tonumber(state.HunterTrapStrafeDirection) or 1)
	local tangent = Vector3.new(-radial.Z, 0, radial.X) * state.HunterTrapStrafeDirection
	local distance = flatOffset.Magnitude
	local desired
	local targetDistance = HUNTER_TRAP_STRAFE_DISTANCE
	local minDistance = 7
	local maxDistance = 13
	local nudgeDistance = 3.5
	if distance < minDistance or distance > maxDistance then
		desired = hunterRoot.Position + radial * targetDistance
	else
		desired = playerRoot.Position + tangent * nudgeDistance
	end
	desired = Vector3.new(desired.X, playerRoot.Position.Y, desired.Z)
	local lookAt = Vector3.new(hunterRoot.Position.X, desired.Y, hunterRoot.Position.Z)
	pcall(function()
		playerRoot.AssemblyLinearVelocity = Vector3.zero
		playerRoot.AssemblyAngularVelocity = Vector3.zero
		character:PivotTo(CFrame.new(desired, lookAt))
	end)
	return hunterRoot
end

local function MobHasText(enemy, terms)
	if not enemy then return false end
	local function hasTerm(value)
		local lower = string.lower(tostring(value or ""))
		for _, term in ipairs(terms) do
			if lower:find(term, 1, true) then return true end
		end
		return false
	end
	if hasTerm(enemy.Name) then return true end
	for _, attributeName in ipairs({"EnemyType", "Type", "MobType", "MonsterType", "DisplayName"}) do
		if hasTerm(enemy:GetAttribute(attributeName)) then return true end
	end
	for _, child in ipairs(enemy:GetDescendants()) do
		if child:IsA("StringValue") and hasTerm(child.Value) then return true end
		if (child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("TextBox")) and hasTerm(child.Text) then return true end
	end
	return false
end

local function IsRangedMob(enemy)
	if state.MobFarmRangedEnemy == enemy and state.MobFarmRangedValue ~= nil then
		return state.MobFarmRangedValue == true
	end
	local ranged = MobHasText(enemy, {"throw", "ranged", "archer", "shooter", "caster", "mage", "spitter"})
	state.MobFarmRangedEnemy = enemy
	state.MobFarmRangedValue = ranged
	return ranged
end

local function MobFarmAttackDistance(enemy, mobRoot)
	local distance = IsRangedMob(enemy) and MOB_FARM_RANGED_DISTANCE or MOB_FARM_STRAFE_DISTANCE
	if mobRoot and mobRoot:IsA("BasePart") then
		local original = state.MobFarmHitboxOriginals and state.MobFarmHitboxOriginals[mobRoot]
		local size = original and original.Size or mobRoot.Size
		local maxSize = math.max(size.X, size.Y, size.Z)
		if maxSize > 10 then
			distance = math.clamp((maxSize * 0.42) + 2, distance, 9)
		end
	end
	return distance
end

local function StrafeAroundMobRoot(enemy, mobRoot, runId)
	if not IsAutoMobRunActive(runId) or not mobRoot or not mobRoot.Parent then return false end
	local character = Player and Player.Character
	local playerRoot = PlayerRoot()
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not character or not playerRoot then return false end
	if humanoid then humanoid.AutoRotate = false end
	local now = os.clock()
	local attackDistance = MobFarmAttackDistance(enemy, mobRoot)
	local ranged = IsRangedMob(enemy)
	if now - (state.LastMobFarmStrafeAt or 0) < MOB_FARM_STRAFE_INTERVAL then
		local lookAt = Vector3.new(mobRoot.Position.X, playerRoot.Position.Y, mobRoot.Position.Z)
		if (lookAt - playerRoot.Position).Magnitude > 0.25 then
			pcall(function()
				playerRoot.AssemblyAngularVelocity = Vector3.zero
				character:PivotTo(CFrame.new(playerRoot.Position, lookAt))
			end)
		end
		return true
	end
	state.LastMobFarmStrafeAt = now
	local offset = playerRoot.Position - mobRoot.Position
	local flatOffset = Vector3.new(offset.X, 0, offset.Z)
	if flatOffset.Magnitude < 1 then
		local fallback = -mobRoot.CFrame.LookVector
		flatOffset = Vector3.new(fallback.X, 0, fallback.Z)
	end
	if flatOffset.Magnitude < 1 then flatOffset = Vector3.new(0, 0, 1) end
	local radial = flatOffset.Unit
	state.MobFarmStrafeDirection = -(tonumber(state.MobFarmStrafeDirection) or 1)
	local tangent = Vector3.new(-radial.Z, 0, radial.X) * state.MobFarmStrafeDirection
	local distance = flatOffset.Magnitude
	local desired = mobRoot.Position + radial * attackDistance
	if not ranged and distance >= attackDistance - 1.25 and distance <= attackDistance + 1.75 then
		desired = playerRoot.Position + tangent * MOB_FARM_NUDGE_DISTANCE
	else
		desired = mobRoot.Position + radial * attackDistance
	end
	desired = Vector3.new(desired.X, playerRoot.Position.Y, desired.Z)
	local lookAt = Vector3.new(mobRoot.Position.X, desired.Y, mobRoot.Position.Z)
	pcall(function()
		playerRoot.AssemblyLinearVelocity = Vector3.zero
		playerRoot.AssemblyAngularVelocity = Vector3.zero
		character:PivotTo(CFrame.new(desired, lookAt))
	end)
	return true
end


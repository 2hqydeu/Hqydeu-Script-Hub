local function SanitizeFilterName(value)
	value = tostring(value or "")
	value = value:gsub("^%s+", ""):gsub("%s+$", ""):gsub("%s+", " ")
	value = value:gsub("%s*%(%d+%)$", ""):gsub("[%s_%-%#]*%d+$", "")
	value = value:gsub("^%s+", ""):gsub("%s+$", "")
	return value ~= "" and value or "Unknown"
end

local function RegisterEnemyFilterOption(value)
	value = SanitizeFilterName(value)
	if not state.KnownEnemyTypes[value] then
		state.KnownEnemyTypes[value] = true
		state.SelectedEnemyTypes[value] = true
		lastFilterSignature = ""
	end
	return value
end

local function SortedEnemyFilterOptions()
	local options = {}
	for value in pairs(state.KnownEnemyTypes) do
		table.insert(options, value)
	end
	table.sort(options, function(a, b)
		return string.lower(a) < string.lower(b)
	end)
	return options
end


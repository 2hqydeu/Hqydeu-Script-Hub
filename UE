local function StructureFilterKey(name)
	name = tostring(name or "")
	local lower = string.lower(name)
	if lower:find("hunter", 1, true) and lower:find("trap", 1, true) then return "Hunter Trap" end
	if lower:find("cave", 1, true) then return "Cave" end
	return name
end

local function DiscoverRarityTiers()
	local tiers = {}
	local itemsFolder = ReplicatedStorage:FindFirstChild("Items")
	local dropsFolder = itemsFolder and itemsFolder:FindFirstChild("Drops")
	if dropsFolder then
		for _, child in ipairs(dropsFolder:GetChildren()) do
			if child:IsA("Folder") then table.insert(tiers, child.Name) end
		end
	end
	return tiers
end

	{Name = "Mythic", Key = "mythic", Color = Color3.fromRGB(255, 60, 90)},
	{Name = "Legendary", Key = "legendary", Color = Color3.fromRGB(255, 170, 0)},
	{Name = "Epic", Key = "epic", Color = Color3.fromRGB(190, 80, 255)},
	{Name = "Rare", Key = "rare", Color = Color3.fromRGB(0, 170, 255)},

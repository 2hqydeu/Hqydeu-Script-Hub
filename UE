local function SafeGet(instance, property)
	local ok, value = pcall(function()
		return instance[property]
	end)
	if ok then return value end
	return nil
end

local function SafeSet(instance, property, value)
	pcall(function()
		instance[property] = value
	end)
end

local function CleanStructureName(name)
	name = tostring(name or "Structure")
	name = name:gsub("^%s+", ""):gsub("%s+$", ""):gsub("%s+", " ")
	name = name:gsub("%s*%(%d+%)$", ""):gsub("[%s_%-%#]*%d+$", "")
	name = name:gsub("^%s+", ""):gsub("%s+$", "")
	return name ~= "" and name or "Structure"
end

local function StructureDisplayName(structure)
	if not structure then return "Structure" end
	local displayName = structure:GetAttribute("DisplayName") or structure:GetAttribute("StructureName") or structure:GetAttribute("Name")
	if displayName and tostring(displayName) ~= "" then return CleanStructureName(displayName) end
	local stringValue = structure:FindFirstChild("Name")
	if stringValue and stringValue:IsA("StringValue") and tostring(stringValue.Value) ~= "" then
		return CleanStructureName(stringValue.Value)
	end
	return CleanStructureName(structure.Name)
end


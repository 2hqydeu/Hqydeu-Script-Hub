-- Undead Expedition module for Serenity. Wiped down to a blank slate to match the new
-- hub's approach -- full copy of the old feature-rich version kept in
-- UE_Legacy_Full.lua. This loads standalone (Serenity no longer exposes a shared
-- runtime/theme table for modules to hook into), starting small with just Base TP.
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local Player = Players.LocalPlayer
local FrameColor = Color3.fromRGB(0x1E, 0x1E, 0x1E)
local AccentColor = Color3.fromRGB(255, 255, 255)
local UIFont = Enum.Font.Ubuntu

-- Carried over from the old hub's Undead Expedition module.
local BASE_POSITION = Vector3.new(130, 53, -397)

local function StableTeleport(cframe)
	local character = Player and Player.Character
	local root = character and character:FindFirstChild("HumanoidRootPart")
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not character or not root then return false end
	if humanoid then
		humanoid.Sit = false
		humanoid.PlatformStand = false
		humanoid.AutoRotate = true
		pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.GettingUp) end)
	end
	pcall(function()
		root.AssemblyLinearVelocity = Vector3.zero
		root.AssemblyAngularVelocity = Vector3.zero
	end)
	character:PivotTo(cframe)
	task.delay(0.08, function()
		if root and root.Parent then
			pcall(function()
				root.AssemblyLinearVelocity = Vector3.zero
				root.AssemblyAngularVelocity = Vector3.zero
			end)
		end
		if humanoid and humanoid.Parent then
			humanoid.Sit = false
			humanoid.PlatformStand = false
			pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.Running) end)
		end
	end)
	return true
end

local function TeleportToBase()
	return StableTeleport(CFrame.new(BASE_POSITION + Vector3.new(0, 4, 0)))
end


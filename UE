			button.BackgroundColor3 = ESPSelectedRarities[tier] == true and Green or Red
		end)
		itemFilterButtons[tier] = button
	end

	local function RefreshAllChipColors()
		mobsEspToggleButton.Text = ESPMobsEnabled and "On" or "Off"
		mobsEspToggleButton.BackgroundColor3 = ESPMobsEnabled and Green or Red
		for boxType, button in pairs(boxFilterButtons) do
			button.BackgroundColor3 = SelectedBoxTypes[boxType] == true and Green or Red
		end
		for name, button in pairs(structureFilterButtons) do
			button.BackgroundColor3 = SelectedStructureTypes[name] == true and Green or Red
		end
		for tier, button in pairs(itemFilterButtons) do
			button.BackgroundColor3 = ESPSelectedRarities[tier] == true and Green or Red
		end
	end

	ESPToggle.MouseButton1Click:Connect(function()
		ESPToggleDock()
		if ESPDock.Visible then RefreshAllChipColors() end
	end)

	-- Periodic scan: keeps ESP highlights, distances, and the options dock's growing
	-- structure type list up to date without needing every click to trigger a refresh.
	local lastESPScan = 0
	RunService.Heartbeat:Connect(function()
		if not ScreenGui.Parent then return end
		RefreshBoxDistances()
		local now = os.clock()
		if now - lastESPScan >= ESP_SCAN_INTERVAL then
			lastESPScan = now
			UpdateBoxESP()
			UpdateStructuresESP()
			UpdateItemsESP()
			UpdateMobsESP()
		end
	end)

	-- Close reset (ESP dock + structure alerts half): the rest -- Lighting, ScreenGui
	-- teardown -- is wired directly to CloseButton further down, past where those exist.
	CloseButton.MouseButton1Click:Connect(function()
		ESPDock.Visible = false
		StructureNotificationsEnabled = false
		ClearStructureAlerts()
	end)
end

-- Minimize: shrinks to just the header, matching Serenity's own minimize behavior. Every
-- row/button lives inside ContentScroll now, so hiding that one frame is enough.
local minimized = false
local function ToggleMinimize()
	minimized = not minimized
	HeaderDivider.Visible = not minimized
	ContentScroll.Visible = not minimized
	PanelFrame.Size = UDim2.new(0, 280, 0, minimized and MINI_HEIGHT or FULL_HEIGHT)
	MinimizeButton.Text = minimized and "+" or "-"
end
MinimizeButton.MouseButton1Click:Connect(ToggleMinimize)

-- Close: reverses No Darkness before tearing down, regardless of what else is toggled.
CloseButton.MouseButton1Click:Connect(function()
	SetNoDarkness(false)
	ScreenGui:Destroy()
end)

-- Dragging
local dragging = false
local dragStart = nil
local startPos = nil
PanelFrame.InputBegan:Connect(function(input)
	if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
	dragging = true
	dragStart = input.Position
	startPos = PanelFrame.Position
	input.Changed:Connect(function()
		if input.UserInputState == Enum.UserInputState.End then
			dragging = false
		end
	end)
end)
UserInputService.InputChanged:Connect(function(input)
	if not dragging or (input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch) then return end
	local delta = input.Position - dragStart
	PanelFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end)

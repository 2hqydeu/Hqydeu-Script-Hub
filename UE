function HasHunterTrapText(value)
	local lower = string.lower(tostring(value or ""))
	return lower:find("hunter", 1, true) ~= nil and lower:find("trap", 1, true) ~= nil
end

local function HunterTrapPart(box)
	if not box then return nil end
	if box:IsA("BasePart") and string.lower(box.Name) == "string" then return box end
	local direct = box:FindFirstChild("string")
	if direct and direct:IsA("BasePart") then return direct end
	for _, child in ipairs(box:GetDescendants()) do
		if child:IsA("BasePart") and string.lower(child.Name) == "string" then
			return child
		end
	end
	return nil
end

function BoxRoot(box)
	if not box then return nil end
	if HasHunterTrapText(box.Name) then
		local trapPart = HunterTrapPart(box)
		if trapPart then return trapPart end
	end
	if box:IsA("BasePart") then return box end
	if box:IsA("Model") then return box.PrimaryPart or box:FindFirstChildWhichIsA("BasePart", true) end
	return box:FindFirstChildWhichIsA("BasePart", true)
end

function BoxTypeFromName(name)
	local lower = string.lower(tostring(name or ""))
	if HasHunterTrapText(lower) then return "Hunter Trap" end
	for _, boxType in ipairs(BOX_TYPES) do
		if lower:find(string.lower(boxType), 1, true) then return boxType end
	end
	return nil
end

function BoxType(box)
	local nameType = BoxTypeFromName(box and box.Name)
	if nameType then return nameType end
	for _, child in ipairs(box:GetDescendants()) do
		if child:IsA("StringValue") or child:IsA("TextLabel") or child:IsA("TextButton") then
			local value = child:IsA("StringValue") and tostring(child.Value or "") or tostring(child.Text or "")
			local valueLower = string.lower(value)
			if HasHunterTrapText(valueLower) then return "Hunter Trap" end
			local textType = BoxTypeFromName(valueLower)
			if textType then return textType end
		end
	end
	return nil
end

local function FindOpenPrompt(box)
	local fallback
	for _, child in ipairs(box:GetDescendants()) do
		if child:IsA("ProximityPrompt") then
			local action = string.lower(tostring(child.ActionText or ""))
			if action:find("open", 1, true) then return child end
			fallback = fallback or child
		end
	end
	return fallback
end

local function FindNearbyClaimPrompt(position, radius)
	-- Key drops always get claimed regardless of the rarity filter (Auto Farm needs them
	-- for the boss crates no matter what's toggled off in Pickup Filter).
	local bestPrompt, bestPart, bestDist
	for _, inst in ipairs(workspace:GetDescendants()) do
		if inst:IsA("ProximityPrompt") and inst.Enabled then
			local action = string.lower(tostring(inst.ActionText or ""))
			if action:find("claim", 1, true) then
				local part = inst.Parent
				if part and part:IsA("BasePart") then
					local dist = (part.Position - position).Magnitude
					local allowed = IsKeyDrop(part) or IsRarityAllowed(GetDropRarity(part))
					if dist <= radius and (not bestDist or dist < bestDist) and allowed then
						bestDist = dist
						bestPrompt = inst
						bestPart = part
					end
				end
			end
		end
	end
	return bestPrompt, bestPart
end

local function PressInteractKey(keyCode)
	if type(keypress) == "function" then
		local ok = pcall(keypress, keyCode)
		if ok then return true end
	end
	return pcall(function()
		VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
	end)
end

local function ReleaseInteractKey(keyCode)
	if type(keyrelease) == "function" then
		local ok = pcall(keyrelease, keyCode)
		if ok then return end
	end
	pcall(function()
		VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
	end)
end

local function FindKeyTool(keyName)
